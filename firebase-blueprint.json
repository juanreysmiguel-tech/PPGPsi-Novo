                    <div class="col-md-6 col-lg-5">
                        <div class="card shadow-lg border-0 animate-fadeInUp">
                             <div class="card-header bg-primary text-white text-center py-4" style="background: linear-gradient(135deg, #004b85 0%, #007bff 100%);">
                                <h4 class="mb-0">Área do Aluno</h4>
                                <small>Identificação Segura PPGPsi</small>
                             </div>
                             <div class="card-body p-5">
                                 <div id="login-step-1">
                                     <p class="text-muted mb-4 text-center">
                                        Identificamos que você não está logado automaticamente.<br>
                                        Se você é <strong>Aluno PPGPsi</strong>, digite seu e-mail institucional (@estudante.ufscar.br).
                                     </p>
