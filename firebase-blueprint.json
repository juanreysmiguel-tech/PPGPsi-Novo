        _updateDocenteLists: function () {
            const requests = Views._rawDocenteRequests || [];

            // Current State IDs
            const currentUserId = String(App.user.id);

            // Filters for Own Requests
            const ownSearch = document.getElementById('own-req-search')?.value.toLowerCase() || '';
            const ownStatus = document.getElementById('own-req-status')?.value || 'ALL';

            // Filters for Student Requests
            const studentSearch = document.getElementById('student-req-search')?.value.toLowerCase() || '';
            const studentStatus = document.getElementById('student-req-status')?.value || 'ALL';

            const ownFiltered = requests.filter(r => {
                if (String(r.ID_Usuario) !== currentUserId) return false;

                const matchesSearch = !ownSearch ||
                    (r.Tipo_Solicitacao || '').toLowerCase().includes(ownSearch) ||
                    (r.ID || '').toLowerCase().includes(ownSearch);

                const status = (r.Status || '').toUpperCase();
                let matchesStatus = true;
                if (ownStatus === 'PENDENTE') matchesStatus = status.includes('PENDENTE') || status.includes('REVISÃO') || status.includes('AGUARDANDO');
                else if (ownStatus === 'APROVADO') matchesStatus = status.includes('APROVADO');
                else if (ownStatus === 'CONCLUIDO') matchesStatus = status.includes('CONCLUÍDO') || status.includes('CONCLUIDO') || status.includes('CONCLUIDO_PG');

                return matchesSearch && matchesStatus;
            });

            const studentFiltered = requests.filter(r => {
                if (String(r.ID_Usuario) === currentUserId) return false;

                const matchesSearch = !studentSearch ||
                    (r.Tipo_Solicitacao || '').toLowerCase().includes(studentSearch) ||
                    (r.Nome_Solicitante || '').toLowerCase().includes(studentSearch) ||
                    (r.ID || '').toLowerCase().includes(studentSearch);

                const status = (r.Status || '').toUpperCase();
                let matchesStatus = true;
                if (studentStatus === 'PENDENTE') matchesStatus = status.includes('AGUARDANDO ORIENTADOR');
                else if (studentStatus === 'PROCESSADOS') matchesStatus = !status.includes('AGUARDANDO ORIENTADOR');

                return matchesSearch && matchesStatus;
            });

            Views._renderDocenteListUI('own-requests-list', ownFiltered, 'own-count');
            Views._renderDocenteListUI('student-requests-list', studentFiltered, 'student-count');
        },

        _renderDocenteListUI: function (containerId, requests, countId) {
            const container = document.getElementById(containerId);
            const countEl = document.getElementById(countId);
            if (!container) return;

            countEl.textContent = requests.length;

            if (requests.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5 text-muted small">
                        <div class="fs-4 mb-2 opacity-25">📁</div>
                        Nenhuma solicitação encontrada
                    </div>`;
                return;
            }

            container.innerHTML = requests.slice(0, 50).map(r => {
                const date = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                const status = r.Status || 'Pendente';
                const isStudent = String(r.ID_Usuario) !== String(App.user.id);

                const statusInfo = UIHelpers.getStatusBadgeInfo(status);

                const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                let actionBtn = '';

                // Students Requests (Pendencies)
                if (isStudent && status.toUpperCase().includes('AGUARDANDO ORIENTADOR')) {
                    actionBtn = `<button class="btn btn-sm btn-success px-3 shadow-sm" onclick="Forms.openDocenteModal('${r.ID}', 'Aprovar', '${r.Tipo_Solicitacao || ''}'); event.stopPropagation();">Analisar</button>`;
                }
                // Debugging Button Visibility
                // console.log("DocenteUI Debug:", { id: r.ID, status: status, user: App.user.id, owner: r.ID_Usuario, isStudent: isStudent });

                // My Requests (Accountability)
                // Relaxed check: case insensitive and trim
                const statusUpper = status.toUpperCase().trim();
                if (!isStudent && (statusUpper === 'PRESTAÇÃO DE CONTAS SOLICITADA' || statusUpper === 'PRESTACAO DE CONTAS SOLICITADA')) {
                    console.log("Rendering Accountability Button for:", r.ID);
                    actionBtn = `<button class="btn btn-sm btn-warning fw-bold px-3 shadow-sm" onclick="event.stopPropagation(); Forms.openStudentAccountabilityModal('${r.ID}')">📉 Prestação de Contas</button>`;
                }
                // Default Details
                else {
                    actionBtn = `<button class="btn btn-sm btn-outline-primary" onclick="Forms.openRequestDetailModal('${reqDataStr}')">Detalhes</button>`;
                }

                return `
                <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-0 border-bottom clickable-item" onclick="Forms.openRequestDetailModal('${reqDataStr}')">
                    <div class="text-truncate me-3">
                        <div class="fw-bold text-dark small text-truncate mb-0">${isStudent ? (r.Nome_Solicitante || 'Estudante') : 'Minha Solicitação'}</div>
                        <div class="small text-muted text-truncate">${r.Tipo_Solicitacao} <span class="mx-1">•</span> ${date}</div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge ${statusInfo.class} small" style="font-size: 0.7rem; font-weight: 500;">${status}</span>
                        <div class="ms-2">${actionBtn}</div>
                    </div>
                </div>`;
            }).join('');
        },

        _renderDocentePendencies: function (requests) {
            const container = document.getElementById('docente-pendencies-container');
            if (!container) return;

            const currentUserId = String(App.user.id);

            const studentPendencies = requests.filter(r =>
                String(r.ID_Usuario) !== currentUserId &&
                (r.Status || '').toUpperCase().includes('AGUARDANDO ORIENTADOR')
            );

            const ownPendencies = requests.filter(r =>
                String(r.ID_Usuario) === currentUserId &&
                ((r.Status || '').toUpperCase().includes('REVISÃO') || (r.Status || '').toUpperCase().includes('RETORNADO AO ALUNO'))
            );

            if (studentPendencies.length === 0 && ownPendencies.length === 0) {
                container.innerHTML = `
                    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center">
                        <div class="fs-4 me-3">✅</div>
                        <div class="small fw-medium">Você está em dia! Não há pendências urgentes no momento.</div>
                    </div>`;
                return;
            }

            let html = '<div class="row g-3">';

            if (studentPendencies.length > 0) {
                html += `
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm overflow-hidden" style="border-left: 4px solid #ffc107 !important;">
                        <div class="card-body d-flex align-items-center p-3">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3 me-3">
                                <span class="fs-4">🔔</span>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Pendências de Discentes</h6>
                                <p class="mb-0 small text-muted">Existem <strong>${studentPendencies.length}</strong> pedidos de alunos aguardando seu aceite técnico.</p>
                            </div>
                        </div>
                    </div>
                </div>`;
            }

            if (ownPendencies.length > 0) {
                html += `
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm overflow-hidden" style="border-left: 4px solid #17a2b8 !important;">
                        <div class="card-body d-flex align-items-center p-3">
                            <div class="bg-info bg-opacity-10 text-info rounded-circle p-3 me-3">
                                <span class="fs-4">📝</span>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Suas Pendências</h6>
                                <p class="mb-0 small text-muted">Existem <strong>${ownPendencies.length}</strong> solicitações próprias que requerem sua ação ou revisão.</p>
                            </div>
                        </div>
                    </div>
                </div>`;
            }

            html += '</div>';
            container.innerHTML = html;
        },

