                    'Em Pauta (Reunião do Colegiado)': 'primary',
                    'Em Pauta (Reunião)': 'primary',
                    'Aguardando Depósito Financeiro': 'primary',
                    'Aguardando Depósito': 'primary',

                    // Accountability (info)
                    'Prestação de Contas Solicitada': 'info',
                    'Prestação de Contas em Análise': 'info',
                    'Prestação em Análise': 'info',

                    // Final states
                    'Concluído / Arquivado': 'secondary',
                    'Concluído': 'secondary',
                    'Indeferido / Recusado': 'danger',
                    'Indeferido': 'danger',
                    'Excluído': 'dark',

                    // V3.2 Status Codes
                    'PENDING_ADVISOR': 'warning',
                    'PENDING_CG': 'info',
                    'PENDING_INFO': 'secondary',
                    'APPROVED_CG': 'success',
                    'IN_MEETING': 'primary',
                    'WAITING_DEPOSIT': 'primary',
                    'ACCOUNTABILITY_REQUESTED': 'info',
                    'WAITING_CHECK': 'info',
                    'COMPLETED': 'secondary',
                    'REJECTED': 'danger',
                    'DELETED': 'dark'
                };

                let html = '<div class="table-responsive"><table class="table table-hover"><thead><tr>';
                html += '<th>Data</th><th>Tipo</th><th>Valor</th><th>Status</th><th>Ações</th>';
                html += '</tr></thead><tbody>';

                financial.forEach(r => {
                    let details = {};
                    try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                    const valor = details['Valor Solicitado (R$)'] || details['valor'] || '—';
                    const dataFormatted = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '—';
                    const statusColor = statusColors[r.Status] || 'secondary';

                    html += `
                        <tr>
