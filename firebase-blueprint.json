        renderCGStats: function (stats) {
            // Update next parecerista
            const nextEl = document.getElementById('next-parecerista');
            if (stats && stats.next) {
                nextEl.innerHTML = stats.next.nome + '<br><small class="opacity-75">' + stats.next.pareceres + ' pareceres</small>';
            } else {
                nextEl.textContent = 'Nenhum membro CG';
            }

            // Update pareceristas table
            const statsEl = document.getElementById('pareceristas-stats');
            if (!stats || !stats.members || stats.members.length === 0) {
                statsEl.innerHTML = '<p class="text-muted text-center">Nenhum membro CG cadastrado</p>';
                return;
            }

            let html = '<div class="row g-3">';
            stats.members.forEach(function (m, i) {
                const isNext = stats.next && stats.next.id === m.id;
                const bgClass = isNext ? 'bg-success text-white' : 'bg-light';

                html += `
                <div class="col-md-4">
                    <div class="p-3 rounded ${bgClass} text-center">
                        <div class="fw-bold">${m.nome}</div>
                        <div class="fs-4 fw-bold">${m.pareceres}</div>
                        <small>pareceres</small>
                        ${isNext ? '<div class="badge bg-white text-success mt-1">Próximo</div>' : ''}
                    </div>
                </div>`;
            });
            html += '</div>';

            statsEl.innerHTML = html;
        },

        renderCGFinancialRequests: function (requests) {
            const container = document.getElementById('cg-financial-requests');

            // Filter only financial requests
            const financial = requests.filter(function (r) {
                return r.Tipo_Solicitacao && r.Tipo_Solicitacao.includes('Financeiro');
            });

            if (financial.length === 0) {
                container.innerHTML = '<div class="text-center py-4 text-muted">Nenhum pedido financeiro pendente</div>';
                return;
            }

            let html = '<div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Solicitante</th><th>Tipo</th><th>Status</th><th>Data</th><th>Ações</th></tr></thead><tbody>';

            financial.forEach(function (r) {
                const dateStr = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                html += `
                <tr>
                    <td class="fw-medium">${r.Nome_Solicitante || '-'}</td>
                    <td>${r.Tipo_Solicitacao || '-'}</td>
                    <td><span class="badge bg-warning">${r.Status || 'Pendente'}</span></td>
                    <td>${dateStr}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="Forms.openCGParecerModal('${r.ID}')">
                            Analisar
                        </button>
                    </td>
                </tr>`;
            });

            html += '</tbody></table></div>';
            container.innerHTML = html;
        },

