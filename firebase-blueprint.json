            container.innerHTML = `
            <div class="view-section animate-fadeInUp">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="display-6 fw-bold text-dark mb-0">📁 Gestão de Solicitações</h1>
                </div>

                <!-- Pendências -->
                <div id="docente-pendencies-container" class="mb-4"></div>

                <div class="row g-4">
                    <!-- Minhas Solicitações -->
                    <div class="col-xl-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white border-0 py-3">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="mb-0 fw-bold text-primary">🙋 Minhas Solicitações</h5>
                                    <span class="badge bg-primary rounded-pill px-3" id="own-count">0</span>
