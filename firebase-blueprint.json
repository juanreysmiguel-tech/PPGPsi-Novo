                                     </button>
                                     
                                     <div class="text-center pt-3 border-top">
                                         <small class="text-muted d-block mb-2">Não possui conta institucional ou é visitante?</small>
                                         <button class="btn btn-outline-secondary w-100" onclick="App.init()">
                                            Continuar como Visitante
                                         </button>
                                     </div>
                                 </div>
                                 
                                 <div id="login-step-2" style="display:none;">
                                     <div class="alert alert-info py-2 text-center">
                                        <small>Enviamos um código para:<br><strong id="sent-email-display"></strong></small>
                                     </div>
                                     <div class="mb-3">
                                         <label class="form-label text-center w-100">Digite o código de 6 dígitos</label>
                                         <input type="text" id="login-code" class="form-control form-control-lg text-center" maxlength="6" placeholder="000000" style="letter-spacing: 5px; font-size: 1.5rem;">
