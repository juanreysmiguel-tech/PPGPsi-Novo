        renderMuralPosts: function (posts) {
            const container = document.getElementById('mural-posts-container');

            if (!posts || posts.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5 text-muted">
                        <span class="fs-1">📭</span>
                        <p class="mt-2">Nenhuma publicação ainda. Seja o primeiro a publicar!</p>
                    </div>`;
                return;
            }

            let html = '';
            posts.forEach(function (post) {
                const dateStr = post.Data_Publicacao ?
                    new Date(post.Data_Publicacao).toLocaleString('pt-BR') : '';
                const initials = post.Nome_Usuario ? post.Nome_Usuario.charAt(0).toUpperCase() : '?';

                html += `
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-4">
                        <div class="d-flex gap-3">
                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold" 
                                 style="width:50px; height:50px; flex-shrink:0; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                ${post.FotoUrl ? '<img src="' + post.FotoUrl + '" style="width:100%;height:100%;object-fit:cover;border-radius:50%">' : initials}
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-bold">${post.Nome_Usuario || 'Anônimo'}</span>
                                    <small class="text-muted">${dateStr}</small>
                                </div>
                                <p class="mb-0" style="white-space: pre-wrap;">${post.Conteudo || ''}</p>
                            </div>
                        </div>
                    </div>
                </div>`;
            });

            container.innerHTML = html;
        },

        // =========================================================================
        // DASHBOARD CG - GESTÃO FINANCEIRA
        // =========================================================================
        renderCGDashboard: function () {
            const container = document.getElementById('main-content');
            container.innerHTML = `
            <div class="view-section">
                <div class="d-flex justify-content-between align-items-center mb-4">
