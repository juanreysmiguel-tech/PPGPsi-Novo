    // =========================================================================
    // PPGPsiu - VALIDAÇÃO DE PERIÓDICOS QUALIS
    // =========================================================================
    Views.renderPPGPsiuView = function () {
        const container = document.getElementById('main-content');

        // Show loading state initially
        container.innerHTML = `
            < div class="view-section animate-fadeInUp" >
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="mb-0">📚 Consultar Periódicos</h2>
                        <p class="text-muted mb-0">Validação de Periódicos na Base Qualis CAPES</p>
                    </div>
                </div>

                <div class="card border-0 shadow-lg">
                    <div class="card-body text-center py-5">
                        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                        <h4 class="text-muted">Carregando Base de Periódicos...</h4>
                        <p class="text-muted small">Isso pode levar alguns segundos na primeira vez.</p>
                    </div>
                </div>
            </div >
            `;

        // Load filter options, then render form
        API.getQualisFilterOptions(
            function (res) {
                // Build options HTML
                let areaOptions = '<option value="">Todas</option>';
                let estratoOptions = '<option value="">Todos</option>';
                let eventoOptions = '<option value="">Todos</option>';

                if (res && res.success) {
                    res.areas.forEach(a => areaOptions += `< option value = "${a}" > ${a}</option > `);
                    res.estratos.forEach(e => estratoOptions += `< option value = "${e}" > ${e}</option > `);
                    res.eventos.forEach(ev => eventoOptions += `< option value = "${ev}" > ${ev}</option > `);
                }

                // Now render the full form
                container.innerHTML = `
            < div class="view-section animate-fadeInUp" >
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h2 class="mb-0">📚 Consultar Periódicos</h2>
                                <p class="text-muted mb-0">Validação de Periódicos na Base Qualis CAPES</p>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">🔍 Buscar Periódico</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label small text-muted">ISSN</label>
                                        <input type="text" class="form-control" id="qualis-issn" placeholder="Ex: 1234-5678">
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label small text-muted">Título do Periódico</label>
                                        <input type="text" class="form-control" id="qualis-titulo" placeholder="Ex: Journal of Psychology">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small text-muted">Área de Avaliação</label>
                                        <select class="form-select" id="qualis-area">
                                            ${areaOptions}
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small text-muted">Estrato (Classificação)</label>
                                        <select class="form-select" id="qualis-estrato">
                                            ${estratoOptions}
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small text-muted">Evento de Classificação</label>
                                        <select class="form-select" id="qualis-evento">
                                            ${eventoOptions}
                                        </select>
                                    </div>
                                </div>
                                <div class="mt-4 text-center">
                                    <button class="btn btn-primary btn-lg px-5" onclick="Forms.searchQualis()">
                                        🔎 Buscar Periódico
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div id="qualis-results">
                            <!-- Results will appear here -->
                        </div>
                    </div >
            `;
            },
            function (err) {
                container.innerHTML = `
            < div class="view-section" >
                <div class="alert alert-danger">
                    <h5>❌ Erro ao carregar</h5>
                    <p>${err.message}</p>
                    <button class="btn btn-primary" onclick="Views.renderPPGPsiuView()">Tentar Novamente</button>
                </div>
        </div >
            `;
            }
        );
    };

    // Search Function
    Forms.searchQualis = function () {
        const filters = {
            issn: document.getElementById('qualis-issn').value,
            titulo: document.getElementById('qualis-titulo').value,
            areaAvaliacao: document.getElementById('qualis-area').value,
            estrato: document.getElementById('qualis-estrato').value,
            evento: document.getElementById('qualis-evento').value
        };

        const resultsContainer = document.getElementById('qualis-results');
        resultsContainer.innerHTML = `
            < div class="text-center py-4" >
                <div class="spinner-border text-primary"></div>
                <p class="text-muted mt-2">Buscando na base Qualis...</p>
            </div >
            `;

        // Build Search logic
        API.searchQualisPeriodicos(
            filters,
            function (res) {
                // Success Callback
                if (res && res.success) {
                    if (res.results.length === 0) {
                        resultsContainer.innerHTML = `
            < div class="alert alert-warning text-center" >
                                <h5>Nenhum periódico encontrado</h5>
                                <p class="mb-0">Tente buscar com termos mais amplos ou verifique o ISSN.</p>
                            </div >
            `;
                        return;
                    }

                    // Build table
                    let tableHTML = `
            < div class="alert alert-success d-flex justify-content-between align-items-center" >
                <div>
                    <strong>${res.totalFound}</strong> resultados encontrados.
                    ${res.limitReached ? '<span class="text-danger ms-2">(Limite de exibição atingido. Refine a busca se necessário)</span>' : ''}
                </div>
                        </div >
            <div class="table-responsive bg-white rounded shadow-sm border">
                <table class="table table-hover table-striped mb-0 text-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ISSN</th>
                            <th>Título</th>
                            <th>Área</th>
                            <th>Estrato</th>
                            <th>Evento</th>
                        </tr>
                    </thead>
                    <tbody>
                        `;

                    res.results.forEach(item => {
                        let badgeColor = 'secondary';
                        if (['A1', 'A2', 'A3', 'A4'].includes(item.estrato)) badgeColor = 'success';
                        else if (['B1', 'B2', 'B3', 'B4'].includes(item.estrato)) badgeColor = 'primary';
                        else if (item.estrato === 'C') badgeColor = 'warning';

                        tableHTML += `
                        <tr>
                            <td class="fw-bold text-nowrap">${item.issn}</td>
                            <td class="text-wrap" style="max-width: 300px;">${item.titulo}</td>
                            <td>${item.area}</td>
                            <td><span class="badge bg-${badgeColor} text-white fs-6">${item.estrato}</span></td>
                            <td class="text-muted small">${item.evento}</td>
                        </tr>
                        `;
                    });

                    tableHTML += `
                    </tbody>
                </table>
            </div>
        `;

                    resultsContainer.innerHTML = tableHTML;
                } else {
                    resultsContainer.innerHTML = `
            < div class="alert alert-danger" >
                            <h5>Erro na busca</h5>
                            <p>${res ? res.error : 'Resposta inválida do servidor.'}</p>
                        </div >
            `;
                }
            },
            function (err) {
                // Failure Callback
                resultsContainer.innerHTML = `
            < div class="alert alert-danger" >
                        <h5>Erro de Conexão</h5>
                        <p>${err.message}</p>
                    </div >
            `;
            }
        );
    };

    // Add new forms
    Forms.openMeetingModal = function (encodedData = null) {
        let isEdit = false;
        let meeting = {};

        if (encodedData) {
            try {
                meeting = JSON.parse(decodeURIComponent(encodedData));
                isEdit = true;
                // Normalize dates for input[type="date"] (YYYY-MM-DD)
                const formatDate = (dateStr) => {
                    if (!dateStr) return '';
                    const d = new Date(dateStr);
                    return d.toISOString().split('T')[0];
                };
                meeting.date = formatDate(meeting.Data_Reuniao);
                meeting.start = formatDate(meeting.Data_Inicio_Periodo);
                meeting.end = formatDate(meeting.Data_Fim_Periodo);
                meeting.deadline = formatDate(meeting.Prazo_Fechamento);
            } catch (e) { console.error("Error parsing meeting", e); }
        }

        const modalHtml = `
            <div class="modal fade" id="modalMeeting" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">${isEdit ? '✏️ Editar Reunião' : '➕ Nova Reunião CPG'}</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <form id="form-meeting">
                                <input type="hidden" id="m-id" value="${meeting.ID || ''}">
                                    <div class="mb-3">
                                        <label class="form-label">Nome</label>
                                        <input type="text" id="m-name" class="form-control" value="${meeting.Nome || ''}" placeholder="ex: Reunião Março">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Data da Reunião</label>
                                        <input type="date" id="m-date" class="form-control" value="${meeting.date || ''}">
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col">
                                            <label class="form-label">Início Período</label>
                                            <input type="date" id="m-start" class="form-control" value="${meeting.start || ''}">
                                        </div>
                                        <div class="col">
                                            <label class="form-label">Fim Período</label>
                                            <input type="date" id="m-end" class="form-control" value="${meeting.end || ''}">
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Prazo Fechamento (Docentes)</label>
                                        <input type="date" id="m-dead" class="form-control" value="${meeting.deadline || ''}">
                                    </div>
                                    ${isEdit ? `
                 <div class="mb-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" id="m-status">
                        <option value="Aberto" ${meeting.Status === 'Aberto' ? 'selected' : ''}>Aberto</option>
                        <option value="Fechado" ${meeting.Status === 'Fechado' ? 'selected' : ''}>Fechado</option>
                    </select>
                 </div>` : ''}
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button class="btn btn-success" onclick="Forms.saveMeeting()">
                                ${isEdit ? '💾 Salvar Alterações' : '✨ Criar Reunião'}
                            </button>
                        </div>
                    </div></div></div>`;

        let old = document.getElementById('modalMeeting');
        if (old) {
            const instance = bootstrap.Modal.getInstance(old);
            if (instance) instance.dispose();
            old.remove();
        }

        document.body.insertAdjacentHTML('beforeend', modalHtml);
        new bootstrap.Modal(document.getElementById('modalMeeting')).show();
    };

    Forms.deleteRequest = function (id) {
        UI.confirm({
            title: 'Excluir Pedido',
            message: 'Tem certeza que deseja excluir este pedido permanentemente?',
            type: 'danger',
            confirmLabel: 'Sim, Excluir',
            onConfirm: function () {
                UI.showLoading(true);
                google.script.run
                    .withSuccessHandler(function () {
                        UI.showLoading(false);
                        UI.toast('Pedido excluído com sucesso.', 'success');
                        // Refresh the current view
                        if (typeof Views.renderKanbanView === 'function') {
                            Views.renderKanbanView();
                        } else {
                            App.init();
                        }
                    })
                    .withFailureHandler(function (err) {
                        UI.showLoading(false);
                        UI.toast('Erro ao excluir: ' + err.message, 'error');
                    })
                    .deleteRequest(id);
            }
        });
    };

    // NOTE: openDocenteModal and submitDocenteAction are defined in the Forms object above (line ~4010-4082)

    // Secretariat: Insert into Agenda - Sets status to "Em Pauta" (Purple)
    // --- AGENDA MANAGEMENT ---
    Forms.openAgendaSelectionModal = function (requestId) {
        // Fetch open meetings
        UI.showLoading(true, "Carregando reuniões...");
        google.script.run
            .withSuccessHandler(function (meetings) {
                UI.showLoading(false);
                if (!meetings || meetings.length === 0) {
                    UI.alert("Não há reuniões abertas disponíveis para pauta.");
                    return;
                }

                let options = meetings.map(m => `< option value = "${m.ID}" > ${m.Nome} (${new Date(m.Data_Reuniao).toLocaleDateString()})</option > `).join('');

                const modalHtml = `
            <div class="modal fade" id="modalAgendaSelection" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-purple text-white">
                            <h5 class="modal-title">📥 Inserir na Pauta</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p>Selecione a reunião para a qual este pedido será encaminhado:</p>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Reunião CPG</label>
                                <select class="form-select" id="agenda-meeting-select">
                                    ${options}
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="button" class="btn btn-purple" onclick="Forms.submitAgendaSelection('${requestId}')">Confirmar e Pautar</button>
                        </div>
                    </div>
                </div>
            </div>`;

                // Remove old
                const old = document.getElementById('modalAgendaSelection');
                if (old) old.remove();

                document.body.insertAdjacentHTML('beforeend', modalHtml);
                new bootstrap.Modal(document.getElementById('modalAgendaSelection')).show();
            })
            .withFailureHandler(function (err) {
                UI.showLoading(false);
                UI.toast("Erro ao carregar reuniões: " + err.message, 'error');
            })
            .getMeetings(true); // activeOnly = true
    };

    Forms.submitAgendaSelection = function (requestId) {
        const meetingId = document.getElementById('agenda-meeting-select').value;
        if (!meetingId) {
            UI.toast("Selecione uma reunião.", 'warning');
            return;
        }

        UI.showLoading(true, 'Inserindo na pauta...');

        google.script.run
            .withSuccessHandler(function (res) {
                UI.showLoading(false);
                UI.toast('Pedido inserido na pauta com sucesso!', 'success');

                // Close modal
                const el = document.getElementById('modalAgendaSelection');
                if (el) {
                    const modal = bootstrap.Modal.getInstance(el);
                    if (modal) modal.hide();
                }

                // Refresh View (Try Financial Kanban or reload)
                if (typeof Views !== 'undefined' && Views.renderFinancialManagement) Views.renderFinancialManagement();
                else App.init();
            })
            .withFailureHandler(function (err) {
                UI.showLoading(false);
                UI.showError(err);
            })
            .sendToAgenda(requestId, meetingId);
    };

    Forms.sendToAgenda = function (requestId) {
        // Now redirects to Modal first
        Forms.openAgendaSelectionModal(requestId);
    };

    Forms.saveMeeting = function () {
        const id = document.getElementById('m-id').value;
        const isEdit = !!id;

        let data = {
            id: id,
            name: document.getElementById('m-name').value,
            date: document.getElementById('m-date').value,
            start: document.getElementById('m-start').value,
            end: document.getElementById('m-end').value,
            deadline: document.getElementById('m-dead').value
        };

        if (isEdit) {
            data.status = document.getElementById('m-status').value;
        }

        // Basic validation
        if (!data.name || !data.date) {
            return UI.toast("Nome e Data são obrigatórios", "warning");
        }

        UI.showLoading(true, isEdit ? "Atualizando..." : "Criando...");

        const callback = function () {
            UI.showLoading(false);
            UI.toast(isEdit ? "Reunião atualizada!" : "Reunião criada!", "success");
            const modalEl = document.getElementById('modalMeeting');
            if (modalEl) {
                const instance = bootstrap.Modal.getInstance(modalEl);
                if (instance) instance.hide();
            }
            Views.renderCalendarManagement(); // Refresh
        };

        if (isEdit) {
            API.updateMeeting(data, callback);
        } else {
            API.createMeeting(data, callback);
        }
    };

    // NOTE: Another duplicate openDocenteModal and submitDocenteAction removed - use the ones in Forms object

    Forms.openEditContactModal = function () {
        if (!App.user) return;

        // Pre-fill fields
        document.getElementById('contact-telefone').value = App.user.Telefone || '';
        document.getElementById('contact-celular').value = App.user.Celular || '';
        document.getElementById('contact-endereco').value = App.user.Endereco || '';
        document.getElementById('contact-emergencia-nome').value = App.user.EmergenciaNome || '';
        document.getElementById('contact-emergencia-tel').value = App.user.EmergenciaTel || '';

        var modal = new bootstrap.Modal(document.getElementById('modalEditContact'));
        modal.show();
    };

    Forms.submitContactUpdate = function () {
        var data = {
            Telefone: document.getElementById('contact-telefone').value,
            Celular: document.getElementById('contact-celular').value,
            Endereco: document.getElementById('contact-endereco').value,
            EmergenciaNome: document.getElementById('contact-emergencia-nome').value,
            EmergenciaTel: document.getElementById('contact-emergencia-tel').value
        };

        UI.showLoading(true, "Salvando contatos...");

        API.updateContactInfo(data, function (res) {
            UI.showLoading(false);
            if (res && res.success) {
                UI.toast("Contatos atualizados com sucesso!", "success");

                // Update App.user locally
                Object.assign(App.user, data);

                // Close modal
                var el = document.getElementById('modalEditContact');
                var modal = bootstrap.Modal.getInstance(el);
                if (modal) modal.hide();

                // Re-render view based on current role
                UI.updateUserInfo(); // Update header info if needed
            } else {
                UI.showError("Erro desconhecido ao salvar.");
            }
        });
    };

    // =========================================================================
    // PROPGWEB CSV IMPORT MODAL AND FUNCTIONS
    // =========================================================================

    Forms.openImportCSVModal = function () {
        const modalHtml = `
            < div class="modal fade" id = "modalImportCSV" tabindex = "-1" >
                <div class="modal-dialog modal-lg">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-success text-white">
                            <h5 class="modal-title">📥 Importar Dados do ProPGWeb (CSV)</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body p-4">
                            <div class="alert alert-info">
                                <strong>📋 Formato esperado:</strong>
                                <p class="mb-1 small">O arquivo CSV deve conter as seguintes colunas (separadas por vírgula):</p>
                                <code class="small d-block text-wrap">nome_aluno, nivel, status, email, data_matricula, creditos_disciplinas_optativas, creditos_disciplinas_obrigatorias, data_para_defesa, data_para_qualificacao, data_para_integralizacao, nome_orientador, data_defesa, cpf, rg, orgao_expedidor, data_emissao, data_nascimento, sexo, raca, telefone_celular, logradouro, numero, complemento, bairro, cidade, uf, cep</code>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Selecione o arquivo CSV:</label>
                                <input type="file" class="form-control" id="csv-file-input" accept=".csv,.txt">
                                    <small class="text-muted">Aceita arquivos .csv ou .txt (encoding UTF-8 recomendado)</small>
                            </div>

                            <div id="csv-preview-container" style="display:none">
                                <label class="form-label fw-bold">📄 Prévia do arquivo:</label>
                                <div class="bg-light p-3 rounded border" style="max-height:200px; overflow:auto">
                                    <pre id="csv-preview" class="mb-0 small"></pre>
                                </div>
                                <p class="mt-2 small text-muted" id="csv-line-count"></p>
                            </div>

                            <div id="import-result-container" style="display:none" class="mt-4">
                                <h6 class="fw-bold">📊 Resultado da Importação:</h6>
                                <div id="import-result"></div>
                            </div>
                        </div>
                        <div class="modal-footer bg-light">
                            <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="button" class="btn btn-success px-4" id="btn-process-csv" onclick="Forms.processImportCSV()" disabled>
                                📥 Processar Importação
                            </button>
                        </div>
                    </div>
                </div>
        </div > `;

        // Remove old modal if exists
        let old = document.getElementById('modalImportCSV');
        if (old) {
            const instance = bootstrap.Modal.getInstance(old);
            if (instance) instance.dispose();
            old.remove();
        }

        document.body.insertAdjacentHTML('beforeend', modalHtml);

        // Add file change listener
        document.getElementById('csv-file-input').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function (evt) {
                const content = evt.target.result;
                const lines = content.split(/\r?\n/).filter(function (l) { return l.trim(); });

                // Show preview (first 5 lines)
                const preview = lines.slice(0, 5).join('\n');
                document.getElementById('csv-preview').textContent = preview + (lines.length > 5 ? '\n...' : '');
                document.getElementById('csv-preview-container').style.display = 'block';
                document.getElementById('csv-line-count').textContent = 'Total: ' + lines.length + ' linhas (1 cabeçalho + ' + (lines.length - 1) + ' registros)';

                // Store content for processing
                Forms._csvContent = content;

                // Enable button
                document.getElementById('btn-process-csv').disabled = false;

                // Hide previous results
                document.getElementById('import-result-container').style.display = 'none';
            };
            reader.readAsText(file, 'UTF-8');
        });

        new bootstrap.Modal(document.getElementById('modalImportCSV')).show();
    };

    Forms._csvContent = null;

    Forms.processImportCSV = function () {
        if (!Forms._csvContent) {
            UI.toast("Selecione um arquivo CSV primeiro.", "error");
            return;
        }

        const btn = document.getElementById('btn-process-csv');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processando...';

        UI.showLoading(true, "Importando dados do ProPGWeb...");

        google.script.run
            .withSuccessHandler(function (result) {
                UI.showLoading(false);
                btn.innerHTML = '📥 Processar Importação';
                btn.disabled = false;

                const container = document.getElementById('import-result-container');
                const resultDiv = document.getElementById('import-result');
                container.style.display = 'block';

                if (result.success) {
                    resultDiv.innerHTML = `
            < div class="alert alert-success" >
                <strong>✅ Importação concluída com sucesso!</strong>
                        </div >
            <div class="row g-3 text-center">
                <div class="col-4">
                    <div class="card border-success">
                        <div class="card-body py-3">
                            <div class="fs-3 fw-bold text-success">${result.inserted || 0}</div>
                            <small class="text-muted">Novos alunos</small>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-info">
                        <div class="card-body py-3">
                            <div class="fs-3 fw-bold text-info">${result.updated || 0}</div>
                            <small class="text-muted">Atualizados</small>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-warning">
                        <div class="card-body py-3">
                            <div class="fs-3 fw-bold text-warning">${result.errors || 0}</div>
                            <small class="text-muted">Erros</small>
                        </div>
                    </div>
                </div>
            </div>
                        ${result.errorMessages && result.errorMessages.length > 0 ?
                            '<div class="alert alert-warning mt-3"><strong>Avisos:</strong><ul class="mb-0">' +
                            result.errorMessages.slice(0, 10).map(function (m) { return '<li>' + m + '</li>'; }).join('') +
                            '</ul></div>' : ''
                        }
        `;

                    UI.toast("Importação concluída: " + (result.inserted || 0) + " novos, " + (result.updated || 0) + " atualizados", "success");
                } else {
                    resultDiv.innerHTML = `
            < div class="alert alert-danger" >
                            <strong>❌ Erro na importação:</strong>
                            <p class="mb-0">${result.error || 'Erro desconhecido'}</p>
                        </div >
            `;
                    UI.toast("Erro na importação", "error");
                }
            })
            .withFailureHandler(function (error) {
                UI.showLoading(false);
                btn.innerHTML = '📥 Processar Importação';
                btn.disabled = false;

                document.getElementById('import-result-container').style.display = 'block';
                document.getElementById('import-result').innerHTML = `
            < div class="alert alert-danger" >
                <strong>❌ Erro:</strong> ${error.message || error}
                    </div >
            `;
                UI.toast("Erro: " + error.message, "error");
            })
            .importProPGWebCSV(Forms._csvContent);
    };

    // Alias for index.html navigation compatibility
    Views.renderArchiveViewer = function () {
        const container = document.getElementById('main-content');
        container.innerHTML = `
            < div class="row align-items-center mb-4" >
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#" onclick="Views.renderSecretariaDashboard(); return false;">Painel</a></li>
                        <li class="breadcrumb-item active">Arquivo Morto</li>
                    </ol>
                </nav>
                <h4 class="mb-0 mt-2"><i class="fas fa-archive text-secondary me-2"></i>Arquivo Morto</h4>
                <p class="text-muted small">Histórico completo de solicitações finalizadas ou concluídas.</p>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary" onclick="Views.renderSecretariaDashboard()">Voltar</button>
            </div>
        </div >

            <div id="archive-content-area">
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Carregando Acervo Histórico...</p>
                </div>
            </div>
        `;

        API.getArchivedRequests(function (items) {
            if (!items || items.length === 0) {
                document.getElementById('archive-content-area').innerHTML = `
            < div class="alert alert-info text-center py-5 shadow-sm border-0" >
                    <h5><i class="fas fa-inbox fa-2x mb-3 text-info"></i><br>Nenhum registro encontrado no Arquivo.</h5>
                    <p class="mb-0 text-muted">Solicitações arquivadas pela tela de Edição de Usuário aparecerão aqui.</p>
                </div > `;
                return;
            }

            // Store active data for filtering
            window._activeArchiveData = items;

            // Build distinct options for Dropdowns
            const reunioes = [...new Set(items.map(i => i.ID_Reuniao || "Desconhecida").filter(Boolean))].sort().reverse();
            const alunos = [...new Set(items.map(i => i.Nome_Aluno || "Desconhecido").filter(Boolean))].sort();
            const anos = [...new Set(items.map(i => i.Meta_Ano || "N/A").filter(Boolean))].sort().reverse();
            const statusList = [...new Set(items.map(i => i.Meta_Status || "Ativo").filter(Boolean))].sort();
            const orientadores = [...new Set(items.map(i => i.Meta_Orientador || "Sem Orientador").filter(Boolean))].sort();
            const niveis = [...new Set(items.map(i => i.Meta_Nivel || "-").filter(Boolean))].sort();

            // Stats Map for Dashboard
            let statConcluidas = 0;
            let statRejeitadas = 0;
            let statCanceladas = 0;
            let recentYear = anos[0] || "N/A";
            let countRecentYear = 0;

            items.forEach(req => {
                const st = (req.Status || "").toLowerCase();
                if (st.includes("concluíd") || st.includes("concluid") || st.includes("aceita") || st.includes("finalizad")) statConcluidas++;
                else if (st.includes("rejeitad") || st.includes("indeferid") || st.includes("não acatad")) statRejeitadas++;
                else if (st.includes("cancelad")) statCanceladas++;

                if (req.Meta_Ano === recentYear) countRecentYear++;
            });

            const html = `
            < !--DASHBOARD ROW-- >
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card bg-white border-0 shadow-sm h-100 border-start border-4 border-secondary">
                        <div class="card-body">
                            <h6 class="text-muted text-uppercase mb-2">Total no Arquivo</h6>
                            <h3 class="mb-0 text-dark">${items.length}</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-white-50 text-uppercase mb-2">Concluídas / Aceitas</h6>
                            <h3 class="mb-0">${statConcluidas}</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-danger text-white border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-white-50 text-uppercase mb-2">Rejeitadas / Indeferidas</h6>
                            <h3 class="mb-0">${statRejeitadas}</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-white-50 text-uppercase mb-2">Ingressos de ${recentYear}</h6>
                            <h3 class="mb-0">${countRecentYear}</h3>
                        </div>
                    </div>
                </div>
            </div>

            <!--FILTERS -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0"><i class="fas fa-filter text-muted me-2"></i>Filtros Avançados</h6>
                </div>
                <div class="card-body bg-light">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small text-muted">Reunião CG</label>
                            <select class="form-select form-select-sm" id="af-reuniao" onchange="Views.applyArchiveFilters()">
                                <option value="">Todas</option>
                                ${reunioes.map(r => '<option value=\"' + r + '\">' + r + '</option>').join('')}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted">Aluno</label>
                            <select class="form-select form-select-sm" id="af-aluno" onchange="Views.applyArchiveFilters()">
                                <option value="">Todos</option>
                                ${alunos.map(a => '<option value=\"' + a + '\">' + a + '</option>').join('')}
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small text-muted">Ano de Ingresso</label>
                            <select class="form-select form-select-sm" id="af-ano" onchange="Views.applyArchiveFilters()">
                                <option value="">Todos</option>
                                ${anos.map(a => '<option value=\"' + a + '\">' + a + '</option>').join('')}
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small text-muted">Status do Aluno</label>
                            <select class="form-select form-select-sm" id="af-status" onchange="Views.applyArchiveFilters()">
                                <option value="">Todos</option>
                                ${statusList.map(s => '<option value=\"' + s + '\">' + s + '</option>').join('')}
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small text-muted">Nível</label>
                            <select class="form-select form-select-sm" id="af-nivel" onchange="Views.applyArchiveFilters()">
                                <option value="">Qualquer</option>
                                ${niveis.map(n => '<option value=\"' + n + '\">' + n + '</option>').join('')}
                            </select>
                        </div>
                        
                        <div class="col-md-4">
                            <label class="form-label small text-muted">Orientador(a)</label>
                            <select class="form-select form-select-sm" id="af-orientador" onchange="Views.applyArchiveFilters()">
                                <option value="">Todos</option>
                                ${orientadores.map(o => '<option value=\"' + o + '\">' + o + '</option>').join('')}
                            </select>
                        </div>
                        
                        <div class="col-md-4">
                            <label class="form-label small text-muted">Ano da Defesa</label>
                            <input type="number" class="form-control form-control-sm" id="af-defesaano" placeholder="Ex: 2025" oninput="Views.applyArchiveFilters()">
                        </div>
                        
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-sm btn-outline-secondary w-100" onclick="Views.resetArchiveFilters()"><i class="fas fa-eraser me-1"></i>Limpar Filtros</button>
                        </div>
                    </div>
                </div>
            </div>

            <!--TABLE -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="archive-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Criação</th>
                                    <th>Tipo</th>
                                    <th>Aluno</th>
                                    <th>Orientador</th>
                                    <th>Status Histórico</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="archive-tbody">
                            </tbody>
                        </table>
                    </div>
                    <div class="p-5 text-center text-muted" id="archive-empty-msg" style="display:none;">
                        <i class="fas fa-search fa-2x mb-3 text-light"></i><br>
                            Nenhum registro corresponde aos filtros selecionados.
                    </div>
                </div>
            </div>
        `;
            document.getElementById('archive-content-area').innerHTML = html;
            Views.applyArchiveFilters(); // Initial render
        });
    };

    Views.resetArchiveFilters = function () {
        ['af-reuniao', 'af-aluno', 'af-ano', 'af-status', 'af-nivel', 'af-orientador', 'af-defesaano'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        Views.applyArchiveFilters();
    };

    Views.applyArchiveFilters = function () {
        const data = window._activeArchiveData || [];
        const fReuniao = document.getElementById('af-reuniao').value;
        const fAluno = document.getElementById('af-aluno').value;
        const fAno = document.getElementById('af-ano').value;
        const fStatus = document.getElementById('af-status').value;
        const fNivel = document.getElementById('af-nivel').value;
        const fOrientador = document.getElementById('af-orientador').value;
        const fDefesaAno = document.getElementById('af-defesaano').value.trim();

        const filtered = data.filter(r => {
            if (fReuniao && r.ID_Reuniao !== fReuniao) return false;
            if (fAluno && r.Nome_Aluno !== fAluno) return false;
            if (fAno && r.Meta_Ano !== fAno) return false;
            if (fStatus && r.Meta_Status !== fStatus) return false;
            if (fNivel && r.Meta_Nivel !== fNivel) return false;
            if (fOrientador && r.Meta_Orientador !== fOrientador) return false;
            if (fDefesaAno && r.Meta_Defesa) {
                const y = new Date(r.Meta_Defesa).getFullYear().toString();
                if (y !== fDefesaAno) return false;
            } else if (fDefesaAno && !r.Meta_Defesa) {
                return false;
            }
            return true;
        });

        const tbody = document.getElementById('archive-tbody');
        const emptyMsg = document.getElementById('archive-empty-msg');

        if (filtered.length === 0) {
            tbody.innerHTML = '';
            emptyMsg.style.display = 'block';
            return;
        }

        emptyMsg.style.display = 'none';
        let rowsHtml = '';

        filtered.forEach(req => {
            const dt = new Date(req.Timestamp || req.Data_Criacao);
            const dataStr = isNaN(dt.getTime()) ? "-" : dt.toLocaleDateString('pt-BR');

            let typeBadge = "secondary";
            if ((req.Tipo || "").includes("FIN_")) typeBadge = "success";
            else if ((req.Tipo || "").includes("ACAD_")) typeBadge = "primary";

            let statusBadge = "secondary";
            const st = (req.Status || "").toLowerCase();
            if (st.includes("concluíd") || st.includes("aceita") || st.includes("finalizad")) statusBadge = "success";
            if (st.includes("rejeitad") || st.includes("indeferid") || st.includes("não acatad")) statusBadge = "danger";
            if (st.includes("ressalva")) statusBadge = "warning text-dark";

            // Details Parser
            let detailsBtn = '';
            try {
                const detStr = JSON.stringify(req).replace(/'/g, "%27").replace(/"/g, "&quot;");
                detailsBtn = `< button class="btn btn-sm btn-outline-info" onclick = "Views.showArchivedDetails('${detStr}')" > <i class="fas fa-eye"></i> Detalhes</button > `;
            } catch (e) { }

            rowsHtml += `
            < tr >
                <td class="small text-muted">${dataStr}</td>
                <td><span class="badge bg-${typeBadge}">${req.Tipo || "Desconhecido"}</span></td>
                <td>
                    <div class="fw-bold">${req.Nome_Aluno || "-"}</div>
                    <div class="small text-muted">${req.Meta_Nivel || ""} | Ingresso: ${req.Meta_Ano || "-"}</div>
                </td>
                <td class="small">${req.Meta_Orientador || "-"}</td>
                <td><span class="badge bg-${statusBadge}">${req.Status || "-"}</span></td>
                <td>${detailsBtn}</td>
            </tr >
            `;
        });

        tbody.innerHTML = rowsHtml;
    };

    Views.showArchivedDetails = function (jsonStr) {
        try {
            const req = JSON.parse(decodeURIComponent(jsonStr).replace(/&quot;/g, '"'));
            const modalHtml = `
            < div class="modal fade" id = "modalArchiveDetails" tabindex = "-1" aria - hidden="true" >
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-light">
                            <h5 class="modal-title"><i class="fas fa-archive me-2 text-secondary"></i>Detalhes do Arquivo</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row mb-3 pb-3 border-bottom">
                                <div class="col-md-6">
                                    <small class="text-muted d-block">Aluno(a)</small>
                                    <strong>${req.Nome_Aluno || "-"}</strong>
                                </div>
                                <div class="col-md-6 text-end">
                                    <small class="text-muted d-block">Status de Fechamento</small>
                                    <span class="badge bg-secondary">${req.Status || "-"}</span>
                                </div>
                            </div>

                            <h6 class="text-muted mb-3">Conteúdo Base</h6>
                            <div class="bg-light p-3 rounded mb-3" style="font-family: monospace; white-space: pre-wrap; font-size: 0.85rem;">${req.Detalhes || "Sem detalhes estruturados."}</div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                        </div>
                    </div>
                </div>
        </div >`;

            const old = document.getElementById('modalArchiveDetails');
            if (old) {
                const instance = bootstrap.Modal.getInstance(old);
                if (instance) instance.dispose();
                old.remove();
            }

            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const modal = new bootstrap.Modal(document.getElementById('modalArchiveDetails'));
            modal.show();
        } catch (e) {
            UI.toast("Erro ao ler detalhes.", "error");
        }
    }

    // Alias for index.html navigation compatibility
    Views.renderCGDashboard = Views.renderCGParecerView;

    window.onload = App.init;
</script>