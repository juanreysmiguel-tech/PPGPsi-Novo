        selectCountryGroup: function (letter, value) {
            const display = document.getElementById('diaria-grupo-display');
            if (display) {
                // Force dataset update
                display.setAttribute('data-group-value', value);
                display.dataset.groupValue = value;

                display.value = `Grupo ${letter} (US$ ${value})`;

                // Trigger calculation update
                display.dispatchEvent(new Event('change', { bubbles: true }));
                display.dispatchEvent(new Event('input', { bubbles: true }));
            }
            bootstrap.Modal.getInstance(document.getElementById('modalCountryGroup')).hide();
        },

        // --- MURAL DA COMUNIDADE ---
        submitMuralPost: function () {
            const textarea = document.getElementById('mural-post-content');
            const conteudo = textarea ? textarea.value.trim() : '';

            if (!conteudo) {
                UI.toast('Escreva algo para publicar.', 'warning');
                return;
            }

            UI.showLoading(true, 'Publicando...');

            google.script.run
                .withSuccessHandler(function (result) {
                    UI.showLoading(false);
                    if (result && result.success) {
                        UI.toast('Publicação criada!', 'success');
                        textarea.value = '';
                        // Reload posts
                        Views.renderMural();
                    } else {
                        UI.toast('Erro: ' + (result ? result.error : 'desconhecido'), 'error');
                    }
                })
                .withFailureHandler(function (err) {
                    UI.showLoading(false);
                    UI.toast('Erro ao publicar: ' + err.message, 'error');
                })
                .createMuralPost(conteudo);
        },

        uploadPhoto: function (input) {
            if (!input.files || !input.files[0]) return;

            const file = input.files[0];
            if (file.size > 2 * 1024 * 1024) {
                UI.toast('Foto muito grande (máximo 2MB)', 'error');
                return;
            }

            UI.showLoading(true, 'Enviando foto...');

            const reader = new FileReader();
            reader.onload = function (e) {
                const base64 = e.target.result.split(',')[1];

                google.script.run
                    .withSuccessHandler(function (url) {
                        UI.showLoading(false);
                        UI.toast('Foto atualizada!', 'success');
                        App.user.photo = url;

                        // Update display
                        const img = document.getElementById('profile-photo');
                        const placeholder = document.getElementById('photo-placeholder');
                        if (img) {
                            img.src = url;
                            img.style.display = 'block';
                        }
                        if (placeholder) placeholder.style.display = 'none';
                    })
                    .withFailureHandler(function (err) {
                        UI.showLoading(false);
                        UI.toast('Erro ao enviar foto: ' + err.message, 'error');
                    })
                    .uploadUserPhoto(base64, file.name, file.type);
            };
            reader.readAsDataURL(file);
        },

        // --- REQUESTS ---
        openNewRequestModal: function (categoryFilter = null) {
            // Populate select - filter by category if specified
            const select = document.getElementById('req-type');
            select.innerHTML = '<option value="">Selecione o tipo...</option>';

            Object.keys(RequestConfig).forEach(key => {
                const config = RequestConfig[key];
                const itemCategory = config.category || 'academic'; // default to academic

                // Filter by category if specified
                if (categoryFilter && itemCategory !== categoryFilter) return;

                // Also exclude financial from default view (when no filter)
                if (!categoryFilter && (itemCategory === 'financial')) return;

                const opt = document.createElement('option');
                opt.value = key;
                opt.innerText = config.title;
                select.appendChild(opt);
            });

            // Dados do aluno já carregados em App.user - serão usados para pré-preencher campos
            // Não exibir seção separada "Dados do ProPGWeb"
            const propgContainer = document.getElementById('propg-header-container');
            if (propgContainer) {
                propgContainer.innerHTML = '';
            }

            // Clean previous fields
            document.getElementById('dynamic-fields-msg').style.display = 'block';
            document.getElementById('dynamic-fields-container').innerHTML = '';

            // Add change listener
            select.onchange = function () {
                Forms.renderDynamicFields(this.value);
            };

            new bootstrap.Modal(document.getElementById('modalRequest')).show();
        },

        renderDynamicFields: function (typeKey) {
            const container = document.getElementById('dynamic-fields-container');
            const msg = document.getElementById('dynamic-fields-msg');
            container.innerHTML = '';

            if (!typeKey || !RequestConfig[typeKey]) {
                msg.style.display = 'block';
                return;
            }

            msg.style.display = 'none';
            const config = RequestConfig[typeKey];

            // Map of field labels to App.user properties for auto-fill
            const autoFillMap = {
                'Prazo Regulamentar para Qualificação': 'Data_Qualificacao',
                'Prazo regulamentar para a defesa': 'Data_Defesa',
                'Prazo regulamentar para integralização': 'Data_Integralizacao',
                'Data de Ingresso': 'Data_Ingresso',
                'Créditos em Disciplinas Optativas': 'Creditos_Optativas',
                'Créditos em Disciplinas Obrigatórias': 'Creditos_Obrigatorias',
                'Nome do Orientador': 'Nome_Orientador',
                'E-mail do Orientador': 'Email_Orientador',
                'CPF': 'CPF'
            };

            config.fields.forEach(function (field, index) {
                const div = document.createElement('div');
                div.className = 'mb-3';

                // Handle special field types first
                if (field.type === 'heading') {
                    div.className = 'mt-4 mb-2';
                    div.innerHTML = '<h6 class="fw-bold text-primary border-bottom pb-2">' + field.label + '</h6>';
                    container.appendChild(div);
                    return;
                }

                if (field.type === 'info') {
                    div.className = 'alert alert-light small py-2 mb-3';
                    div.innerHTML = field.label;
                    container.appendChild(div);
                    return;
                }

                // Handle conditional fields
                if (field.conditional && field.showWhen) {
                    div.dataset.conditionalField = field.id;
                    div.dataset.showWhenField = field.showWhen.field;
                    div.dataset.showWhenValue = field.showWhen.value;
                    div.style.display = 'none'; // Initially hidden
                }

                let input;

                // Checkbox type
                if (field.type === 'checkbox') {
                    div.className = 'form-check mb-2';
                    input = document.createElement('input');
                    input.type = 'checkbox';
                    input.className = 'form-check-input';
                    input.id = field.id || 'field-' + index;
                    input.name = field.id || 'field-' + index;

                    const checkLabel = document.createElement('label');
                    checkLabel.className = 'form-check-label';
                    checkLabel.htmlFor = input.id;
                    checkLabel.innerText = field.label;

                    div.appendChild(input);
                    div.appendChild(checkLabel);
                    container.appendChild(div);
                    return;
                }

                // Radio type
                if (field.type === 'radio') {
                    div.className = 'mb-3';
                    const radioLabelGroup = document.createElement('label');
                    radioLabelGroup.className = 'form-label d-block fw-bold';
                    radioLabelGroup.innerText = field.label + (field.required ? ' *' : '');
                    div.appendChild(radioLabelGroup);

                    const radioContainer = document.createElement('div');
                    field.options.forEach(function (opt, i) {
                        const checkDiv = document.createElement('div');
                        checkDiv.className = 'form-check form-check-inline mt-1';

                        const rInput = document.createElement('input');
                        rInput.type = 'radio';
                        rInput.className = 'form-check-input';
                        rInput.name = field.id || 'field-' + index;
                        rInput.id = (field.id || 'field-' + index) + '-' + i;
                        rInput.value = opt;
                        if (field.required) rInput.required = true;

                        rInput.dataset.label = field.label;
                        rInput.dataset.type = field.type;

                        if (field.onChange) {
                            rInput.addEventListener('change', function () {
                                field.onChange(this.value, container);
                            });
                        }

                        const rLabel = document.createElement('label');
                        rLabel.className = 'form-check-label';
                        rLabel.htmlFor = rInput.id;
                        rLabel.innerText = opt;

                        checkDiv.appendChild(rInput);
                        checkDiv.appendChild(rLabel);
                        radioContainer.appendChild(checkDiv);
                    });

                    div.appendChild(radioContainer);
                    container.appendChild(div);
                    return;
                }

                // Standard label for non-checkbox fields
                const label = document.createElement('label');
                label.className = 'form-label';
                label.innerText = field.label + (field.required ? ' *' : '');
                div.appendChild(label);

                if (field.type === 'textarea') {
                    input = document.createElement('textarea');
                    input.className = 'form-control';
                    input.rows = 3;
                } else if (field.type === 'select') {
                    input = document.createElement('select');
                    input.className = 'form-select';
                    field.options.forEach(function (opt) {
                        const o = document.createElement('option');
                        o.value = opt;
                        o.innerText = opt;
                        input.appendChild(o);
                    });
                } else {
                    input = document.createElement('input');
                    input.className = 'form-control';
                    input.type = field.type;
                    if (field.min !== undefined) input.min = field.min;
                }

                // Set ID if specified
                if (field.id) {
                    input.id = field.id;
                }

                // Handle readonly fields
                if (field.readonly) {
                    input.readOnly = true;
                    input.classList.add('bg-light', 'fw-bold');
                }

                input.dataset.label = field.label;
                input.dataset.type = field.type;
                input.required = field.required;

                // Auto-fill from App.user data if applicable
                if (App.user && (App.currentRole === 'Discente' || App.currentRole === 'Docente')) {
                    const userProp = autoFillMap[field.label];
                    if (userProp && App.user[userProp]) {
                        let userValue = App.user[userProp];
                        if (field.type === 'date' && userValue) {
                            try {
                                const d = new Date(userValue);
                                if (!isNaN(d)) {
                                    userValue = d.toISOString().split('T')[0];
                                }
                            } catch (e) { }
                        }
                        input.value = userValue;
                        if (field.label.includes('Prazo Regulamentar') || field.label.includes('Prazo regulamentar')) {
                            input.readOnly = true;
                            input.classList.add('bg-light');
                            const helper = document.createElement('small');
                            helper.className = 'text-muted';
                            helper.innerText = '* Preenchido automaticamente com seus dados';
                            div.appendChild(input);
                            div.appendChild(helper);
                            container.appendChild(div);
                            return;
                        }
                    }
                }

                div.appendChild(input);

                // Add helpText if present
                if (field.helpText) {
                    const helper = document.createElement('small');
                    helper.className = 'text-muted d-block mt-1';
                    helper.innerText = field.helpText;
                    div.appendChild(helper);
                }

                container.appendChild(div);
            });

            // --- SPECIAL HANDLERS ---

            // 1. Trancamento Auto-Fill
            if (typeKey === '8') {
                const pPeriodo = document.getElementById('trancamento-periodo');
                const pAnterior = document.getElementById('trancamento-anterior');

                if (pPeriodo) {
                    pPeriodo.value = "Verificando...";
                    // Async fetch
                    google.script.run
                        .withSuccessHandler(function (res) {
                            if (res && res.success) {
                                if (pPeriodo) pPeriodo.value = res.currentPeriod;
                                if (pAnterior) pAnterior.value = res.hasPrevious ? "Sim" : "Não";
                            } else {
                                console.error("Erro Trancamento check: " + (res ? res.error : "Unknown"));
                            }
                        })
                        .checkTrancamentoContext(App.authToken);
                }
            }

            // 2. Diaria Calculation
            if (config.hasDiariaCalculation) {
                Forms.setupDiariaCalculation();
            }

            // 3. General Currency Logic
            if (config.hasCurrencyLogic) {
                Forms.setupCurrencyLogic();
            }

            // 3. Conditional Fields (Generic)
            Forms.setupConditionalFields();
        },

        setupConditionalFields: function () {
            const conditionals = document.querySelectorAll('[data-conditional-field]');
            conditionals.forEach(div => {
                const triggerId = div.dataset.showWhenField;
                const requiredValue = div.dataset.showWhenValue;
                const triggerEl = document.getElementById(triggerId);

                if (triggerEl) {
                    const checkVisibility = () => {
                        let val = triggerEl.value;
                        if (triggerEl.type === 'checkbox') val = triggerEl.checked.toString();

                        // Find inputs inside the conditional div
                        const inputs = div.querySelectorAll('input, select, textarea');

                        if (val === requiredValue) {
                            div.style.display = 'block';
                            // Restore required if it was originally required
                            inputs.forEach(input => {
                                // Restore required state if it was meant to be required
                                // We check the original schema or data attribute? 
                                // Ideally we stored the original state.
                                // Simplified approach: If it has 'data-required-orig' use that, else check validation.
                                // BETTER: Just set required = true if it has a label with asterisk? NO.
                                // BEST: renderDynamicFields sets 'required' prop. 
                                // Let's use 'dataset.requiredOrig' which we should have set or just assume 
                                // all inputs in these specific conditional blocks ARE required when shown 
                                // (based on the current known schema for Trancamento/Diarias).
                                // TO BE ROBUST: We should set data-original-required during creation.

                                // Let's assume if it is in a conditional block defined in config as 'required: true', 
                                // it should be required when shown.
                                // But we don't have easy access to config here.

                                // WORKAROUND: In renderDynamicFields, add data-original-required="true" 
                                // to inputs that are required.

                                // FALLBACK: If dataset.label ends with '*', it is required? No.

                                // Let's rely on the fact we are only toggling 'required' property. 
                                // The browser property 'required' might be lost if we set it false.
                                // We need to store it first time.

                                if (input.dataset.originalRequired === undefined) {
                                    input.dataset.originalRequired = input.required;
                                }

                                if (input.dataset.originalRequired === "true") {
                                    input.required = true;
                                }
                            });
                        } else {
                            div.style.display = 'none';
                            inputs.forEach(input => {
                                if (input.dataset.originalRequired === undefined) {
                                    input.dataset.originalRequired = input.required;
                                }
                                input.required = false;
                            });
                        }
                    };

                    triggerEl.addEventListener('change', checkVisibility);
                    triggerEl.addEventListener('input', checkVisibility);
                    // Defer initial check slightly to ensure DOM is ready or just run it?
                    // Run it but we need to ensure inputs have 'required' set correctly first.
                    // renderDynamicFields sets 'required' initially.
                    setTimeout(checkVisibility, 0);
                } else {
                    console.warn('Trigger field not found for conditional:', triggerId);
                }
            });
        },

        // =========================================================================
        // DIARIA CALCULATION LOGIC (Updated for Dates & BCB API)
        // =========================================================================
        setupDiariaCalculation: function () {
            // New Inputs
            const dataInicio = document.getElementById('diaria-data-inicio');
            const dataFim = document.getElementById('diaria-data-fim');

            // Old Inputs (retained IDs for config compatibility)
            const localizacaoSelect = document.getElementById('diaria-localizacao');
            const presencialSelect = document.getElementById('diaria-presencial');
            const grupoDisplay = document.getElementById('diaria-grupo-display');
            const valorOutput = document.getElementById('diaria-valor-calculado');

            if (!dataInicio || !dataFim || !localizacaoSelect || !valorOutput) return;

            const calcularDiaria = function () {
                const presencial = presencialSelect ? presencialSelect.value : 'Sim';

                // PRIORITY 1: Non-Presential overrides EVERYTHING.
                if (presencial === 'N\u00E3o') {
                    valorOutput.readOnly = false;
                    valorOutput.classList.remove('bg-light');
                    if (valorOutput.value.includes('Calculado') || valorOutput.value.includes('R$')) {
                        valorOutput.value = '';
                    }
                    valorOutput.placeholder = 'Digite o valor da taxa de inscri\u00E7\u00E3o ou outros custos...';
                    return;
                }

                // Presential: Auto Calc
                valorOutput.readOnly = true;
                valorOutput.classList.add('bg-light');
                valorOutput.placeholder = 'Calculando...';

                // 1. Calculate Days
                let dias = 0;
                if (dataInicio.value && dataFim.value) {
                    const start = new Date(dataInicio.value);
                    const end = new Date(dataFim.value);
                    const diffTime = end - start;
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                    dias = diffDays > 0 ? diffDays : 1; // Minimum 1 day if Same day? Or strictly follow prompt. Prompt: "Date End - Date Start". If 0, let's say 0? No, event implies participation. Let's assume min 1.
                    // Actually, let's stick to strict diff for now, but user probably wants inclusive. 10 to 12 is 3 days usually (10, 11, 12). 
                    // Prompt said "Data Fim - Data Início". 12 - 10 = 2.
                    // I'll stick to 2.
                }

                const localizacao = localizacaoSelect.value;
                const grupoContainer = grupoDisplay ? grupoDisplay.closest('.mb-3') : null;

                // Toggle Country Group Display
                if (grupoContainer) {
                    if (localizacao === 'Exterior') {
                        grupoContainer.style.display = 'block';
                        grupoDisplay.style.cursor = 'pointer';
                        grupoDisplay.classList.add('bg-white');
                        grupoDisplay.onclick = Forms.openCountryGroupModal;
                    } else {
                        grupoContainer.style.display = 'none';
                        grupoDisplay.onclick = null;
                        grupoDisplay.dataset.groupValue = '';
                        grupoDisplay.value = '';
                    }
                }

                // If days not calculated yet, wait
                if (!dias || dias < 0) {
                    valorOutput.value = "Selecione as datas...";
                    return;
                }

                let valor = '';

                if (localizacao === 'Outro Estado (Brasil)') {
                    if (dias >= 3) {
                        valor = 'R$ 1.140,00 (Teto para >= 3 dias)';
                        valorOutput.dataset.cleanValue = '1140.00';
                    } else {
                        valor = 'R$ ' + (dias * 380).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) + ' (' + dias + ' di\u00E1rias)';
                        valorOutput.dataset.cleanValue = (dias * 380).toFixed(2);
                    }
                    valorOutput.value = valor;

                } else if (localizacao === 'S\u00E3o Paulo (Estado)') {
                    if (dias >= 2) {
                        valor = 'R$ 760,00 (Teto para >= 2 dias)';
                        valorOutput.dataset.cleanValue = '760.00';
                    } else {
                        valor = 'R$ 380,00 (1 di\u00E1ria)';
                        valorOutput.dataset.cleanValue = '380.00';
                    }
                    valorOutput.value = valor;

                } else if (localizacao === 'Exterior') {
                    // Exterior Logic with BCB API
                    const groupValue = grupoDisplay ? parseInt(grupoDisplay.dataset.groupValue) : 0;

                    if (groupValue > 0) {
                        valorOutput.value = "Buscando cotação do Dólar...";

                        // Call Backend
                        // Rate Date = Start Date
                        const rateDate = dataInicio.value;

                        google.script.run
                            .withSuccessHandler(function (res) {
                                if (res.success) {
                                    const rate = res.rate;
                                    const totalUSD = groupValue * dias; // Daily Rate * Days
                                    // Actually, is existing logic "Daily Rate" or "Flat Rate"?
                                    // Previous code: "US$ " + groupValue + ",00 (Valor fixo de 1 diária)". 
                                    // Prompt: "O cálculo final deve ser: (Valor da Diária na Moeda Estrangeira * Quantidade de Dias) * Taxa de Câmbio".
                                    // So it seems previously it was fixed 1 daily, now it is * Days.

                                    const totalBRL = totalUSD * rate;

                                    valorOutput.dataset.cleanValue = totalBRL.toFixed(2);
                                    valorOutput.value = `R$ ${totalBRL.toLocaleString('pt-BR', { minimumFractionDigits: 2 })} (US$ ${totalUSD} x ${rate.toFixed(4)} em ${new Date(res.dateUsed).toLocaleDateString('pt-BR')})`;
                                } else {
                                    valorOutput.value = "Erro na cotação: " + res.error;
                                    valorOutput.dataset.cleanValue = '';
                                }
                            })
                            .withFailureHandler(err => valorOutput.value = "Erro de conexão: " + err.message)
                            .getBCBExchangeRate('USD', rateDate);

                    } else {
                        valorOutput.value = "Selecione o Grupo de Países...";
                    }
                }
            };

            // Listeners
            if (dataInicio) dataInicio.addEventListener('change', calcularDiaria);
            if (dataFim) dataFim.addEventListener('change', calcularDiaria);
            if (localizacaoSelect) localizacaoSelect.addEventListener('change', calcularDiaria);
            if (presencialSelect) presencialSelect.addEventListener('change', calcularDiaria);
            if (grupoDisplay) {
                grupoDisplay.addEventListener('change', calcularDiaria);
                grupoDisplay.addEventListener('input', calcularDiaria); // support custom event dispatch
            }
        },

        // =========================================================================
        // GENERAL CURRENCY LOGIC (Material / Outros)
        // =========================================================================
        setupCurrencyLogic: function () {
            const moedaSelect = document.getElementById('fin-moeda');
            const dateInput = document.getElementById('fin-data-invoice');
            const valorOriginalInput = document.getElementById('fin-valor-original');
            const valorOutput = document.getElementById('diaria-valor-calculado'); // Reusing same output ID

            if (!moedaSelect || !valorOutput) return;

            // Helper to toggle date visibility
            const toggleDate = () => {
                const isForeign = moedaSelect.value !== 'Real (BRL)';
                const dateContainer = dateInput ? dateInput.closest('.mb-3') : null;
                if (dateContainer) {
                    if (isForeign) {
                        dateContainer.style.display = 'block';
                        if (dateInput) dateInput.required = true;
                    } else {
                        dateContainer.style.display = 'none';
                        if (dateInput) dateInput.required = false;
                    }
                }
            };

            const calculate = () => {
                const currencyFull = moedaSelect.value; // "Dolar (USD)"
                const currency = currencyFull.includes('USD') ? 'USD' :
                    currencyFull.includes('EUR') ? 'EUR' :
                        currencyFull.includes('GBP') ? 'GBP' : 'BRL';

                const valOriginal = parseFloat(valorOriginalInput.value);
                const dateStr = dateInput ? dateInput.value : null;

                if (isNaN(valOriginal)) {
                    valorOutput.value = '';
                    return;
                }


                if (currency === 'BRL') {
                    // Direct Value
                    valorOutput.dataset.cleanValue = valOriginal.toFixed(2);
                    valorOutput.value = valOriginal.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                } else {
                    // Needs Conversion
                    if (!dateStr) {
                        valorOutput.value = "Informe a data da Invoice...";
                        return;
                    }

                    valorOutput.value = "Buscando cotação...";

                    google.script.run
                        .withSuccessHandler(function (res) {
                            if (res.success) {
                                const rate = res.rate;
                                const totalBRL = valOriginal * rate;
                                valorOutput.dataset.cleanValue = totalBRL.toFixed(2);
                                valorOutput.value = `R$ ${totalBRL.toLocaleString('pt-BR', { minimumFractionDigits: 2 })} (${currency} ${valOriginal} x ${rate.toFixed(4)} em ${new Date(res.dateUsed).toLocaleDateString('pt-BR')})`;
                            } else {
                                valorOutput.value = "Erro: " + res.error;
                                valorOutput.dataset.cleanValue = '';
                            }
                        })
                        .withFailureHandler(err => valorOutput.value = "Erro: " + err.message)
                        .getBCBExchangeRate(currency, dateStr);
                }
            };

            // Listeners
            moedaSelect.addEventListener('change', () => { toggleDate(); calculate(); });
            if (dateInput) dateInput.addEventListener('change', calculate);
            if (valorOriginalInput) valorOriginalInput.addEventListener('input', calculate); // Live calc on typing

            // Init
            toggleDate();
        },

        // --- LOGIN / OTP UI ---
