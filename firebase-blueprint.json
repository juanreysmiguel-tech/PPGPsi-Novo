                                                                        <label class="form-check-label" for="cpg-ata-yes">Sim</label>
                                                                    </div>
                                                                </div>
                                                                <div id="cpg-ata-container" style="display:none" class="mt-2">
                                                                    <textarea class="form-control form-control-sm" id="cpg-ata-obs" rows="2" placeholder="Observação para a Ata..."></textarea>
                                                                </div>
                                                            </div>
                                                            
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label fw-bold">Enviar info para aluno/orientador?</label>
                                                                <div class="d-flex gap-3">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="radio" name="cpg-info" id="cpg-info-no" value="no" checked onchange="document.getElementById('cpg-info-container').style.display='none'">
                                                                        <label class="form-check-label" for="cpg-info-no">Não</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="radio" name="cpg-info" id="cpg-info-yes" value="yes" onchange="document.getElementById('cpg-info-container').style.display='block'">
                                                                        <label class="form-check-label" for="cpg-info-yes">Sim</label>
                                                                    </div>
                                                                </div>
                                                                <div id="cpg-info-container" style="display:none" class="mt-2">
                                                                    <textarea class="form-control form-control-sm" id="cpg-add-info" rows="2" placeholder="Mensagem adicional..."></textarea>
