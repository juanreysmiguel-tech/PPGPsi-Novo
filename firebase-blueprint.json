        submitDocenteAction: function (requestId, action, requestType) {
            // Try to get justification from either modal
            const justifEl = document.getElementById('doc-justif') || document.getElementById('docente-obs');
            const justif = justifEl ? justifEl.value : '';

            // Determine status based on action
            let newStatus = '';
            if (action === 'Aprovar') {
                // For financial requests, approved by advisor goes to CG
                // For academic requests, approved by advisor goes to Secretariat (Pendente)
                // Relaxed check:
                if (requestType && (requestType.includes('Auxílio Financeiro') || requestType.indexOf('FIN_') !== -1)) {
                    newStatus = 'Aguardando CG';
                } else {
                    newStatus = 'Pendente';
                }
            } else if (action === 'Rejeitar') {
                newStatus = 'Rejeitado';
            } else if (action === 'Elucidar') {
                newStatus = 'Retornado ao Aluno';
            }

            UI.showLoading(true, 'Processando...');

            API.updateRequestStatus(requestId, newStatus, justif, '', function () {
                UI.showLoading(false);
                // Close whichever modal is open
                const modalDocente = document.getElementById('modalDocente');
                const modalDetail = document.getElementById('modalRequestDetail');
                if (modalDocente) { try { bootstrap.Modal.getInstance(modalDocente)?.hide(); } catch (e) { } }
                if (modalDetail) { try { bootstrap.Modal.getInstance(modalDetail)?.hide(); } catch (e) { } }
                UI.toast('Status atualizado para: ' + newStatus, 'success');
                UI.renderView();
            });
        },

