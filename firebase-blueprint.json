<script>
    /* ==========================================================================
       APP STATE & UTILS
       ========================================================================== */

    // Helper function to parse monetary values from various formats
    function parseMoneyValue(val) {
        if (val === null || val === undefined || val === '') return 0;
        if (typeof val === 'number') return isNaN(val) ? 0 : val;

        // Convert to string and clean up
        let str = String(val).trim();

        // Remove currency symbols and text
        str = str.replace(/R\$\s*/gi, '').replace(/[^\d.,\-]/g, '').trim();

        if (!str) return 0;

        // Handle Brazilian format: 1.234,56 -> 1234.56
        // If has both dot and comma, determine format
        if (str.includes(',') && str.includes('.')) {
            // If comma comes after dot, it's Brazilian: 1.234,56
            if (str.lastIndexOf(',') > str.lastIndexOf('.')) {
                str = str.replace(/\./g, '').replace(',', '.');
            } else {
                // Otherwise US format: 1,234.56
                str = str.replace(/,/g, '');
            }
        } else if (str.includes(',')) {
            // Only comma: could be 1234,56 (Brazilian decimal)
            str = str.replace(',', '.');
        } else if (str.includes('.')) {
            // Only dot: could be 1234.56 (US decimal) or 1.234 (BR thousands)
            // If dot is followed by exactly 3 digits and nothing else, assume thousands
            let parts = str.split('.');
            if (parts.length === 2 && parts[1].length === 3) {
                str = str.replace(/\./g, '');
            }
        }

        const num = parseFloat(str);
        return isNaN(num) ? 0 : num;
    }

    const App = {
        user: null,
        currentRole: null,

        init: function () {
            UI.showLoading(true);
            API.getUserData(function (user) {
                console.log("DEBUG getUserData retornou:", user);
                console.log("DEBUG user.roles:", user ? user.roles : "user is null/undefined");

                App.user = user || {};

                // ROBUST ROLE HANDLING
                if (!App.user.roles) {
                    App.user.roles = ['Externo'];
                } else if (typeof App.user.roles === 'string') {
                    // Handle case where backend sent a string by mistake or CSV
                    try {
                        // If it looks like JSON array
                        if (App.user.roles.trim().startsWith('[')) {
                            App.user.roles = JSON.parse(App.user.roles);
                        } else {
                            // Assume CSV or single value
                            App.user.roles = App.user.roles.split(',').map(r => r.trim());
                        }
                    } catch (e) {
                        App.user.roles = [App.user.roles];
                    }
                }

                // Critical Safety Check: Ensure it is an array
                if (!Array.isArray(App.user.roles)) {
                    console.warn("Roles ainda não é array:", App.user.roles);
                    App.user.roles = ['Externo'];
                }
                App.currentRole = App.user.roles[0] || 'Visitante';
                console.log("DEBUG currentRole:", App.currentRole);

                // Show Sidebar Menu if authenticated
                const authMenu = document.getElementById('auth-menu');
                if (authMenu && App.currentRole !== 'Externo') {
                    authMenu.style.display = 'block';
                }

                // Smart Role Selection
                const storedRole = localStorage.getItem('ppgpsi_role');
                if (storedRole && App.user.roles.includes(storedRole)) {
                    App.switchRole(storedRole, false);
                } else if (App.user.roles.length > 0) {
                    App.switchRole(App.user.roles[0], false);
                } else {
                    App.switchRole('Externo', false);
                }

                // Setup Features
                App.setupRoleSwitcher();
                App.setupAdminMenu();
                UI.updateUserInfo();
                UI.renderView();
                UI.showLoading(false);

                // --- SECURITY CHECK ---
                if (App.user.email === 'desconhecido' || App.user.roles.includes('Externo-anonimo')) {
                    // NEW: Trigger OTP Login if unknown
                    console.log("Usuário desconhecido detectado, iniciando fluxo de Login OTP.");
                    Forms.renderLoginModal();
                }
            });
        },

        switchRole: function (role, animate = true) {
            App.currentRole = role;
            localStorage.setItem('ppgpsi_role', role);

            // Animate badge
            const badge = document.getElementById('current-role-display');
            if (badge) {
                badge.innerText = role;
                if (animate) {
                    badge.classList.remove('badge-animate');
                    void badge.offsetWidth; // Trigger reflow
                    badge.classList.add('badge-animate');
                }
            }

            // Update admin menu visibility
            App.setupAdminMenu();

            // Transition to new view
            UI.transitionView();
        },

        setupRoleSwitcher: function () {
            const selector = document.getElementById('role-selector');
            const container = document.getElementById('role-switcher-container');
            if (!selector || !container) return;

            selector.innerHTML = '';

            if (App.user.roles.length <= 1) {
                container.style.display = 'none';
                return;
            }

            container.style.display = 'block';

            App.user.roles.forEach(role => {
                let li = document.createElement('li');
                let a = document.createElement('a');
                a.className = 'dropdown-item d-flex align-items-center gap-2';
                a.href = '#';
                a.innerHTML = `<span class="badge ${role === App.currentRole ? 'bg-primary' : 'bg-secondary'} rounded-pill">●</span> ${role}`;
                a.onclick = function (e) {
                    e.preventDefault();
                    App.switchRole(role);
                };
                li.appendChild(a);
                selector.appendChild(li);
            });
        },

        setupAdminMenu: function () {
            const calendarNav = document.getElementById('nav-calendar');
            const usersNav = document.getElementById('nav-users');
            const financialNav = document.getElementById('nav-financial');
            const cgParecerNav = document.getElementById('nav-cg-parecer');
            const requestMgmtNav = document.getElementById('nav-request-management');
            const docenteMgmtNav = document.getElementById('nav-docente-mgmt');
            const depositNav = document.getElementById('nav-deposits');

            const isAdmin = ['Secretaria', 'Coordenação'].includes(App.currentRole);
            const isDiscente = App.currentRole === 'Discente';
            const isDocente = App.currentRole === 'Docente';
            const isCGMember = ['CG', 'Conselho', 'Coordenação'].includes(App.currentRole) ||
                (App.user && App.user.roles && App.user.roles.some(r => String(r).includes('CG')));

            if (calendarNav) calendarNav.style.display = isAdmin ? 'block' : 'none';
            if (usersNav) usersNav.style.display = isAdmin ? 'block' : 'none';
            // Gestão Financeira: visible for Discente, Secretaria, Conselho
            if (financialNav) {
                financialNav.style.display = (isDiscente || isAdmin || isCGMember) ? 'block' : 'none';
                if (isDiscente) {
                    financialNav.innerHTML = '<span class="nav-icon">💰</span> PROEX $';
                } else {
                    financialNav.innerHTML = '<span class="nav-icon">💰</span> Gestão Financeira';
                }
            }
            // Emitir Parecer (CG Parecer): visible for Conselho members only
            if (cgParecerNav) cgParecerNav.style.display = isCGMember ? 'block' : 'none';
            // Gestão de Solicitações (Admin Table): visible for Secretaria/Coordenação only (not Docente)
            if (requestMgmtNav) requestMgmtNav.style.display = isAdmin ? 'block' : 'none';
            // Gestão de Solicitações (Docente version): visible ONLY for Docente
            if (docenteMgmtNav) docenteMgmtNav.style.display = isDocente ? 'block' : 'none';

            // Recursos PROEX (visible ONLY for Docente)
            const proexNav = document.getElementById('nav-proex');
            if (proexNav) proexNav.style.display = isDocente ? 'block' : 'none';

            // PPGPsiu (visible for Discente and Docente)
            const ppgpsiuNav = document.getElementById('nav-ppgpsiu');
            if (ppgpsiuNav) ppgpsiuNav.style.display = (isDiscente || isDocente) ? 'block' : 'none';

            // PTT (visible for Discente and Docente)
            const pttNav = document.getElementById('nav-ptt');
            if (pttNav) pttNav.style.display = (isDiscente || isDocente) ? 'block' : 'none';

            // Agendar Defesa (visible for Discente)
            const defesaNav = document.getElementById('nav-defesa');
            if (defesaNav) defesaNav.style.display = isDiscente ? 'block' : 'none';

            // Pending Deposits (visible for Secretaria/Coordenação)
            if (depositNav) depositNav.style.display = isAdmin ? 'block' : 'none';
        },

        setActiveNav: function (element) {
            // Remove active from all
            document.querySelectorAll('.sidebar-nav-item').forEach(item => {
                item.classList.remove('active');
            });
            // Add to clicked
            if (element) {
                element.classList.add('active');
            }
        }
    };

    /* ==========================================================================
       API WRAPPER
       ========================================================================== */
    /* ==========================================================================
       AUTH MANAGER (OTP Frontend)
       ========================================================================== */
    const Auth = {
        KEY: 'PPGPsi_AuthToken',
        getToken: function () { return localStorage.getItem(this.KEY); },
        setToken: function (t) { localStorage.setItem(this.KEY, t); },
        clearToken: function () { localStorage.removeItem(this.KEY); },
    };

    /* ==========================================================================
       API WRAPPER
       ========================================================================== */
    const API = {
        run: function (funcName, args, onSuccess, onFailure) {
            // INJECT AUTH TOKEN
            const AUTH_AWARE_FUNCTIONS = ['submitRequest', 'getRequests', 'getArchivedRequests', 'createMeeting', 'updateMeeting', 'getUserData', 'updateRequestStatus', 'deleteRequest', 'submitCGAction', 'sendToAgenda', 'getQualisFilterOptions', 'searchQualisPeriodicos', 'submitDefesa', 'requestDefesaChange'];

            if (AUTH_AWARE_FUNCTIONS.includes(funcName)) {
                const token = Auth.getToken();
                if (token) {
                    args.push(token); // Append token as last argument
                    console.log("[Auth] Injecting token for:", funcName);
                }
            }

            google.script.run
                .withSuccessHandler(onSuccess)
                .withFailureHandler(onFailure || UI.showError)
            [funcName].apply(null, args);
        },

        // Auth Methods
        sendAuthCode: function (email, cb) { API.run('sendAuthCode', [email], cb); },
        verifyAuthCode: function (email, code, cb) { API.run('verifyAuthCode', [email, code], cb); },

        getUserData: function (cb) {
            google.script.run
                .withSuccessHandler(function (dataStr) {
                    console.log("getUserData RAW return:", dataStr);
                    var user = null;
                    try {
                        user = JSON.parse(dataStr);
                    } catch (e) {
                        console.error("Erro parsing JSON user data:", e);
                        user = null;
                    }
                    console.log("getUserData PARSED:", user);
                    cb(user);
                })
                .withFailureHandler(function (error) {
                    console.error("getUserData ERRO:", error);
                    // Return fallback user object instead of null
                    cb({
                        email: "erro@erro.com",
                        roles: ["Externo"],
                        nome: "Erro ao carregar",
                        id: "error"
                    });
                })
                .getUserDataJSON();
        },
        submitRequest: function (type, details, cb) { API.run('submitRequest', [type, details], cb); },
        sendToAgenda: function (id, onSuccess) {
            google.script.run
                .withSuccessHandler(onSuccess)
                .withFailureHandler(function (e) { UI.toast("Erro: " + e.message, "error"); })
                .sendToAgenda(id);
        },
        getRequests: function (role, userId, cb) { API.run('getRequests', [role, userId], cb); },
        getArchivedRequests: function (cb) { API.run('getArchivedRequests', [], cb); },
        getAllRequests: function (cb) { API.run('getAllRequests', [], cb); },
        updateRequestStatus: function (id, status, justif, obs, cb) { API.run('updateRequestStatus', [id, status, justif, obs], cb); },
        updateRequestMeeting: function (id, meetingId, cb) { API.run('updateRequestMeeting', [id, meetingId], cb); },
        getAllUsers: function (cb) { API.run('getAllUsers', [], cb); },
        saveUser: function (user, cb) { API.run('saveUser', [user], cb); },
        archiveStudentRequests: function (email, cb) { API.run('archiveStudentRequests', [email], cb); },
        getMeetings: function (activeOnly, cb) { API.run('getMeetings', [activeOnly], cb); },
        createMeeting: function (data, cb) { API.run('createMeeting', [data], cb); },
        updateMeeting: function (data, cb) { API.run('updateMeeting', [data], cb); },
        updateContactInfo: function (data, cb) { API.run('updateContactInfo', [data], cb); },
        getQualisFilterOptions: function (cb, onFail) { API.run('getQualisFilterOptions', [], cb, onFail); },
        searchQualisPeriodicos: function (filters, cb, onFail) { API.run('searchQualisPeriodicos', [filters], cb, onFail); }
    };

    /* ==========================================================================
       UI CORE
       ========================================================================== */
    const UI = {
        showLoading: function (show, message = 'Carregando...') {
            const el = document.getElementById('loading-overlay');
            if (el) {
                el.style.display = show ? 'flex' : 'none';
                // Update loading text if exists
                const textEl = el.querySelector('.loading-text');
                if (textEl) textEl.innerText = message;
            }
        },

        showError: function (err) {
            UI.showLoading(false);
            UI.toast("Erro: " + (err.message || err), 'error');
        },

        toast: function (msg, type = 'info') {
            // Create container if missing
            let container = document.querySelector('.toast-container');
            if (!container) {
                container = document.createElement('div');
                container.className = 'toast-container';
                document.body.appendChild(container);
            }

            // Icon mapping
            const icons = {
                success: '✓',
                error: '✗',
                warning: '⚠',
                info: 'ℹ'
            };

            const el = document.createElement('div');
            el.className = `custom-toast toast-${type}`;
            el.innerHTML = `
                <span class="toast-icon me-2" style="font-size:1.2em">${icons[type] || icons.info}</span>
                <div style="flex:1">${msg}</div>
                <button onclick="UI.dismissToast(this.parentElement)" style="background:none;border:none;font-size:1.2em;cursor:pointer;opacity:0.5">&times;</button>
            `;
            container.appendChild(el);

            // Auto dismiss after 5s
            setTimeout(() => UI.dismissToast(el), 5000);
        },

        dismissToast: function (el) {
            if (!el || !el.parentElement) return;
            el.classList.add('toast-exit');
            setTimeout(() => el.remove(), 300);
        },

        /* ===== MODAL HELPERS ===== */
        alert: function (title, message) {
            // Support (message) or (title, message)
            if (!message) { message = title; title = 'Atenção'; }

            Components.Modal.open({
                id: 'ui-alert-modal',
                title: title,
                body: message,
                footer: '<button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>'
            });
        },

        confirm: function (opt) {
            // opt: { title, message, confirmLabel, cancelLabel, type, onConfirm }
            // OR (message, onConfirm)
            if (typeof opt === 'string') {
                opt = { message: opt, onConfirm: arguments[1] };
            }
            opt = opt || {};

            const type = opt.type || 'primary';
            const btnClass = type === 'danger' ? 'btn-danger' : 'btn-primary';

            const footer = `
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">${opt.cancelLabel || 'Cancelar'}</button>
                <button type="button" id="ui-confirm-btn" class="btn ${btnClass}">${opt.confirmLabel || 'Confirmar'}</button>
            `;

            const modal = Components.Modal.open({
                id: 'ui-confirm-modal',
                title: opt.title || 'Confirmação',
                body: opt.message || 'Tem certeza?',
                footer: footer
            });

            setTimeout(() => {
                const btn = document.getElementById('ui-confirm-btn');
                if (btn) {
                    btn.onclick = function () {
                        modal.hide();
                        if (opt.onConfirm) opt.onConfirm();
                    };
                }
            }, 50);
        },

        updateUserInfo: function () {
            const nameEl = document.getElementById('user-name');
            const emailEl = document.getElementById('user-email');
            if (nameEl && App.user) nameEl.innerText = App.user.nome || "Usuário"; // FIX: name -> nome
            if (emailEl && App.user) emailEl.innerText = App.user.email;
        },

        renderNavRole: function () {
            const badge = document.getElementById('current-role-display');
            if (badge) badge.innerText = App.currentRole;
        },

        transitionView: function () {
            const container = document.getElementById('main-content');
            if (!container) return;

            // Fade out current content
            container.style.opacity = '0';
            container.style.transform = 'translateY(10px)';

            setTimeout(() => {
                // Render new content
                UI.renderView();

                // Fade in
                container.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                container.style.opacity = '1';
                container.style.transform = 'translateY(0)';
            }, 150);
        },

        renderView: function () {
            const container = document.getElementById('main-content');
            if (!container) return;

            container.innerHTML = '';

            const wrapper = document.createElement('div');
            wrapper.className = 'view-section animate-fadeInUp';
            container.appendChild(wrapper);

            switch (App.currentRole) {
                case 'Externo': Views.renderExternal(wrapper); break;
                case 'Secretaria':
                case 'Coordenação': Views.renderSecretariaDashboard(wrapper); break;
                case 'Docente': Views.renderProfessor(wrapper); break;
                case 'Discente': Views.renderStudent(wrapper); break;
                case 'Conselho':
                case 'CG': Views.renderConselhoFinanceiro(wrapper); break;
                default: UI.renderView(); break;
            }
        }
    };

    /* ==========================================================================
       VIEWS
       ========================================================================== */
    const Views = {
        renderExternal: function (container) {
            container.innerHTML = `
      <div class="row">
        <div class="col-md-6 mb-4">
          <div class="card h-100 p-4">
             <h3 class="text-primary mb-3">Processos Seletivos</h3>
             <p class="text-muted">Acesse os editais abertos para Mestrado e Doutorado no PPGPsi.</p>
             <button class="btn btn-primary mt-auto" onclick="Forms.openProcessoSeletivo()">Ver Editais</button>
          </div>
        </div>
        <div class="col-md-6 mb-4">
          <div class="card h-100 p-4">
             <h3 class="text-danger mb-3">Aluno Especial</h3>
             <p class="text-muted">Inscrições para cursar disciplinas isoladas neste semestre.</p>
             <button class="btn btn-outline-danger mt-auto" onclick="Forms.openAlunoEspecial()">Inscreva-se</button>
          </div>
        </div>
      </div>`;
        },

        renderStudent: function (container) {
            const user = App.user || {};
            const formatDate = (d) => {
                if (!d) return '-';
                try { return new Date(d).toLocaleDateString('pt-BR'); } catch (e) { return '-'; }
            };

            // V2 Student Dashboard: Profile First, Accordion Requests
            container.innerHTML = `
            <div class="view-section">
                <!-- Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="display-6 fw-bold text-dark">Olá, ${user.nome ? user.nome.split(' ')[0] : 'Aluno'}</h1>
                        <p class="text-muted fs-5 mb-0">Painel do Discente</p>
                    </div>
                </div>

                <!-- 1. Profile Card (Always Expanded) -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                <span class="fs-4">👤</span>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0">${user.nome || 'Usuário'}</h5>
                                <div class="text-muted small">${user.email || '-'}</div>
                            </div>
                            <div class="ms-auto">
                                <button class="btn btn-sm btn-outline-secondary" onclick="Forms.openEditContactModal()">
                                    ✏️ Editar Contatos
                                </button>
                            </div>
                        </div>
                        
                        <div class="row g-4 mt-1 border-top pt-3">
                             <div class="col-md-3">
                                <small class="text-muted text-uppercase d-block mb-1">Orientador(a)</small>
                                <div class="fw-medium text-dark">${user.Nome_Orientador || '-'}</div>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted text-uppercase d-block mb-1">Data Defesa</small>
                                <div class="fw-medium text-dark">${formatDate(user.Data_Defesa)}</div>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted text-uppercase d-block mb-1">Créditos</small>
                                <div class="fw-bold fs-5 text-primary">${user.Creditos_Totais || '0'}</div>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted text-uppercase d-block mb-1">Nível</small>
                                <div class="fw-medium text-dark">${user.Nivel || '-'}</div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- 2. Next Meeting Alert -->
                <div class="alert alert-light border-0 shadow-sm mb-4 p-4" id="meeting-alert">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <span class="fs-2">📅</span>
                            <div>
                                <div class="fw-bold" id="next-meeting-info">Carregando próxima reunião...</div>
                                <small class="text-muted" id="meeting-countdown"></small>
                            </div>
                        </div>
                        <button class="btn btn-primary px-4" onclick="Forms.openNewRequestModal()" id="btn-new-request-meeting">
                            + Nova Solicitação
                        </button>
                    </div>
                </div>

                <!-- 3. Request Accordions -->
                <div class="accordion mb-4" id="studentRequestsAccordion">
                    
                    <!-- Acadêmico (CPG) -->
                    <div class="accordion-item border-0 shadow-sm mb-3 rounded overflow-hidden">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-4 bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAcademico">
                                <div class="d-flex align-items-center gap-3 w-100">
                                    <div class="bg-primary bg-opacity-10 rounded p-2 text-primary">
                                        <span class="fs-5">📚</span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="fw-bold mb-0 text-dark">Solicitações Acadêmicas (CPG)</h5>
                                        <small class="text-muted">Aproveitamento, coorientação, banca...</small>
                                    </div>
                                    <span class="badge bg-primary bg-opacity-10 text-primary mx-3" id="badge-academico-count">
                                        0
                                    </span>
                                </div>
                            </button>
                        </h2>
                        <div id="collapseAcademico" class="accordion-collapse collapse" data-bs-parent="#studentRequestsAccordion">
                            <div class="accordion-body bg-light">
                                <div id="student-requests-academico-content">
                                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div> Carregando...</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Financeiro -->
                    <div class="accordion-item border-0 shadow-sm mb-3 rounded overflow-hidden">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-4 bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFinanceiro">
                                <div class="d-flex align-items-center gap-3 w-100">
                                    <div class="bg-success bg-opacity-10 rounded p-2 text-success">
                                        <span class="fs-5">💰</span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="fw-bold mb-0 text-dark">Solicitações Financeiras</h5>
                                        <small class="text-muted">Auxílios, Verbas PROEX, Bolsas, reembolsos...</small>
                                    </div>
                                    <span class="badge bg-success bg-opacity-10 text-success mx-3" id="badge-financeiro-count">
                                        0
                                    </span>
                                </div>
                            </button>
                        </h2>
                        <div id="collapseFinanceiro" class="accordion-collapse collapse" data-bs-parent="#studentRequestsAccordion">
                            <div class="accordion-body bg-light">
                                <div class="d-flex justify-content-end mb-3">
                                    <button class="btn btn-sm btn-success shadow-sm" onclick="Forms.openNewRequestModal('financial')">
                                        + Novo Auxílio Financeiro
                                    </button>
                                </div>
                                <div id="student-requests-financeiro-content">
                                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-success"></div> Carregando...</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                
                <!-- 4. Mural da Comunidade -->
                <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-1">📢 Mural da Comunidade PPGPsi</h5>
                                <p class="text-muted small mb-0">Publicize sua pesquisa, artigos e produtos técnicos.</p>
                            </div>
                        </div>
                        <div id="mural-preview-student" class="mt-3">
                            <div class="text-center text-muted py-2">
                                <div class="spinner-border spinner-border-sm"></div> Carregando...
                            </div>
                        </div>
                    </div>
                </div>

            </div>`;

            // --- LOGIC: Fetch Data ---

            // Load Meetings similar to before...
            API.getMeetings(false, function (meetings) {
                // Find next open meeting
                const openMeetings = meetings.filter(m => m.Status === 'Aberto').sort((a, b) => {
                    return new Date(a.Data_Reuniao) - new Date(b.Data_Reuniao);
                });

                if (openMeetings.length > 0) {
                    const nextMeeting = openMeetings[0];
                    const meetingDate = new Date(nextMeeting.Data_Reuniao);
                    const deadlineDate = nextMeeting.Prazo_Fechamento ? new Date(nextMeeting.Prazo_Fechamento) : null;
                    const today = new Date();
                    today.setHours(0, 0, 0, 0);

                    // Calculate days until deadline
                    let countdownHtml = '';
                    if (deadlineDate) {
                        const daysUntilDeadline = Math.ceil((deadlineDate - today) / (1000 * 60 * 60 * 24));

                        if (daysUntilDeadline <= 0) {
                            countdownHtml = '<span class="badge bg-danger fs-6 px-3 py-2">Prazo encerrado</span>';
                            document.getElementById('btn-new-request-meeting').disabled = true;
                        } else if (daysUntilDeadline <= 3) {
                            countdownHtml = `<span class="badge bg-danger fs-6 px-3 py-2">⏰ ${daysUntilDeadline} dia(s) para fazer pedido!</span>`;
                        } else if (daysUntilDeadline <= 7) {
                            countdownHtml = `<span class="badge bg-warning text-dark fs-6 px-3 py-2">⏰ ${daysUntilDeadline} dias restantes</span>`;
                        } else {
                            countdownHtml = `<span class="badge bg-info fs-6 px-3 py-2">${daysUntilDeadline} dias para fazer pedido</span>`;
                        }
                    }

                    const infoEl = document.getElementById('next-meeting-info');
                    if (infoEl) {
                        infoEl.innerHTML = `
                        <strong>${nextMeeting.Nome}</strong><br>
                        📅 Data: ${meetingDate.toLocaleDateString('pt-BR')}
                        ${deadlineDate ? ` | Prazo: ${deadlineDate.toLocaleDateString('pt-BR')}` : ''}
                    `;
                    }

                    const countdownEl = document.getElementById('meeting-countdown');
                    if (countdownEl) countdownEl.innerHTML = countdownHtml;
                } else {
                    const infoEl = document.getElementById('next-meeting-info');
                    if (infoEl) infoEl.textContent = 'Nenhuma reunião aberta no momento';

                    const countdownEl = document.getElementById('meeting-countdown');
                    if (countdownEl) countdownEl.innerHTML = '';
                }

                // Load requests and counts
                API.getRequests('Discente', App.user.id, function (data) {
                    App.cachedStudentRequests = data;
                    App.cachedMeetings = meetings;

                    const financeiroTypes = ['Auxílio Evento', 'Auxílio Financeiro', 'Solicitação de Reembolso'];
                    const isFinType = (r) => {
                        const t = (r.Tipo_Solicitacao || '').toLowerCase();
                        return t.includes('auxílio') || t.includes('financeiro') || t.includes('reembolso') || t.startsWith('fin_');
                    };
                    const financeiro = data.filter(isFinType);
                    const academico = data.filter(r => !isFinType(r));

                    // Update Badges
                    const elFinCount = document.getElementById('badge-financeiro-count');
                    if (elFinCount) elFinCount.textContent = financeiro.length;

                    const elAcadCount = document.getElementById('badge-academico-count');
                    if (elAcadCount) elAcadCount.textContent = academico.length;

                    // Render Lists
                    Views.renderStudentRequestCards(academico, document.getElementById('student-requests-academico-content'), false);
                    Views.renderStudentRequestCards(financeiro, document.getElementById('student-requests-financeiro-content'), true);
                });
            });

            // Load Mural Preview for Student
            google.script.run
                .withSuccessHandler(function (posts) {
                    const container = document.getElementById('mural-preview-student');
                    if (!container) return;

                    if (!posts || posts.length === 0) {
                        container.innerHTML = '<p class="text-muted text-center mb-0">Nenhuma publicação ainda. <button class="btn btn-sm btn-link" onclick="Views.renderMural()">Seja o primeiro a publicar!</button></p>';
                        return;
                    }

                    let html = '';
                    posts.slice(0, 2).forEach(function (p) {
                        const date = p.Data_Publicacao ? new Date(p.Data_Publicacao).toLocaleDateString('pt-BR') : '';
                        html += '<div class="border-bottom py-2"><strong>' + (p.Nome_Usuario || '') + '</strong> <small class="text-muted">' + date + '</small><p class="mb-0 small text-truncate">' + (p.Conteudo || '').substring(0, 100) + '...</p></div>';
                    });
                    html += '<div class="text-center mt-2"><button class="btn btn-sm btn-outline-primary" onclick="Views.renderMural()">Ver todas as publicações</button></div>';
                    container.innerHTML = html;
                })
                .getMuralPosts();
        },



        showStudentCategory: function (category) {
            const container = document.getElementById('student-requests-container');
            const titleEl = document.getElementById('student-category-title');
            const contentEl = document.getElementById('student-kanban');

            container.style.display = 'block';

            // Check if data is loaded
            if (!App.cachedStudentRequests) {
                contentEl.innerHTML = `
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Carregando...</p>
                    </div>
                `;
                // Try to load data
                API.getRequests('Discente', App.user.id, function (data) {
                    App.cachedStudentRequests = data || [];
                    Views.showStudentCategory(category); // Retry after loading
                });
                return;
            }

            // Check if request is financial type (substring match for composite names)
            const checkIsFinanceiro = (r) => {
                const tipo = (r.Tipo_Solicitacao || '').toLowerCase();
                return tipo.includes('auxílio') ||
                    tipo.includes('auxilio') ||
                    tipo.includes('financeiro') ||
                    tipo.includes('reembolso') ||
                    tipo.startsWith('fin_');
            };
            let filtered = [];
            let isFinTypeCategory = false;

            if (category === 'financeiro') {
                titleEl.textContent = '💰 Pedidos Financeiros';
                filtered = (App.cachedStudentRequests || []).filter(checkIsFinanceiro);
                isFinTypeCategory = true;
            } else {
                titleEl.textContent = '📚 Pedidos Acadêmicos (CPG)';
                filtered = (App.cachedStudentRequests || []).filter(r => !checkIsFinanceiro(r));
            }

            // Render as cards instead of Kanban
            Views.renderStudentRequestCards(filtered, contentEl, isFinTypeCategory);

            // Scroll to container
            container.scrollIntoView({ behavior: 'smooth' });
        },

        // Stepper Helper - generates visual progress timeline for requests
        getStepperHTML: function (status, isFinanceiro) {
            const s = (status || '').toLowerCase();

            // Define steps per type
            const academicSteps = [
                { label: 'Enviado', key: 'enviado' },
                { label: 'Orientador', key: 'orientador' },
                { label: 'Secretaria', key: 'secretaria' },
                { label: 'CPG', key: 'cpg' },
                { label: 'Concluído', key: 'concluido' }
            ];

            const financialSteps = [
                { label: 'Enviado', key: 'enviado' },
                { label: 'Orientador', key: 'orientador' },
                { label: 'CG', key: 'cg' },
                { label: 'CPG', key: 'cpg' },
                { label: 'Concluído', key: 'concluido' }
            ];

            const steps = isFinanceiro ? financialSteps : academicSteps;

            // Determine current step index based on status
            let currentIdx = 0;
            let isRejected = false;

            // Status mapping (order matters - check more specific first)
            if (s.includes('prestação de contas') || s.includes('concluído') || s.includes('finalizado')) {
                currentIdx = 4; // Concluído
            } else if (s.includes('aprovado na cpg') || s.includes('aprovado cpg') || s.includes('ressalvas') || s.includes('aprovado_cpg')) {
                currentIdx = 4; // Passed CPG -> Concluído
            } else if (s.includes('pautado') || s.includes('em pauta')) {
                currentIdx = 3; // At CPG stage
            } else if (s.includes('aprovado_cg') || s.includes('aprovado cg') || s.includes('aguardando cpg')) {
                currentIdx = 3; // Passed CG, at CPG
            } else if (s.includes('aguardando cg') || s.includes('pendente') || s.includes('com aval')) {
                currentIdx = 2; // At CG/Secretaria stage
            } else if (s.includes('aguardando orientador')) {
                currentIdx = 1; // At Orientador stage
            } else if (s.includes('reprovado') || s.includes('rejeitado') || s.includes('recusado')) {
                isRejected = true;
                if (s.includes('orientador')) currentIdx = 1;
                else if (s.includes('cg')) currentIdx = 2;
                else if (s.includes('cpg')) currentIdx = 3;
                else currentIdx = 3;
            }

            let html = '<div class="request-stepper">';
            steps.forEach((step, idx) => {
                let stepClass = '';
                if (isRejected && idx === currentIdx) stepClass = 'rejected';
                else if (idx < currentIdx) stepClass = 'completed';
                else if (idx === currentIdx) stepClass = 'current';

                const icon = stepClass === 'completed' ? '✓' : (stepClass === 'rejected' ? '✗' : (idx + 1));

                html += `
                    <div class="stepper-step ${stepClass}">
                        <div class="stepper-dot">${icon}</div>
                        <div class="stepper-label">${step.label}</div>
                    </div>
                `;
            });
            html += '</div>';
            return html;
        },

        renderStudentRequestCards: function (requests, container, isFinanceiro) {
            if (!container) return;

            if (!requests || requests.length === 0) {
                const btnText = isFinanceiro ? '+ Solicitar Auxílio Financeiro' : '+ Solicitação à CPG';
                const btnAction = isFinanceiro ? "Forms.openNewRequestModal('financial')" : "Forms.openNewRequestModal()";
                container.innerHTML = `
                    <div class="text-center py-5 text-muted">
                        <div class="fs-1 mb-3">📭</div>
                        <p>Nenhuma solicitação nesta categoria.</p>
                        <button class="btn btn-primary" onclick="${btnAction}">${btnText}</button>
                    </div>
                `;
                return;
            }

            // Get meeting names map
            const meetingMap = {};
            (App.cachedMeetings || []).forEach(m => {
                meetingMap[m.ID] = m.Nome;
            });

            let cardsHtml = '<div class="row g-3">';

            requests.forEach(r => {
                // Parse details to get meeting ID
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }

                const meetingName = meetingMap[details.ID_Reuniao] || 'Sem reunião';
                const dateStr = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';


                let statusColor = 'secondary';
                const status = String(r.Status || '');
                if (status.includes('Aguardando')) statusColor = 'warning';
                else if (status.includes('Pautado')) statusColor = 'info';
                else if (status.includes('Aprovado')) statusColor = 'success';
                else if (status.includes('Reprovado') || status.includes('Rejeitado')) statusColor = 'danger';
                else if (status.includes('Retornado')) statusColor = 'warning';

                const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                cardsHtml += `
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm student-request-card" 
                             onclick="Forms.openRequestDetailModal('${reqDataStr}')" style="cursor:pointer">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="badge bg-${statusColor} px-3 py-2">${r.Status || 'Pendente'}</span>
                                    <small class="text-muted">📅 ${dateStr}</small>
                                </div>
                                
                                <h6 class="fw-bold text-primary mb-3">${r.Tipo_Solicitacao || 'Solicitação'}</h6>
                                
                                <div class="border-top pt-3">
                                    <div class="row small">
                                        <div class="col-6">
                                            <span class="text-muted">📋 Reunião:</span>
                                            <div class="fw-medium text-truncate" title="${meetingName}">${meetingName}</div>
                                        </div>
                                        <div class="col-6">
                                            <span class="text-muted">🔢 ID:</span>
                                            <div class="fw-medium text-truncate">${r.ID ? r.ID.substring(0, 8) + '...' : '-'}</div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Stepper Progress -->
                                <div class="border-top pt-3 mt-3">
                                    ${Views.getStepperHTML(r.Status, isFinanceiro)}
                                </div>
                            </div>
                            </div>
                            <div class="card-footer bg-transparent border-top-0 pt-0">
                                ${(status === 'Prestação de Contas Solicitada') ?
                        `<button class="btn btn-warning w-100 fw-bold mb-2 shadow-sm" onclick="event.stopPropagation(); Forms.openStudentAccountabilityModal('${r.ID}')">
                                        📤 Entregar Prestação de Contas
                                    </button>` : ''
                    }
                                <button class="btn btn-outline-primary btn-sm w-100">
                                    Ver Detalhes →
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });

            cardsHtml += '</div>';
            container.innerHTML = cardsHtml;
        },

