            </div>`;

            // Load dashboard data
            Views.loadSecretariaDashboardData();
        },

        loadSecretariaDashboardData: function () {
            google.script.run
                .withSuccessHandler(function (data) {
                    // Update stats
                    document.getElementById('stat-aguardando').textContent = data.stats.aguardandoOrientador;
                    document.getElementById('stat-pautados').textContent = data.stats.pautadosCPG;
                    document.getElementById('stat-aprovados').textContent = data.stats.aprovadosHoje;
                    document.getElementById('stat-total').textContent = data.stats.totalPendentes;

                    // Render pending actions
                    const pendingContainer = document.getElementById('pending-actions-container');
                    document.getElementById('pending-count').textContent = data.pendingActions.length;

                    if (data.pendingActions.length === 0) {
                        pendingContainer.innerHTML = '<div class="text-center py-5 text-muted"><div class="fs-1 mb-2">🎉</div>Nenhuma ação pendente!</div>';
                    } else {
                        pendingContainer.innerHTML = `
                            <div class="list-group list-group-flush">
                                ${data.pendingActions.map((item, index) => `
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-3 ${index % 2 === 0 ? 'bg-light bg-opacity-50' : ''}">
                                        <div style="cursor:pointer" onclick="Views.renderKanbanView()">
                                            <div class="fw-bold">${item.tipo}</div>
                                            <div class="small text-muted">${item.aluno} • ${new Date(item.data).toLocaleDateString('pt-BR')}</div>
                                            <div class="small fw-medium text-${item.status.includes('Aprovado') ? 'success' : 'warning'}">${item.status}</div>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            
                                            ${(item.status === 'Pendente') ?
                                `<button class="btn btn-sm btn-outline-purple" onclick="Forms.openPautarModal('${item.id}')" title="Inserir na Pauta">
                                                    📥 Pautar
                                                </button>` : ''}

                                            ${(item.status.includes('Aprovado pela CG')) ?
                                `<div class="btn-group">
                                                    <button class="btn btn-sm btn-outline-purple" onclick="Forms.openPautarModal('${item.id}')" title="Inserir na Pauta para Referendo">
                                                        📥 Pautar
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-info" onclick="Forms.openPrestacaoContasModal('${item.id}')" title="Solicitar Prestação de Contas">
                                                        📉 Prestação
                                                    </button>
                                                </div>` : ''}

                                            ${(item.status === 'Prestação de Contas em Análise') ?
                                `<div class="btn-group">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="Forms.openRequestDetailModal('${item.id}')" title="Ver Detalhes e Histórico">
                                                        👁️
                                                    </button>
                                                    <button class="btn btn-sm btn-success" onclick="Forms.aprovarPrestacaoContas('${item.id}')" title="Aprovar Prestação de Contas">
                                                        Aprovar
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-warning" onclick="Forms.solicitarAjustesPrestacao('${item.id}')" title="Solicitar Ajustes na Prestação">
                                                        Ajustes
                                                    </button>
                                                </div>` : ''}

                                        </div>
                                    </div>
                                `).join('')}
                            </div>
                        `;
                    }

                    // Render recent approvals
                    const approvalsContainer = document.getElementById('recent-approvals-container');
                    if (data.recentApprovals.length === 0) {
                        approvalsContainer.innerHTML = '<div class="text-center py-4 text-muted small">Nenhuma aprovação recente</div>';
                    } else {
                        approvalsContainer.innerHTML = `
                            <ul class="list-group list-group-flush">
                                ${data.recentApprovals.map(item => `
                                    <li class="list-group-item py-2">
                                        <div class="small fw-medium text-truncate">${item.tipo}</div>
                                        <div class="small text-muted">${item.aluno}</div>
                                        <span class="badge bg-success bg-opacity-75 small">${item.status}</span>
                                    </li>
                                `).join('')}
                            </ul>
                        `;
                    }

                    // Render upcoming meetings
                    const meetingsContainer = document.getElementById('upcoming-meetings-container');
                    if (data.upcomingMeetings.length === 0) {
                        meetingsContainer.innerHTML = '<div class="text-center py-4 text-muted small">Nenhuma reunião agendada</div>';
                    } else {
                        meetingsContainer.innerHTML = `
                            <ul class="list-group list-group-flush">
                                ${data.upcomingMeetings.map(m => {
                            const meetDate = new Date(m.data);
                            const today = new Date();
                            const diffDays = Math.ceil((meetDate - today) / (1000 * 60 * 60 * 24));
                            const countdownText = diffDays <= 0 ? 'Hoje!' : diffDays === 1 ? 'Amanhã' : `Em ${diffDays} dias`;
                            const countdownClass = diffDays <= 1 ? 'bg-danger' : diffDays <= 7 ? 'bg-warning text-dark' : 'bg-info';

                            return `
                                        <li class="list-group-item py-3">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <div class="fw-bold">${m.nome}</div>
                                                    <div class="small text-muted">${meetDate.toLocaleDateString('pt-BR')}</div>
                                                </div>
                                                <span class="badge ${countdownClass} rounded-pill">${countdownText}</span>
                                            </div>
                                        </li>
                                    `;
                        }).join('')}
                            </ul>
                        `;
                    }
                })
                .withFailureHandler(function (err) {
                    console.error('Dashboard error:', err);
                    document.getElementById('pending-actions-container').innerHTML =
                        '<div class="alert alert-danger m-3">Erro ao carregar dados: ' + err.message + '</div>';
                })
                .getSecretariaDashboardData();
        },

        // --- KANBAN VIEW (Full View) with Filters ---
        renderKanbanView: function () {
            const container = document.getElementById('main-content');
            const mode = App.currentRole;

            container.innerHTML = `
            <div class="view-section">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <button class="btn btn-link ps-0 text-decoration-none" onclick="UI.renderView()">← Voltar ao Dashboard</button>
                        <h3 class="d-inline-block align-middle ms-2 mb-0">Quadro de Solicitações</h3>
                    </div>
                </div>
                
                <!-- Filters -->
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small text-muted fw-bold">Filtrar por Tipo de Pedido</label>
                                <select class="form-select" id="filter-tipo" onchange="Views.applyKanbanFilters()">
                                    <option value="">Todos os tipos</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-muted fw-bold">Filtrar por Reunião</label>
                                <select class="form-select" id="filter-reuniao" onchange="Views.applyKanbanFilters()">
                                    <option value="">Todas as reuniões</option>
                                </select>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button class="btn btn-outline-secondary w-100" onclick="Views.clearKanbanFilters()">
                                    🔄 Limpar Filtros
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="card bg-light border-0">
                    <div class="card-body p-0">
                        <div id="full-kanban-board" class="kanban-container">Carregando Kanban...</div>
                    </div>
                </div>
            </div>`;

            API.getMeetings(false, function (meetings) {
                App.cachedMeetings = meetings;

                // Populate meeting filter
                const reuniaoSelect = document.getElementById('filter-reuniao');
                if (reuniaoSelect) {
                    meetings.forEach(m => {
                        const opt = document.createElement('option');
                        opt.value = m.ID;
                        opt.textContent = m.Nome;
                        reuniaoSelect.appendChild(opt);
                    });
                }

                API.getRequests(mode, App.user.id, function (data) {
                    // Store data for filtering
                    App.cachedKanbanData = data;

                    // Populate type filter
                    const tipoSelect = document.getElementById('filter-tipo');
                    if (tipoSelect) {
                        const tipos = [...new Set(data.map(r => r.Tipo_Solicitacao).filter(Boolean))].sort();
                        tipos.forEach(tipo => {
                            const opt = document.createElement('option');
                            opt.value = tipo;
                            opt.textContent = tipo;
                            tipoSelect.appendChild(opt);
                        });
                    }

                    UIHelpers.renderStatusCards(data, 'full-kanban-board');
                });
            });
        },

        applyKanbanFilters: function () {
            const tipoFilter = document.getElementById('filter-tipo').value;
            const reuniaoFilter = document.getElementById('filter-reuniao').value;

            if (!App.cachedKanbanData) return;

            let filtered = [...App.cachedKanbanData];

            // Filter by type
            if (tipoFilter) {
                filtered = filtered.filter(r => r.Tipo_Solicitacao === tipoFilter);
            }

            // Filter by meeting
            if (reuniaoFilter) {
                filtered = filtered.filter(r => {
                    let details = {};
                    try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                    return details.ID_Reuniao === reuniaoFilter;
                });
            }

            UIHelpers.renderStatusCards(filtered, 'full-kanban-board');
        },

        clearKanbanFilters: function () {
            document.getElementById('filter-tipo').value = '';
            document.getElementById('filter-reuniao').value = '';
            Views.applyKanbanFilters();
        },

        // --- CALENDAR MANAGEMENT ---
        renderCalendarManagement: function () {
            const container = document.getElementById('main-content');
            container.innerHTML = `
             <div class="view-section">
               <div class="d-flex justify-content-between align-items-center mb-4">
                  <button class="btn btn-link ps-0" onclick="UI.renderView()">&larr; Voltar</button>
                  <h3>Gestão de Calendário CPG</h3>
                  <button class="btn btn-primary" onclick="Forms.openMeetingModal()">+ Nova Reunião</button>
               </div>
               <div id="calendar-list">Carregando...</div>
             </div>`;

            API.getMeetings(false, function (data) {
                if (!data || data.length === 0) {
                    document.getElementById('calendar-list').innerHTML = '<div class="text-center p-4">Nenhuma reunião cadastrada.</div>';
                    return;
                }
                let html = '<div class="list-group">';
                data.forEach(m => {
                    let statusBadge = m.Status === 'Aberto' ? 'bg-success' : 'bg-secondary';
                    let start = m.Data_Inicio_Periodo ? new Date(m.Data_Inicio_Periodo).toLocaleDateString() : '?';
                    let end = m.Data_Fim_Periodo ? new Date(m.Data_Fim_Periodo).toLocaleDateString() : '?';
                    let meetDate = m.Data_Reuniao ? new Date(m.Data_Reuniao).toLocaleDateString() : '?';

                    html += `
                     <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                           <h5 class="mb-1">${m.Nome}</h5>
                           <small class="text-muted">Reunião: ${meetDate} | Período: ${start} a ${end}</small>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge ${statusBadge} me-2">${m.Status}</span>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" onclick="Views.renderMeetingDetails('${encodeURIComponent(JSON.stringify(m)).replace(/'/g, "%27")}')" title="Ver Detalhes">
                                    📋 Detalhes
                                </button>
                                <button class="btn btn-outline-secondary" onclick="Forms.openMeetingModal('${encodeURIComponent(JSON.stringify(m)).replace(/'/g, "%27")}')" title="Editar Reunião">
                                    ✏️
                                </button>
                            </div>
                        </div>
                     </div>`;
                });
                html += '</div>';
                document.getElementById('calendar-list').innerHTML = html;
            });
        },

