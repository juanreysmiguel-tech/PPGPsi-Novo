        loadHomeNotifications: function () {
            const container = document.getElementById('notifications-block');
            if (!container) return;

            google.script.run
                .withSuccessHandler(function (notifications) {
                    if (!notifications || notifications.length === 0) {
                        container.innerHTML = '';
                        return;
                    }

                    const notifHtml = notifications.slice(0, 5).map(n => {
                        const typeColors = {
                            'aprovado': 'success',
                            'aprovado_alteracoes': 'warning',
                            'reprovado': 'danger',
                            'info': 'info'
                        };
                        const color = typeColors[n.tipo] || 'secondary';
                        const date = new Date(n.data).toLocaleDateString('pt-BR');

                        return `
                            <div class="alert alert-${color} d-flex align-items-center py-2 mb-2 ${n.lido ? 'opacity-75' : ''}" role="alert">
                                <div class="flex-grow-1">
                                    <strong>${n.titulo}</strong>
                                    <div class="small">${n.mensagem}</div>
                                    <small class="text-muted">${date}</small>
                                </div>
                                ${!n.lido ? `<button class="btn btn-sm btn-outline-${color} ms-2" onclick="Views.markAsRead('${n.id}', this)">✓</button>` : ''}
                            </div>`;
                    }).join('');

                    container.innerHTML = `
                        <div class="card border-0 bg-transparent">
                            <div class="card-header bg-transparent fw-bold d-flex justify-content-between align-items-center">
                                <span>🔔 Notificações</span>
                                ${notifications.filter(n => !n.lido).length > 0 ?
                            `<span class="badge bg-danger">${notifications.filter(n => !n.lido).length} novas</span>` : ''}
                            </div>
                            <div class="card-body pt-2">${notifHtml}</div>
                        </div>`;
                })
                .withFailureHandler(function () {
                    container.innerHTML = '';
                })
                .getNotifications(false);
        },

        markAsRead: function (notifId, btn) {
            btn.disabled = true;
            google.script.run
                .withSuccessHandler(function () {
                    btn.parentElement.classList.add('opacity-75');
                    btn.remove();
                })
                .markNotificationRead(notifId);
        },

        loadPendingRequests: function () {
            const container = document.getElementById('pending-requests-block');
            if (!container) return;

            API.getRequests(App.currentRole, App.user.id, function (requests) {
                if (!requests || requests.length === 0) {
                    container.innerHTML = '';
                    return;
                }

                // Filter only pending/in-process requests
                const pending = requests.filter(r =>
                    ['Pendente', 'Pautado CPG', 'Aguardando Elucidação'].includes(r.Status)
                );

                if (pending.length === 0) {
                    container.innerHTML = '';
                    return;
                }

                const statusColors = {
                    'Pendente': 'warning',
                    'Pautado CPG': 'info',
                    'Aguardando Elucidação': 'secondary'
                };

                const cardsHtml = pending.slice(0, 5).map(r => {
                    const color = statusColors[r.Status] || 'secondary';
                    return `
                        <div class="col-md-4 col-lg-3">
                            <div class="card h-100 border-${color}" style="cursor:pointer" 
                                 onclick="Forms.openRequestDetailModal('${encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27")}')">
                                <div class="card-body py-3">
                                    <div class="fw-bold text-truncate">${r.Tipo_Solicitacao}</div>
                                    <span class="badge bg-${color}">${r.Status}</span>
                                </div>
                            </div>
                        </div>`;
                }).join('');

                container.innerHTML = `
                    <div class="card bg-light border-0">
                        <div class="card-header bg-transparent fw-bold">📋 Meus Pedidos em Tramitação</div>
                        <div class="card-body">
                            <div class="row g-2">${cardsHtml}</div>
                        </div>
                    </div>`;
            });
        },

        renderMeetingList: function () {
            const container = document.getElementById('main-content');
            container.innerHTML = `
             <div class="view-section">
                <h2 class="mb-4">Reuniões CPG</h2>
                <div id="meetings-list-container" class="row">Carregando...</div>
             </div>`;

            API.getMeetings(false, function (meetings) {
                if (!meetings || meetings.length === 0) {
                    document.getElementById('meetings-list-container').innerHTML = '<div class="col-12 text-muted">Nenhuma reunião encontrada.</div>';
                    return;
                }

                let html = '';
                meetings.forEach(m => {
                    let dateStr = 'Data N/D';
                    try { dateStr = new Date(m.Data_Reuniao).toLocaleDateString(); } catch (e) { }
                    let statusBadge = m.Status === 'Aberto' ? 'success' : 'secondary';

                    html += `
                     <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm clickable header-strip" style="cursor:pointer" onclick="Views.renderMeetingDashboard('${m.ID}', '${m.Nome}')">
                           <div class="card-body">
                              <h5 class="card-title text-primary">${m.Nome}</h5>
                              <div class="mb-2"><span class="badge bg-${statusBadge}">${m.Status}</span></div>
                              <p class="card-text text-muted">
                                 <small>Data Reunião: ${dateStr}</small><br>
                              </p>
                              <div class="text-end text-primary fw-bold small mt-3">ACESSAR PAINEL →</div>
                           </div>
                        </div>
                     </div>`;
                });

                document.getElementById('meetings-list-container').innerHTML = html;
            });
        },

        renderMeetingDashboard: function (meetingId, meetingName) {
            const container = document.getElementById('main-content');
            let isAdmin = (App.currentRole === 'Docente' || App.currentRole === 'Secretaria' || App.currentRole === 'Coordenação');

            container.innerHTML = `
             <div class="view-section">
                <div class="d-flex justify-content-between align-items-center mb-4">
                   <div>
                       <button class="btn btn-link ps-0 text-decoration-none" onclick="Views.renderMeetingList()">&larr; Voltar para Reuniões</button>
                       <h3 class="mt-2 mb-0">📋 ${meetingName}</h3>
                       <small class="text-muted">Painel de Solicitações da Reunião</small>
                   </div>
                   <div>
                        <select id="meeting-filter-type" class="form-select" onchange="Views.applyMeetingDashboardFilters()">
                            <option value="">Todos os Tipos</option>
                        </select>
                   </div>
                </div>
                <div id="meeting-dashboard-cards" class="row g-4">
                    <div class="col-12 text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Carregando pedidos...</p>
                    </div>
                </div>
             </div>`;

            API.getRequests(App.currentRole, App.user.id, function (allData) {
                let filtered = allData.filter(r => {
                    let det = {};
                    try { det = JSON.parse(r.Detalhes); } catch (e) { }
                    return det.ID_Reuniao === meetingId;
                });

                // Cache for filtering
                App.cachedMeetingDashboardRequests = filtered;
                App.currentMeetingId = meetingId;
                App.currentMeetingName = meetingName;

                // Populate Type Filter
                const types = [...new Set(filtered.map(r => r.Tipo_Solicitacao).filter(Boolean))].sort();
                const typeSelect = document.getElementById('meeting-filter-type');
                if (typeSelect) {
                    types.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value = t;
                        opt.textContent = t;
                        typeSelect.appendChild(opt);
                    });
                }

                // Render with UIHelpers.renderStatusCards
                UIHelpers.renderStatusCards(filtered, 'meeting-dashboard-cards');
            });
        },

        applyMeetingDashboardFilters: function () {
            const typeFilter = document.getElementById('meeting-filter-type')?.value || '';
            const requests = App.cachedMeetingDashboardRequests || [];

            let filtered = requests;
            if (typeFilter) {
                filtered = requests.filter(r => r.Tipo_Solicitacao === typeFilter);
            }

            UIHelpers.renderStatusCards(filtered, 'meeting-dashboard-cards');
        },

        // =========================================================================
        // CG PARECER VIEW - For Financial Requests Review
        // =========================================================================
        // =========================================================================
        // CG PARECER VIEW - For Financial Requests Review
        // =========================================================================
        renderCGParecerView: function (tab = 'pending') {
            const container = document.getElementById('main-content');
            container.innerHTML = `
                <div class="view-section">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="mb-0">⚖️ Pareceres CG - Auxílios Financeiros</h2>
                        <span class="badge bg-info px-3 py-2">Membro: ${App.currentRole}</span>
                    </div>

                    <!-- Tabs -->
                    <ul class="nav nav-tabs mb-4">
                        <li class="nav-item">
                            <a class="nav-link ${tab === 'pending' ? 'active fw-bold' : ''}" href="#" onclick="Views.renderCGParecerView('pending'); return false;">
                                🟡 Pendentes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ${tab === 'history' ? 'active fw-bold' : ''}" href="#" onclick="Views.renderCGParecerView('history'); return false;">
                                📜 Histórico / Anteriores
                            </a>
                        </li>
                    </ul>

                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div id="cg-parecer-list">
                                <div class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status"></div>
                                    <p class="mt-2 text-muted">Carregando solicitações...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>`;

            // Load all requests
            API.getRequests(App.currentRole, App.user.id, function (requests) {
                const list = document.getElementById('cg-parecer-list');

                // 1. Strict Filter for Financial Types Only
                const financial = requests.filter(r => {
                    const tipo = (r.Tipo_Solicitacao || '').trim();
                    return tipo.includes('Auxílio Financeiro') || tipo.includes('FIN_') || tipo === 'Auxílio Evento' || tipo === 'Solicitação de Reembolso';
                });

                // 2. Separate by Status
                // Pending: 'Aguardando CG', 'PENDING_CG', 'Em Análise CG', 'Aguardando Avaliação do Orientador' (maybe show as future?)
                // Actually, CG only mostly cares about what is waiting for THEIR action.
                // But let's show 'Aguardando CG' and 'PENDING_CG' as actionable.

                let displayList = [];

                if (tab === 'pending') {
                    displayList = financial.filter(r => {
                        const s = (r.Status || '').toUpperCase();
                        // Strict inclusion for Pending, Strict exclusion for Approved/Rejected
                        // FIX: Added 'DEVOLVIDO PARA CG' and 'RETORNADO' to be caught as pending for CG re-evaluation
                        // Also fixed 'EM ANÁLISE' matching to be more robust
                        const isPending = s.includes('AGUARDANDO CG') || s === 'PENDING_CG' || s.includes('EM ANÁLISE') || s.includes('DEVOLVIDO PARA CG') || s.includes('RETORNADO PELA SECRETARIA');
                        const isProcessed = s.includes('APROVADO') || s.includes('APPROVED') || s.includes('REJEITADO') || s.includes('REJECTED');
                        return isPending && !isProcessed;
                    });
                } else {
                    // History: Everything that is NOT strictly 'Pending Assessment'
                    // Includes: Approved, Rejected, Returned, Accountability, Completed
                    displayList = financial.filter(r => {
                        const s = (r.Status || '').toUpperCase();
                        // If it's NOT in the pending list process, it's history
                        // Pending list is: AGUARDANDO CG, PENDING_CG, EM ANÁLISE CG
                        const isPendingAction = s.includes('AGUARDANDO CG') || s === 'PENDING_CG' || s.includes('EM ANÁLISE CG');
                        return !isPendingAction;
                    });
                }

                if (displayList.length === 0) {
                    list.innerHTML = `
                        <div class="text-center py-5 text-muted">
                            <div class="fs-1 mb-3">${tab === 'pending' ? '✅' : '📂'}</div>
                            <h4>${tab === 'pending' ? 'Nenhum parecer pendente' : 'Nenhum histórico recente'}</h4>
                            <p>${tab === 'pending' ? 'Você zerou a fila! Não há solicitações aguardando análise.' : 'Não foram encontrados registros anteriores.'}</p>
                        </div>`;
                    return;
                }

                if (tab === 'history') {
                    // History Filter Dropdown
                    const filterHtml = `
                        <div class="d-flex justify-content-end mb-3">
                             <div class="d-flex align-items-center gap-2">
                                <label class="small fw-bold text-muted">Filtrar por Status:</label>
                                <select id="cg-history-filter" class="form-select form-select-sm" style="width: auto;" onchange="Views.applyCGHistoryFilter()">
                                    <option value="">Todos</option>
                                    <option value="APROVADO">Aprovados</option>
                                    <option value="REJEITADO">Negados / Recusados</option>
                                    <option value="ELUCIDA">Elucidação / Ajustes</option>
                                    <option value="CONCLUÍDO">Concluídos</option>
                                </select>
                             </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="cg-history-table">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Solicitante</th>
                                        <th>Tipo</th>
                                        <th>Valor</th>
                                        <th>Status</th>
                                        <th>Parecerista</th>
                                        <th>Parecer / Justificativa</th>
                                        <th class="text-end">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>`;

                    let rowsHtml = '';
                    displayList.forEach(r => {
                        let details = {};
                        try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                        const valor = details['Valor do Auxílio (R$)'] || details['Valor Solicitado (R$)'] || details['valor'] || '—';
                        const reqJson = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");
                        const statusInfo = UIHelpers.getStatusBadgeInfo(r.Status);

                        // Find Parecer Info from History
                        let history = [];
                        try { history = JSON.parse(r.Historico_Aprovacao || '[]'); } catch (e) { }

                        // Find the last action by Consiglio/CG
                        let lastCGAction = history.slice().reverse().find(h =>
                            (h.user && (h.user.includes('Conselho') || h.user.includes('CG'))) ||
                            (h.action && (h.action.includes('Conselho') || h.action.includes('CG') || h.action.includes('Elucidação')))
                        );

                        // Robust Parecerista Fallback
                        let parecerista = '—';
                        if (lastCGAction && lastCGAction.user) {
                            parecerista = lastCGAction.user;
                        } else if (details.Parecerista) {
                            parecerista = details.Parecerista;
                        } else if (r.ID_Parecerista_CG) {
                            // Try to look up? For now just use stored ID if nothing else
                            parecerista = 'Membro CG (' + r.ID_Parecerista_CG.substring(0, 5) + ')';
                        }

                        const parecer = lastCGAction ? (lastCGAction.justification || lastCGAction.action) : (details.Parecer_CG_Justificativa || '—');

                        // Truncate long justifications
                        const shortParecer = parecer.length > 60 ? parecer.substring(0, 60) + '...' : parecer;

                        // Row Class for Filter
                        const statusUpper = (r.Status || '').toUpperCase();
                        let filterClass = '';
                        if (statusUpper.includes('APROVADO') || statusUpper.includes('APPROVED')) filterClass = 'filter-APROVADO';
                        else if (statusUpper.includes('REJEITADO') || statusUpper.includes('REJECTED') || statusUpper.includes('INDEFERIDO')) filterClass = 'filter-REJEITADO';
                        else if (statusUpper.includes('ELUCIDA') || statusUpper.includes('PENDING_INFO')) filterClass = 'filter-ELUCIDA';
                        else if (statusUpper.includes('CONCLUÍDO') || statusUpper.includes('COMPLETED')) filterClass = 'filter-CONCLUÍDO';

                        rowsHtml += `
                            <tr class="cg-history-row ${filterClass}">
                                <td class="fw-bold">
                                    ${r.Nome_Aluno || 'Solicitante'}
                                    <div class="small text-muted" style="font-size:0.75em">${new Date(r.Data_Criacao).toLocaleDateString('pt-BR')}</div>
                                </td>
                                <td><small>${r.Tipo_Solicitacao}</small></td>
                                <td><small>R$ ${valor}</small></td>
                                <td><span class="badge ${statusInfo.class}">${r.Status}</span></td>
                                <td><small class="text-muted">${parecerista}</small></td>
                                <td title="${parecer.replace(/"/g, '&quot;')}"><small>${shortParecer}</small></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" onclick="Forms.openRequestDetailModal('${reqJson}')">
                                        👁️ Ver
                                    </button>
                                </td>
                            </tr>`;
                    });

                    if (!rowsHtml) rowsHtml = '<tr><td colspan="7" class="text-center text-muted py-4">Nenhum registro encontrado para exibição.</td></tr>';

                    list.innerHTML = filterHtml + rowsHtml + '</tbody></table></div>';

                    // Inject Filter Logic Script (Inline for simplicity or call Views method)
                    Views.applyCGHistoryFilter = function () {
                        const val = document.getElementById('cg-history-filter').value;
                        const rows = document.querySelectorAll('.cg-history-row');
                        rows.forEach(row => {
                            if (!val || row.classList.contains('filter-' + val)) {
                                row.style.display = '';
                            } else {
                                row.style.display = 'none';
                            }
                        });
                    };

                } else {
                    // CARD VIEW FOR PENDING
                    let html = '<div class="row g-3">';
                    displayList.forEach(r => {
                        let details = {};
                        try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                        const valor = details['Valor do Auxílio (R$)'] || details['Valor Solicitado (R$)'] || details['valor'] || '—';
                        const evento = details['Nome do Evento'] || details['evento'] || r.Tipo_Solicitacao;
                        const dataFormatted = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '—';

                        const reqJson = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                        // Card Color based on status
                        let borderClass = 'border-secondary';
                        let badgeClass = 'bg-secondary';
                        const s = (r.Status || '').toUpperCase();

                        if (s.includes('AGUARDANDO') || s.includes('PENDING')) {
                            borderClass = 'border-warning';
                            badgeClass = 'bg-warning text-dark';
                        } else if (s.includes('APROVADO') || s.includes('APPROVED')) {
                            borderClass = 'border-success';
                            badgeClass = 'bg-success';
                        } else if (s.includes('REJEITADO') || s.includes('REJECTED')) {
                            borderClass = 'border-danger';
                            badgeClass = 'bg-danger';
                        }

                        html += `
                            <div class="col-md-6">
                                <div class="card h-100 ${borderClass} shadow-sm hover-lift" style="border-left-width: 5px;">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="card-title mb-0 fw-bold text-truncate" title="${r.Nome_Aluno}">${r.Nome_Aluno || 'Solicitante'}</h5>
                                            <span class="badge ${badgeClass}">${r.Status}</span>
                                        </div>
                                        <p class="text-muted small mb-2 text-truncate">${evento}</p>
                                        <div class="d-flex gap-3 mb-3 align-items-center">
                                            <span class="badge bg-light text-dark border">💰 R$ ${valor}</span>
                                            <span class="text-muted small">📅 ${dataFormatted}</span>
                                        </div>
                                        
                                        <div class="d-grid">
                                            <button class="btn btn-primary btn-sm" onclick="Forms.openCGParecerModal('${reqJson}')">
                                                ⚖️ Analisar / Emitir Parecer
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                    });
                    html += '</div>';
                    list.innerHTML = html;
                }
            });
        },

