        loadConselhoFinanceiroData: function () {
            google.script.run
                .withSuccessHandler(function (requests) {
                    // Filter only financial requests
                    // Filter only financial requests and Map Reviewer Info
                    const financial = (requests || []).filter(r => {
                        const tipo = r.Tipo_Solicitacao || '';
                        return tipo.includes('Auxílio') || tipo.includes('Reembolso') || tipo.startsWith('FIN_');
                    }).map(r => {
                        // Extract Parecerista info from Details if not in root
                        if (!r.Parecerista) {
                            try {
                                const d = JSON.parse(r.Detalhes || '{}');
                                if (d.Parecerista) r.Parecerista = d.Parecerista;
                                if (d.Data_Parecer) r.Data_Parecer = d.Data_Parecer;
                            } catch (e) { }
                        }
                        return r;
                    });

                    // Calculate stats
                    // Calculate stats
                    const pendingCG = financial.filter(r => {
                        const s = (r.Status || '').toUpperCase();
                        const isPending = s.includes('AGUARDANDO CG') || s === 'PENDING_CG' || s.includes('EM ANÁLISE CG');
                        const isProcessed = s.includes('APROVADO') || s.includes('APPROVED') || s.includes('REJEITADO') || s.includes('REJECTED');
                        return isPending && !isProcessed;
                    });
                    const approved = financial.filter(r => {
                        const s = (r.Status || '').toUpperCase();
                        return s.includes('APROVADO') || s.includes('APPROVED');
                    });
                    const deposited = financial.filter(r => {
                        const s = (r.Status || '').toUpperCase();
                        return s.includes('CONCLUÍDO') || s.includes('CONCLUIDO') || s.includes('DEPOSITADO');
                    });

                    // Calculate total value
                    let totalValue = 0;
                    approved.forEach(r => {
                        try {
                            const details = JSON.parse(r.Detalhes || '{}');
                            const valor = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);
                            if (!isNaN(valor)) totalValue += valor;
                        } catch (e) { }
                    });

                    // Update stats
                    document.getElementById('fin-stat-pending').textContent = pendingCG.length;
                    document.getElementById('fin-stat-approved').textContent = approved.length;
                    document.getElementById('fin-stat-deposited').textContent = deposited.length;
                    document.getElementById('fin-stat-total').textContent = 'R$ ' + totalValue.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    document.getElementById('fin-pending-count').textContent = pendingCG.length;
                    document.getElementById('fin-total-year').textContent = 'R$ ' + totalValue.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                    // Render pending list
                    const pendingContainer = document.getElementById('fin-pending-container');
                    if (pendingCG.length === 0) {
                        pendingContainer.innerHTML = `
                            <div class="text-center py-5 text-muted">
                                <div class="fs-1 mb-2">🎉</div>
                                <p>Nenhum parecer pendente!</p>
                            </div>
                        `;
                    } else {
                        pendingContainer.innerHTML = `
                            <div class="list-group list-group-flush">
                                ${pendingCG.slice(0, 10).map((item, i) => {
                            let details = {};
                            try { details = JSON.parse(item.Detalhes || '{}'); } catch (e) { }
                            const valor = details['Valor Solicitado (R$)'] || details['valor'] || '-';
                            const dataStr = item.Data_Criacao ? new Date(item.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                            const reqDataStr = encodeURIComponent(JSON.stringify(item)).replace(/'/g, "%27");

                            return `
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 ${i % 2 === 0 ? 'bg-light bg-opacity-50' : ''}" 
                                             style="cursor:pointer" onclick="Forms.openCGParecerModal('${reqDataStr}')">
                                            <div>
                                                <div class="fw-bold">${item.Nome_Aluno || 'Aluno'}</div>
                                                <div class="small text-muted">${item.Tipo_Solicitacao} • ${dataStr}</div>
                                            </div>
                                            <div class="text-end">
                                                <div class="fw-bold text-success">R$ ${valor}</div>
                                                <span class="badge bg-warning text-dark small">${item.Status || 'Pendente'}</span>
                                            </div>
                                        </div>
                                    `;
                        }).join('')}
                            </div>
                        `;
                    }

                    // Render recent approvals
                    const recentContainer = document.getElementById('fin-recent-container');
                    const recent = approved.slice(0, 5);
                    if (recent.length === 0) {
                        recentContainer.innerHTML = '<div class="text-center py-3 text-muted small">Nenhuma aprovação recente</div>';
                    } else {
                        recentContainer.innerHTML = `
                            <ul class="list-group list-group-flush">
                                ${recent.map(item => `
                                    <li class="list-group-item py-2">
                                        <div class="small fw-medium text-truncate">${item.Nome_Aluno || 'Aluno'}</div>
                                        <div class="d-flex justify-content-between">
                                            <span class="small text-muted">${item.Tipo_Solicitacao}</span>
                                            <span class="badge bg-success small">✓</span>
                                        </div>
                                    </li>
                                `).join('')}
                            </ul>
                        `;
                    }

                    // Load Parecerista rotation
                    Views.loadPareceristaRotation(financial);
                })
                .withFailureHandler(function (error) {
                    console.error('Erro ao carregar dados financeiros:', error);
                    document.getElementById('fin-pending-container').innerHTML =
                        '<div class="text-center py-4 text-danger">Erro ao carregar dados</div>';
                })
                .getAllRequests();
        },

        loadPareceristaRotation: function (financialRequests) {
            const container = document.getElementById('parecerista-container');
            if (!container) return;

            // Use backend API for consistent rotation logic (matches CG Dashboard)
            google.script.run
                .withSuccessHandler(function (stats) {
                    if (!stats || !stats.next) {
                        container.innerHTML = `
                            <div class="text-center text-muted small">
                                <p class="mb-0">Nenhum membro CG cadastrado</p>
                            </div>
                        `;
                        return;
                    }

                    // Find last parecerista from stats
                    let lastParecerista = null;
                    if (stats.members && stats.members.length > 0) {
                        // Find member with most pareceres (likely the last active one)
                        const sorted = [...stats.members].sort((a, b) => b.pareceres - a.pareceres);
                        if (sorted[0].pareceres > 0) {
                            lastParecerista = sorted[0].nome;
                        }
                    }

                    // Also try to get last from financial requests
                    if (!lastParecerista && financialRequests) {
                        const approvedWithParecerista = financialRequests
                            .filter(r => {
                                const status = (r.Status || '').toUpperCase();
                                return (status.includes('APROVADO') || status.includes('APPROVED')) && r.Parecerista;
                            })
                            .sort((a, b) => new Date(b.Data_Parecer || b.Data_Atualizacao || 0) - new Date(a.Data_Parecer || a.Data_Atualizacao || 0));

                        if (approvedWithParecerista.length > 0) {
                            lastParecerista = approvedWithParecerista[0].Parecerista;
                        }
                    }

                    // Find next after current
                    let nextAfterCurrent = '-';
                    if (stats.members && stats.members.length > 1) {
                        const currentIdx = stats.members.findIndex(m => m.id === stats.next.id);
                        if (currentIdx !== -1) {
                            const nextIdx = (currentIdx + 1) % stats.members.length;
                            nextAfterCurrent = stats.members[nextIdx].nome;
                        }
                    }

                    // Render rotation info
                    container.innerHTML = `
                        <div class="text-center">
                            <div class="mb-3">
                                <div class="bg-white bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center" 
                                     style="width: 50px; height: 50px;">
                                    <span class="fs-4">🎯</span>
                                </div>
                            </div>
                            <div class="fw-bold text-white mb-1">${stats.next.nome || 'A definir'}</div>
                            <small class="text-white text-opacity-75 d-block mb-3">Parecerista Atual</small>
                            
                            <hr class="my-2 border-white opacity-25">
                            
                            <div class="row text-center small">
                                <div class="col-6">
                                    <div class="text-white text-opacity-75">Próximo</div>
                                    <div class="fw-medium text-white text-truncate">${nextAfterCurrent}</div>
                                </div>
                                <div class="col-6">
                                    <div class="text-white text-opacity-75">Último</div>
                                    <div class="fw-medium text-white text-truncate">${lastParecerista || 'Nenhum'}</div>
                                </div>
                            </div>
                        </div>
                    `;
                })
                .withFailureHandler(function (error) {
                    console.error('Erro ao carregar stats CG:', error);
                    container.innerHTML = '<div class="text-center text-muted small">Erro ao carregar</div>';
                })
                .getCGPareceristaStats();
        },

        // --- MEETING DETAILS VIEW (Enhanced Status Cards) ---
        renderMeetingDetails: function (meetingJsonStr) {
            let meeting;
            try { meeting = JSON.parse(decodeURIComponent(meetingJsonStr)); } catch (e) { return UI.toast("Erro ao carregar reunião", "error"); }

            const container = document.getElementById('main-content');

            // Layout Structure
            const html = `
            <div class="view-section">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <button class="btn btn-link ps-0 text-decoration-none" onclick="Views.renderCalendarManagement()">&larr; Voltar para Calendário</button>
                        <h3 class="mt-2 mb-0">${meeting.Nome}</h3>
                        <small class="text-muted">
                            Data: ${new Date(meeting.Data_Reuniao).toLocaleDateString()}
                        </small>
                    </div>
                    <div>
                         <select id="meet-filter-type" class="form-select" onchange="Views.applyMeetingDetailsFilters()">
                            <option value="">Todos os Tipos de Pedido</option>
                        </select>
                    </div>
                </div>

                <!-- Status Cards Container -->
                <div id="meeting-status-cards" class="row g-4">
                    <div class="col-12 text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Carregando pedidos...</p>
                    </div>
                </div>
            </div>`;

            container.innerHTML = html;

            // Fetch and Render Requests
            API.getRequests('Secretaria', App.user.id, function (requests) {
                // Filter for this meeting
                const meetingRequests = requests.filter(r => {
                    let details = {};
                    try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                    return String(details.ID_Reuniao) === String(meeting.ID);
                });

                // Cache for filtering
                App.cachedMeetingRequests = meetingRequests;

                // Populate Type Filter
                const types = [...new Set(meetingRequests.map(r => r.Tipo_Solicitacao).filter(Boolean))].sort();
                const typeSelect = document.getElementById('meet-filter-type');
                types.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t;
                    opt.textContent = t;
                    typeSelect.appendChild(opt);
                });

                // Initial Render
                Views.renderMeetingStatusCards(meetingRequests);
            });
        },

        renderMeetingStatusCards: function (requests) {
            const container = document.getElementById('meeting-status-cards');

            if (requests.length === 0) {
                container.innerHTML = '<div class="col-12 text-center py-5 text-muted">Nenhum pedido nesta reunião.</div>';
                return;
            }

            // Group by Status
            const groups = {};
            requests.forEach(r => {
                const status = r.Status || 'Sem Status';
                if (!groups[status]) groups[status] = [];
                groups[status].push(r);
            });

            // Order of statuses (optional, or just iterate)
            const statusOrder = ['Em Pauta', 'Pendente', 'Aprovado', 'Aprovado com Ressalvas', 'Rejeitado', 'Retornado', 'Aguardando Orientador'];
            const sortedKeys = Object.keys(groups).sort((a, b) => {
                const idxA = statusOrder.indexOf(a);
                const idxB = statusOrder.indexOf(b);
                if (idxA === -1 && idxB === -1) return a.localeCompare(b);
                if (idxA === -1) return 1;
                if (idxB === -1) return -1;
                return idxA - idxB;
            });

            let html = '';
            sortedKeys.forEach(status => {
                const items = groups[status];
                // Determine Color
                let borderClass = 'border-secondary';
                let textClass = 'text-secondary';
                let icon = '📁';

                if (status.includes('Em Pauta') || status.includes('Pautado')) { borderClass = 'border-purple'; textClass = 'text-purple'; icon = '📋'; }
                else if (status.includes('Pendente')) { borderClass = 'border-primary'; textClass = 'text-primary'; icon = '⏳'; }
                else if (status.includes('Aprovado')) { borderClass = 'border-success'; textClass = 'text-success'; icon = '✅'; }
                else if (status.includes('Rejeitado')) { borderClass = 'border-danger'; textClass = 'text-danger'; icon = '❌'; }
                else if (status.includes('Aguardando')) { borderClass = 'border-warning'; textClass = 'text-warning'; icon = '⚠️'; }

                // Custom styling for border color since utilities might be missing 'border-purple' etc in BS5 default
                // We rely on our custom classes .border-purple defined or use inline style for specific colors
                let style = '';
                if (status.includes('Em Pauta')) style = 'border-left: 5px solid #6f42c1;';
                else if (status.includes('Pendente')) style = 'border-left: 5px solid #0d6efd;';
                else if (status.includes('Aprovado')) style = 'border-left: 5px solid #198754;';
                else if (status.includes('Rejeitado')) style = 'border-left: 5px solid #dc3545;';
                else if (status.includes('Aguardando')) style = 'border-left: 5px solid #ffc107;';
                else style = 'border-left: 5px solid #6c757d;';


                html += `
                 <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100" style="${style}">
                        <div class="card-header bg-white border-0 pt-3 pb-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 fw-bold ${textClass}">${icon} ${status}</h5>
                                <span class="badge rounded-pill bg-light text-dark border">${items.length}</span>
                            </div>
                        </div>
                        <div class="card-body pt-0">
                            <div class="list-group list-group-flush">
                                ${items.map(r => {
                    const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");
                    return `
                                    <div class="list-group-item px-0 py-2 border-0 border-bottom d-flex justify-content-between align-items-start" style="cursor:pointer" onclick="Forms.openRequestDetailModal('${reqDataStr}')">
                                        <div class="ms-2 me-auto">
                                            <div class="fw-bold text-truncate" style="max-width: 200px;">${r.Nome_Solicitante || 'Aluno'}</div>
                                            <div class="small text-muted">${r.Tipo_Solicitacao}</div>
                                        </div>
                                        <span class="badge bg-light text-secondary">Ver &rarr;</span>
                                    </div>
                                    `;
                }).join('')}
                            </div>
                        </div>
                    </div>
                 </div>
                 `;
            });

            container.innerHTML = html;
        },

        applyMeetingDetailsFilters: function () {
            const typeFilter = document.getElementById('meet-filter-type').value;
            const requests = App.cachedMeetingRequests || [];

            if (!typeFilter) {
                Views.renderMeetingStatusCards(requests);
            } else {
                const filtered = requests.filter(r => r.Tipo_Solicitacao === typeFilter);
                Views.renderMeetingStatusCards(filtered);
            }
        },

