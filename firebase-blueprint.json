                return;
            }

            let html = '<div class="d-flex flex-column gap-3">';
            requests.forEach(function (r) {
                const date = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                const status = (r.Status || 'Pendente').toUpperCase();
                const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                // Status Badge Logic
                let statusClass = 'bg-secondary';
                let statusIcon = '⏳';
                if (status.includes('APROVADO') || status.includes('APPROVED')) { statusClass = 'bg-success'; statusIcon = '✅'; }
                else if (status.includes('REJEITADO') || status.includes('REPROVADO')) { statusClass = 'bg-danger'; statusIcon = '❌'; }
                else if (status.includes('EM ANÁLISE') || status.includes('AGUARDANDO')) { statusClass = 'bg-warning text-dark'; statusIcon = '🧐'; }

                // Details parsing
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }

                // Stepper HTML
                const stepperHtml = Views.getStepperHTML ? Views.getStepperHTML(r.Status, true) : '';

                html += `
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge ${statusClass} bg-opacity-10 text-${statusClass.replace('bg-', '').replace(' text-dark', '')} border border-${statusClass.replace('bg-', '').replace(' text-dark', '')} border-opacity-25 px-3 py-2 rounded-pill">
                                    ${statusIcon} ${r.Status}
                                </span>
                                <small class="text-muted fw-medium">📅 ${date}</small>
                            </div>
                        </div>
                        <div class="card-body px-4 pt-2 pb-4">
                            <h5 class="fw-bold text-primary mb-3 mt-2">${r.Tipo_Solicitacao}</h5>
                            
                             <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center gap-2 text-muted">
                                        <div class="bg-light rounded p-2"><span class="small">🆔</span></div>
                                        <div class="d-flex flex-column">
                                            <small class="text-uppercase" style="font-size:0.7rem">ID do Pedido</small>
                                            <span class="fw-medium text-dark small">${(r.ID || '').substring(0, 8)}...</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                   ${details.valor ? `
                                    <div class="d-flex align-items-center gap-2 text-muted">
                                        <div class="bg-light rounded p-2"><span class="small">💰</span></div>
                                        <div class="d-flex flex-column">
                                            <small class="text-uppercase" style="font-size:0.7rem">Valor Solicitado</small>
                                            <span class="fw-medium text-success small">R$ ${parseFloat(details.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span>
                                        </div>
                                    </div>` : ''}
                                </div>
                            </div>

                            <!-- Stepper -->
                            <div class="border-top pt-3 mt-3">
                                ${stepperHtml}
                            </div>
                            
                            <div class="mt-3 text-end">
                                <button class="btn btn-link text-decoration-none fw-bold small" onclick="Forms.openRequestDetailModal('${reqDataStr}')">
                                    Ver Detalhes →
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            container.innerHTML = html;
        },

        filterDocenteRequests: function (filter, btn) {
            // Update button states
            if (btn) {
                document.querySelectorAll('#docente-filters .btn').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
            }

            const requests = App.cachedDocenteRequests || [];
            const container = document.getElementById('docente-requests-container');
            if (!container) return;

            // 1. Pre-filter by category (Acadêmico vs Financeiro)
            const activeCategory = App.docenteActiveCategory || 'academico';
            const isFinType = (r) => {
                const tipo = (r.Tipo_Solicitacao || '').toLowerCase();
                return tipo.includes('auxílio') || tipo.includes('auxilio') || tipo.includes('financeiro') || tipo.includes('reembolso') || tipo.startsWith('fin_');
            };

            const categoryFiltered = activeCategory === 'financeiro'
                ? requests.filter(isFinType)
                : requests.filter(r => !isFinType(r));

            // 2. Apply status filter
            let filtered = [];
            categoryFiltered.forEach(function (r) {
                const status = (r.Status || '').toLowerCase();
                if (filter === 'pendentes' && status.includes('aguardando orientador')) filtered.push(r);
                else if (filter === 'aceitos' && (status.includes('aprovado') || status.includes('aceito') || status.includes('com aval') || status.includes('pendente'))) filtered.push(r);
                else if (filter === 'pautados' && status.includes('pautado')) filtered.push(r);
                else if (filter === 'recusados' && (status.includes('reprovado') || status.includes('recusado') || status.includes('rejeitado'))) filtered.push(r);
            });

            if (filtered.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-4">Nenhum pedido nesta categoria</div>';
                return;
            }

            let html = '<div class="row g-3">';
            filtered.forEach(function (r) {
                const date = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }

                const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                // Determine Status Color
                let statusColor = 'secondary';
                const s = (r.Status || '').toLowerCase();
                if (s.includes('aguardando') || s.includes('pendente')) statusColor = 'warning';
                else if (s.includes('aprovado') || s.includes('aceito')) statusColor = 'success';
                else if (s.includes('reprovado') || s.includes('recusado')) statusColor = 'danger';
                else if (s.includes('pautado')) statusColor = 'info';

                // Status Label
                const statusLabel = r.Status || 'Pendente';

                html += '<div class="col-md-6">';
                html += `
                <div class="card border-0 shadow-sm h-100" style="cursor:pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'" onclick="Forms.openRequestDetailModal('${reqDataStr}')">
                    <div class="card-body position-relative border-start border-4 border-${statusColor}">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                             <div class="d-flex flex-column">
                                <span class="badge bg-light text-muted border mb-1 align-self-start" style="font-weight:400">${r.Tipo_Solicitacao || '-'}</span>
                                <h6 class="fw-bold text-dark mb-0">${r.Nome_Solicitante || details.nome || 'Aluno'}</h6>
                             </div>
                             <span class="badge bg-${statusColor} bg-opacity-10 text-${statusColor === 'warning' ? 'dark' : statusColor} border border-${statusColor} border-opacity-25" style="font-size:0.7rem">
                                ${statusLabel}
                             </span>
                        </div>
                        
                        <div class="mt-3 d-flex justify-content-between align-items-end">
                            <small class="text-muted">📅 ${date}</small>
                            <span class="text-primary small fw-bold">Ver <i class="bi bi-arrow-right"></i></span>
                        </div>
                    </div>
                </div>`;
                html += '</div>';
            });
            html += '</div>';
            container.innerHTML = html;
        },

        showOrientandoRequests: function (orientandoId, nome) {
            const requests = App.cachedDocenteRequests || [];
            // Fix: Compare as trimmed strings to align with Backend robust logic
            const filtered = requests.filter(function (r) {
                return String(r.ID_Usuario || '').trim() === String(orientandoId || '').trim();
            });


            const container = document.getElementById('docente-requests-container');
            if (!container) return;

            // --- UI Updates ---
            // 1. Update Title
            const titleEl = document.getElementById('docente-card-title');
            if (titleEl) titleEl.textContent = 'Pedidos de ' + nome;

            // 2. Hide Filters
            const filtersEl = document.getElementById('docente-filters');
            if (filtersEl) filtersEl.classList.add('d-none');

            // 3. Show Back Button
            const backBtn = document.getElementById('btn-docente-back');
            if (backBtn) backBtn.classList.remove('d-none');
            // ------------------

            if (filtered.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-4">Nenhum pedido deste orientando</div>';
                return;
            }

            let html = '<div class="row g-3">';
            filtered.forEach(function (r) {
                const date = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                // Determine Status Color
                let statusColor = 'secondary';
                const s = (r.Status || '').toLowerCase();
                if (s.includes('aguardando') || s.includes('pendente')) statusColor = 'warning';
                else if (s.includes('aprovado') || s.includes('aceito')) statusColor = 'success';
                else if (s.includes('reprovado') || s.includes('recusado')) statusColor = 'danger';
                else if (s.includes('pautado')) statusColor = 'info';

                // Status Label
                const statusLabel = r.Status || 'Pendente';

                html += '<div class="col-md-6">';
                html += `
                <div class="card border-0 shadow-sm h-100" style="cursor:pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'" onclick="Forms.openRequestDetailModal('${reqDataStr}')">
                    <div class="card-body position-relative border-start border-4 border-${statusColor}">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                             <div class="d-flex flex-column">
                                <span class="badge bg-light text-muted border mb-1 align-self-start" style="font-weight:400">${r.Tipo_Solicitacao || '-'}</span>
                             </div>
                             <span class="badge bg-${statusColor} bg-opacity-10 text-${statusColor === 'warning' ? 'dark' : statusColor} border border-${statusColor} border-opacity-25" style="font-size:0.7rem">
                                ${statusLabel}
                             </span>
                        </div>
                        
                        <div class="mt-3 d-flex justify-content-between align-items-end">
                             <!-- Status Message for Orientador -->
                             ${s.includes('aguardando orientador') ? '<span class="text-warning small fw-bold">⚠️ Aguardando seu parecer</span>' : '<span class="text-muted small">Processado</span>'}

                            <div class="text-end">
                                <small class="text-muted d-block">${date}</small>
                                <span class="text-primary small fw-bold">Ver <i class="bi bi-arrow-right"></i></span>
                            </div>
                        </div>
                    </div>
                </div>`;
                html += '</div>';
            });
            html += '</div>';
            container.innerHTML = html;
        },

        resetDocenteDashboard: function () {
            // Restore Title
            const titleEl = document.getElementById('docente-card-title');
            if (titleEl) titleEl.textContent = '📋 Pedidos de Alunos';

            // Show Filters
            const filtersEl = document.getElementById('docente-filters');
            if (filtersEl) filtersEl.classList.remove('d-none');

            // Hide Back Button
            const backBtn = document.getElementById('btn-docente-back');
            if (backBtn) backBtn.classList.add('d-none');

            // Re-apply current filter (defaulting to active button)
            const activeBtn = document.querySelector('#docente-filters .btn.active') || document.querySelector('#docente-filters .btn-outline-warning');

            // Trigger click to refresh view or manually call filter
            if (activeBtn) {
                // Extract filter mode from onclick attribute or class
                if (activeBtn.textContent.includes('Pendentes')) Views.filterDocenteRequests('pendentes', activeBtn);
                else if (activeBtn.textContent.includes('Aceitos')) Views.filterDocenteRequests('aceitos', activeBtn);
                else if (activeBtn.textContent.includes('Pautados')) Views.filterDocenteRequests('pautados', activeBtn);
                else if (activeBtn.textContent.includes('Recusados')) Views.filterDocenteRequests('recusados', activeBtn);
            }
        },


