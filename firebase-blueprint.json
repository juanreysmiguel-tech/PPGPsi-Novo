                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm text-center py-3 border-start border-info border-4">
                            <div class="fs-3 fw-bold text-info" id="summary-value">R$ -</div>
                            <small class="text-muted">Valor Total</small>
                        </div>
                    </div>
                </div>
                
                <!-- Filters Card -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0 py-3">
                        <span class="fw-bold">🔍 Filtros</span>
                        <button class="btn btn-link btn-sm float-end" onclick="Views.clearRequestFilters()">Limpar Filtros</button>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label small text-muted">Tipo de Solicitação</label>
                                <select class="form-select form-select-sm" id="filter-type" onchange="Views.applyRequestFilters()">
                                    <option value="">Todos os tipos</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">Status</label>
                                <select class="form-select form-select-sm" id="filter-status" onchange="Views.applyRequestFilters()">
                                    <option value="">Todos os status</option>
                                    <option value="Pendente">Pendente</option>
                                    <option value="Aguardando">Aguardando</option>
                                    <option value="Aprovado">Aprovado</option>
                                    <option value="Rejeitado">Rejeitado</option>
                                    <option value="Concluído">Concluído</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small text-muted">Data Início</label>
                                <input type="date" class="form-control form-control-sm" id="filter-date-start" onchange="Views.applyRequestFilters()">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small text-muted">Data Fim</label>
                                <input type="date" class="form-control form-control-sm" id="filter-date-end" onchange="Views.applyRequestFilters()">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small text-muted">Valor Mínimo (R$)</label>
                                <input type="number" class="form-control form-control-sm" id="filter-value-min" placeholder="0" onchange="Views.applyRequestFilters()">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">Valor Máximo (R$)</label>
                                <input type="number" class="form-control form-control-sm" id="filter-value-max" placeholder="999999" onchange="Views.applyRequestFilters()">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-muted">Buscar (Nome/ID)</label>
                                <input type="text" class="form-control form-control-sm" id="filter-search" placeholder="Digite para buscar..." oninput="Views.applyRequestFilters()">
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Results Table -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                        <span class="fw-bold">📋 Solicitações</span>
                        <span class="badge bg-secondary" id="results-count">Carregando...</span>
                    </div>
                    <div class="card-body p-0" id="req-mgmt-table-container">
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary"></div>
                            <p class="mt-2 text-muted">Carregando solicitações...</p>
                        </div>
                    </div>
                </div>
            </div>`;

            // Store all requests for filtering
            Views._allRequests = [];
            Views._filteredRequests = [];

            // Load all requests
            google.script.run
                .withSuccessHandler(function (requests) {
                    Views._allRequests = requests || [];
                    Views._filteredRequests = [...Views._allRequests];
                    Views.populateRequestTypeFilter();
                    Views.renderRequestManagementTable();
                    Views.updateRequestSummary();
                })
                .withFailureHandler(function (err) {
                    console.error('Erro ao carregar solicitações:', err);
                    document.getElementById('req-mgmt-table-container').innerHTML =
                        '<div class="text-center p-4 text-danger">Erro ao carregar solicitações</div>';
                })
                .getAllRequests();
        },

        _allRequests: [],
        _filteredRequests: [],

        populateRequestTypeFilter: function () {
            const select = document.getElementById('filter-type');
            if (!select) return;

            // Get unique types
            const types = [...new Set(Views._allRequests.map(r => r.Tipo_Solicitacao).filter(Boolean))];
            types.sort();

            types.forEach(type => {
                const opt = document.createElement('option');
                opt.value = type;
                opt.textContent = type;
                select.appendChild(opt);
            });
        },

        applyRequestFilters: function () {
            const typeFilter = document.getElementById('filter-type')?.value || '';
            const roleFilter = document.getElementById('filter-role')?.value || '';
            const statusFilter = document.getElementById('filter-status')?.value || '';
            const dateStart = document.getElementById('filter-date-start')?.value || '';
            const dateEnd = document.getElementById('filter-date-end')?.value || '';
            const valueMin = parseFloat(document.getElementById('filter-value-min')?.value) || 0;
            const valueMax = parseFloat(document.getElementById('filter-value-max')?.value) || Infinity;
            const search = (document.getElementById('filter-search')?.value || '').toLowerCase();

            Views._filteredRequests = Views._allRequests.filter(r => {
                // Type filter
                if (typeFilter && r.Tipo_Solicitacao !== typeFilter) return false;

                // Status filter
                if (statusFilter) {
                    const status = (r.Status || '').toLowerCase();
                    if (!status.includes(statusFilter.toLowerCase())) return false;
                }

                // Role filter
                if (roleFilter) {
                    const role = (r.Role_Solicitante || '').toLowerCase();
                    if (!role.includes(roleFilter.toLowerCase())) return false;
                }

                // Date range filter
                if (dateStart || dateEnd) {
                    const reqDate = new Date(r.Data_Criacao);
                    if (dateStart && reqDate < new Date(dateStart)) return false;
                    if (dateEnd && reqDate > new Date(dateEnd + 'T23:59:59')) return false;
                }

                // Value range filter
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                const valor = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);
                if (valor < valueMin || valor > valueMax) return false;

                // Search filter
                if (search) {
                    const searchText = [
                        r.ID,
                        r.Nome_Solicitante,
                        r.Tipo_Solicitacao,
                        r.Status,
                        r.ID_Usuario
                    ].join(' ').toLowerCase();
                    if (!searchText.includes(search)) return false;
                }

                return true;
            });

            Views.renderRequestManagementTable();
            Views.updateRequestSummary();
        },

        clearRequestFilters: function () {
            document.getElementById('filter-type').value = '';
            document.getElementById('filter-role').value = '';
            document.getElementById('filter-status').value = '';
            document.getElementById('filter-date-start').value = '';
            document.getElementById('filter-date-end').value = '';
            document.getElementById('filter-value-min').value = '';
            document.getElementById('filter-value-max').value = '';
            document.getElementById('filter-search').value = '';
            Views._filteredRequests = [...Views._allRequests];
            Views.renderRequestManagementTable();
            Views.updateRequestSummary();
        },

        // PROEX Export - generates CSV for CAPES/Sucupira compliance
        exportRequestsToCSV: function () {
            const requests = Views._filteredRequests.length > 0 ? Views._filteredRequests : Views._allRequests;

            if (!requests || requests.length === 0) {
                UI.toast('Nenhuma solicitação para exportar', 'warning');
                return;
            }

            // CSV Headers
            const headers = [
                'ID',
                'Data_Solicitacao',
                'Nome_Solicitante',
                'Email_Solicitante',
                'Tipo_Solicitacao',
                'Status',
                'Valor_Solicitado',
                'Reuniao',
                'Data_Ultima_Atualizacao',
                'Observacoes'
            ];

            // Build CSV content
            let csvContent = headers.join(';') + '\n';

            requests.forEach(r => {
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }

                const row = [
                    r.ID || '',
                    r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '',
                    (r.Nome_Solicitante || details.nome || '').replace(/;/g, ','),
                    (r.Email_Solicitante || '').replace(/;/g, ','),
                    r.Tipo_Solicitacao || '',
                    r.Status || '',
                    details.valorSolicitado || details.valorTotal || '',
                    r.Nome_Reuniao || '',
                    r.Data_Atualizacao ? new Date(r.Data_Atualizacao).toLocaleDateString('pt-BR') : '',
                    (r.Observacao_Final || '').replace(/;/g, ',').replace(/\n/g, ' ')
                ];

                csvContent += row.join(';') + '\n';
            });

            // Create download
            const BOM = '\uFEFF';
            const blob = new Blob([BOM + csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.setAttribute('href', url);
            link.setAttribute('download', 'solicitacoes_ppgpsi_' + new Date().toISOString().slice(0, 10) + '.csv');
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);

            UI.toast('CSV exportado com sucesso (' + requests.length + ' registros)', 'success');
        },

        updateRequestSummary: function () {
            const requests = Views._filteredRequests;

            // Total count
            document.getElementById('summary-total').textContent = requests.length;

            // Pending count
            const pending = requests.filter(r => {
                const s = (r.Status || '').toLowerCase();
                return s.includes('pendente') || s.includes('aguardando');
            }).length;
            document.getElementById('summary-pending').textContent = pending;

            // Approved count
            const approved = requests.filter(r => {
                const s = (r.Status || '').toLowerCase();
                return s.includes('aprovado') || s.includes('approved');
            }).length;
            document.getElementById('summary-approved').textContent = approved;

            // Total value
            let totalValue = 0;
            requests.forEach(r => {
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                const valor = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);
                totalValue += valor;
            });
            document.getElementById('summary-value').textContent = 'R$ ' + totalValue.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
        },

        renderRequestManagementTable: function () {
            const container = document.getElementById('req-mgmt-table-container');
            const requests = Views._filteredRequests;

            // Update count badge
            document.getElementById('results-count').textContent = requests.length + ' resultado(s)';

            if (requests.length === 0) {
                container.innerHTML = `
                    <div class="text-center p-5">
                        <div class="fs-1 mb-3">📭</div>
                        <h5>Nenhuma solicitação encontrada</h5>
                        <p class="text-muted">Ajuste os filtros para ver mais resultados.</p>
                    </div>`;
                return;
            }

            // Build table
            let html = `
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="small">ID</th>
                            <th class="small">Solicitante</th>
                            <th class="small">Role</th>
                            <th class="small">Tipo</th>
                            <th class="small">Status</th>
                            <th class="small">Data</th>
                            <th class="small">Valor</th>
                            <th class="small text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>`;

            requests.forEach(r => {
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }

                const dateStr = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                const valor = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);
                const valorStr = valor > 0 ? 'R$ ' + valor.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) : '-';

                // Status badge color
                const status = r.Status || 'Pendente';
                let statusClass = 'secondary';
                const statusLower = status.toLowerCase();
                if (statusLower.includes('aprovado') || statusLower.includes('approved')) statusClass = 'success';
                else if (statusLower.includes('pendente') || statusLower.includes('aguardando')) statusClass = 'warning';
                else if (statusLower.includes('rejeitado') || statusLower.includes('rejected')) statusClass = 'danger';
                else if (statusLower.includes('conclu')) statusClass = 'info';

                const encodedData = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                html += `
                    <tr>
                        <td class="small text-muted">${(r.ID || '').substring(0, 8)}...</td>
                        <td class="fw-medium">
                           <div class="fw-bold text-dark small">${r.Nome_Solicitante || r.ID_Usuario || '-'}</div>
                           <div class="text-muted" style="font-size:0.7rem">${r.Email_Solicitante || ''}</div>
                        </td>
                        <td>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-2" style="font-size:0.7rem; font-weight:500">
                               ${r.Role_Solicitante || 'Externo'}
                            </span>
                        </td>
                        <td class="small">${r.Tipo_Solicitacao || '-'}</td>
                        <td><span class="badge bg-${statusClass} ${statusClass === 'warning' ? 'text-dark' : ''}">${status}</span></td>
                        <td class="small">${dateStr}</td>
                        <td class="small fw-medium">${valorStr}</td>
                        <td class="text-center">
                            <button class="btn btn-outline-primary btn-sm" onclick="Forms.openRequestDetailModal('${encodedData}')" title="Ver Detalhes">
                                👁️
                            </button>
                        </td>
                    </tr>`;
            });

            html += '</tbody></table></div>';
            container.innerHTML = html;
        },

        exportRequestsToCSV: function () {
            const requests = Views._filteredRequests;
            if (requests.length === 0) {
                UI.toast('Nenhum dado para exportar', 'warning');
                return;
            }

            // Build CSV content
            let csv = 'ID,Solicitante,Tipo,Status,Data,Valor\n';
            requests.forEach(r => {
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                const valor = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);
                const dateStr = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '';

                csv += `"${r.ID || ''}","${r.Nome_Solicitante || r.ID_Usuario || ''}","${r.Tipo_Solicitacao || ''}","${r.Status || ''}","${dateStr}","${valor}"\n`;
            });

            // Download
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'solicitacoes_' + new Date().toISOString().split('T')[0] + '.csv';
            link.click();
            UI.toast('Exportação iniciada!', 'success');
        },

        renderDocenteManagement: function () {
