                    </div>
                    <div class="col-md-6">
                       <label class="form-label">Status</label>
                       <select class="form-select" id="u-status">
                          <option value="Ativo" ${user.Status === 'Ativo' ? 'selected' : ''}>Ativo</option>
                          <option value="Inativo" ${user.Status === 'Inativo' ? 'selected' : ''}>Inativo</option>
                       </select>
                    </div>
                 </div>
                 
                 <!-- Academic Info Section (for Students) -->
                 <h6 class="text-muted text-uppercase border-bottom pb-2 mb-3">Informações Acadêmicas (Discentes)</h6>
                 <div class="row g-3 mb-4">
                    <div class="col-md-4">
                       <label class="form-label">Data de Ingresso</label>
                       <input type="date" class="form-control" id="u-data-ingresso" value="${user.Data_Ingresso || ''}">
                    </div>
                    <div class="col-md-4">
                       <label class="form-label">Créditos Obtidos</label>
                       <input type="number" class="form-control" id="u-creditos" value="${user.Creditos_Totais || ''}" min="0">
                    </div>
                    <div class="col-md-4">
                       <label class="form-label">Data Integralização</label>
                       <input type="date" class="form-control" id="u-data-integralizacao" value="${user.Data_Integralizacao || ''}">
                    </div>
                 </div>
                 
                 <div class="row g-3 mb-4">
                    <div class="col-md-6">
                       <label class="form-label">Data Regulamentar Qualificação</label>
                       <input type="date" class="form-control" id="u-data-qualificacao" value="${user.Data_Qualificacao || ''}">
                    </div>
                    <div class="col-md-6">
                       <label class="form-label">Data Regulamentar Defesa</label>
                       <input type="date" class="form-control" id="u-data-defesa" value="${user.Data_Defesa || ''}">
                    </div>
                 </div>
                 
                 <!-- Advisor Info -->
                 <h6 class="text-muted text-uppercase border-bottom pb-2 mb-3">Orientação</h6>
                 <div class="row g-3 mb-3">
                    <div class="col-md-6">
                       <label class="form-label">Nome do(a) Orientador(a)</label>
                       <input type="text" class="form-control" id="u-nome-orientador" value="${user.Nome_Orientador || ''}">
                    </div>
                    <div class="col-md-6">
                       <label class="form-label">E-mail do(a) Orientador(a)</label>
                       <input type="email" class="form-control" id="u-email-orientador" value="${user.Email_Orientador || ''}">
                    </div>
                 </div>
                 
                 <!-- Archiving Section (for Concluded Students) -->
                 ${isEdit && userRoles.includes('Discente') ? '<h6 class="text-muted text-uppercase border-bottom pb-2 mb-3 mt-4 text-warning">Arquivamento</h6><div class="row g-3 mb-3"><div class="col-12"><button type="button" class="btn btn-outline-warning w-100" onclick="Forms.archiveStudentRequests(\'' + user.Email + '\')">📦 Arquivar Solicitações Concluídas/Finalizadas deste Aluno</button></div></div>' : ''}
              </form>
            </div>
            <div class="modal-footer border-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
              <button type="button" class="btn btn-success" onclick="Forms.saveUser()">💾 Salvar</button>
            </div>
          </div>
        </div>
      </div>`;

            // Remove old modal if exists
            const old = document.getElementById('modalUser');
            if (old) {
                const instance = bootstrap.Modal.getInstance(old);
                if (instance) instance.dispose();
                old.remove();
            }

            // Append and Show
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            new bootstrap.Modal(document.getElementById('modalUser')).show();
        },

        saveUser: function () {
            const id = document.getElementById('u-id').value;
            const name = document.getElementById('u-name').value;
            const email = document.getElementById('u-email').value;
            const status = document.getElementById('u-status').value;

            // Get Roles
            const checkboxes = document.querySelectorAll('input[name="u-role"]:checked');
            const roles = Array.from(checkboxes).map(cb => cb.value);

            if (!name || !email || roles.length === 0) {
                return UI.toast("Preencha nome, email e selecione pelo menos um perfil.", "error");
            }

            // Academic fields
            const dataIngresso = document.getElementById('u-data-ingresso').value;
            const creditos = document.getElementById('u-creditos').value;
            const dataIntegralizacao = document.getElementById('u-data-integralizacao').value;
            const dataQualificacao = document.getElementById('u-data-qualificacao').value;
            const dataDefesa = document.getElementById('u-data-defesa').value;
            const nomeOrientador = document.getElementById('u-nome-orientador').value;
            const emailOrientador = document.getElementById('u-email-orientador').value;

            const payload = {
                id: id,
                name: name,
                email: email,
                roles: roles,
                status: status,
                dataIngresso: dataIngresso,
                creditos: creditos,
                dataIntegralizacao: dataIntegralizacao,
                dataQualificacao: dataQualificacao,
                dataDefesa: dataDefesa,
                nomeOrientador: nomeOrientador,
                emailOrientador: emailOrientador
            };

            UI.showLoading(true);
            API.saveUser(payload, function () {
                UI.showLoading(false);
                bootstrap.Modal.getInstance(document.getElementById('modalUser')).hide();
                UI.toast("Usuário salvo com sucesso!", 'success');
                App.loadUsers(); // Refresh Table
            });
        },

        archiveStudentRequests: function (studentEmail) {
            if (!confirm(`Deseja realmente arquivar todas as solicitações finais de ${studentEmail}? Elas serão movidas para a aba de Arquivo.`)) return;

            UI.showLoading(true, "Arquivando solicitações...");
            API.archiveStudentRequests(studentEmail, function (res) {
                UI.showLoading(false);
                if (res.success) {
                    UI.toast(`${res.count} solicitações de ${studentEmail} foram arquivadas com sucesso!`, 'success');
                    bootstrap.Modal.getInstance(document.getElementById('modalUser')).hide();
                } else {
                    UI.toast("Erro ao arquivar: " + res.error, 'error');
                }
            });
        },

        // --- AGENDA MANAGEMENT ---
        // (Use Forms.sendToAgenda defined below at Forms.sendToAgenda = function...)


        // --- CG (Conselho de Gestão) ACTIONS FOR FINANCIAL REQUESTS ---
        submitCGAction: function (requestId, action) {
            const justification = document.getElementById('cg-justif').value;

            if (action !== 'Aprovar' && (!justification || justification.trim().length < 5)) {
                UI.toast('Por favor, justifique a decisão (mínimo 5 caracteres).', 'warning');
                return;
            }

            if (!confirm(`Confirma a ação: ${action} ? `)) return;

            // Collect Council CAPES Responses (if any)
            let cgCapesResponse = {};
            const checkboxes = document.querySelectorAll('input[name="cg_capes_check"]:checked');
            checkboxes.forEach(cb => {
                cgCapesResponse[cb.dataset.label] = true;
            });

            // Capture Approved Value
            let approvedValue = document.getElementById('cg-approved-value').value;
            // Basic validation/cleanup (ensure it's string format we expect or parse it)
            // Just sending as string, backend can parse/clean it if needed or store as is. 
            // Better to parse here to double check it's a number?
            // parseMoneyValue returns float. 
            // But let's send the raw string, backend logic updates 'valor' which often is a string in this system.

            UI.showLoading(true, 'Processando parecer...');

            const actionData = {
                requestId: requestId,
                action: action,
                justification: justification,
                user: App.user,
                currentRole: App.currentRole || (App.user && App.user.roles && App.user.roles[0]) || 'Externo', // Add the active selected role with fallback
                cgCapesResponse: cgCapesResponse,
                approvedValue: approvedValue // Send value
            };

            google.script.run
                .withSuccessHandler(function (res) {
                    UI.showLoading(false);
                    UI.toast('Parecer registrado com sucesso!', 'success');

                    // Close Modals
                    const modalDetail = bootstrap.Modal.getInstance(document.getElementById('modalRequestDetail'));
                    if (modalDetail) modalDetail.hide();

                    const modalParecer = bootstrap.Modal.getInstance(document.getElementById('modalCGParecer'));
                    if (modalParecer) modalParecer.hide();

                    // Refresh List
                    Views.renderCGParecerView();
                })
                .withFailureHandler(function (err) {
                    UI.showLoading(false);
                    console.error(err);
                    UI.toast('Erro: ' + err.message, 'danger');
                })
                .submitCGAction(actionData);
        },

        openCGParecerModal: function (reqJson) {
            let req = {};
            if (typeof reqJson === 'string') {
                try { req = JSON.parse(decodeURIComponent(reqJson)); } catch (e) {
                    try { req = JSON.parse(reqJson); } catch (e2) { console.error(e2); }
                }
            } else {
                req = reqJson;
            }

            // 1. Parsing Details & Files
            let details = {};
            try { details = JSON.parse(req.Detalhes || '{}'); } catch (e) { }

            // Fix Value Display: Prefer 'Valor do Auxílio (R$)' (calculated/final), then 'Valor Solicitado (R$)', then 'valor'
            const rawValue = details['Valor do Aux\u00EDlio (R$)'] || details['Valor Solicitado (R$)'] || details['valor'] || '0';
            const displayValue = parseMoneyValue(rawValue); // FIX: Pass value directly, not object

            // Identify CAPES Fields to display them separately/highlighted
            const capesIds = typeof CAPES_FIELDS !== 'undefined' ? CAPES_FIELDS.map(f => f.id).filter(id => id) : [];

            // Build Files List with Icons
            let filesHtml = '';
            let files = [];

            // Check keys for files
            Object.keys(details).forEach(k => {
                const kLower = k.toLowerCase();
                if (kLower.includes('arquivo') || kLower.includes('comprovante') || kLower.includes('anexo') || kLower.includes('file') || kLower.includes('pdf') || kLower.includes('link') || kLower.includes('folder') || kLower.includes('pasta')) {
                    const url = details[k];
                    if (url && typeof url === 'string' && url.startsWith('http')) {
                        // Clean Name: remove internal keys like "Arquivo_01" if possible, or key name
                        let name = k.replace(/_/g, ' ');
                        files.push({ name: name, url: url });
                    }
                }
            });

            if (files.length > 0) {
                filesHtml = `<div class="card mb-3 border-0 bg-light">
                    <div class="card-header bg-transparent fw-bold small text-uppercase">📂 Arquivos Anexados</div>
                    <ul class="list-group list-group-flush bg-transparent">
                        ${files.map(f => `<a href="${f.url}" target="_blank" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-transparent">
                            <span class="text-truncate fw-medium"><i class="bi bi-paperclip me-2 text-primary"></i>${f.name}</span>
                            <i class="bi bi-box-arrow-up-right small text-muted"></i>
                        </a>`).join('')}
                    </ul>
                </div>`;
            }

            // Build Fields HTML
            // Separate CAPES fields from General fields
            let capesResponses = [];
            let generalHtml = '';

            // Keys to exclude from General View (Internal/System keys)
            const excludeKeys = [
                'ID_Reunião', 'ID_Reuniao', 'Observacao_Docente', 'Observação_Docente',
                'Parecer_CG_Justificativa', 'ID_Parecerista_CG',
                'Parecer_CG_CAPES', 'Historico_Aprovacao', 'Status', 'Tipo_Solicitacao'
                // Removed 'Diretrizes_CAPES' from exclude list to handle it manually below relative to CAPES section
            ];

            // 1. Try to parse 'Diretrizes_CAPES' field if it exists (Aggregated String)
            if (details['Diretrizes_CAPES']) {
                const lines = String(details['Diretrizes_CAPES']).split('\n');
                lines.forEach(line => {
                    const trimmed = line.trim();
                    if (trimmed) {
                        capesResponses.push(`<li class="mb-1"><i class="bi bi-check-circle-fill text-success me-2"></i>${trimmed}</li>`);
                    }
                });
            }

            Object.entries(details).forEach(([key, value]) => {
                // Skip file keys and internal keys
                const kLower = key.toLowerCase();
                if (kLower.includes('arquivo') || kLower.includes('comprovante') || kLower.includes('anexo') || kLower.includes('file') || kLower.includes('pdf') || kLower.includes('link') || kLower.includes('folder') || kLower.includes('pasta') || key === 'valor') return;

                if (excludeKeys.includes(key)) return;

                // Skip Diretrizes_CAPES here as we handled it above
                if (key === 'Diretrizes_CAPES') return;

                // Check if it's a CAPES field (individual boolean keys)
                const isCapes = typeof CAPES_FIELDS !== 'undefined' && CAPES_FIELDS.some(f => f.label === key || f.id === key);

                if (isCapes) {
                    if (value === true || value === 'true' || value === 'Sim') {
                        capesResponses.push(`<li class="mb-1"><i class="bi bi-check-circle-fill text-success me-2"></i>${key}</li>`);
                    } else if (key === 'Justificativa (descreva como o pedido se relaciona com os itens marcados)' || key === 'capes-justificativa') {
                        capesResponses.push(`<li class="mt-2 p-2 bg-white border rounded"><strong>Justificativa do Aluno:</strong><br>${value}</li>`);
                    }
                } else {
                    generalHtml += `<div class="mb-2">
                        <small class="text-muted d-block">${key}</small>
                        <span class="fw-medium">${value}</span>
                     </div>`;
                }
            });

            let capesSectionHtml = '';
            if (capesResponses.length > 0) {
                capesSectionHtml = `
        <div class="card mb-3 border-info">
                    <div class="card-header bg-info bg-opacity-10 text-info fw-bold">
                        📋 Diretrizes CAPES & PPGPsi (Preenchido pelo Aluno)
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0 small">
                            ${capesResponses.join('')}
                        </ul>
                    </div>
                </div>`;
            }

            // Build Council's CAPES Form (Mirror)
            let councilCapesForm = '';
            if (typeof CAPES_FIELDS !== 'undefined') {
                const fieldsHtml = CAPES_FIELDS.map(field => {
                    const id = `cg-${field.id || 'field-' + Math.random().toString(36).substr(2, 9)}`;

                    if (field.type === 'heading') {
                        return `<h6 class="fw-bold mt-3 mb-2 small text-uppercase text-secondary border-bottom pb-1">${field.label}</h6>`;
                    } else if (field.type === 'info') {
                        return `<p class="small text-muted mb-2 fst-italic">${field.label}</p>`;
                    } else if (field.type === 'checkbox') {
                        return `
        <div class="form-check mb-1">
            <input class="form-check-input" type="checkbox" id="${id}" name="cg_capes_check" data-label="${field.label}">
                <label class="form-check-label small" for="${id}">${field.label}</label>
            </div>`;
                    } else if (field.type === 'textarea' && field.id === 'capes-justificativa') {
                        // Skip main justification here, as we have a specific Council Justification box
                        return '';
                    }
                    return '';
                }).join('');

                councilCapesForm = `
                <div class="bg-light p-3 rounded mb-3 border">
                     <h6 class="fw-bold text-primary small mb-3">📋 Avaliação do Conselho - Diretrizes CAPES</h6>
                     <div style="max-height: 250px; overflow-y: auto;" class="pe-2 custom-scrollbar">
                         ${fieldsHtml}
                     </div>
                </div>`;
            }

            // 2. History
            let history = [];
            try { history = JSON.parse(req.Historico_Aprovacao || '[]'); } catch (e) { }
            const formatDate = (dateStr) => dateStr ? new Date(dateStr).toLocaleString('pt-BR') : '-';

            const historyHtml = history.length > 0 ?
                history.slice().reverse().map(h => `
        <div class="timeline-item pb-3 border-start ps-3 ms-2 position-relative" style="border-color: #dee2e6;">
                        <div class="position-absolute bg-white border rounded-circle" style="left: -6px; top: 0; width: 12px; height: 12px;"></div>
                        <div class="small text-muted mb-1">${formatDate(h.date)}</div>
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">${h.action}</div>
                        <div class="small text-muted mb-1">${h.user || '—'}</div>
                        ${h.justification ? `<div class="p-2 bg-light rounded border small fst-italic mt-1">"${h.justification}"</div>` : ''}
                    </div>
        `).join('')
                : '<div class="text-center text-muted small py-3">Sem histórico.</div>';


            const modalHtml = `
        <div class="modal fade" id="modalCGParecer" tabindex="-1">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header bg-dark text-white">
                        <div>
                            <h5 class="modal-title">⚖️ Parecer do Conselho de Gestão</h5>
                            <div class="small opacity-75">
                                <span class="me-3">Solicitação: <strong>${req.Tipo_Solicitacao || 'N/A'}</strong></span>
                                <span>Solicitante: <strong>${req.Nome_Aluno || req.Nome_Solicitante || 'Desconhecido'}</strong></span>
                            </div>
                        </div>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="row g-0 h-100">
                            <!-- LEFT: REQUEST CONTEXT (Scrollable) -->
                            <div class="col-lg-7 p-4 border-end bg-light bg-opacity-50" style="min-height: 400px;">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small">Detalhes da Solicitação</h6>

                                <!-- CAPES Mirror (Student) -->
                                ${capesSectionHtml}

                                <!-- Files -->
                                ${filesHtml}

                                <!-- General Fields -->
                                <div class="card card-body border-0 shadow-sm mb-3">
                                    <div class="row row-cols-1 row-cols-md-2 g-3">
                                        <div class="col">
                                            <small class="text-muted d-block">Status Atual</small>
                                            <span class="badge bg-secondary text-wrap">${req.Status}</span>
                                        </div>
                                        <div class="col">
                                            <small class="text-muted d-block">Valor Solicitado</small>
                                            <span class="fw-bold text-success">R$ ${displayValue.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span>
                                        </div>
                                    </div>
                                    <hr class="my-3 opacity-25">
                                        ${generalHtml || '<div class="text-muted small">Sem dados adicionais.</div>'}
                                </div>
                            </div>

                            <!-- RIGHT: ACTION & HISTORY -->
                            <div class="col-lg-5 d-flex flex-column h-100">

                                <!-- Decision Form (Fixed Top/Middle) -->
                                <div class="p-4 bg-white border-bottom shadow-sm" style="z-index: 10;">

                                    <!-- Council CAPES Evaluation -->
                                    ${councilCapesForm}

                                    <h6 class="text-uppercase text-primary fw-bold mb-3 small">📝 Emitir Parecer Final</h6>

                                    <div class="row mb-3">
                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted">Valor Aprovado (R$)</label>
                                            <div class="input-group">
                                                <span class="input-group-text">R$</span>
                                                <input type="text" class="form-control" id="cg-approved-value" value="${displayValue.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}" placeholder="0,00">
                                            </div>
                                            <small class="text-muted" style="font-size: 0.75rem;">Altere este valor caso o conselho decida aprovar um montante diferente do solicitado.</small>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Justificativa / Parecer Técnico</label>
                                        <textarea class="form-control" id="cg-justif" rows="4" placeholder="Descreva o parecer do conselho, solicitações de ajuste ou motivo da negativa..."></textarea>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-warning flex-fill text-dark small" onclick="Forms.submitCGAction('${req.ID}', 'Elucidar')">
                                                ❓ Pedir Elucidação
                                            </button>
                                            <button type="button" class="btn btn-danger flex-fill small" onclick="Forms.submitCGAction('${req.ID}', 'Negar')">
                                                ❌ Negar
                                            </button>
                                        </div>
                                        <button type="button" class="btn btn-success fw-bold py-2" onclick="Forms.submitCGAction('${req.ID}', 'Aprovar')">
                                            ✅ Aprovar Solicitação
                                        </button>
                                    </div>
                                </div>

                                <!-- History (Scrollable Bottom) -->
                                <div class="flex-grow-1 p-4 bg-light overflow-auto">
                                    <h6 class="text-uppercase text-muted fw-bold mb-3 small">📜 Histórico de Tramitação</h6>
                                    <div class="ps-1">
                                        ${historyHtml}
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>`;

            // Remove old
            const old = document.getElementById('modalCGParecer');
            if (old) {
                const instance = bootstrap.Modal.getInstance(old);
                if (instance) instance.dispose();
                old.remove();
            }

            document.body.insertAdjacentHTML('beforeend', modalHtml);
            new bootstrap.Modal(document.getElementById('modalCGParecer')).show();
        },
    };

    /* ==========================================================================
       UI HELPERS
       ========================================================================== */
    const UIHelpers = {
        renderRequestsTable: function (data, targetId, showActions) {
            try {
                const container = document.getElementById(targetId);
                if (!container) return;

                if (!data || data.length === 0) {
                    var debugInfo = data ? "Array Vazio" : "Nulo/Undefined";
                    container.innerHTML = `< div class="text-center p-4 text-muted" > Nenhuma solicitação encontrada(${debugInfo}).</div > `;
                    return;
                }

                let html = `< table class="table table-hover" ><thead><tr><th>Tipo</th><th>Data</th><th>Status</th>${showActions ? '<th>Ações</th>' : ''}</tr></thead><tbody>`;
                data.forEach(row => {
                    let dateStr = 'Data Inválida';
                    try {
                        if (row.Data_Criacao) {
                            // Handle both Google Apps Script Date objects (strings) and standard dates
                            let d = new Date(row.Data_Criacao);
                            if (!isNaN(d.getTime())) {
                                dateStr = d.toLocaleDateString();
                            }
                        }
                    } catch (e) { console.error("Date error", e); }

                    let typeStr = row.Tipo_Solicitacao || 'Sem Tipo';
                    let statusStr = row.Status || 'Indefinido';
                    let statusClass = statusStr.split(' ')[0] || 'secondary';

                    let actions = '';
                    // FIX: Expanded actions for Secretariat in Table View
                    const statusLower = (statusStr || '').toLowerCase();
                    if (showActions) {
                        if (statusLower === 'pendente') {
                            actions = `
                               <button class="btn btn-sm btn-outline-success" title="Aprovar" onclick="Forms.approveRequest('${row.ID}', 'Aprovar')">✓</button>
                               <button class="btn btn-sm btn-outline-danger" title="Rejeitar" onclick="Forms.approveRequest('${row.ID}', 'Rejeitar')">✗</button>
                             `;
                        } else if (statusLower.includes('aprovado') && (statusLower.includes('cg') || statusLower.includes('conselho'))) {
                            // Approved CG Actions
                            actions = `<button class="btn btn-sm btn-info text-white" title="Prestação de Contas" onclick="Forms.openPrestacaoContasModal('${row.ID}')">📉</button>`;
                            actions += `<button class="btn btn-sm btn-outline-warning ms-1" title="Devolver p/ CG" onclick="Forms.returnToCG('${row.ID}')">↩️</button>`;
                            actions += `<button class="btn btn-sm btn-purple ms-1" title="Pautar" onclick="Forms.sendToAgenda('${row.ID}')">📥</button>`;
                        }
                    }
                    html += `<tr><td><span class="fw-medium">${typeStr}</span></td><td>${dateStr}</td><td><span class="badge status-${statusClass}">${statusStr}</span></td>${showActions ? `<td>${actions}</td>` : ''}</tr>`;
                });
                html += `</tbody></table > `;
                container.innerHTML = html;
            } catch (err) {
                document.getElementById(targetId).innerHTML = `< div class="alert alert-danger" > Erro de Renderização: ${err.message}</div > `;
            }
        },

        renderUsersTable: function (data) {
            const tbody = document.getElementById('users-table-body');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center">Nenhum usuário encontrado.</td></tr>';
                return;
            }

            let html = '';
            data.forEach(u => {
                // Parse roles safely
                let rolesStr = u.Roles;
                try {
                    let r = JSON.parse(u.Roles);
                    rolesStr = Array.isArray(r) ? r.join(', ') : r;
                } catch (e) { }

                html += `
        < tr >
               <td><div class="fw-bold">${u.Nome}</div></td>
               <td>${u.Email}</td>
               <td><small class="text-muted bg-light px-2 py-1 rounded border">${rolesStr}</small></td>
               <td><span class="badge ${u.Status === 'Ativo' ? 'bg-success' : 'bg-secondary'}">${u.Status}</span></td>
               <td>
                  <button class="btn btn-sm btn-outline-primary" onclick="Forms.openUserModal('${u.ID}')">Editar</button>
               </td>
            </tr >
        `;
            });
            tbody.innerHTML = html;
        },

        filterUsersTable: function () {
            const term = document.getElementById('user-search').value.toLowerCase();
            if (!App.cachedUsers) return;

            const filtered = App.cachedUsers.filter(u =>
                u.Nome.toLowerCase().includes(term) ||
                u.Email.toLowerCase().includes(term)
            );
            UIHelpers.renderUsersTable(filtered);
        },

        getStatusBadgeInfo: function (status) {
            const s = (status || '').toUpperCase();
            let cls = 'bg-secondary';
            let icon = '';

            if (s.includes('AGUARDANDO') || s.includes('PENDENTE') || s.includes('ANÁLISE')) {
                cls = 'bg-warning text-dark';
                icon = '⏳';
            }
            if (s.includes('APROVADO') || s.includes('DEPOSITADO') || s.includes('CONCLUÍDO')) {
                cls = 'bg-success';
                icon = '✓';
            }
            if (s.includes('REJEITADO') || s.includes('REPROVADO') || s.includes('INDEFERIDO')) {
                cls = 'bg-danger';
                icon = '✗';
            }
            if (s.includes('RETORNADO') || s.includes('ELUCIDAÇÃO')) {
                cls = 'bg-info text-dark';
                icon = '↩️';
            }
            if (s.includes('PAUTADO') || s.includes('PAUTA')) {
                cls = 'bg-primary';
                icon = '📅';
            }

            return { class: cls, icon: icon };
        },
        renderStatusCards: function (data, containerId, filterType) {
            const container = document.getElementById(containerId);
            if (!container) return;

            if (!data || data.length === 0) {
                container.innerHTML = '<div class="p-5 text-center text-muted">Nenhuma solicitação encontrada.</div>';
                return;
            }

            // Apply Type Filter if provided
            let filteredRequests = data;
            if (filterType) {
                filteredRequests = data.filter(r => r.Tipo_Solicitacao === filterType);
            }

            // IMPORTANT: For CPG views (Secretaria/Coordenação), filter OUT financial requests
            // Financial requests follow a different workflow: Discente → Docente → CG → Secretaria
            const isCPGView = (App.currentRole === 'Secretaria' || App.currentRole === 'Coordenação') && containerId !== 'financial-requests-container';
            if (isCPGView) {
                filteredRequests = filteredRequests.filter(r => r.Tipo_Solicitacao !== 'Auxílio Financeiro');
            }

            // Group by Status
            const groups = {};
            filteredRequests.forEach(r => {
                const status = r.Status || 'Aguardando Orientador';
                if (!groups[status]) groups[status] = [];
                groups[status].push(r);
            });

            // Define Status Order and Icons (includes both CPG and CG statuses)
            const statusConfig = {
                'Em Pauta': { icon: '📋', text: 'text-purple', style: 'border-left: 5px solid #6f42c1;' },
                'Pautado na CPG': { icon: '📋', text: 'text-purple', style: 'border-left: 5px solid #6f42c1;' },
                'Pautado na CPG (com aval)': { icon: '📋', text: 'text-purple', style: 'border-left: 5px solid #6f42c1;' },
                'Pendente': { icon: '⏳', text: 'text-primary', style: 'border-left: 5px solid #0d6efd;' },
                'Aguardando CG': { icon: '⏳', text: 'text-info', style: 'border-left: 5px solid #0dcaf0;' },
                'Aprovado': { icon: '✅', text: 'text-success', style: 'border-left: 5px solid #198754;' },
                'Aprovado na CPG': { icon: '✅', text: 'text-success', style: 'border-left: 5px solid #198754;' },
                'Aprovado CG': { icon: '✅', text: 'text-success', style: 'border-left: 5px solid #198754;' },
                'Aprovado com Ressalvas': { icon: '⚠️', text: 'text-success', style: 'border-left: 5px solid #198754;' },
                'Rejeitado': { icon: '❌', text: 'text-danger', style: 'border-left: 5px solid #dc3545;' },
                'Reprovado na CPG': { icon: '❌', text: 'text-danger', style: 'border-left: 5px solid #dc3545;' },
                'Rejeitado CG': { icon: '❌', text: 'text-danger', style: 'border-left: 5px solid #dc3545;' },
                'Retornado': { icon: '↩️', text: 'text-warning', style: 'border-left: 5px solid #ffc107;' },
                'Retornado ao Aluno': { icon: '↩️', text: 'text-warning', style: 'border-left: 5px solid #ffc107;' },
                'Aguardando Orientador': { icon: '🕒', text: 'text-warning', style: 'border-left: 5px solid #ffc107;' },
                'Finalizado': { icon: '📦', text: 'text-secondary', style: 'border-left: 5px solid #6c757d;' }
            };

            const statusOrder = ['Em Pauta', 'Pautado na CPG (com aval)', 'Pendente', 'Aprovado na CPG', 'Aprovado com Ressalvas', 'Reprovado na CPG', 'Retornado', 'Aguardando Orientador'];

            const sortedKeys = Object.keys(groups).sort((a, b) => {
                const idxA = statusOrder.indexOf(a);
                const idxB = statusOrder.indexOf(b);
                if (idxA !== -1 && idxB !== -1) return idxA - idxB;
                if (idxA !== -1) return -1;
                if (idxB !== -1) return 1;
                return a.localeCompare(b);
            });

            let html = '<div class="row g-4">';

            sortedKeys.forEach(status => {
                const items = groups[status];
                let conf = statusConfig[status];
                if (!conf) {
                    const key = Object.keys(statusConfig).find(k => status.includes(k));
                    conf = key ? statusConfig[key] : { icon: '📁', text: 'text-secondary', style: 'border-left: 5px solid #6c757d;' };
                }

                const cardsHtml = items.map(r => {
                    let acts = '';
                    const isSec = (App.currentRole === 'Secretaria' || App.currentRole === 'Coordenação');
                    const isDocente = App.currentRole === 'Docente';
                    const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");
                    const statusLower = (r.Status || '').toLowerCase();


                    // Final statuses - no action buttons
                    // EXCEPTION: 'Aprovado CG' is NOT final for Secretariat (needs Accountability or Agenda)
                    // Also include 'Aprovado na CPG' and 'Aprovado com Ressalvas' as valid states for next steps
                    // FIX: Added 'aprovado pela cg' to match backend status "Aprovado pela CG (Aguardando Trâmite da Secretaria)"
                    // FIX: Broadened check to ensure any "Aprovado ... CG/Conselho" status is caught.
                    const isApprovedCG = (statusLower.includes('aprovado') && (statusLower.includes('cg') || statusLower.includes('conselho'))) || statusLower === 'approved_cg' || statusLower.includes('aprovado na cpg') || statusLower.includes('aprovado com ressalvas');
                    const isFinal = (statusLower.includes('aprovado') && !isApprovedCG) || statusLower.includes('rejeitado') || statusLower.includes('reprovado') || statusLower.includes('finalizado');

                    // Em Pauta - only "Analisar" (CPG decision)
                    const isEmPauta = statusLower.includes('em pauta') || statusLower.includes('pautado');

                    // Pre-Pauta statuses: Aguardando Orientador, Pendente, Retornado
                    const isPrePauta = statusLower.includes('aguardando') || statusLower === 'pendente' || statusLower.includes('retornado');

                    if (isSec && !isFinal) {
                        if (isApprovedCG) {
                            // APPROVED BY CG -> Secretariat chooses: Accountability OR Agenda
                            acts = '<div class="mt-2 pt-2 border-top d-grid gap-2">';
                            // Strict check: Accountability only for FINANCIAL requests
                            const isFin = (r.Tipo_Solicitacao || '').toLowerCase().includes('financeiro') || (r.Tipo_Solicitacao || '').toLowerCase().includes('auxílio');

                            if (isFin) {
                                acts += '<button class="btn btn-sm btn-info text-white" onclick="Forms.openPrestacaoContasModal(\'' + reqDataStr + '\'); event.stopPropagation();">📉 Solicitar Prestação de Contas</button>';
                                acts += '<button class="btn btn-sm btn-outline-warning mt-1" onclick="Forms.returnToCG(\'' + r.ID + '\'); event.stopPropagation();">↩️ Devolver p/ CG</button>';
                            }

                            // "Pautar na CPG" available for Approved CG.
                            // BUT NOT if already "Aprovado na CPG" or "Aprovado com Ressalvas" (already passed CPG)
                            const alreadyCPG = statusLower.includes('aprovado na cpg') || statusLower.includes('aprovado com ressalvas') || statusLower.includes('reprovado na cpg');

                            if (!alreadyCPG) {
                                acts += '<button class="btn btn-sm btn-purple" onclick="Forms.sendToAgenda(\'' + r.ID + '\'); event.stopPropagation();">📥 Pautar na CPG</button>';
                            }

                            acts += '</div>';
                        } else if (isEmPauta) {
                            // Only "Analisar CPG" button - opens the detail modal for CPG decision
                            acts = '<div class="mt-2 pt-2 border-top">' +
                                '<button class="btn btn-sm btn-purple w-100" onclick="Forms.openRequestDetailModal(\'' + reqDataStr + '\'); event.stopPropagation();">⚖️ Analisar na CPG</button>' +
                                '</div>';
                        } else if (isPrePauta) {
                            // Pre-pauta: Edit, Pautar (if Pendente), Delete - all open detail modal
                            let buttons = '<button class="btn btn-sm btn-outline-primary flex-grow-1" onclick="Forms.openRequestDetailModal(\'' + reqDataStr + '\'); event.stopPropagation();">📝 Editar</button>';
                            if (statusLower === 'pendente') {
                                buttons += '<button class="btn btn-sm btn-purple" onclick="Forms.sendToAgenda(\'' + r.ID + '\'); event.stopPropagation();">📥 Pautar</button>';
                            }
                            buttons += '<button class="btn btn-sm btn-outline-danger" onclick="Forms.deleteRequest(\'' + r.ID + '\'); event.stopPropagation();">🗑️</button>';
                            acts = '<div class="mt-2 pt-2 border-top d-flex gap-2">' + buttons + '</div>';
                        }
                    } else if (isDocente && (statusLower.includes('aguardando orientador') || statusLower.includes('retornado'))) {
                        // Docente can analyze requests waiting for them
                        acts = '<div class="mt-2 text-end"><button class="btn btn-sm btn-outline-success" onclick="Forms.openRequestDetailModal(\'' + reqDataStr + '\'); event.stopPropagation();">Analisar</button></div>';
                    }

                    return '<div class="list-group-item px-0 py-3 border-0 border-bottom clickable" onclick="Forms.openRequestDetailModal(\'' + reqDataStr + '\')">' +
                        '<div class="d-flex justify-content-between align-items-start">' +
                        '<div>' +
                        '<div class="fw-bold text-dark">' + (r.Nome_Aluno || r.Nome_Solicitante || 'Aluno') + '</div>' +
                        '<div class="text-muted small">Orientador: ' + (r.Nome_Orientador || 'N/A') + '</div>' +
                        '</div>' +
                        '<span class="badge bg-light text-secondary border fw-normal" style="font-size:0.75rem">' + (r.Tipo_Solicitacao || 'Geral') + '</span>' +
                        '</div>' +
                        acts +
                        '</div>';
                }).join('');

                html += '<div class="col-md-6 col-lg-4">' +
                    '<div class="card shadow-sm h-100" style="' + conf.style + '">' +
                    '<div class="card-header bg-white border-0 pt-3 pb-2">' +
                    '<div class="d-flex justify-content-between align-items-center">' +
                    '<h5 class="mb-0 fw-bold ' + conf.text + '">' + conf.icon + ' ' + status + '</h5>' +
                    '<span class="badge rounded-pill bg-light text-dark border">' + items.length + '</span>' +
                    '</div>' +
                    '</div>' +
                    '<div class="card-body pt-0">' +
                    '<div class="list-group list-group-flush">' + cardsHtml + '</div>' +
                    '</div>' +
                    '</div>' +
                    '</div>';
            });

            html += '</div>';
            container.innerHTML = html;
        }
    };

    // =========================================================================
    // AGENDAR DEFESA
    // =========================================================================
    let defesaState = {
        nivel: '', // 'Mestrado' or 'Doutorado'
        articles: [], // { titulo, apa, qualisValido: false, estrato: '' }
        roomType: '', // 'hibrida' or 'propria'
        roomDetails: '',
        title: ''
    };

    Views.renderDefesaView = function () {
        const container = document.getElementById('main-content');

        // Check for existing Defesa request
        const existingReqs = AppState.get('requests') || [];
        const myDefesa = existingReqs.find(r => r.Tipo_Solicitacao === 'Agendamento de Defesa');

        if (myDefesa) {
            Views.renderDefesaStatus(myDefesa);
            return;
        }

        // Reset state when opening
        defesaState = { nivel: App.user.Nivel || '', articles: [], roomType: '', roomDetails: '', title: '' };

        container.innerHTML = `
            <div class="view-section animate-fadeInUp">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="mb-0">🎓 Agendar Defesa</h2>
                        <p class="text-muted mb-0">Requisitos de Agendamento e Reserva de Sala</p>
                    </div>
                </div>
                
                <div id="defesa-wizard-container"></div>
            </div>
        `;

        Views.renderDefesaStep1();
    };

    Views.renderDefesaStatus = function (req) {
        const container = document.getElementById('main-content');
        let details = {};
        try { details = JSON.parse(req.Detalhes || '{}'); } catch (e) { }

        const pdfUrl = details.Declaracao_PDF || '';

        container.innerHTML = `
            <div class="view-section animate-fadeInUp">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="mb-0">🎓 Minha Defesa</h2>
                        <span class="badge bg-primary mt-2 fs-6">Status: ${req.Status}</span>
                    </div>
                </div>
                
                <div class="card border-0 shadow-sm p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Detalhes do Agendamento</h5>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Título do Trabalho</p>
                            <div class="fw-bold fs-5">${details.Titulo || '-'}</div>
                        </div>
                        <div class="col-md-3">
                            <p class="text-muted small mb-1">Data Escolhida</p>
                            <div class="fw-bold fs-5">${details.Data_Defesa || '-'}</div>
                        </div>
                        <div class="col-md-3">
                            <p class="text-muted small mb-1">Horário</p>
                            <div class="fw-bold fs-5">${details.Horario_Defesa || '-'}</div>
                        </div>
                        <div class="col-12 mt-3">
                            <p class="text-muted small mb-1">Local / Sala</p>
                            <div class="fw-bold text-primary fs-5">${details.Local || '-'}</div>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-3 border-top pt-4">
                        ${pdfUrl ? `<a href="${pdfUrl}" target="_blank" class="btn btn-primary shadow"><i class="bi bi-file-earmark-pdf"></i> Imprimir Declaração (PDF)</a>` : ''}
                        <button class="btn btn-outline-warning shadow-sm" onclick="Forms.openDefesaAlterationModal('${req.ID}')"><i class="bi bi-pencil-square"></i> Solicitar Alteração</button>
                    </div>
                </div>
            </div>
        `;
    };

    Forms.openDefesaAlterationModal = function (reqId) {
        const reason = prompt("Informe qual alteração você deseja realizar na sua defesa (Data, Horário, Local, etc) ou observações que a Secretaria deva analisar.");
        if (!reason) return;

        UI.showLoading();
        API.run('requestDefesaChange', [reqId, reason], function (res) {
            UI.hideLoading();
            if (res && res.success) {
                UI.toast("Solicitação envida com sucesso para a Secretaria.", "success");
                setTimeout(App.init, 1500); // Reload entire state to reflect changes
            } else {
                UI.toast("Erro ao solicitar alteração: " + (res ? res.error : ""), "error");
            }
        }, function (err) {
            UI.hideLoading();
            UI.toast("Erro: " + err.message, "error");
        });
    };

    Views.renderDefesaStep1 = function () {
        const container = document.getElementById('defesa-wizard-container');
        // Let user choose Nivel if not preset, or confirm it
        let nivelSelect = `
            <div class="mb-4 p-4 bg-white rounded shadow-sm border">
                <h5>1. Confirme seu Nível</h5>
                <select class="form-select w-auto" id="defesa-nivel" onchange="Forms.updateDefesaNivel(this.value)">
                    <option value="">Selecione...</option>
                    <option value="Mestrado" ${defesaState.nivel === 'Mestrado' ? 'selected' : ''}>Mestrado</option>
                    <option value="Doutorado" ${defesaState.nivel === 'Doutorado' ? 'selected' : ''}>Doutorado</option>
                </select>
            </div>
        `;

        let articlesHtml = '';
        if (defesaState.nivel) {
            const numArticles = defesaState.nivel === 'Doutorado' ? 2 : 1;
            articlesHtml += `<div class="p-4 bg-white rounded shadow-sm border mb-4"><h5>2. Validação de Artigos (Qualis)</h5><p class="text-muted small">Mestrado exige 1 artigo em estrato A1-A4. Doutorado exige 2 artigos nestes estratos.</p>`;

            for (let i = 1; i <= numArticles; i++) {
                let art = defesaState.articles[i - 1] || { titulo: '', apa: '', qualisValido: false, estrato: '', issn: '' };

                articlesHtml += `
                    <div class="card mb-3 border ${art.qualisValido ? 'border-success' : ''}">
                        <div class="card-header ${art.qualisValido ? 'bg-success text-white' : 'bg-light fw-bold'}">Artigo ${i} ${art.qualisValido ? '✅ Verificado' : ''}</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label text-muted small">Referência APA do Artigo *</label>
                                <textarea class="form-control" id="defesa-artigo-${i}-apa" rows="2" ${art.qualisValido ? 'readonly' : ''}>${art.apa}</textarea>
                            </div>
                            <div class="row g-2 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label text-muted small">ISSN do Periódico *</label>
                                    <input type="text" class="form-control" id="defesa-artigo-${i}-issn" placeholder="Ex: 1234-5678" value="${art.issn}" ${art.qualisValido ? 'readonly' : ''}>
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label text-muted small">Título do Periódico para Busca (Opcional se tiver ISSN)</label>
                                    <input type="text" class="form-control" id="defesa-artigo-${i}-titulo" value="${art.titulo}" ${art.qualisValido ? 'readonly' : ''}>
                                </div>
                                <div class="col-md-2">
                                    ${art.qualisValido ?
                        `<button class="btn btn-outline-danger w-100" onclick="Forms.resetDefesaArticle(${i - 1})">Refazer</button>` :
                        `<button class="btn btn-primary w-100" id="btn-validar-artigo-${i}" onclick="Forms.validateDefesaArticle(${i - 1})">Validar</button>`
                    }
                                </div>
                            </div>
                            <div id="defesa-artigo-${i}-result" class="mt-2 text-danger small"></div>
                        </div>
                    </div>
                `;
            }
            articlesHtml += `</div>`;

            // Check if all needed articles are valid
            let allValid = true;
            for (let i = 0; i < numArticles; i++) {
                if (!defesaState.articles[i] || !defesaState.articles[i].qualisValido) allValid = false;
            }

            if (allValid) {
                articlesHtml += `
                    <div class="text-end">
                        <button class="btn btn-success btn-lg px-5 shadow" onclick="Views.renderDefesaStep2()">Continuar para Agendamento ➡️</button>
                    </div>
                `;
            }
        }

        container.innerHTML = nivelSelect + articlesHtml;
    };

    Forms.updateDefesaNivel = function (val) {
        defesaState.nivel = val;
        // Reset articles when changing nivel
        defesaState.articles = [];
        Views.renderDefesaStep1();
    };

    Forms.resetDefesaArticle = function (idx) {
        if (defesaState.articles[idx]) {
            defesaState.articles[idx].qualisValido = false;
            defesaState.articles[idx].estrato = '';
        }
        Views.renderDefesaStep1();
    };

    Forms.validateDefesaArticle = function (idx) {
        const i = idx + 1; // 1-based index for DOM
        const apa = document.getElementById('defesa-artigo-' + i + '-apa').value.trim();
        const issnOrig = document.getElementById('defesa-artigo-' + i + '-issn').value.trim();
        const tituloOrig = document.getElementById('defesa-artigo-' + i + '-titulo').value.trim();
        const resultDiv = document.getElementById('defesa-artigo-' + i + '-result');
        const btn = document.getElementById('btn-validar-artigo-' + i);

        if (!apa || (!issnOrig && !tituloOrig)) {
            resultDiv.innerHTML = "Preencha a referência APA e o ISSN ou Título do periódico para validar.";
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        resultDiv.innerHTML = '<span class="text-muted">Buscando na base Qualis... Pode levar alguns segundos.</span>';

        const filters = {
            issn: issnOrig,
            titulo: tituloOrig,
            areaAvaliacao: '',
            estrato: '',
            evento: '' // Will match anywhere
        };

        API.searchQualisPeriodicos(filters, function (res) {
            btn.disabled = false;
            btn.innerHTML = 'Validar';
            if (res && res.success && res.results.length > 0) {
                // Check if any returned result is A1, A2, A3, A4
                let validStrata = ['A1', 'A2', 'A3', 'A4'];
                let bestMatch = null;
                for (let match of res.results) {
                    if (validStrata.includes(match.estrato)) {
                        bestMatch = match;
                        break;
                    }
                }

                if (bestMatch) {
                    resultDiv.innerHTML = '<span class="text-success fw-bold">Periódico Validado! Encontrado <strong>' + bestMatch.titulo + '</strong> com Qualis <strong>' + bestMatch.estrato + '</strong>.</span>';
                    defesaState.articles[idx] = {
                        apa: apa,
                        issn: issnOrig,
                        titulo: tituloOrig,
                        qualisValido: true,
                        estrato: bestMatch.estrato,
                        periodicoEncontrado: bestMatch.titulo
                    };
                    setTimeout(Views.renderDefesaStep1, 1000);
                } else {
                    let highest = res.results[0].estrato;
                    resultDiv.innerHTML = '<span class="text-danger fw-bold">O periódico encontrado (<strong>' + res.results[0].titulo + '</strong>) possui extrato <strong>' + highest + '</strong>, que não atende aos requisitos (apenas A1 a A4). A defesa não poderá ser agendada.</span>';
                }

            } else {
                resultDiv.innerHTML = '<span class="text-danger fw-bold">Nenhum periódico encontrado. Verifique se o ISSN está correto (ex: 1234-5678).</span>';
            }
        }, function (err) {
            btn.disabled = false;
            btn.innerHTML = 'Validar';
            resultDiv.innerHTML = 'Erro: ' + err.message;
        });
    };

    Views.renderDefesaStep2 = function () {
        const container = document.getElementById('defesa-wizard-container');

        container.innerHTML = `
            <div class="mb-4">
                <button class="btn btn-outline-secondary btn-sm" onclick="Views.renderDefesaStep1()">⬅️ Voltar aos Artigos</button>
            </div>
            
            <div class="p-4 bg-white rounded shadow-sm border mb-4 animate-fadeInUp">
                <h5>3. Informações da Defesa</h5>
                
                <div class="mb-4 mt-3">
                    <label class="form-label fw-bold">Título Exato da Dissertação/Tese *</label>
                    <textarea class="form-control" id="defesa-titulo-trabalho" rows="2" placeholder="Sua declaração será gerada com este título...">${defesaState.title}</textarea>
                </div>

                <h6 class="fw-bold mt-4 border-bottom pb-2">Agendamento de Sala</h6>
                <p class="text-muted small">Verifique a disponibilidade da Sala Híbrida do PPGPsi ou informe uma sala própria.</p>
                
                <div class="mb-4 mt-3 p-3 bg-light rounded border">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="defesaRoomType" id="roomHibrida" value="hibrida" onchange="Views.toggleDefesaRoom()" ${defesaState.roomType === 'hibrida' ? 'checked' : ''}>
                        <label class="form-check-label fw-medium" for="roomHibrida">Utilizar Sala Híbrida PPGPsi "Profª Drª Ana Lúcia Rossito Aiello"</label>
                    </div>
                    <div class="form-check form-check-inline mt-2 mt-md-0">
                        <input class="form-check-input" type="radio" name="defesaRoomType" id="roomPropria" value="propria" onchange="Views.toggleDefesaRoom()" ${defesaState.roomType === 'propria' ? 'checked' : ''}>
                        <label class="form-check-label fw-medium" for="roomPropria">Possuo Sala Própria (Ex: Auditório, Remoto, etc)</label>
                    </div>
                </div>

                <div id="defesa-room-hibrida-container" style="display:none;" class="mt-3">
                    <p class="text-info small mb-3"><strong>Atenção:</strong> As defesas ocorrem em dias úteis nos períodos: Matutino (08h às 12h), Vespertino (13h às 17h) ou Noturno (18h às 22h).</p>
                    <div class="ratio ratio-16x9 mb-4 border rounded shadow-sm" style="min-height:500px; max-height: 600px;">
                        <iframe src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FSao_Paulo&showPrint=0&showTabs=0&showCalendars=0&showTz=0&title=Disponibilidade%20-%20Sala%20H%C3%ADbrida&src=dWZzY2FyLmJyX2NsYXNzcm9vbTIzMDUzZTU5QGdyb3VwLmNhbGVuZGFyLmdvb2dsZS5jb20&color=%237986CB" style="border: 0" width="100%" height="600" frameborder="0" scrolling="no"></iframe>
                    </div>
                    <div class="row g-3 bg-light p-3 rounded border">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Data Escolhida para Reserva *</label>
                            <input type="date" class="form-control" id="defesa-data">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Período *</label>
                            <select class="form-select" id="defesa-periodo">
                                <option value="">Selecione...</option>
                                <option value="Matutino (08h às 12h)">Matutino (08h às 12h)</option>
                                <option value="Vespertino (13h às 17h)">Vespertino (13h às 17h)</option>
                                <option value="Noturno (18h às 22h)">Noturno (18h às 22h)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div id="defesa-room-propria-container" style="display:none;" class="mt-3 p-4 bg-light border rounded">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Qual sala foi reservada e onde? *</label>
                        <input type="text" class="form-control" id="defesa-sala-propria-detalhes" placeholder="Ex: Auditório do CCHB, Link do Google Meet..." value="${defesaState.roomDetails}">
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Data da Defesa *</label>
                            <input type="date" class="form-control" id="defesa-data-propria">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Horário (Ex: 14:00) *</label>
                            <input type="time" class="form-control" id="defesa-hora-propria">
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end" id="btn-finalizar-defesa-container" style="display:none;">
                    <button class="btn btn-success btn-lg px-5 shadow" id="btn-finalizar-defesa" onclick="Forms.submitDefesa()">Concluir Agendamento ✅</button>
                </div>
            </div>
        `;
        Views.toggleDefesaRoom();
    };

    Views.toggleDefesaRoom = function () {
        const typeRadios = document.getElementsByName('defesaRoomType');
        let type = '';
        for (let r of typeRadios) if (r.checked) type = r.value;
        defesaState.roomType = type;

        // Persist title
        const tc = document.getElementById('defesa-titulo-trabalho');
        if (tc) defesaState.title = tc.value;

        const hibridaContainer = document.getElementById('defesa-room-hibrida-container');
        const propriaContainer = document.getElementById('defesa-room-propria-container');
        const finalBtn = document.getElementById('btn-finalizar-defesa-container');

        if (hibridaContainer) hibridaContainer.style.display = (type === 'hibrida') ? 'block' : 'none';
        if (propriaContainer) propriaContainer.style.display = (type === 'propria') ? 'block' : 'none';
        if (finalBtn) finalBtn.style.display = (type !== '') ? 'block' : 'none';
    };

    Forms.submitDefesa = function () {
        // Retrieve title before validation
        defesaState.title = document.getElementById('defesa-titulo-trabalho').value.trim();

        if (!defesaState.title) return UI.toast("Informe o título da dissertação/tese.", "warning");

        let roomData = {};
        if (defesaState.roomType === 'hibrida') {
            const date = document.getElementById('defesa-data').value;
            const period = document.getElementById('defesa-periodo').value;
            if (!date || !period) return UI.toast("Informe data e período para a Sala Híbrida.", "warning");
            roomData = {
                Local: 'Sala Híbrida PPGPsi "Profª Drª Ana Lúcia Rossito Aiello"',
                Data: date,
                Horario: period
            };
        } else {
            const details = document.getElementById('defesa-sala-propria-detalhes').value.trim();
            const date = document.getElementById('defesa-data-propria').value;
            const time = document.getElementById('defesa-hora-propria').value;
            if (!details || !date || !time) return UI.toast("Preencha todos os detalhes da sala própria.", "warning");
            roomData = {
                Local: details,
                Data: date,
                Horario: time
            };
        }

        const btn = document.getElementById('btn-finalizar-defesa');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Registrando...';

        const payload = {
            tipo: 'DEFESA',
            nivel: defesaState.nivel,
            titulo: defesaState.title,
            artigos: defesaState.articles, // Sent for PDF generation
            local: roomData.Local,
            data_defesa: roomData.Data,
            horario_defesa: roomData.Horario
        };

        API.run('submitDefesa', [payload],
            function (res) {
                if (res && res.success) {
                    UI.toast("Agendamento concluído com sucesso!", "success");
                    Views.renderDefesaSuccess(res.pdfUrl);
                } else {
                    btn.disabled = false;
                    btn.innerHTML = 'Concluir Agendamento ✅';
                    UI.toast(res ? res.error : "Erro ao agendar.", "error");
                }
            },
            function (err) {
                btn.disabled = false;
                btn.innerHTML = 'Concluir Agendamento ✅';
                UI.toast("Erro de conexão: " + err.message, "error");
            }
        );
    };

    Views.renderDefesaSuccess = function (pdfUrl) {
        const container = document.getElementById('defesa-wizard-container');
        container.innerHTML = `
            <div class="alert alert-success mt-4 p-5 text-center shadow-sm animate-fadeInUp">
                <div class="mb-3"><span style="font-size: 4rem;">🎉</span></div>
                <h3 class="fw-bold mb-3">Defesa Agendada com Sucesso!</h3>
                <p class="fs-5 text-muted">A <strong>Declaração de Agendamento</strong> foi gerada em formato PDF.</p>
                
                <div class="mt-4 d-flex justify-content-center gap-3">
                    <a href="${pdfUrl || '#'}" target="_blank" class="btn btn-primary btn-lg px-4"><span class="fs-5 me-2">📄</span> Baixar Declaração</a>
                    <button class="btn btn-outline-secondary btn-lg" onclick="App.init()">Voltar ao Início</button>
                </div>
            </div>
         `;
    };

