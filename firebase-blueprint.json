        // =========================================================================
        // MURAL DA COMUNIDADE
        // =========================================================================
        renderMural: function () {
            const container = document.getElementById('main-content');
            container.innerHTML = `
            <div class="view-section">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <button class="btn btn-link text-decoration-none ps-0" onclick="UI.renderView()">&larr; Voltar</button>
                        <h2 class="d-inline-block align-middle ms-2">📢 Mural da Comunidade PPGPsi</h2>
                    </div>
                </div>
                
                <!-- New Post Form -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex gap-3">
                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" 
                                 style="width:50px; height:50px; flex-shrink:0">
                                ${App.user && App.user.nome ? App.user.nome.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div class="flex-grow-1">
                                <textarea id="mural-post-content" class="form-control border-0 bg-light" 
                                          rows="3" placeholder="Compartilhe algo com a comunidade..."></textarea>
