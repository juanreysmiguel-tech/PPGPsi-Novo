                            <td>${r.Tipo_Solicitacao}</td>
                            <td><strong>R$ ${valor}</strong></td>
                            <td><span class="badge bg-${statusColor}">${r.Status}</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" 
                                    onclick="Forms.openRequestDetailModal('${encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27")}')">
                                    Ver Detalhes
