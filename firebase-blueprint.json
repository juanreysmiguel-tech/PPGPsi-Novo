        openCGParecerModal: function (reqDataStr) {
            try {
                const req = JSON.parse(decodeURIComponent(reqDataStr));
                let details = {};
                try { details = JSON.parse(req.Detalhes || '{}'); } catch (e) { }

                // Prepare values
                // Prepare values
                const valorSolicitado = details['Valor Solicitado (R$)'] ||
                    details['Valor do Auxílio'] ||
                    details['Valor do Aux\u00EDlio'] ||
                    details['valor'] ||
                    '0,00';

                // Build CAPES Side-by-Side HTML
                let capesHtml = '';
                // Use ALL fields (except main heading/info if desired, but user said "completo", so let's include structure)
                // Actually, structure headings are useful.

                CAPES_FIELDS.forEach((field, index) => {
                    // Logic to retrieve student answer
                    // Check first if saved as individual field
                    let studentVal = details[field.label] || details[field.id] || '';

                    // FIX: Check in the grouped array 'Diretrizes_CAPES' (with underscore)
                    // This is how checkboxes are saved in submitRequest() line 3909
                    const diretrizesArray = details['Diretrizes_CAPES'] || details['Diretrizes CAPES'] || [];

                    // Check if field.label is in the array (for checkbox items)
                    let isInDiretrizesArray = false;
                    if (Array.isArray(diretrizesArray)) {
                        isInDiretrizesArray = diretrizesArray.some(item =>
                            item === field.label ||
                            (typeof item === 'string' && item.includes(field.label))
                        );
                    } else if (typeof diretrizesArray === 'string') {
                        isInDiretrizesArray = diretrizesArray.includes(field.label);
                    }

                    if (isInDiretrizesArray) {
                        studentVal = 'Sim';
                    }

                    const isCheckedStudent = studentVal === 'Sim' || studentVal === 'true' || studentVal === true || isInDiretrizesArray;

                    // Generate Unique ID for CG Input
                    const cgInputId = field.id ? `cg-capes-${field.id}` : `cg-capes-${index}`;

                    if (field.type === 'heading') {
                        capesHtml += `
                            <div class="row bg-light py-2 mt-2 border-top border-bottom">
                                <div class="col-12 fw-bold text-primary">${field.label}</div>
                            </div>`;
                    } else if (field.type === 'info') {
                        // Skip info for cleaner view or include? User said "completo".
                        // Info is usually instructions. Let's skip to save space unless critical.
                        // But Mirror view: maybe just one info block?
                        // Let's skip instructions to focus on items.
                    } else if (field.type === 'checkbox') {
                        capesHtml += `
                            <div class="row py-2 border-bottom align-items-center">
                                <!-- LEFT: Student -->
                                <div class="col-md-6 border-end bg-light bg-opacity-10">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" disabled ${isCheckedStudent ? 'checked' : ''}>
                                        <label class="form-check-label text-muted small ${isCheckedStudent ? 'fw-bold text-dark' : ''}">${field.label}</label>
                                    </div>
                                </div>
                                <!-- RIGHT: CG (Selection - same field for reviewer to check) -->
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input cg-capes-input" type="checkbox" id="${cgInputId}" data-label="${field.label}" value="Sim">
                                        <label class="form-check-label small" for="${cgInputId}">${field.label}</label>
                                    </div>
                                </div>
                            </div>`;
                    } else if (field.type === 'textarea' || field.type === 'text') {
                        capesHtml += `
                            <div class="row py-2 border-bottom">
                                <!-- LEFT: Student -->
                                <div class="col-md-6 border-end bg-light bg-opacity-10">
                                    <label class="small fw-bold text-muted mb-1">${field.label}</label>
                                    <div class="p-2 border rounded bg-white text-break small">${studentVal || '<em class="text-muted">Não preenchido</em>'}</div>
                                </div>
                                <!-- RIGHT: CG (Comment/Validation) -->
                                <div class="col-md-6">
                                    <label class="small fw-bold text-primary mb-1">Parecer / Observação do CG</label>
                                    <textarea class="form-control form-control-sm cg-capes-input" id="${cgInputId}" data-label="${field.label}" rows="2" placeholder="Digite analise sobre este item..."></textarea>
                                </div>
                            </div>`;
                    }
                });

                const modalHtml = `
            <div class="modal fade" id="modalCGParecer" tabindex="-1">
               <div class="modal-dialog modal-xl modal-dialog-scrollable">
                  <div class="modal-content border-0 shadow-lg">
                     <div class="modal-header bg-warning text-dark">
                        <div>
                            <h5 class="modal-title fw-bold">⚖️ Parecer do Conselho de Gestão (CG)</h5>
                            <small>${req.Nome_Aluno || 'Aluno'} | ${req.Tipo_Solicitacao}</small>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                     </div>
                     <div class="modal-body bg-light">
                        
                        <!-- 1. Value Validation Section -->
                        <div class="card mb-3 border-primary">
                            <div class="card-header bg-white fw-bold text-primary d-flex justify-content-between align-items-center">
                                <span>💰 Validação Financeira</span>
                                <span class="badge bg-primary fs-6">Solicitado: R$ ${valorSolicitado}</span>
                            </div>
                            <div class="card-body">
                                <label class="form-label fw-bold">Decisão sobre o Valor:</label>
                                <div class="d-flex gap-4 align-items-center flex-wrap">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="cg-value-decision" id="val-approve" value="approve" checked onchange="document.getElementById('cg-new-value-box').style.display='none'">
                                        <label class="form-check-label fw-bold" for="val-approve">
                                            Aprovar Valor Solicitado (R$ ${valorSolicitado})
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="cg-value-decision" id="val-change" value="change" onchange="document.getElementById('cg-new-value-box').style.display='block'">
                                        <label class="form-check-label fw-bold text-danger" for="val-change">
                                            Aprovar Outro Valor
                                        </label>
                                    </div>
                                </div>
                                
                                <div id="cg-new-value-box" class="mt-3 p-3 bg-white border rounded" style="display:none; max-width: 300px;">
                                    <label class="form-label small text-muted">Novo Valor Aprovado (R$)</label>
                                    <input type="number" class="form-control" id="cg-new-value" placeholder="0.00">
                                </div>
                            </div>
                        </div>

                        <!-- 2. Side-by-Side Review -->
                        <div class="card mb-3">
                            <div class="card-header bg-white fw-bold">
                                📋 Conferência das Diretrizes CAPES
                            </div>
                            <div class="card-body p-0">
                                <div class="row g-0 bg-secondary bg-opacity-25 py-2 px-3 fw-bold border-bottom">
                                    <div class="col-md-6 border-end">Preenchimento do Aluno</div>
                                    <div class="col-md-6 ps-3">Avaliação do Conselho (CG)</div>
                                </div>
                                <div class="px-3 pb-3">
                                    ${capesHtml}
                                </div>
                            </div>
                        </div>

                        <!-- 3. Final Opinion -->
                        <div class="card">
                            <div class="card-header bg-white fw-bold">
                                📝 Parecer Descritivo Final (Opcional)
                            </div>
                            <div class="card-body">
                                <textarea class="form-control" id="cg-final-comment" rows="3" placeholder="Insira observações gerais, justificativas para alteração de valor ou motivos para recusa..."></textarea>
                            </div>
                        </div>

                     </div>
                     <div class="modal-footer bg-white shadow-top">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <div class="vr mx-2"></div>
                        <button type="button" class="btn btn-outline-info" onclick="Forms.submitCGParecer('${req.ID}', 'info')">❓ Pedir Elucidação</button>
                        <button type="button" class="btn btn-outline-danger" onclick="Forms.submitCGParecer('${req.ID}', 'recusar')">✕ Negar Pedido</button>
                        <button type="button" class="btn btn-success px-4" onclick="Forms.submitCGParecer('${req.ID}', 'aprovar', '${valorSolicitado}')">
                            ✓ Aprovar Pedido
                        </button>
                     </div>
                  </div>
               </div>
            </div>`;

                // Remove old
                const old = document.getElementById('modalCGParecer');
                if (old) old.remove();

                document.body.insertAdjacentHTML('beforeend', modalHtml);
                new bootstrap.Modal(document.getElementById('modalCGParecer')).show();

            } catch (e) {
                console.error(e);
                UI.toast('Erro ao abrir parecer: ' + e.message, 'error');
            }
        },

        submitCGParecer: function (requestId, action, originalValue) {
            let newStatus = '';
            let justificativa = document.getElementById('cg-final-comment')?.value || '';
            let finalValue = originalValue; // Default to requested
            let confirmMsg = '';

            const processParecer = function () {
                // Gather CAPES Analysis Data (Mirrored Form)
                const capesAnalysis = {};
                const capesInputs = document.querySelectorAll('.cg-capes-input');

                if (capesInputs.length > 0) {
                    capesInputs.forEach(input => {
                        // Checkboxes are only relevant if checked
                        if (input.type === 'checkbox') {
                            if (input.checked) {
                                capesAnalysis[input.dataset.label] = "Pertinente/Sim";
                            }
                        } else {
                            // Textareas/Text - save if not empty
                            if (input.value && input.value.trim() !== '') {
                                capesAnalysis[input.dataset.label] = input.value.trim();
                            }
                        }
                    });
                }

                // Prepare Payload
                const payload = {
                    requestId: requestId,
                    action: action,
                    status: newStatus,
                    justification: justificativa,
                    approvedValue: finalValue,
                    capesAnalysis: capesAnalysis
                };

                UI.showLoading(true, 'Registrando parecer...');

                google.script.run
                    .withSuccessHandler(() => {
                        UI.showLoading(false);
                        bootstrap.Modal.getInstance(document.getElementById('modalCGParecer')).hide();
                        UI.toast('Parecer registrado com sucesso!', 'success');
                        Views.renderCGParecerView();
                    })
                    .withFailureHandler((e) => UI.toast('Erro: ' + e.message, 'error'))
                    .processCGParecer(payload);
            };

            // Gather Data
            if (action === 'aprovar') {
                newStatus = 'APPROVED_CG';

                // Check Value Decision
                const valDecision = document.querySelector('input[name="cg-value-decision"]:checked')?.value;
                if (valDecision === 'change') {
                    const changedVal = document.getElementById('cg-new-value')?.value;
                    if (!changedVal || parseFloat(changedVal) <= 0) {
                        UI.alert('Por favor, informe o novo valor aprovado.');
                        return;
                    }
                    finalValue = changedVal;
                    justificativa = `(Valor Alterado pelo CG para R$ ${finalValue}) \n` + justificativa;
                }

                if (!justificativa) justificativa = 'Parecer favorável da CG.';
                confirmMsg = 'Confirma a APROVAÇÃO deste auxílio?';

            } else if (action === 'recusar') {
                if (!justificativa) {
                    UI.alert({
                        title: 'Justificativa Necessária',
                        message: 'Para recusar, é necessário informar o motivo no campo de Parecer.'
                    });
                    return;
                }
                newStatus = 'REJECTED';
                confirmMsg = 'Confirma a RECUSA deste pedido?';

            } else if (action === 'info') {
                if (!justificativa) {
                    UI.alert('Informe o que precisa ser elucidado no campo de Parecer.');
                    return;
                }
                newStatus = 'PENDING_INFO';
            }

            if (confirmMsg) {
                UI.confirm({
                    message: confirmMsg,
                    type: action === 'recusar' ? 'danger' : 'primary', // Red for rejection
                    onConfirm: processParecer
                });
            } else {
                // Info action doesn't strictly need confirmation if user is just asking for info, but keeping it direct is fine.
                processParecer();
            }
        },

        // --- SECRETARIA ACTION MODAL ---
        // Current request being edited by Secretaria
        _currentSecRequest: null,
        _currentSecDetails: null,

        openSecretariaActionModal: function (encodedData) {
            try {
                const req = JSON.parse(decodeURIComponent(encodedData));
                let details = {};
                try { details = JSON.parse(req.Detalhes || '{}'); } catch (e) { }

                // Store for later use
                Forms._currentSecRequest = req;
                Forms._currentSecDetails = details;

                // Build editable fields from details
                const excludeKeys = ['ID_Reuniao', 'Data_Criacao', '__metadata', 'Parecer_CG_Capes'];

                // Helper function to format values for display/edit
                const formatValueForEdit = (val) => {
                    if (val === null || val === undefined) return '';
                    if (typeof val === 'object') {
                        if (Array.isArray(val)) return val.join(', ');
                        return JSON.stringify(val);
                    }
                    return String(val);
                };

                let editableFieldsHtml = Object.entries(details)
                    .filter(([key]) => !excludeKeys.includes(key))
                    .map(([key, value]) => {
                        const valueStr = formatValueForEdit(value);
                        const isLongText = valueStr.length > 100;
                        const isFile = valueStr.includes('drive.google.com') || valueStr.startsWith('Arquivo:');

                        if (isFile) {
                            return `
                            <div class="col-md-6 mb-3">
                                <label class="form-label small text-muted">${key}</label>
                                <div class="input-group">
                                    <input type="text" class="form-control form-control-sm" data-field="${key}" value="${valueStr}" readonly>
                                    <a href="${valueStr.replace('Arquivo: ', '')}" target="_blank" class="btn btn-outline-primary btn-sm">📎</a>
                                </div>
                            </div>`;
                        }

                        return isLongText ? `
                            <div class="col-12 mb-3">
                                <label class="form-label small text-muted">${key}</label>
                                <textarea class="form-control form-control-sm sec-editable-field" data-field="${key}" rows="3">${valueStr}</textarea>
                            </div>` : `
                            <div class="col-md-6 mb-3">
                                <label class="form-label small text-muted">${key}</label>
                                <input type="text" class="form-control form-control-sm sec-editable-field" data-field="${key}" value="${valueStr}">
                            </div>`;
                    }).join('');

                // Add CG Parecer section if exists (read-only, highlighted)
                if (details['Parecer_CG_Capes']) {
                    const parecer = details['Parecer_CG_Capes'];
                    const items = typeof parecer === 'object' ? Object.entries(parecer) : [];
                    if (items.length > 0) {
                        editableFieldsHtml += `
                            <div class="col-12 mb-3">
                                <div class="card border-success">
                                    <div class="card-header bg-success bg-opacity-10 py-2">
                                        <span class="fw-bold text-success">✅ Parecer CG - Análise Técnica</span>
                                    </div>
                                    <div class="card-body py-2">
                                        ${items.map(([label, val]) => {
                            const isComment = val && String(val).length > 20;
                            if (isComment) {
                                return `<div class="alert alert-primary mb-2"><strong>📝 Observação:</strong><br>${val}</div>`;
                            }
                            return `<span class="badge bg-success me-1 mb-1">${label}</span>`;
                        }).join('')}
                                    </div>
                                </div>
                            </div>`;
                    }
                }

                const modalHtml = `
                <div class="modal fade" id="modalSecretaria" tabindex="-1">
                   <div class="modal-dialog modal-xl modal-dialog-scrollable">
                      <div class="modal-content border-0 shadow-lg">
                         <div class="modal-header bg-primary text-white">
                            <div>
                               <h5 class="modal-title">📋 Análise CPG: ${req.Tipo_Solicitacao || 'Solicitação'}</h5>
                               <small class="opacity-75">${req.Nome_Aluno || req.ID_Usuario} | Status: ${req.Status}</small>
                            </div>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                         </div>
                         <div class="modal-body">
                            <!-- Return Actions Bar -->
                            <div class="alert alert-light border d-flex justify-content-between align-items-center mb-4">
                                <span class="text-muted">Retornar solicitação para correção/complementação:</span>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-warning btn-sm" onclick="Forms.returnRequest('${req.ID}', 'orientador')">
                                        ↩️ Retornar para Orientador
                                    </button>
                                    <button class="btn btn-outline-info btn-sm" onclick="Forms.returnRequest('${req.ID}', 'aluno')">
                                        ↩️ Retornar para Aluno
                                    </button>
                                </div>
                            </div>

                            <!-- Editable Fields Section -->
                            <div class="card mb-4">
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">📝 Dados da Solicitação</h6>
                                    <small class="text-muted">Campos são editáveis pela Secretaria</small>
                                </div>
                                <div class="card-body">
                                    <div class="row" id="sec-editable-fields-container">
                                        ${editableFieldsHtml || '<div class="text-muted">Nenhum campo para editar.</div>'}
                                    </div>
                                </div>
                            </div>

                            <!-- Decision Section -->
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">⚖️ Decisão da CPG</h6>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex gap-2 flex-wrap mb-4">
                                       <button class="btn btn-success btn-lg flex-fill" onclick="Forms.setSecAction('Aprovar')">
                                          ✓ Aprovar na CPG
                                       </button>
                                       <button class="btn btn-warning btn-lg flex-fill" onclick="Forms.setSecAction('Editar')">
                                          ✏️ Aprovar com Ressalvas
                                       </button>
                                       <button class="btn btn-danger btn-lg flex-fill" onclick="Forms.setSecAction('Reprovar')">
                                          ✗ Reprovar na CPG
                                       </button>
                                    </div>
                                    
                                    <!-- Step 2: Details (hidden initially) -->
                                    <div id="sec-step-2" style="display:none">
                                       <div class="alert alert-secondary" id="sec-action-preview"></div>
                                       
                                       <div class="mb-3">
                                          <label class="form-label fw-bold">Justificativa da Decisão</label>
                                          <textarea class="form-control" id="sec-justif" rows="3" placeholder="Justificativa..."></textarea>
                                       </div>
                                       
                                       <hr>
                                       
                                       <!-- Ata Option -->
                                       <div class="row">
                                           <div class="col-md-6 mb-3">
                                              <label class="form-label fw-bold">Inserir observação na Ata?</label>
                                              <div class="form-check form-check-inline">
                                                 <input class="form-check-input" type="radio" name="sec-ata" id="sec-ata-no" value="no" checked onchange="Forms.toggleAtaField()">
                                                 <label class="form-check-label" for="sec-ata-no">Não</label>
                                              </div>
                                              <div class="form-check form-check-inline">
                                                 <input class="form-check-input" type="radio" name="sec-ata" id="sec-ata-yes" value="yes" onchange="Forms.toggleAtaField()">
                                                 <label class="form-check-label" for="sec-ata-yes">Sim</label>
                                              </div>
                                              <div id="sec-ata-container" style="display:none" class="mt-2">
                                                 <textarea class="form-control form-control-sm" id="sec-ata-obs" rows="2" placeholder="Observação para a Ata..."></textarea>
                                              </div>
                                           </div>
                                           
                                           <!-- Additional Info Option -->
                                           <div class="col-md-6 mb-3">
                                              <label class="form-label fw-bold">Enviar info para aluno/orientador?</label>
                                              <div class="form-check form-check-inline">
                                                 <input class="form-check-input" type="radio" name="sec-info" id="sec-info-no" value="no" checked onchange="Forms.toggleInfoField()">
                                                 <label class="form-check-label" for="sec-info-no">Não</label>
                                              </div>
                                              <div class="form-check form-check-inline">
                                                 <input class="form-check-input" type="radio" name="sec-info" id="sec-info-yes" value="yes" onchange="Forms.toggleInfoField()">
                                                 <label class="form-check-label" for="sec-info-yes">Sim</label>
                                              </div>
                                              <div id="sec-info-container" style="display:none" class="mt-2">
                                                 <textarea class="form-control form-control-sm" id="sec-add-info" rows="2" placeholder="Mensagem adicional..."></textarea>
                                              </div>
                                           </div>
                                       </div>
                                    </div>
                                </div>
                            </div>
                         </div>
                         <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="button" class="btn btn-primary" id="sec-confirm-btn" style="display:none" 
                                    onclick="Forms.submitSecretariaAction('${req.ID}')">
                               ✓ Confirmar Decisão
                            </button>
                         </div>
                      </div>
                   </div>
                </div>`;

                const old = document.getElementById('modalSecretaria');
                if (old) old.remove();

                document.body.insertAdjacentHTML('beforeend', modalHtml);
                Forms._currentSecAction = null;
                new bootstrap.Modal(document.getElementById('modalSecretaria')).show();

            } catch (e) {
                UI.toast('Erro ao abrir modal: ' + e.message, 'error');
            }
        },

        // Return request to Orientador or Aluno
        returnRequest: function (requestId, target) {
            const targetLabel = target === 'orientador' ? 'Orientador' : 'Aluno';
            const reason = prompt(`Motivo para retornar ao ${targetLabel}:`);

            if (reason === null) return; // Cancelled

            const newStatus = target === 'orientador' ? 'Pendente (Retornado ao Orientador)' : 'Pendente (Retornado ao Aluno)';

            UI.showLoading(true, `Retornando para ${targetLabel}...`);

            API.updateRequestStatus(requestId, newStatus, reason, '', function () {
                UI.showLoading(false);
                const modal = document.getElementById('modalSecretaria');
                if (modal) bootstrap.Modal.getInstance(modal)?.hide();
                UI.toast(`Solicitação retornada para ${targetLabel}!`, 'success');
                UI.renderView();
            });
        },

        // Resubmit request back to flow (used by student or advisor)
        resubmitRequest: function (requestId, role) {
            let comment = '';
            let newStatus = '';
            let fileInput = null;

            if (role === 'aluno') {
                comment = document.getElementById('student-correction-comment')?.value || '';
                newStatus = 'Aguardando Orientador';
                fileInput = document.getElementById('student-attachment');
            } else if (role === 'orientador') {
                comment = document.getElementById('advisor-revision-comment')?.value || '';
                newStatus = 'Pautado na CPG (com aval)';
                fileInput = document.getElementById('advisor-attachment');
            }

            if (!comment.trim()) {
                UI.toast('Por favor, adicione um comentário antes de reenviar.', 'warning');
                return;
            }

            UI.showLoading(true, 'Reenviando solicitação...');

            // Check if there's a file to upload
            if (fileInput && fileInput.files && fileInput.files[0]) {
                const file = fileInput.files[0];
                const reader = new FileReader();

                reader.onload = function (e) {
                    const base64Data = e.target.result.split(',')[1];
                    const fileData = {
                        name: file.name,
                        type: file.type,
                        data: base64Data
                    };

                    // Upload file first, then update status
                    google.script.run
                        .withSuccessHandler(function (fileUrl) {
                            // Now update status with file reference in comment
                            const fullComment = comment + '\n\n📎 Anexo: ' + fileUrl;

                            API.updateRequestStatus(requestId, newStatus, fullComment, '', function () {
                                UI.showLoading(false);
                                const modal = document.getElementById('modalRequestDetail');
                                if (modal) bootstrap.Modal.getInstance(modal)?.hide();
                                UI.toast('Solicitação reenviada com sucesso!', 'success');
                                UI.renderView();
                            });
                        })
                        .withFailureHandler(function (err) {
                            UI.showLoading(false);
                            UI.toast('Erro ao enviar anexo: ' + err.message, 'error');
                        })
                        .uploadFile(fileData, requestId);
                };

                reader.readAsDataURL(file);
            } else {
                // No file, just update status
                API.updateRequestStatus(requestId, newStatus, comment, '', function () {
                    UI.showLoading(false);
                    const modal = document.getElementById('modalRequestDetail');
                    if (modal) bootstrap.Modal.getInstance(modal)?.hide();
                    UI.toast('Solicitação reenviada com sucesso!', 'success');
                    UI.renderView();
                });
            }
        },

        // Return to Student (used by advisor)
        returnToStudent: function (requestId) {
            const reason = prompt('Motivo para devolver ao aluno:');
            if (reason === null) return;

            UI.showLoading(true, 'Devolvendo ao aluno...');

            API.updateRequestStatus(requestId, 'Pendente (Retornado ao Aluno)', reason, '', function () {
                UI.showLoading(false);
                UI.toast('Solicitação devolvida ao aluno!', 'success');
                UI.renderView();
            });
        },

        _currentSecAction: null,

        setSecAction: function (action) {
            Forms._currentSecAction = action;

            // Show step 2 (decision details)
            document.getElementById('sec-step-2').style.display = 'block';
            document.getElementById('sec-confirm-btn').style.display = 'block';

            // Set preview text
            const previewTexts = {
                'Aprovar': '✓ Ação: <strong>APROVADO NA CPG</strong> - Aluno e orientador serão notificados da aprovação.',
                'Editar': '✏️ Ação: <strong>APROVADO COM RESSALVAS</strong> - Os campos editados acima serão salvos. Aluno e orientador serão notificados.',
                'Reprovar': '✗ Ação: <strong>REPROVADO NA CPG</strong> - Aluno e orientador serão notificados da reprovação.',
                'AprovarPrestacao': '✓ Ação: <strong>APROVAR PRESTAÇÃO DE CONTAS</strong> - Solicitação avançará para a fase de Depósito.',
                'ReprovarPrestacao': '✗ Ação: <strong>SOLICITAR AJUSTES</strong> - A Prestação de Contas será devolvida ao Aluno para correção.'
            };
            document.getElementById('sec-action-preview').innerHTML = previewTexts[action];
        },

        toggleAtaField: function () {
            const show = document.getElementById('sec-ata-yes').checked;
            document.getElementById('sec-ata-container').style.display = show ? 'block' : 'none';
        },

        toggleInfoField: function () {
            const show = document.getElementById('sec-info-yes').checked;
            document.getElementById('sec-info-container').style.display = show ? 'block' : 'none';
        },

        submitSecretariaAction: function (requestId, actionParam) {
            // Use passed action parameter OR stored action (from old modal)
            const action = actionParam || Forms._currentSecAction;
            if (!action) {
                UI.toast('Selecione uma ação primeiro', 'error');
                return;
            }

            // Collect all edited field values
            const editedDetails = {};
            document.querySelectorAll('.sec-editable-field').forEach(el => {
                const fieldName = el.getAttribute('data-field');
                if (fieldName) {
                    editedDetails[fieldName] = el.value;
                }
            });

            // Check for values in either cpg-* (new detail modal) or sec-* (old Secretaria modal)
            const justifEl = document.getElementById('cpg-justif') || document.getElementById('sec-justif');
            const ataYesEl = document.getElementById('cpg-ata-yes') || document.getElementById('sec-ata-yes');
            const ataObsEl = document.getElementById('cpg-ata-obs') || document.getElementById('sec-ata-obs');
            const infoYesEl = document.getElementById('cpg-info-yes') || document.getElementById('sec-info-yes');
            const addInfoEl = document.getElementById('cpg-add-info') || document.getElementById('sec-add-info');

            const actionData = {
                requestId: requestId,
                action: action,
                justification: justifEl ? justifEl.value : '',
                editedDetails: editedDetails,
                ataObservation: (ataYesEl && ataYesEl.checked && ataObsEl) ? ataObsEl.value : null,
                additionalInfo: (infoYesEl && infoYesEl.checked && addInfoEl) ? addInfoEl.value : null
            };

            UI.showLoading(true, 'Processando ação CPG...');

            google.script.run
                .withSuccessHandler(function (result) {
                    UI.showLoading(false);
                    // Close whichever modal is open
                    const modalSec = document.getElementById('modalSecretaria');
                    const modalDetail = document.getElementById('modalRequestDetail');
                    if (modalSec) { try { bootstrap.Modal.getInstance(modalSec)?.hide(); } catch (e) { } }
                    if (modalDetail) { try { bootstrap.Modal.getInstance(modalDetail)?.hide(); } catch (e) { } }
                    UI.toast('Ação processada com sucesso! Status: ' + result.newStatus, 'success');
                    UI.renderView();
                })
                .withFailureHandler(function (err) {
                    UI.showLoading(false);
                    UI.toast('Erro: ' + err.message, 'error');
                })
                .processSecretariaAction(actionData);
        },

        // Users
        openUserModal: function (userId = null) {
            // Setup Modal Content
            const isEdit = !!userId;
            let user = { Nome: '', Email: '', Roles: '["Discente"]', Status: 'Ativo' };

            if (isEdit) {
                user = App.cachedUsers.find(u => u.ID === userId);
            }

            // Determine roles array for checkbox checking
            let userRoles = [];
            try { userRoles = JSON.parse(user.Roles); } catch (e) { userRoles = [user.Roles]; }

            const modalHtml = `
      <div class="modal fade" id="modalUser" tabindex="-1">
        <div class="modal-dialog modal-lg">
          <div class="modal-content">
            <div class="modal-header bg-primary text-white">
              <h5 class="modal-title fw-bold">${isEdit ? '✏️ Editar Usuário' : '➕ Novo Usuário'}</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <form id="form-user">
                 <input type="hidden" id="u-id" value="${user.ID || ''}">
                 
                 <!-- Basic Info Section -->
                 <h6 class="text-muted text-uppercase border-bottom pb-2 mb-3">Informações Básicas</h6>
                 <div class="row g-3 mb-4">
                    <div class="col-md-6">
                       <label class="form-label">Nome Completo *</label>
                       <input type="text" class="form-control" id="u-name" value="${user.Nome}" required>
                    </div>
                    <div class="col-md-6">
                       <label class="form-label">Email Institucional *</label>
                       <input type="email" class="form-control" id="u-email" value="${user.Email}" required ${isEdit ? 'readonly' : ''}>
                    </div>
                 </div>
                 
                 <div class="row g-3 mb-4">
                    <div class="col-md-6">
                       <label class="form-label">Perfis (Roles) *</label>
                       <div class="d-flex flex-wrap gap-2">
                          ${['Discente', 'Docente', 'Secretaria', 'Coordenação', 'Conselho'].map(r => `
                            <div class="form-check">
                              <input class="form-check-input" type="checkbox" name="u-role" value="${r}" id="check-${r}" ${userRoles.includes(r) ? 'checked' : ''}>
                              <label class="form-check-label" for="check-${r}">${r}</label>
                            </div>
                          `).join('')}
