                if (!request && App.cachedSecretariaRequests) request = App.cachedSecretariaRequests.find(r => r.ID == requestId); // Fallback
                if (!request && App.cachedPendingRequests) request = App.cachedPendingRequests.find(r => r.ID == requestId);
                if (!request && Views._allRequests) request = Views._allRequests.find(r => r.ID == requestId);
                // Search in Docente raw requests
                if (!request && Views._rawDocenteRequests) request = Views._rawDocenteRequests.find(r => r.ID == requestId);
                if (!request && Views._secFinData) request = Views._secFinData.find(r => r.ID == requestId);
