        renderFinancialDashboard: function () {
            // Route based on Role
            if (App.currentRole === 'Secretaria' || App.currentRole === 'Coordenação' || App.currentRole === 'Conselho') {
                Views.renderSecretariaFinancialDashboard();
                return;
            }

            // Student View
            const container = document.getElementById('main-content');
            container.innerHTML = `
                <div class="view-section">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="mb-0">💰 Meus Auxílios Financeiros</h2>
