                     `;
                });
                tbody.innerHTML = html;
            });
        },

        // --- EXPORT DEPOSITS TO PDF ---
        exportDepositsPDF: function () {
            UI.showLoading(true, 'Gerando PDF...');

            API.getRequests('Secretaria', App.user.id, function (data) {
                try {
                    const { jsPDF } = window.jspdf;
                    const doc = new jsPDF({ orientation: 'landscape' });

                    // Filter for 'Aguardando Depósito'
                    const pending = (data || []).filter(r => (r.Status || '').includes('Aguardando Depósito'));

                    if (pending.length === 0) {
                        UI.showLoading(false);
                        UI.toast('Não há depósitos pendentes para exportar.', 'warning');
                        return;
                    }

                    const today = new Date().toLocaleDateString('pt-BR');

                    // Header
                    doc.setFontSize(18);
                    doc.setFont(undefined, 'bold');
                    doc.text('PPGPsi - UFSCar', 148.5, 15, { align: 'center' });

                    doc.setFontSize(14);
                    doc.setFont(undefined, 'normal');
                    doc.text('Lista de Depósitos Pendentes', 148.5, 23, { align: 'center' });

                    doc.setFontSize(10);
                    doc.setTextColor(100);
                    doc.text('Gerado em: ' + today, 148.5, 30, { align: 'center' });

                    // Instructions box
                    doc.setDrawColor(0, 128, 255);
                    doc.setFillColor(240, 248, 255);
                    doc.roundedRect(14, 35, 269, 25, 3, 3, 'FD');

                    doc.setTextColor(0, 0, 100);
                    doc.setFontSize(9);
                    doc.setFont(undefined, 'bold');
                    doc.text('Instruções:', 18, 42);
                    doc.setFont(undefined, 'normal');
                    doc.text('1. Realize os depósitos/transferências conforme os dados bancários abaixo.', 18, 48);
                    doc.text('2. Guarde os comprovantes de transferência.', 18, 53);
                    doc.text('3. Após realizar o depósito, acesse o sistema e clique em "Confirmar" para cada item. O aluno será notificado por e-mail.', 18, 58);

                    // Build table data
                    const tableData = pending.map(r => {
                        let details = {};
                        try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                        const bank = details.Dados_Bancarios || {};

                        // Get value
                        let valorNum = 0;
                        if (details['Valor Aprovado (R$)']) {
                            valorNum = parseMoneyValue(details['Valor Aprovado (R$)']);
                        } else if (details['Valor Solicitado (R$)']) {
                            valorNum = parseMoneyValue(details['Valor Solicitado (R$)']);
                        } else if (details['valor']) {
                            valorNum = parseMoneyValue(details['valor']);
                        } else if (r.Valor_Solicitado) {
                            valorNum = parseMoneyValue(r.Valor_Solicitado);
                        }

                        const valor = valorNum > 0
                            ? valorNum.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })
                            : '-';

                        let dataStr = '-';
                        try {
                            const d = new Date(r.Data_Solicitacao || r.Data_Criacao);
                            if (!isNaN(d.getTime())) dataStr = d.toLocaleDateString('pt-BR');
                        } catch (e) { }

                        return [
                            r.Nome_Aluno || '-',
                            r.Tipo_Solicitacao || '-',
                            bank.cpf || '-',
                            bank.banco || '-',
                            (bank.agencia || '-') + ' / ' + (bank.conta || '-'),
                            bank.pix || '-',
                            valor,
                            dataStr
                        ];
                    });

                    // Create table
                    doc.autoTable({
                        startY: 65,
                        head: [['Solicitante', 'Tipo', 'CPF', 'Banco', 'Ag / Conta', 'PIX', 'Valor', 'Data']],
                        body: tableData,
                        theme: 'striped',
                        headStyles: {
                            fillColor: [26, 35, 126],
                            textColor: 255,
                            fontStyle: 'bold',
                            fontSize: 9
                        },
                        bodyStyles: { fontSize: 8 },
                        columnStyles: {
                            0: { cellWidth: 45 },
                            1: { cellWidth: 50 },
                            6: { fontStyle: 'bold', halign: 'right' }
                        },
                        margin: { left: 14, right: 14 }
                    });

                    // Footer - Signature line
                    const finalY = doc.lastAutoTable.finalY + 15;
                    doc.setTextColor(0);
                    doc.setFontSize(9);
                    doc.line(14, finalY + 10, 100, finalY + 10);
                    doc.text('Assinatura do Responsável', 14, finalY + 15);
                    doc.text('Data: ____/____/________', 200, finalY + 15);

                    // Save PDF
                    doc.save('depositos_pendentes_' + today.replace(/\//g, '-') + '.pdf');

                    UI.showLoading(false);
                    UI.toast('PDF gerado com sucesso!', 'success');

                } catch (e) {
                    UI.showLoading(false);
                    console.error('Error generating PDF:', e);
                    UI.toast('Erro ao gerar PDF: ' + e.message, 'error');
                }
            });
        },


