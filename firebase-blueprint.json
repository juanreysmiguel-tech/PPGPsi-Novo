                            <div class="card-body text-white p-4">
                                <h6 class="text-uppercase text-white text-opacity-75 mb-2">Próximo Parecerista</h6>
                                <div id="next-parecerista" class="fs-4 fw-bold">Carregando...</div>
                                <small class="text-white text-opacity-75">Próximo a receber parecer</small>
