        // --- DOCENTE DATA LOADING ---
        loadDocenteDashboardData: function () {
            // Load Mural Preview
            google.script.run
                .withSuccessHandler(function (posts) {
                    const container = document.getElementById('mural-preview');
                    if (!container) return;

                    if (!posts || posts.length === 0) {
                        container.innerHTML = '<p class="text-muted text-center mb-0">Nenhuma publicação ainda.</p>';
                        return;
                    }

                    // Show last 2 posts
                    let html = '';
                    posts.slice(0, 2).forEach(function (p) {
                        const date = p.Data_Publicacao ? new Date(p.Data_Publicacao).toLocaleDateString('pt-BR') : '';
                        html += '<div class="border-bottom py-2"><strong>' + (p.Nome_Usuario || '') + '</strong> <small class="text-muted">' + date + '</small><p class="mb-0 small text-truncate">' + (p.Conteudo || '').substring(0, 100) + '...</p></div>';
                    });
                    html += '<div class="text-center mt-2"><button class="btn btn-sm btn-outline-primary" onclick="Views.renderMural()">Ver todas as publicações</button></div>';
                    container.innerHTML = html;
                })
                .getMuralPosts();

            // Load Orientandos
            google.script.run
                .withSuccessHandler(function (orientandos) {
                    console.log('DEBUG orientandos recebidos:', orientandos);
                    console.log('DEBUG quantidade:', orientandos ? orientandos.length : 0);
                    Views.renderOrientandosList(orientandos);
                })
                .withFailureHandler(function (e) {
                    console.error('ERRO ao carregar orientandos:', e);
                    document.getElementById('orientandos-list').innerHTML = '<p class="text-danger p-3">' + e.message + '</p>';
                })
                .getOrientandosAtivos();

            // Load Requests for Docente (Student Requests)
            google.script.run
                .withSuccessHandler(function (requests) {
                    App.cachedDocenteRequests = requests || [];
                    App.docenteActiveCategory = 'academico'; // Default
                    Views.categorizeDocenteRequests(requests || []);
                    Views.filterDocenteRequests('pendentes', document.querySelector('#docente-filters .btn-outline-warning'));
                })
                .withFailureHandler(function (e) {
                    document.getElementById('docente-requests-container').innerHTML = '<p class="text-danger">' + e.message + '</p>';
                })
                .getRequestsForDocente();

            // Load Docente's Own Financial Requests
            google.script.run
                .withSuccessHandler(function (myRequests) {
                    App.cachedDocenteOwnRequests = myRequests || [];
                    const isFinType = (r) => {
                        const tipo = (r.Tipo_Solicitacao || '').toLowerCase();
                        return tipo.includes('auxílio') || tipo.includes('auxilio') || tipo.includes('financeiro') || tipo.includes('reembolso') || tipo.startsWith('fin_');
                    };
                    const myFinancial = myRequests.filter(isFinType);

                    // Update count badge
                    const countEl = document.getElementById('my-requests-count');
                    if (countEl) countEl.textContent = myFinancial.length;

                    // Render in accordion
                    Views.renderDocenteOwnRequests(myFinancial);
                })
                .withFailureHandler(function (e) {
                    const container = document.getElementById('docente-own-requests-content');
                    if (container) container.innerHTML = '<p class="text-danger p-3">' + e.message + '</p>';
                })
                .getRequests('Docente', App.user.id);
        },

        renderOrientandosList: function (orientandos) {
            const container = document.getElementById('orientandos-list');
            if (!container) return;

            if (!orientandos || orientandos.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-4">Nenhum orientando ativo</div>';
                return;
            }

            let html = '<div class="list-group list-group-flush">';
            orientandos.forEach(function (o) {
                const defesa = o.Data_Defesa ? new Date(o.Data_Defesa).toLocaleDateString('pt-BR') : '-';
                const hasPendente = o.hasPendingRequest;

                // Usar encodeURIComponent para evitar problemas com caracteres especiais
                const safeId = encodeURIComponent(o.ID || '');
                const safeName = encodeURIComponent(o.Nome || '');

                html += '<a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" onclick="event.preventDefault(); Views.showOrientandoRequests(decodeURIComponent(\'' + safeId + '\'), decodeURIComponent(\'' + safeName + '\'))">';
                html += '<div>';
                html += '<strong>' + (o.Nome || '-') + '</strong>';
                if (hasPendente) html += ' <span class="badge bg-warning text-dark">⚠️</span>';
                html += '<br><small class="text-muted">Prazo: ' + defesa + '</small>';
                html += '</div>';
                html += '<span class="text-muted">→</span>';
                html += '</a>';
            });
            html += '</div>';
            container.innerHTML = html;
        },

        categorizeDocenteRequests: function (requests) {
            // Define financial type check (substring match for composite names)
            const isFinType = (r) => {
                const tipo = (r.Tipo_Solicitacao || '').toLowerCase();
                return tipo.includes('auxílio') || tipo.includes('auxilio') || tipo.includes('financeiro') || tipo.includes('reembolso') || tipo.startsWith('fin_');
            };

            // Split by category
            const academico = requests.filter(r => !isFinType(r));
            const financeiro = requests.filter(isFinType);

            // Update category tab counts
            const catAcadEl = document.getElementById('cat-count-academico');
            if (catAcadEl) catAcadEl.textContent = academico.length;

            const catFinEl = document.getElementById('cat-count-financeiro');
            if (catFinEl) catFinEl.textContent = financeiro.length;

            // Update status counts for the active category
            Views.updateDocenteStatusCounts();
        },

        // Update status counts based on active category
        updateDocenteStatusCounts: function () {
            const requests = App.cachedDocenteRequests || [];
            const activeCategory = App.docenteActiveCategory || 'academico';

            const isFinType = (r) => {
                const tipo = (r.Tipo_Solicitacao || '').toLowerCase();
                return tipo.includes('auxílio') || tipo.includes('auxilio') || tipo.includes('financeiro') || tipo.includes('reembolso') || tipo.startsWith('fin_');
            };

            // Filter by category first
            const categoryFiltered = activeCategory === 'financeiro'
                ? requests.filter(isFinType)
                : requests.filter(r => !isFinType(r));

            // Count by status
            const counts = { pendentes: 0, aceitos: 0, pautados: 0, recusados: 0 };
            categoryFiltered.forEach(function (r) {
                const status = (r.Status || '').toLowerCase();
                if (status.includes('aguardando orientador')) counts.pendentes++;
                else if (status.includes('aprovado') || status.includes('aceito') || status.includes('com aval') || status.includes('pendente')) counts.aceitos++;
                else if (status.includes('em pauta') || status.includes('pautado')) counts.pautados++;
                else if (status.includes('reprovado') || status.includes('recusado') || status.includes('rejeitado')) counts.recusados++;
            });

            const elPend = document.getElementById('count-pendentes');
            if (elPend) elPend.textContent = counts.pendentes;

            const elAceitos = document.getElementById('count-aceitos');
            if (elAceitos) elAceitos.textContent = counts.aceitos;

            const elPautados = document.getElementById('count-pautados');
            if (elPautados) elPautados.textContent = counts.pautados;

            const elRecusados = document.getElementById('count-recusados');
            if (elRecusados) elRecusados.textContent = counts.recusados;
        },

        // Switch category tab
        switchDocenteCategory: function (category, btn) {
            App.docenteActiveCategory = category;

            // Update tab active states
            document.querySelectorAll('#docenteCategoryTabs .nav-link').forEach(t => t.classList.remove('active'));
            if (btn) btn.classList.add('active');

            // Update status counts for new category
            Views.updateDocenteStatusCounts();

            // Re-apply filter with first status filter (pendentes)
            const defaultFilterBtn = document.querySelector('#docente-filters .btn-outline-warning');
            if (defaultFilterBtn) {
                defaultFilterBtn.classList.add('active');
                document.querySelectorAll('#docente-filters .btn').forEach(b => { if (b !== defaultFilterBtn) b.classList.remove('active'); });
            }
            Views.filterDocenteRequests('pendentes', defaultFilterBtn);
        },

        // Render Docente's own financial requests
        renderDocenteOwnRequests: function (requests) {
            const container = document.getElementById('docente-own-requests-content');
            if (!container) return;

            if (!requests || requests.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-4 text-muted">
                        <div class="fs-1 mb-2">📭</div>
