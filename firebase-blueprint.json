                              </div>
                              <div class="col-12"><hr><h6 class="text-muted">Contato de Emergência</h6></div>
                              <div class="col-md-6">
                                 <label class="form-label">Nome do Contato</label>
                                 <input type="text" class="form-control" id="pd-emerg-nome" value="${u.emergencia_nome || ''}" placeholder="Nome completo">
                              </div>
                              <div class="col-md-6">
                                 <label class="form-label">Telefone de Emergência</label>
                                 <input type="tel" class="form-control" id="pd-emerg-tel" value="${u.emergencia_tel || ''}" placeholder="(XX) XXXXX-XXXX">
                              </div>
                           </div>
                        </form>
                     </div>
                     <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-success px-4" onclick="Forms.savePersonalData()">Salvar</button>
                     </div>
                  </div>
               </div>
            </div>`;

            // Remove old modal if exists
            const old = document.getElementById('modalPersonalData');
            if (old) old.remove();

            document.body.insertAdjacentHTML('beforeend', modalHtml);
            new bootstrap.Modal(document.getElementById('modalPersonalData')).show();
        },

        savePersonalData: function () {
            const data = {
                telefone: document.getElementById('pd-telefone').value,
                celular: document.getElementById('pd-celular').value,
                endereco: document.getElementById('pd-endereco').value,
                emergencia_nome: document.getElementById('pd-emerg-nome').value,
                emergencia_tel: document.getElementById('pd-emerg-tel').value
            };

            UI.showLoading(true, 'Salvando dados...');

            // Call backend to save
            google.script.run
                .withSuccessHandler(function () {
                    UI.showLoading(false);
                    bootstrap.Modal.getInstance(document.getElementById('modalPersonalData')).hide();
                    UI.toast('Dados salvos com sucesso!', 'success');

                    // Update local user data
                    Object.assign(App.user, data);
                    Views.renderHome();
                })
                .withFailureHandler(function (err) {
                    UI.showLoading(false);
                    UI.toast('Erro ao salvar: ' + err.message, 'error');
                })
                .updateUserProfile(data);
        },

