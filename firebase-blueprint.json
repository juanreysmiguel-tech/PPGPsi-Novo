            API.getAllRequests(function (allRequests) {
                // Filter Financial Only (Robust check)
                const financial = allRequests.filter(r => {
                    const tipo = (r.Tipo_Solicitacao || '').toLowerCase();
                    return tipo.includes('auxílio') || tipo.includes('reembolso') || tipo.includes('financeiro') || tipo.startsWith('fin_');
                });

                Views._secFinData = financial;
                Views._calcSecFinStats(financial);
                Views._filterSecFinRequests();
            });
        },

        _calcSecFinStats: function (requests) {
            let grandTotal = 0;
            const typeStats = {};

            requests.forEach(r => {
                const status = (r.Status || '').toUpperCase();
                // Count Approved, Completed, Deposited, and Aprovado CG
                const isApproved = status.includes('APROVADO') || status.includes('CONCLUÍDO') || status.includes('DEPOSITADO') || status.includes('APPROVED');

                if (isApproved) {
                    let details = {};
                    try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                    const val = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);

                    if (!isNaN(val)) {
                        grandTotal += val;

                        // Categorize Type
                        let type = r.Tipo_Solicitacao || 'Outros';
                        // Simplify type names for grouping
                        if (type.includes('Congresso')) type = 'Congresso/Evento';
                        else if (type.includes('Coleta')) type = 'Coleta de Dados';
                        else if (type.includes('Revisão') || type.includes('Tradução')) type = 'Tradução/Revisão';
                        else if (type.includes('Publicação')) type = 'Taxa de Publicação';

                        if (!typeStats[type]) typeStats[type] = { count: 0, total: 0 };
                        typeStats[type].count++;
                        typeStats[type].total += val;
                    }
                }
            });

            // Update UI
            document.getElementById('sec-fin-total').textContent = 'R$ ' + grandTotal.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            const tbody = document.getElementById('sec-fin-breakdown');
            if (Object.keys(typeStats).length === 0) {
                tbody.innerHTML = '<tr><td colspan="3" class="text-center py-4 text-muted">Sem dados aprovados ainda</td></tr>';
            } else {
                tbody.innerHTML = Object.entries(typeStats)
                    .sort((a, b) => b[1].total - a[1].total)
                    .map(([type, stat]) => `
                        <tr>
                            <td class="ps-4 fw-medium">${type}</td>
                            <td class="text-center"><span class="badge bg-light text-dark border">${stat.count}</span></td>
                            <td class="text-end pe-4 fw-bold text-success">R$ ${stat.total.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</td>
                        </tr>
                    `).join('');
            }
        },

        _filterSecFinRequests: function () {
            const requests = Views._secFinData || [];
            const search = (document.getElementById('sec-fin-search')?.value || '').toLowerCase();
            const statusFilter = document.getElementById('sec-fin-filter-status')?.value || 'ALL';

            const filtered = requests.filter(r => {
                const matchesSearch = (r.Nome_Aluno || '').toLowerCase().includes(search) ||
                    (r.Tipo_Solicitacao || '').toLowerCase().includes(search);

                let matchesStatus = true;
                const s = (r.Status || '').toUpperCase();
                if (statusFilter === 'APROVADO') matchesStatus = s.includes('APROVADO') || s.includes('CONCLUÍDO') || s.includes('DEPOSITADO');
                else if (statusFilter === 'PENDENTE') matchesStatus = !s.includes('APROVADO') && !s.includes('CONCLUÍDO') && !s.includes('DEPOSITADO') && !s.includes('REJEITADO');

                return matchesSearch && matchesStatus;
            });

            const listContainer = document.getElementById('sec-fin-list');
            const countEl = document.getElementById('sec-fin-count');
            if (countEl) countEl.textContent = filtered.length + ' registros encontrados';

            if (filtered.length === 0) {
                listContainer.innerHTML = '<div class="text-center py-5 text-muted">Nenhuma solicitação encontrada</div>';
                return;
            }

            listContainer.innerHTML = filtered.slice(0, 50).map(r => {
                let details = {};
                try { details = JSON.parse(r.Detalhes || '{}'); } catch (e) { }
                const val = parseMoneyValue(details['Valor Solicitado (R$)'] || details['valor']);
                const date = r.Data_Criacao ? new Date(r.Data_Criacao).toLocaleDateString('pt-BR') : '-';
                const statusInfo = UIHelpers.getStatusBadgeInfo(r.Status);
                const reqDataStr = encodeURIComponent(JSON.stringify(r)).replace(/'/g, "%27");

                return `
                <div class="list-group-item d-flex justify-content-between align-items-center py-3 clickable-item" onclick="Forms.openRequestDetailModal('${reqDataStr}')">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-light rounded-circle p-2 text-muted">💰</div>
                        <div>
                            <div class="fw-bold text-dark">
                                ${r.Nome_Aluno || 'Aluno Desconhecido'}
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-2 ms-2" style="font-size:0.7rem; font-weight:500">
                                   ${r.Role_Solicitante || 'Externo'}
                                </span>
                            </div>
                            <div class="small text-muted">${r.Tipo_Solicitacao} • ${date}</div>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold text-success">R$ ${val.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</div>
                        <span class="badge ${statusInfo.class} small" style="font-size: 0.75rem;">${r.Status}</span>
                    </div>
                </div>`;
            }).join('');
        }

    };


