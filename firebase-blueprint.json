                        <div class="text-center p-4">
                            <div class="spinner-border text-primary"></div>
                        </div>
                    </div>
                </div>
            </div>`;

            // Load CG stats
            google.script.run
                .withSuccessHandler(function (stats) {
                    Views.renderCGStats(stats);
                })
                .withFailureHandler(function (err) {
                    console.error('Erro ao carregar stats CG:', err);
