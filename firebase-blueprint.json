    App.loadUsers = function () {
        UI.showLoading(true);
        google.script.run
            .withSuccessHandler(function (data) {
                UI.showLoading(false);
                console.log("getAllUsers retornou:", data);
                App.cachedUsers = data || [];
                UIHelpers.renderUsersTable(App.cachedUsers);
            })
            .withFailureHandler(function (error) {
                UI.showLoading(false);
                console.error("Erro em getAllUsers:", error);
                const tbody = document.getElementById('users-table-body');
                if (tbody) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center text-danger">Erro: ${error.message || error}</td></tr>`;
                }
            })
            .getAllUsers();
    };

