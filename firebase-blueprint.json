        handleLoginSendCode: function (btn) {
            const email = document.getElementById('login-email').value.trim();
            if (!email) return UI.toast("Informe seu e-mail.", "warning");

            const originalText = btn.innerHTML;
            btn.innerHTML = 'Enviando...';
            btn.disabled = true;

            API.sendAuthCode(email, function (res) {
                btn.innerHTML = originalText;
                btn.disabled = false;

                if (res && res.success) {
                    document.getElementById('login-step-1').style.display = 'none';
                    document.getElementById('login-step-2').style.display = 'block';
                    document.getElementById('sent-email-display').innerText = email;
                    UI.toast("Código enviado! Verifique seu e-mail.", "success");
                }
            });
        },

        handleLoginVerify: function (btn) {
            const email = document.getElementById('sent-email-display').innerText.trim();
            const code = document.getElementById('login-code').value.trim();
            if (!code || code.length < 6) return UI.toast("Código inválido.", "warning");

            btn.disabled = true;
            btn.innerHTML = 'Verificando...';

            API.verifyAuthCode(email, code, function (res) {
                if (res && res.success && res.token) {
                    Auth.setToken(res.token);
                    UI.toast("Autenticado com sucesso!", "success");
                    setTimeout(function () { App.init(); }, 1000);
                } else {
                    btn.disabled = false;
                    btn.innerHTML = 'Entrar';
                }
            });
        },

        submitRequest: async function () {
            const typeKey = document.getElementById('req-type').value;
            if (!typeKey) return UI.toast("Selecione um tipo de solicitação", "error");

            const config = RequestConfig[typeKey];
            const container = document.getElementById('dynamic-fields-container');
            const inputs = container.querySelectorAll('input, select, textarea');

            let details = {};
            let hasError = false;
            let diretrizesCapesItems = [];

            // Process fields sequentially to handle file reads
            for (let input of inputs) {
                // Skip validation for checkboxes/radios where appropriate
                const isCheckbox = input.type === 'checkbox';
                const isRadio = input.type === 'radio';

                // Skip my internal hidden flags which are handled separately below
                if (input.id === 'edit-mode-flag' || input.id === 'edit-request-id' || input.id === 'edit-original-status') continue;

                // Skip inputs without label (unless checkbox)
                if (!input.dataset.label && !isCheckbox && !isRadio) continue;

                if (isRadio) {
                    if (input.required) {
                        const group = container.querySelectorAll('input[name="' + input.name + '"]');
                        const isAnyChecked = Array.from(group).some(r => r.checked);
                        if (!isAnyChecked) {
                            hasError = true;
                            // Add a visual indicator conceptually to the radio parent, handled safely later
                        }
                    }
                    if (!input.checked) continue; // Skip unchecked radios for payload
                }

                if (!isCheckbox && !isRadio && input.required && !input.value) {
                    input.classList.add('is-invalid');
                    hasError = true;
                } else {
                    input.classList.remove('is-invalid');

                    if (input.type === 'file') {
                        if (input.files.length > 0) {
                            const file = input.files[0];
                            // Limit size example: 5MB
                            if (file.size > 5 * 1024 * 1024) {
                                UI.toast(`Arquivo ${input.dataset.label} muito grande (max 5MB).`, 'error');
                                return;
                            }
                            try {
                                const base64 = await Forms.readFileAsBase64(file);
                                details[input.dataset.label] = {
                                    fileName: file.name,
                                    mimeType: file.type,
                                    content: base64
                                };
                            } catch (e) {
                                UI.toast("Erro ao ler arquivo.", 'error');
                                return;
                            }
                        }
                    } else if (isCheckbox) {
                        // Collect checked CAPES checkboxes
                        if (input.checked && input.id.startsWith('capes-')) {
                            // Get label text from adjacent label
                            const labelEl = container.querySelector('label[for="' + input.id + '"]');
                            if (labelEl) {
                                diretrizesCapesItems.push(labelEl.innerText);
                            }
                        }
                    } else {
                        // Check if field has a calculated "clean" value (numeric) to prioritize
                        if (input.dataset.cleanValue) {
                            details[input.dataset.label] = input.dataset.cleanValue;
                            details[input.dataset.label + ' (Detalhe)'] = input.value; // Save explanation too
                        } else {
                            details[input.dataset.label] = input.value;
                        }
                    }
                }
            }

            // Add CAPES diretrizes as a grouped field
            if (diretrizesCapesItems.length > 0) {
                details['Diretrizes_CAPES'] = diretrizesCapesItems;
            }

            // --- HANDLE EDIT MODE METADATA ---
            const editFlag = document.getElementById('edit-mode-flag');
            if (editFlag && editFlag.value === 'true') {
                details['editMode'] = 'true';
                details['requestId'] = document.getElementById('edit-request-id')?.value;
                details['originalStatus'] = document.getElementById('edit-original-status')?.value;
                console.log("Submitting EDIT logic", details);
            }

            if (hasError) {
                return UI.toast("Preencha todos os campos obrigatórios.", "error");
            }

            UI.showLoading(true);
            const typeName = config.title;

            API.submitRequest(typeName, details, function (resp) {
                UI.showLoading(false);
                bootstrap.Modal.getInstance(document.getElementById('modalRequest')).hide();
                UI.toast(resp.message, 'success');
                UI.renderView();
            });
        },

        readFileAsBase64: function (file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => {
                    // remove inputs like "data:application/pdf;base64,"
                    const content = reader.result.split(',')[1];
                    resolve(content);
                };
                reader.onerror = error => reject(error);
                reader.readAsDataURL(file);
            });
        },

        // --- DEPOSIT MODAL ---
        openConfirmDepositModal: function (requestId, studentName) {
            const body = `
                <div class="text-center mb-4">
                    <div class="fs-1 mb-2">$</div>
                    <h5>Confirmar Deposito</h5>
                    <p class="text-muted">Voce esta prestes a finalizar o pagamento para <strong>${studentName}</strong>.</p>
                </div>
                <form id="form-deposit-confirm">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Comprovante de Deposito (Opcional)</label>
                        <input type="file" class="form-control" id="deposit-receipt-file" accept=".pdf,.jpg,.jpeg,.png,.gif">
                        <div class="form-text">O aluno podera visualizar este comprovante.</div>
                    </div>
                    <div class="alert alert-warning small">
                        A solicitacao sera dada como <strong>Concluida/Finalizada</strong> e o aluno sera notificado.
                    </div>
                </form>
            `;

            Components.Modal.open({
                id: 'modalConfirmDeposit',
                title: 'Confirmar Pagamento',
                body: body,
                footer: `
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success" onclick="Forms.submitDepositConfirmation('${requestId}')">Confirmar Depósito</button>
                `
            });
        },

        submitDepositConfirmation: function (requestId) {
            UI.showLoading(true, "Finalizando solicitação...");
            const fileInput = document.getElementById('deposit-receipt-file');

            if (fileInput && fileInput.files && fileInput.files[0]) {
                const file = fileInput.files[0];
                const reader = new FileReader();
                reader.onload = function (e) {
                    const base64 = e.target.result.split(',')[1];
                    const blob = {
                        name: file.name,
                        type: file.type,
                        data: base64
                    };

                    google.script.run
                        .withSuccessHandler(() => Forms._onDepositSuccess())
                        .withFailureHandler(UI.showError)
                        .confirmDeposit(requestId, blob);
                };
                reader.readAsDataURL(file);
            } else {
                google.script.run
                    .withSuccessHandler(() => Forms._onDepositSuccess())
                    .withFailureHandler(UI.showError)
                    .confirmDeposit(requestId, null);
            }
        },

        _onDepositSuccess: function () {
            UI.showLoading(false);
            const modal = document.getElementById('modalConfirmDeposit');
            if (modal) bootstrap.Modal.getInstance(modal)?.hide();
            UI.toast("Depósito confirmado e solicitação finalizada!", "success");
            Views.renderPendingDepositsView(); // Refresh list
        },

        // --- APROVAR/REPROVAR PRESTAÇÃO DE CONTAS ---
        aprovarPrestacaoContas: function (requestId) {
            Components.Modal.open({
                id: 'modalConfirmApproval',
                title: 'Confirmar Aprovação',
                body: `
                    <div class="text-center mb-3">
                        <div class="fs-1 text-success mb-2">✅</div>
                        <h5>Aprovar Prestação de Contas?</h5>
                        <p class="text-muted">O pedido passará para "Aguardando Depósito" e aparecerá na lista de depósitos pendentes.</p>
                    </div>
                `,
                footer: `
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success" onclick="Forms._executeAprovacao('${requestId}')">Aprovar</button>
                `
            });
        },

        _executeAprovacao: function (requestId) {
            // Close confirmation modal
            const confirmModal = document.getElementById('modalConfirmApproval');
            if (confirmModal) bootstrap.Modal.getInstance(confirmModal)?.hide();

            // Close detail modal if open
            const detailModal = document.getElementById('modalRequestDetail');
            if (detailModal) bootstrap.Modal.getInstance(detailModal)?.hide();

            UI.showLoading(true, 'Aprovando prestação de contas...');
            google.script.run
                .withSuccessHandler(function () {
                    UI.showLoading(false);
                    UI.toast('Prestação de contas aprovada! Aguardando depósito.', 'success');
                    Views.loadSecretariaDashboardData();
                })
                .withFailureHandler(function (e) {
                    UI.showLoading(false);
                    UI.showError(e);
                })
                .processSecretariaAction({ requestId: requestId, action: 'AprovarPrestacao', justification: '' });
        },

        solicitarAjustesPrestacao: function (requestId) {
            Components.Modal.open({
                id: 'modalSolicitarAjustes',
                title: 'Solicitar Ajustes',
                body: `
                    <div class="mb-3">
                        <div class="text-center mb-3">
                            <div class="fs-1 text-warning mb-2">↩️</div>
                            <h5>Solicitar Ajustes na Prestação</h5>
                        </div>
                        <label class="form-label fw-bold">Motivo da solicitação de ajustes:</label>
                        <textarea class="form-control" id="motivo-ajustes" rows="3" placeholder="Descreva o que precisa ser corrigido ou complementado..."></textarea>
                        <div class="form-text">O aluno será notificado e poderá editar a prestação de contas.</div>
                    </div>
                `,
                footer: `
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-warning" onclick="Forms._executeAjustes('${requestId}')">Solicitar Ajustes</button>
                `
            });
        },

        _executeAjustes: function (requestId) {
            const motivo = document.getElementById('motivo-ajustes')?.value?.trim();
            if (!motivo) {
                UI.toast('Informe o motivo da solicitação.', 'warning');
                return;
            }

            // Close modals
            const ajustesModal = document.getElementById('modalSolicitarAjustes');
            if (ajustesModal) bootstrap.Modal.getInstance(ajustesModal)?.hide();
            const detailModal = document.getElementById('modalRequestDetail');
            if (detailModal) bootstrap.Modal.getInstance(detailModal)?.hide();

            UI.showLoading(true, 'Solicitando ajustes...');
            google.script.run
                .withSuccessHandler(function () {
                    UI.showLoading(false);
                    UI.toast('Ajustes solicitados. O aluno será notificado.', 'warning');
                    Views.loadSecretariaDashboardData();
                })
                .withFailureHandler(function (e) {
                    UI.showLoading(false);
                    UI.showError(e);
                })
                .processSecretariaAction({ requestId: requestId, action: 'ReprovarPrestacao', justification: motivo });
        },

        // --- PAUTAR MODAL ---
        openPautarModal: function (requestId) {
            UI.showLoading(true, 'Carregando reuniões...');

            // Fetch available CPG meetings
            API.getMeetings(true, function (meetings) {
                UI.showLoading(false);

                // Filter only future meetings or just show all active
                const futureMeetings = meetings || [];

                let meetingOptions = '<option value="">Selecione uma reunião...</option>';
                if (futureMeetings.length === 0) {
                    meetingOptions += '<option value="" disabled>Nenhuma reunião futura agendada.</option>';
                } else {
                    meetingOptions += futureMeetings.map(m => `
                        <option value="${m.ID}">${new Date(m.Data_Reuniao).toLocaleDateString()} - ${m.Nome}</option>
                     `).join('');
                }

                const modalHtml = `
                <div class="modal fade" id="modalPautar" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-purple text-white">
                                <h5 class="modal-title">📥 Inserir na Pauta</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p>Selecione a reunião da CPG onde este pedido será deliberado:</p>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Reunião CPG</label>
                                    <select class="form-select" id="pauta-meeting-id">
                                        ${meetingOptions}
                                    </select>
                                    <div class="form-text">O pedido ficará com status "Em Pauta" vinculado a esta reunião.</div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                <button type="button" class="btn btn-purple" onclick="Forms.confirmPautar('${requestId}')">
                                    Confirmar Pauta
                                </button>
                            </div>
                        </div>
                    </div>
                </div>`;

                // Remove old
                const old = document.getElementById('modalPautar');
                if (old) old.remove();

                document.body.insertAdjacentHTML('beforeend', modalHtml);
                new bootstrap.Modal(document.getElementById('modalPautar')).show();
            });
        },

        confirmPautar: function (requestId) {
            const meetingId = document.getElementById('pauta-meeting-id').value;
            if (!meetingId) {
                UI.alert('Por favor, selecione uma reunião.');
                return;
            }

            UI.showLoading(true, 'Inserindo na pauta...');

            // New signature: sendToAgenda(requestId, meetingId)
            google.script.run
                .withSuccessHandler(function (res) {
                    UI.showLoading(false);
                    UI.toast('Pedido inserido na pauta com sucesso!', 'success');

                    const el = document.getElementById('modalPautar');
                    if (el) {
                        const modal = bootstrap.Modal.getInstance(el);
                        if (modal) modal.hide();
                    }

                    // Refresh Dashboard
                    if (typeof Views !== 'undefined' && Views.renderKanbanView) Views.renderKanbanView();
                    else App.init();
                })
                .withFailureHandler(function (err) {
                    UI.showError(err);
                })
                .sendToAgenda(requestId, meetingId); // Pass meetingId
        },

        returnToCG: function (requestId) {
            if (!confirm('Deseja devolver este pedido para nova análise da CG?')) return;

            UI.showLoading(true, "Devolvendo para CG...");
            google.script.run
                .withSuccessHandler(function () {
                    UI.showLoading(false);
                    UI.toast('Pedido retornado à CG com sucesso.', 'success');
                    if (Views.renderKanbanView) Views.renderKanbanView();
                    else App.init();
                })
                .withFailureHandler(function (err) {
                    UI.showLoading(false);
                    UI.toast('Erro: ' + err.message, 'error');
                })
                .updateRequestStatus(requestId, 'Em Análise pela Comissão de Gestão (CG)', 'Retornado pela Secretaria para Reavaliação', 'Devolvido para CG (Ressalvas/Ajustes)');
        },

        // --- REQUEST DETAIL MODAL ---
        openRequestDetailModal: function (encodedDataOrId) {
            try {
                let req;

                // Check if it's a plain ID (number) or encoded JSON
                if (typeof encodedDataOrId === 'string' && (encodedDataOrId.startsWith('%7B') || encodedDataOrId.startsWith('{'))) {
                    // It's encoded JSON
                    req = JSON.parse(decodeURIComponent(encodedDataOrId));
                    Forms._showRequestDetailModalContent(req);
                } else {
                    // It's a request ID - need to fetch from API
                    UI.showLoading(true, 'Carregando detalhes...');
                    API.getRequests(App.currentRole, App.user.id, function (data) {
                        UI.showLoading(false);
                        const found = (data || []).find(r => String(r.ID) === String(encodedDataOrId));
                        if (found) {
                            Forms._showRequestDetailModalContent(found);
                        } else {
                            UI.toast('Solicitação não encontrada.', 'error');
                        }
                    });
                    return; // Exit early, will continue in callback
                }
            } catch (e) {
                console.error('Error opening request detail:', e);
                UI.toast('Erro ao abrir detalhes: ' + e.message, 'error');
            }
        },

        _showRequestDetailModalContent: function (req) {
            try {
                // NEW: Store in global for easy access by other modals (like Accountability)
                Forms._currentOpenedRequest = req;

                // Parse details
                let details = {};
                try { details = JSON.parse(req.Detalhes || '{}'); } catch (e) { }

                // Parse history
                let history = [];
                try { history = JSON.parse(req.Historico_Aprovacao || '[]'); } catch (e) { }

                // Role Definitions
                const isAdmin = ['Docente', 'Secretaria', 'Coordenação'].includes(App.currentRole);
                const isDiscente = App.currentRole === 'Discente';
                const isDocente = App.currentRole === 'Docente';
                const isSecretaria = App.currentRole === 'Secretaria';
                const isCoord = App.currentRole === 'Coordenação';

                // Status colors
                const statusColors = {
                    'Pendente': 'primary', // Blue (Changed from warning)
                    'Em Pauta': 'purple', // Purple (New)
                    'Pautado na CPG (com aval)': 'purple', // Legacy support
                    'Aprovado': 'success',
                    'Rejeitado': 'danger',
                    'Aguardando Elucidação': 'info'
                };
                let statusColor = statusColors[req.Status] || 'secondary';

                // Format date
                const formatDate = (d) => {
                    try {
                        const date = new Date(d);
                        return date.toLocaleDateString('pt-BR') + ' às ' + date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
                    } catch (e) { return d || '—'; }
                };

                // Build details HTML (excluding system fields)
                const systemFields = ['ID_Reuniao', 'Observacao_Docente', 'Parecer_CG_Capes'];

                // Helper to translate keys
                const formatKey = (key) => {
                    const translations = {
                        'AccountabilityUploads': '📂 Arquivos da Prestação de Contas',
                        'AccountabilityStudentComments': '📝 Detalhes/Observações do Aluno',
                        'AccountabilityItems': '📋 Itens Solicitados (Checklist)',
                        'AccountabilityInstructions': 'ℹ️ Instruções da Secretaria',
                        'AccountabilityMessage': '📢 Mensagem da Secretaria'
                    };
                    return translations[key] || key;
                };

                // Helper function to format values (handles objects)
                const formatValue = (val) => {
                    if (val === null || val === undefined) return '—';
                    if (typeof val === 'object') {
                        if (Array.isArray(val)) {
                            // Handle Array of Objects (AccountabilityUploads)
                            if (val.length > 0 && typeof val[0] === 'object' && val[0].url) {
                                return val.map(f => `<a href="${f.url}" target="_blank" class="d-block mb-1 text-decoration-none">📎 ${f.name}</a>`).join('');
                            }
                            return val.join(', ') || '—';
                        }
                        // For objects like Parecer_CG_Capes
                        const entries = Object.entries(val);
                        if (entries.length === 0) return '—';
                        return entries.map(([k, v]) => `<span class="badge bg-success bg-opacity-25 text-success me-1 mb-1">${k}</span>`).join('');
                    }
                    return String(val) || '—';
                };

                let detailsHtml = Object.entries(details)
                    .filter(([key]) => !systemFields.includes(key))
                    .map(([key, value]) => {
                        // Check if it's a file link (old string format)
                        const valueStr = typeof value === 'string' ? value : '';
                        const isFile = valueStr.startsWith('Arquivo:') || valueStr.includes('drive.google.com');
                        let displayValue = '';

                        if (isFile) {
                            displayValue = `<a href="${valueStr.replace('Arquivo: ', '')}" target="_blank" class="btn btn-sm btn-outline-primary">📎 Ver Arquivo</a>`;
                        } else {
                            displayValue = `<span class="text-dark">${formatValue(value)}</span>`;
                        }

                        return `
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted small mb-1">${formatKey(key)}</label>
                                <div class="fw-medium">${displayValue}</div>
                            </div>`;
                    }).join('');

                // Add special section for CG Parecer if exists
                if (details['Parecer_CG_Capes']) {
                    const parecer = details['Parecer_CG_Capes'];
                    const items = Object.entries(parecer);
                    if (items.length > 0) {
                        detailsHtml += `
                            <div class="col-12 mb-3">
                                <div class="card border-success">
                                    <div class="card-header bg-success bg-opacity-10 py-2">
                                        <span class="fw-bold text-success">✅ Parecer Técnico CG - Análise CAPES</span>
                                    </div>
                                    <div class="card-body py-2">
                                        ${items.map(([label, val]) => {
                            // Check if it's the open comment field (has more text)
                            const isComment = val && String(val).length > 20;
                            if (isComment) {
                                return `<div class="alert alert-primary mb-2"><strong>📝 Observação do Parecerista:</strong><br>${val}</div>`;
                            }
                            return `<span class="badge bg-success me-1 mb-1">${label}</span>`;
                        }).join('')}
                                    </div>
                                </div>
                            </div>`;
                    }
                }

                // Build history timeline
                let historyHtml = history.length > 0
                    ? history.map((h, i) => `
                        <div class="timeline-item ${i === 0 ? 'active' : ''}">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <div class="d-flex justify-content-between align-items-start">
                                    <strong class="text-primary">${h.action || 'Ação'}</strong>
                                    <small class="text-muted">${formatDate(h.date)}</small>
                                </div>
                                <div class="small text-muted">${h.user || '—'}</div>
                                ${h.justification ? `<div class="mt-1 small fst-italic">"${h.justification}"</div>` : ''}
                            </div>
                        </div>
                    `).join('')
                    : '<div class="text-muted text-center py-3">Nenhum histórico registrado.</div>';

                // Build admin actions if applicable
                // (Roles initialized at top)
                const isPending = req.Status === 'Pendente' || req.Status === 'Aguardando Orientador';
                const isReturnedToStudent = String(req.Status).includes('Retornado ao Aluno') || String(req.Status).includes('Aguardando Elucidação') || String(req.Status).includes('Ajustes');
                const isReturnedToAdvisor = String(req.Status).includes('Retornado ao Orientador');

                let actionsHtml = '';

                // Actions for returned requests - OWNER (Student or Docente)
                // Check ownership robustly
                const isOwner = (String(req.ID_Usuario) === String(App.user.id));

                if (isOwner && isReturnedToStudent) {
                    actionsHtml = `
                        <div class="border-top pt-3 mt-3">
                            <div class="alert alert-warning">
                                <strong>⚠️ Ação Necessária:</strong> Este pedido foi retornado para ajustes.
                                <br><small>Por favor, clique em "Editar Pedido" para corrigir os dados e reenviar.</small>
                            </div>
                            <h6 class="text-muted small text-uppercase mb-3">Ações do Solicitante</h6>
                            
                            <!-- Comment field kept for context, but main action is Edit -->
                            <div class="mb-3 d-none"> 
                                <label class="form-label">Comentário (Opcional se editar)</label>
                                <textarea class="form-control" id="student-correction-comment" rows="2"></textarea>
                            </div>

                            <button class="btn btn-warning btn-lg w-100 mb-2" onclick="Forms.editRequest('${req.ID}', '${req.Tipo_Solicitacao}');">
                                ✏️ Editar e Ressubmeter Pedido
                            </button>
                            
                            <div class="text-center">
                                <small class="text-muted">Ao editar, o pedido voltará para análise.</small>
                            </div>
                        </div>
                    `;
                }

                // Action for Accountability (Prestação de Contas Solicitada)
                const isAccountabilityRequested = String(req.Status) === 'Prestação de Contas Solicitada' || String(req.Status) === 'Aguardando Prestação de Contas';
                if (isOwner && isAccountabilityRequested) {
                    actionsHtml += `
                        <div class="border-top pt-3 mt-3">
                            <div class="alert alert-info border-info">
                                <strong>📉 Prestação de Contas Solicitada</strong><br>
                                A Secretaria solicitou que você envie os comprovantes desta solicitação.
                            </div>
                            <h6 class="text-muted small text-uppercase mb-3">Ações do Solicitante</h6>
                            <button class="btn btn-warning btn-lg w-100 shadow-sm mb-2" onclick="Forms.openStudentAccountabilityModal('${req.ID}');">
                                📤 Entregar Prestação de Contas
                            </button>
                        </div>
                    `;
                }

                // Actions for returned requests - Advisor (Docente)
                if (isDocente && isReturnedToAdvisor) {
                    actionsHtml = `
                        <div class="border-top pt-3 mt-3">
                            <div class="alert alert-warning">
                                <strong>⚠️ Ação Necessária:</strong> Este pedido foi retornado para você para revisão.
                            </div>
                            <h6 class="text-muted small text-uppercase mb-3">Ações do Orientador</h6>
                            <div class="mb-3">
                                <label class="form-label">Comentário/Revisão</label>
                                <textarea class="form-control" id="advisor-revision-comment" rows="3" placeholder="Adicione observações ou correções..."></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">📎 Anexar Documento (opcional)</label>
                                <input type="file" class="form-control" id="advisor-attachment" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                                <small class="text-muted">PDF, Word ou imagens (máx. 10MB)</small>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-success flex-fill" onclick="Forms.resubmitRequest('${req.ID}', 'orientador');">
                                    ✓ Reenviar para CPG
                                </button>
                                <button class="btn btn-warning flex-fill" onclick="Forms.returnToStudent('${req.ID}');">
                                    ↩️ Devolver ao Aluno
                                </button>
                            </div>
                        </div>
                    `;
                }

                // Standard admin actions for pending requests - ONLY for Docente on Aguardando Orientador
                // Standard admin actions removed (Moved to Footer)

                // Observação do Docente
                let obsHtml = '';
                if (details.Observacao_Docente) {
                    obsHtml = `
                        <div class="alert alert-warning mt-3">
                            <strong>📝 Observação do Docente:</strong>
                            <p class="mb-0 mt-1">${details.Observacao_Docente}</p>
                        </div>
                    `;
                }

                const modalHtml = `
                <div class="modal fade" id="modalRequestDetail" tabindex="-1">
                    <div class="modal-dialog modal-xl modal-dialog-scrollable">
                        <div class="modal-content border-0 shadow-lg">
                            <div class="modal-header bg-primary text-white">
                                <div>
                                    <h5 class="modal-title mb-1">${req.Tipo_Solicitacao || 'Solicitação'}</h5>
                                    <small class="opacity-75">ID: ${req.ID}</small>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge bg-${statusColor} px-3 py-2 fs-6">${req.Status}</span>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                            </div>
                            <div class="modal-body p-0">
                                <div class="row g-0">
                                    <!-- Left: Request Details -->
                                    <div class="col-lg-8 p-4 border-end">
                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <h6 class="text-muted text-uppercase mb-0">Dados da Solicitação</h6>
                                            <small class="text-muted">Criado em: ${formatDate(req.Data_Criacao)}</small>
                                        </div>
                                        
                                        <div class="row mb-4">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label text-muted small mb-1">Solicitante</label>
                                                <div class="fw-bold text-primary">${req.Nome_Aluno || req.ID_Usuario || '—'}</div>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label text-muted small mb-1">Tipo</label>
                                                <div class="fw-medium">${req.Tipo_Solicitacao || '—'}</div>
