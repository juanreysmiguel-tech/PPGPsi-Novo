        submitStudentAccountability: function () {
            const form = document.getElementById('form-student-accountability');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            if (!confirm('Tem certeza que deseja enviar sua prestação de contas? Verifique se todos os arquivos foram anexados.')) return;

            UI.showLoading(true, 'Enviando arquivos... Isso pode levar alguns instantes.');

            // Google Apps Script `google.script.run` handles form elements natively with file uploads.
            // We pass the form as the ONLY argument to serialization work properly.
            // requestId is now inside the form as hidden input.

            google.script.run
                .withSuccessHandler(function () {
                    UI.showLoading(false);
                    bootstrap.Modal.getInstance(document.getElementById('modalStudentAccountability')).hide();
                    UI.toast('Prestação de contas enviada com sucesso!', 'success');
                    // Refresh Dashboard
                    if (Views.renderStudent) Views.renderStudent(document.getElementById('main-content'));
                })
                .withFailureHandler(function (e) {
                    UI.showLoading(false);
                    UI.toast('Erro ao enviar: ' + e.message, 'error');
                    console.error(e);
                })
                .submitStudentAccountability(form); // Pass ONLY the form element
        },

        undoLastAction: function (requestId) {
            UI.confirm({
                title: 'Desfazer Ação',
                message: "Atenção: Isso desfará a última ação registrada (ignorando comentários). O status retornará ao estado anterior.\n\nDeseja continuar?",
                type: 'danger',
                confirmLabel: 'Sim, Desfazer',
                onConfirm: function () {
                    UI.showLoading(true, "Desfazendo última ação...");
                    google.script.run
                        .withSuccessHandler(function (res) {
                            UI.showLoading(false);
                            UI.toast(res.message, 'success');
                            // Refresh current view
                            const modalDetail = document.getElementById('modalRequestDetail');
                            if (modalDetail) { try { bootstrap.Modal.getInstance(modalDetail)?.hide(); } catch (e) { } }
                            UI.renderView();
                        })
                        .withFailureHandler(function (e) {
                            UI.showLoading(false);
                            UI.toast("Erro: " + e.message, 'error');
                        })
                        .undoLastAction(requestId);
                }
            });
        },

