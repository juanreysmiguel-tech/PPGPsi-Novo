/**
 * Searches the DB_Qualis sheet for journals matching the given filters.
 * 
 * @param {object} filters - Object containing optional search filters:
 *   - issn: string
 *   - titulo: string
 *   - areaAvaliacao: string
 *   - estrato: string (A1, A2, etc.)
 *   - evento: string (e.g., "2017-2020")
 * @returns {object} { success: boolean, results: array, error: string|null }
 */
function searchQualisPeriodicos(filters) {
    try {
        var ss = getSpreadsheet();
        var sheet = ss.getSheetByName('DB_Qualis');
        
        if (!sheet) {
            return { success: false, error: "Aba DB_Qualis não encontrada na planilha." };
        }
        
        var data = sheet.getDataRange().getValues();
        if (data.length < 2) {
            return { success: false, error: "Sem dados na DB_Qualis." };
        }
        
        // First row is headers: ISSN, Título, Área de Avaliação, Estrato, Evento
        var headers = data[0];
        var colISSN = headers.indexOf('ISSN');
        var colTitulo = headers.indexOf('Título');
        var colArea = headers.indexOf('Área de Avaliação');
        var colEstrato = headers.indexOf('Estrato');
        var colEvento = headers.indexOf('Evento');
        
        // Validate columns exist
        if (colISSN === -1 || colTitulo === -1 || colArea === -1 || colEstrato === -1 || colEvento === -1) {
            return { success: false, error: "Colunas obrigatórias não encontradas na DB_Qualis." };
        }
        
        // Parse filters
        var fISSN = filters.issn ? String(filters.issn).trim().toUpperCase() : '';
        var fTitulo = filters.titulo ? String(filters.titulo).trim().toUpperCase() : '';
        var fArea = filters.areaAvaliacao ? String(filters.areaAvaliacao).trim().toUpperCase() : '';
        var fEstrato = filters.estrato ? String(filters.estrato).trim().toUpperCase() : '';
        var fEvento = filters.evento ? String(filters.evento).trim() : '';
        
        // At least one filter must be provided
        if (!fISSN && !fTitulo && !fArea && !fEstrato && !fEvento) {
            return { success: false, error: "Informe ao menos um critério de busca." };
        }
        
        var results = [];
        var TOP_STRATA = ['A1', 'A2', 'A3', 'A4'];
        var MAX_RESULTS = 100; // Limit for performance
        
        for (var i = 1; i < data.length && results.length < MAX_RESULTS; i++) {
            var row = data[i];
            var issn = String(row[colISSN] || '').trim().toUpperCase();
            var titulo = String(row[colTitulo] || '').trim().toUpperCase();
            var area = String(row[colArea] || '').trim().toUpperCase();
            var estrato = String(row[colEstrato] || '').trim().toUpperCase();
            var evento = String(row[colEvento] || '').trim();
            
            // Apply filters (AND logic for all provided filters)
            var match = true;
            
            if (fISSN && !issn.includes(fISSN)) match = false;
            if (fTitulo && !titulo.includes(fTitulo)) match = false;
            if (fArea && !area.includes(fArea)) match = false;
            if (fEstrato && estrato !== fEstrato) match = false;
            if (fEvento && !evento.includes(fEvento)) match = false;
            
            if (match) {
                results.push({
                    issn: row[colISSN],
                    titulo: row[colTitulo],
                    areaAvaliacao: row[colArea],
                    estrato: row[colEstrato],
                    evento: row[colEvento],
                    isTopStrata: TOP_STRATA.indexOf(estrato) !== -1
                });
            }
        }
        
        return {
            success: true,
            results: results,
            totalFound: results.length,
            limitReached: results.length >= MAX_RESULTS
        };
        
    } catch (e) {
        Logger.log("Erro searchQualisPeriodicos: " + e.message);
        return { success: false, error: e.message };
    }
}

/**
 * Fetches distinct values for filter dropdowns (Areas, Estratos, Eventos).
 * @returns {object} { areas: [], estratos: [], eventos: [] }
 */
function getQualisFilterOptions() {
    try {
        var ss = getSpreadsheet();
        var sheet = ss.getSheetByName('DB_Qualis');
        
        if (!sheet) return { success: false };
        
        var data = sheet.getDataRange().getValues();
        var headers = data[0];
        
        var colArea = headers.indexOf('Área de Avaliação');
        var colEstrato = headers.indexOf('Estrato');
        var colEvento = headers.indexOf('Evento');
        
        var areas = {};
        var estratos = {};
        var eventos = {};
        
        for (var i = 1; i < data.length; i++) {
            if (data[i][colArea]) areas[data[i][colArea]] = true;
            if (data[i][colEstrato]) estratos[data[i][colEstrato]] = true;
            if (data[i][colEvento]) eventos[data[i][colEvento]] = true;
        }
        
        return {
            success: true,
            areas: Object.keys(areas).sort(),
            estratos: Object.keys(estratos).sort(),
            eventos: Object.keys(eventos).sort()
        };
    } catch (e) {
        Logger.log("Erro getQualisFilterOptions: " + e.message);
        return { success: false, error: e.message };
    }
}


