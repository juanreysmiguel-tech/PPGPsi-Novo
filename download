function findNextMeeting(requestDate) {
  // STRICT LOGIC: Find the meeting where requestDate is within [Start, End]
  // Used for assigning requests upon creation
  
  var meetings = getDataFromSheet("DB_Calendario_Reunioes");
  var target = null;
  
  var rDate = new Date(requestDate);
  rDate.setHours(12,0,0,0); // Normalize time to noon to avoid edge cases

  // Sort by date ascending
  meetings.sort((a,b) => new Date(a.Data_Reuniao) - new Date(b.Data_Reuniao));

  for (var i = 0; i < meetings.length; i++) {
     var m = meetings[i];
     if (m.Status !== 'Aberto') continue;
     
     // Check strict period: Start <= requestDate <= End
     var start = m.Data_Inicio_Periodo ? new Date(m.Data_Inicio_Periodo) : null;
     var end = m.Data_Fim_Periodo ? new Date(m.Data_Fim_Periodo) : null;
     
     if (start && end) {
         start.setHours(0,0,0,0);
         end.setHours(23,59,59,999);
         
         if (rDate >= start && rDate <= end) {
             target = m;
             break; // Found the specific meeting for this date
         }
     } else {
         // Fallback if periods are missing (should not happen in strict mode, but safety)
         // Use deadline logic as backup
         var deadline = new Date(m.Prazo_Fechamento || m.Data_Reuniao);
         deadline.setHours(23,59,59);
         if (rDate <= deadline) {
             target = m;
             break;
         }
     }
  }
  return target;
}

