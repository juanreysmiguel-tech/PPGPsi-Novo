/**
 * Fetches the exchange rate (Venda) for a specific currency and date from BCB API.
 * Automatically backtracks to finding the nearest previous business day.
 * * @param {string|Date} currency - 'USD', 'EUR', 'GBP', etc.
 * @param {string|Date} dateInput - Date in 'YYYY-MM-DD' format or Date Object.
 * @returns {object} { rate: number, dateUsed: string, error: string|null }
 */
function getBCBExchangeRate(currency, dateInput) {
    // 1. Sanitização da Moeda
    if (!currency) return { success: false, error: "Moeda não informada." };
    
    var safeCurrency = String(currency).trim().toUpperCase();
    if (safeCurrency === 'BRL') {
        return { success: true, rate: 1, dateUsed: new Date().toISOString().slice(0,10), originalDate: dateInput };
    }

    // 2. Normalização da Data (Para garantir que loop funcione)
    var currentDate;
    try {
        if (dateInput instanceof Date) {
            currentDate = new Date(dateInput.getTime());
        } else {
            // Assume YYYY-MM-DD
            var parts = String(dateInput).split('-');
            // Cuidado: Mês em JS é 0-indexado
            currentDate = new Date(parts[0], parseInt(parts[1]) - 1, parts[2]);
        }
    } catch (e) {
        return { success: false, error: "Data inválida: " + e.message };
    }

    // Verifica data futura
    var today = new Date();
    if (currentDate > today) currentDate = new Date();

    var maxRetries = 7;
    var lastError = "";

    // 3. Loop de Tentativas
    for (var i = 0; i < maxRetries; i++) {
        // BCB API exige formato 'MM-dd-yyyy' para a query string
        var dataString = Utilities.formatDate(currentDate, "GMT-3", "MM-dd-yyyy");
        var dateUsedISO = Utilities.formatDate(currentDate, "GMT-3", "yyyy-MM-dd");

        var isUSD = (safeCurrency === 'USD');
        var urlBase = isUSD 
            ? "https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata/CotacaoDolarDia(dataCotacao=@dataCotacao)"
            : "https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata/CotacaoMoedaDia(moeda=@moeda,dataCotacao=@dataCotacao)";
        
        var url;
        if (isUSD) {
            url = urlBase + "?@dataCotacao='" + dataString + "'&$top=100&$format=json";
        } else {
            url = urlBase + "?@moeda='" + safeCurrency + "'&@dataCotacao='" + dataString + "'&$top=100&$format=json";
        }
        
        try {
            // Logger.log("Tentativa " + (i+1) + " BCB URL: " + url); // Descomente para debug
            var response = UrlFetchApp.fetch(url, { muteHttpExceptions: true });
            
            if (response.getResponseCode() !== 200) {
                lastError = "HTTP " + response.getResponseCode();
                // Continua para o dia anterior
            } else {
                var json = JSON.parse(response.getContentText());
                
                if (json && json.value && json.value.length > 0) {
                    // Pega o fechamento (último item do dia)
                    var cotacao = json.value[json.value.length - 1].cotacaoVenda;
                    
                    return {
                        success: true,
                        rate: cotacao,
                        dateUsed: dateUsedISO,
                        originalDate: dateInput,
                        currency: safeCurrency
                    };
                }
            }
        } catch (e) {
            Logger.log("Erro de conexão BCB (" + dataString + "): " + e.message);
            lastError = e.message;
        }
        
        // Recua 1 dia
        currentDate.setDate(currentDate.getDate() - 1);
    }
    
    Logger.log("Falha BCB após retries. Moeda: " + safeCurrency + ", Data Ref: " + dateInput);
    return { success: false, error: "Cotação não encontrada após " + maxRetries + " tentativas. (Último erro: " + lastError + ")" };
}

