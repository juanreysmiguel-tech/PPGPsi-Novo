           try { processAutoApprovals(); } catch(e) { /* Silent */ }
           data = getDataFromSheet("DB_Solicitacoes"); 
      }
      
      // Populate Student Names
      var users = getDataFromSheet("DB_Usuarios");
      var userMap = {};
      users.forEach(u => userMap[String(u.ID)] = u.Nome);
      
      // Create map of user ID to Email_Orientador
      var userOrientadorMap = {};
      users.forEach(u => userOrientadorMap[String(u.ID)] = u.Email_Orientador);
      
      var filtered = data.filter(function(row) {
        // Parse details if string
        var details = {};
        try { details = JSON.parse(row.Detalhes); } catch(e){}

        var match = false;
        var rowId = row.ID_Usuario ? String(row.ID_Usuario).trim() : "";
        var currentId = userId ? String(userId).trim() : "";

        if (roleFilter === "Discente") {
           match = rowId === currentId;
        } else if (roleFilter === "Docente") {
           // Check if current user is the advisor for this student
           var studentOrientadorEmail = userOrientadorMap[rowId] || "";
           var currentUserEmail = (Session.getActiveUser().getEmail() || "").trim().toLowerCase();
           var isAdvisor = studentOrientadorEmail && String(studentOrientadorEmail).trim().toLowerCase() === currentUserEmail; 
           var isOwn = rowId === currentId;
           match = isAdvisor || isOwn;
        } else if (roleFilter === "Secretaria" || roleFilter === "Coordenação" || roleFilter === "Conselho" || roleFilter === "CG") {
           match = true; 
        }
        return match;
      });
      
      // Return filtered requests
      
      // Sanitize for Transport (Fix Date Objects) & Add Names
      return filtered.reverse().map(function(item) {
        var clean = {};
        for (var key in item) {
          var val = item[key];
          if (val instanceof Date) {
             clean[key] = val.toISOString();
