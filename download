        // Check ID_Parecerista_CG column (primary)
        var pareceristaId = String(r.ID_Parecerista_CG || '').trim();
        if (pareceristaId && pareceristaId === memberId) {
          return true;
        }
        
        // Fallback: Check details.Parecerista for historical data
        try {
          var details = typeof r.Detalhes === 'string' ? JSON.parse(r.Detalhes) : (r.Detalhes || {});
          var parecerista = String(details.Parecerista || '').trim().toLowerCase();
