    verifyCode: function(email, code) {
        email = email.trim().toLowerCase();
        var cache = CacheService.getScriptCache();
        var storedCode = cache.get(this.getCodeKey(email));
        
        if (storedCode && storedCode === code) {
             var token = Utilities.getUuid();
             // Store Token -> Email mapping valid for 24 hours (86400 sec)
             // Apps Script Cache max is 6 hours (21600). We set max.
             cache.put(this.getTokenKey(token), email, 21600);
             cache.remove(this.getCodeKey(email)); // Invalidate code
             return { success: true, token: token };
        } else {
             throw new Error("Código inválido ou expirado.");
        }
    },
    
    validateToken: function(token) {
        if (!token) return null;
        var cache = CacheService.getScriptCache();
        return cache.get(this.getTokenKey(token)); // Returns email or null
    }
};

