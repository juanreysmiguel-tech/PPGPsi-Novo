    var allRequests = getDataFromSheet("DB_Solicitacoes");
    var myEmail = (me.email || '').trim().toLowerCase();
    var myName = (me.nome || '').trim().toLowerCase();
    var myId = me.id;

    // 1. Find all students that have this user as advisor (Legacy Support)
    var users = getDataFromSheet("DB_Usuarios");
    
    // Create Map for Name Lookup & ID List
    var userMap = {};
    var myAdviseesIds = [];
    
    users.forEach(function(u) {
       var uId = String(u.ID || '').trim();
       var uName = u.Nome || 'Desconhecido';
       userMap[uId] = uName;
       
       var uOrientadorEmail = (u.Email_Orientador || '').trim().toLowerCase();
       if (uOrientadorEmail === myEmail) {
          myAdviseesIds.push(uId);
       }
    });
    
    // Filter requests
    var filtered = allRequests.filter(function(req) {
      // A. Direct Match (New Requests with metadata)
      var orientadorEmail = (req.Email_Orientador || '').trim().toLowerCase();
      var orientadorNome = (req.Nome_Orientador || '').trim().toLowerCase();
      
      if ((orientadorEmail && orientadorEmail === myEmail) || (orientadorNome && orientadorNome.includes(myName))) {
         return true;
      }

      // B. Indirect Match (Legacy Requests via User DB)
      var reqUserId = String(req.ID_Usuario || '').trim();
      if (reqUserId && myAdviseesIds.includes(reqUserId)) {
         return true;
      }

      return false;
    });
    
    // Sanitize for Transport (Fix Date Objects) & Add Names
    return filtered.reverse().map(function(item) {
        var clean = {};
        for (var key in item) {
           var val = item[key];
           if (val instanceof Date) {
              clean[key] = val.toISOString();
           } else {
              clean[key] = val;
           }
        }
        // Add implicit Name and ensure Email_Orientador
        var uid = String(item.ID_Usuario || '').trim();
        clean.Nome_Aluno = userMap[uid] || "Desconhecido / Externo";
        clean.Nome_Solicitante = clean.Nome_Aluno; // Fallback for Frontend
        if (!clean.Email_Orientador) {
             // Try to find in user DB if not in request (Legacy)
             var userObj = users.find(u => String(u.ID || '').trim() === uid);
             if (userObj) clean.Email_Orientador = userObj.Email_Orientador;
        }
        return clean;
    });

