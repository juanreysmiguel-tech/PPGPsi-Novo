/**
 * Get the next CG parecerista in round-robin order
 */
function getNextCGParecerista() {
  try {
    var cgMembers = getCGMembers();
    if (cgMembers.length === 0) return null;
    
    // Get financial requests to count assignments
    var requests = getDataFromSheet("DB_Solicitacoes");
    var financialRequests = requests.filter(function(r) {
      return r.Tipo_Solicitacao && r.Tipo_Solicitacao.includes("Financeiro");
    });
    
    // Count assignments per CG member (use string keys)
    var counts = {};
    cgMembers.forEach(function(m) { 
      counts[String(m.ID)] = 0; 
    });
    
    financialRequests.forEach(function(r) {
      // Check ID_Parecerista_CG column
      var pareceristaId = String(r.ID_Parecerista_CG || '').trim();
      if (pareceristaId && counts[pareceristaId] !== undefined) {
        counts[pareceristaId]++;
        return;
      }
      
      // Fallback: Check details.Parecerista
      try {
        var details = typeof r.Detalhes === 'string' ? JSON.parse(r.Detalhes) : (r.Detalhes || {});
        var parecerista = String(details.Parecerista || '').trim().toLowerCase();
        if (parecerista) {
          // Try to match by name or email
          cgMembers.forEach(function(m) {
            var memberEmail = String(m.Email || '').trim().toLowerCase();
            var memberName = String(m.Nome || '').trim().toLowerCase();
            if (parecerista === memberEmail || parecerista === memberName || parecerista.includes(memberName)) {
              counts[String(m.ID)]++;
            }
          });
        }
      } catch (e) {}
    });
    
    // Find member with least assignments
    var minCount = Infinity;
    var nextMember = cgMembers[0];
    cgMembers.forEach(function(m) {
      var memberId = String(m.ID);
      if (counts[memberId] < minCount) {
        minCount = counts[memberId];
        nextMember = m;
      }
    });
    
    return {
      id: nextMember.ID,
      nome: nextMember.Nome,
      email: nextMember.Email,
      pareceres: counts[String(nextMember.ID)] || 0
    };
  } catch (e) {
    Logger.log("getNextCGParecerista ERRO: " + e.message);
    return null;
  }
}

