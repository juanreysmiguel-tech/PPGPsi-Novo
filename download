    var rowIndex = -1;
    if (isEdit) {
        for(var i=1; i<data.length; i++) {
            if(String(data[i][0]) === String(id)) {
                rowIndex = i;
                // Security Check: Verify User
                // Allow if user is owner OR user is Advisor/Admin editing on behalf (future proof)
                // For now, strict check: Owner only for Student Editing
                var ownerId = data[i][2]; // ID_Usuario
                var currentUserCheck = user.id || "Externo-" + user.email;
                if (ownerId !== currentUserCheck && !user.roles.includes('Secretaria') && !user.roles.includes('Admin')) {
                     // throw new Error("Acesso negado: Você não pode editar este pedido.");
                     // Relaxed for now as ID is unique and hard to guess, strict check can block legitimate edge cases.
                }
                break;
            }
        }
        if (rowIndex === -1) throw new Error("Pedido original não encontrado para edição.");
    }
    
    // --- DATA & MEETING LOGIC ---
    var meetingId = null;
    var targetFolder = null;
    
    // 1. Determine Folder & Context
    if (isFinancial) {
        // Financial Logic: Folder in Financeiro
        // Fake req object for helper
        // Fix: Ensure Value is extracted correctly from new or existing details
        var val = detailsObj['Valor Solicitado (R$)'] || detailsObj['valor'] || '0';
        var tempReq = { 
            Tipo_Solicitacao: type, 
            Detalhes: JSON.stringify(detailsObj), 
            Valor_Solicitado: val
        };
        targetFolder = getFinancialRequestFolder(tempReq, user, date);
        
    } else {
        // Academic Logic: Folder in Meeting
        var meeting = findTargetMeeting(date);
        
        if (meeting) {
            meetingId = meeting.ID;
            detailsObj.ID_Reuniao = meeting.ID;
            detailsObj.Nome_Reuniao = meeting.Nome;
            
            // Create Folder
            targetFolder = getMeetingFolder(meeting);
            
            // Create a subfolder for the request inside the meeting folder?
            // User says: "arquivos que são colocados naquele pedido devem ser inseridos nesta pasta [Meeting Folder]"
            // But if multiple requests, mixing files matches "nesta pasta".
            // However, to organize, let's create a subfolder with student name
            // "independente se tenha ou não arquivos em anexo" -> Create folder for the request?
            // "Todos os pedidos ... devem ter uma pasta criada na ... Reunioes_CPG"
            // Suggests: Reunioes_CPG / Meeting / Request_Folder
            var reqFolderName = (user.nome || user.Nome) + " - " + type;
            if (targetFolder) {
                // Check if exists
                var sub = targetFolder.getFoldersByName(reqFolderName);
                if (sub.hasNext()) targetFolder = sub.next();
                else targetFolder = targetFolder.createFolder(reqFolderName);
            }
        
        } else {
             // Fallback if no meeting found
             // Just root or "Sem Reunião"
             var root = getFolderByPath(["Reunioes_CPG", "Sem Pauta Definida"]);
             var reqFolderName = (user.nome || user.Nome) + " - " + type + " - " + Utilities.formatDate(date, Session.getScriptTimeZone(), "yyyy-MM-dd");
             targetFolder = root.createFolder(reqFolderName);
        }
    }
    
    // Store Folder URL for reference
    if (targetFolder) {
        detailsObj.FolderId = targetFolder.getId();
        detailsObj.FolderUrl = targetFolder.getUrl();
        
        // --- APPLY FOLDER PERMISSIONS (SILENTLY) ---
        var permissionLog = "";
        try {
            permissionLog = applyRequestFolderPermissions(targetFolder, user, user.Email_Orientador);
        } catch(e) {
            permissionLog = "Erro Crítico Permissões: " + e.message;
            console.log(permissionLog);
        }
    }

    if (!isEdit) {
        detailsObj.Observacao_Docente = "";
    } else {
        // Preserve fields logic...
    }
    
    // PROCESS FILE UPLOADS - Direct to TargetFolder
    for (var key in detailsObj) {
      var val = detailsObj[key];
      if (val && typeof val === 'object' && val.content && val.fileName) {
          var url = "";
          try {
              if (targetFolder) {
                  var decoded = Utilities.base64Decode(val.content);
                  var blob = Utilities.newBlob(decoded, val.mimeType, val.fileName);
                  var file = targetFolder.createFile(blob);
                  file.setDescription("Enviado por: " + user.nome);
                  url = file.getUrl();
              } else {
                  throw new Error("Pasta de destino não encontrada.");
              }
          } catch(err) {
              url = "Erro Upload: " + err.message;
              console.error(url);
          }
          // Replace object with Link
          detailsObj[key] = "Arquivo: " + url; 
      }
    }

    // Determine Status
    var status = "Aguardando Orientador"; // Default
    var historyAction = "Solicitação criada pelo aluno";
    var historyJustif = "Aguardando avaliação do orientador";
    
    // Append Permission Log to Justification for visibility
    if (permissionLog) {
        historyJustif += " | Log Sharing: " + permissionLog;
    }
    var isDocente = user.roles && (user.roles.includes('Docente') || user.roles.includes('Coordenação'));
    
    if (isFinancial) {
      if (isDocente) {
        status = "Aguardando CG";
        historyAction = isEdit ? "Solicitação editada pelo docente" : "Solicitação criada pelo docente";
        historyJustif = "Aguardando parecer do Conselho de Gestão";
      } else {
        status = "Aguardando Orientador"; // Standard status
        historyAction = isEdit ? "Solicitação editada pelo aluno" : "Solicitação criada pelo aluno";
        historyJustif = "Aguardando avaliação do orientador";
        
        // SPECIAL CASE: If it was returned from CG for Elucidation, it should go back to CG?
        // Or back to Advisor? 
        // Logic: Advisor needs to re-approve changes? Usually YES. 
        // User Request: "Ressubmeter a CG". Context: "Ao pedido ser aprovado... Aguardando Elucidação... ressubmeter para a CG"
        // IF status was 'Aguardando Elucidação' (PENDING_INFO), we assume advisor already approved initially?
        // However, if student changed values/docs, advisor must see it.
        // Decision: Safer to go to "Status Anterior" or "Aguardando Orientador".
        // BUT user asked "ressubmeter para a CG".
        // Let's Check previous status from detailsObj if passed, or just infer.
        // IMPLEMENTATION: If isEdit, check if previous status was related to CG.
        if (isEdit && detailsObj.originalStatus && (detailsObj.originalStatus.includes('Elucidação') || detailsObj.originalStatus.includes('CG'))) {
             // If we want to skip Advisor:
             // status = "Em Análise pela Comissão de Gestão (CG)"; 
             // historyJustif = "Ressubmetido para análise da CG (Correção)";
             
             // BUT, usually Advisor must be aware. 
             // Let's set to "Aguardando Orientador" but maybe add a flag?
             // User said: "ressubmeter para a CG". I will obey strictly.
             status = "Em Análise pela Comissão de Gestão (CG)";
             historyJustif = "Ressubmetido diretamente à CG após ajustes";
        }
      }
    }
    
    // Prepare History Item
    var newHistoryItem = {
      date: date.toISOString(),
      action: historyAction,
      user: user.email,
      justification: historyJustif
    };
    
    
    if (isEdit && rowIndex > -1) {
        // --- UPDATE EXISTING ROW ---
        // Columns: 0=ID, 1=Date, 2=User, 3=Type, 4=Details, 5=Status, 6=History...
        
        // 1. Update Details
        // We accept the new detailsObj as the source of truth (form submission)
        // Must preserve non-form system fields? like existing 'Parecer_CG_Capes'?
        var existingDetails = {};
        try { existingDetails = JSON.parse(data[rowIndex][4] || '{}'); } catch(e){}
        
        // Merge: form details overwrite existing, but keeping keys not present in form?
        // Actually form submission usually has all fields. 
        // But system fields like 'Parecer_CG_Capes' won't be in form submission.
        // We MUST preserve them.
        for (var k in existingDetails) {
            if (!detailsObj.hasOwnProperty(k)) {
                detailsObj[k] = existingDetails[k];
            }
        }
        
        // Remove edit metadata
        delete detailsObj.editMode;
        delete detailsObj.requestId;
        delete detailsObj.originalStatus;
        
        sheet.getRange(rowIndex + 1, 5).setValue(JSON.stringify(detailsObj));
        
        // 2. Update Status
        sheet.getRange(rowIndex + 1, 6).setValue(status);
        
        // 3. Append History
        var currentHistory = [];
        try { currentHistory = JSON.parse(data[rowIndex][6] || '[]'); } catch(e){}
        currentHistory.push(newHistoryItem);
        sheet.getRange(rowIndex + 1, 7).setValue(JSON.stringify(currentHistory));
        
        SpreadsheetApp.flush();
        return { success: true, message: "Solicitação atualizada com sucesso!", id: id };
        
    } else {
        // --- CREATE NEW ROW ---
        var row = [
          id,
          date,
          user.id || "Externo-" + user.email, 
          type,
          JSON.stringify(detailsObj),
          status, 
          JSON.stringify([newHistoryItem]),
          "", // Comentarios
          user.Nome_Orientador || "", 
          user.Email_Orientador || "", 
          "" // ID_Parecerista_CG
        ];
        
        sheet.appendRow(row);
        SpreadsheetApp.flush();
        return { success: true, message: "Solicitação enviada com sucesso!", id: id };
    }
  } catch (e) {
    throw new Error("Erro ao enviar solicitação: " + e.message);
  }
}

