   PROPGWEB CSV IMPORT FUNCTION
   ========================================================================== */

/**
 * Import ProPGWeb CSV data to update student records
 * CSV columns expected:
 * nome_aluno,nivel,status,email,data_matricula,creditos_disciplinas_optativas,
 * creditos_disciplinas_obrigatorias,data_para_defesa,data_para_qualificacao,
 * data_para_integralizacao,nome_orientador,data_defesa,cpf,rg,orgao_expedidor,
 * data_emissao,data_nascimento,sexo,raca,telefone_celular,logradouro,numero,
 * complemento,bairro,cidade,uf,cep
 * 
 * @param {string} csvContent - Raw CSV content as string
 * @returns {Object} Result with stats: { success, inserted, updated, errors, errorMessages }
 */
function importProPGWebCSV(csvContent) {
  try {
    // Check permissions
    var user = getUserData();
    if (!user.roles.includes("Secretaria") && !user.roles.includes("Coordenação")) {
      throw new Error("Acesso negado. Apenas Secretaria/Coordenação podem importar dados.");
    }
    
    // Parse CSV
    var lines = csvContent.split(/\r?\n/).filter(function(line) { return line.trim() !== ''; });
    if (lines.length < 2) {
      throw new Error("CSV vazio ou sem dados válidos.");
    }
    
    // Parse header (first line)
    var headerLine = lines[0];
    var headers = parseCSVLine(headerLine);
    
    // Normalize headers (remove quotes, trim, lowercase)
    headers = headers.map(function(h) { 
      return h.replace(/^"|"$/g, '').trim().toLowerCase(); 
    });
    
    // CSV to DB field mapping
    var fieldMapping = {
      'nome_aluno': 'Nome',
      'nivel': 'Nivel',
      'status': 'Status',
      'email': 'Email',
      'data_matricula': 'Data_Ingresso',
      'creditos_disciplinas_optativas': 'Creditos_Optativas',
      'creditos_disciplinas_obrigatorias': 'Creditos_Obrigatorias',
      'data_para_defesa': 'Data_Defesa',
      'data_para_qualificacao': 'Data_Qualificacao',
      'data_para_integralizacao': 'Data_Integralizacao',
      'nome_orientador': 'Nome_Orientador',
      'data_defesa': 'Data_Defesa_Realizada',
      'cpf': 'CPF',
      'rg': 'RG',
      'orgao_expedidor': 'RG_Orgao',
      'data_emissao': 'RG_Data_Emissao',
      'data_nascimento': 'Data_Nascimento',
      'sexo': 'Sexo',
      'raca': 'Raca',
      'telefone_celular': 'Celular',
      'logradouro': 'Logradouro',
      'numero': 'Numero',
      'complemento': 'Complemento',
      'bairro': 'Bairro',
      'cidade': 'Cidade',
      'uf': 'UF',
      'cep': 'CEP'
    };
    
    // Get spreadsheet and users sheet
    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Usuarios");
    var data = sheet.getDataRange().getValues();
    var dbHeaders = data[0];
    
    // Create email index for quick lookup
    var emailColIdx = dbHeaders.indexOf('Email');
    var emailToRowMap = {};
    for (var i = 1; i < data.length; i++) {
      var email = String(data[i][emailColIdx] || '').trim().toLowerCase();
      if (email) emailToRowMap[email] = i + 1; // 1-based row number
    }
    
    // Process results
    var result = {
      success: true,
      total: lines.length - 1,
      inserted: 0,
      updated: 0,
      skipped: 0,
      errors: 0,
      errorMessages: []
    };
    
    // Process each data line (skip header)
    for (var lineIdx = 1; lineIdx < lines.length; lineIdx++) {
      try {
        var values = parseCSVLine(lines[lineIdx]);
        if (values.length < 4) {
          result.skipped++;
          continue;
        }
        
        // Build record from CSV
        var record = {};
        for (var colIdx = 0; colIdx < headers.length && colIdx < values.length; colIdx++) {
          var csvField = headers[colIdx];
          var dbField = fieldMapping[csvField];
          if (dbField) {
            var val = values[colIdx].replace(/^"|"$/g, '').trim();
            record[dbField] = val;
          }
        }
        
        // Validate email
        var email = String(record.Email || '').trim().toLowerCase();
        if (!email || !email.includes('@')) {
          result.errors++;
          result.errorMessages.push("Linha " + (lineIdx + 1) + ": Email inválido");
          continue;
        }
        
        // Check if user exists
        var existingRow = emailToRowMap[email];
        
        if (existingRow) {
          // UPDATE existing user
          for (var dbFieldName in record) {
            var colIndex = dbHeaders.indexOf(dbFieldName);
            if (colIndex >= 0 && record[dbFieldName]) {
              sheet.getRange(existingRow, colIndex + 1).setValue(record[dbFieldName]);
            }
          }
          result.updated++;
        } else {
          // INSERT new user
          var newRow = [];
          for (var hi = 0; hi < dbHeaders.length; hi++) {
            var header = dbHeaders[hi];
            if (header === 'ID') {
              newRow.push(Utilities.getUuid());
            } else if (header === 'Roles') {
              // Default role for students
              var nivel = record.Nivel || 'Discente';
              newRow.push(JSON.stringify(['Discente']));
            } else if (header === 'Status') {
              // Map status or default to Ativo
              var status = record.Status || 'Ativo';
              if (status.toLowerCase().includes('regular') || status.toLowerCase().includes('ativo')) {
                newRow.push('Ativo');
              } else {
                newRow.push('Inativo');
              }
            } else {
              newRow.push(record[header] || '');
            }
          }
          sheet.appendRow(newRow);
          result.inserted++;
          
          // Update email map for subsequent lookups
          emailToRowMap[email] = sheet.getLastRow();
        }
        
      } catch (lineError) {
        result.errors++;
        result.errorMessages.push("Linha " + (lineIdx + 1) + ": " + lineError.message);
      }
    }
    
    SpreadsheetApp.flush();
    
    return result;
    
  } catch (e) {
    return {
      success: false,
      error: e.message,
      inserted: 0,
      updated: 0,
      errors: 1,
      errorMessages: [e.message]
    };
  }
}

/**
 * Parse a single CSV line handling quoted values with commas
 */
function parseCSVLine(line) {
  var result = [];
  var current = '';
  var inQuotes = false;
  
  for (var i = 0; i < line.length; i++) {
    var char = line[i];
    
    if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === ',' && !inQuotes) {
      result.push(current);
      current = '';
    } else {
      current += char;
    }
  }
  result.push(current); // Add last field
  
  return result;
}

