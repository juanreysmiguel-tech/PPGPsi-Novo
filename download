const ROOT_FOLDER_NAME = "!Sistema de Gestão PPGPsi/UFSCar";

function getRootFolder() {
  var folders = DriveApp.getFoldersByName(ROOT_FOLDER_NAME);
  if (folders.hasNext()) return folders.next();
  return DriveApp.createFolder(ROOT_FOLDER_NAME);
}

function getFolderByPath(pathArray) {
  var current = getRootFolder();
  for (var i = 0; i < pathArray.length; i++) {
    var name = pathArray[i];
    var found = false;
    var folders = current.getFoldersByName(name);
    while (folders.hasNext()) {
      var f = folders.next();
      if (f.getName() === name) { // Exact match
        current = f;
        found = true;
        break;
      }
    }
    if (!found) {
      current = current.createFolder(name);
    }
  }
  return current;
}

function getMeetingFolder(meeting) {
  // Format: Reunioes_CPG \ (data_NomeReunião)
  var dateStr = "";
  try {
    var d = new Date(meeting.Data_Reuniao); 
    // Fix: d might be timezone offset if not handled carefully, assuming UTC or script TZ
    dateStr = Utilities.formatDate(d, Session.getScriptTimeZone(), "yyyy-MM-dd");
  } catch(e) { dateStr = "Indefinida"; }
  
  var folderName = dateStr + " - " + meeting.Nome;
  return getFolderByPath(["Reunioes_CPG", folderName]);
}

function getFinancialRequestFolder(req, user, optDate) {
  // Format: Financeiro \ (Tipo - Nome - Valor - Data)
  var details = {};
  try { details = JSON.parse(req.Detalhes || '{}'); } catch(e) {}
  
  var valor = details['Valor Solicitado (R$)'] || details['valor'] || req.Valor_Solicitado || '0';
  var dateStr = Utilities.formatDate(optDate || new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd");
  
  var folderName = [
    (req.Tipo_Solicitacao || 'Financeiro'),
    (user.nome || user.Nome || 'Usuario'),
    "R$ " + String(valor).replace('.', ','),
    dateStr
  ].join(" - ");
  
  return getFolderByPath(["Financeiro", folderName]);
}

function findTargetMeeting(requestDate) {
  var meetings = getDataFromSheet("DB_Calendario_Reunioes");
  var reqDate = new Date(requestDate);
  reqDate.setHours(0,0,0,0);
  
  for (var i = 0; i < meetings.length; i++) {
    var m = meetings[i];
    if (m.Status === 'Concluída' || m.Status === 'Cancelada') continue;
    
    // Parse periods
    var start = new Date(m.Data_Inicio_Periodo);
    var end = new Date(m.Data_Fim_Periodo);
    start.setHours(0,0,0,0);
    end.setHours(23,59,59,999);
    
    if (reqDate >= start && reqDate <= end) {
      return m;
    }
  }
  return null;
}


