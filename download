            if (match && match[1]) {
                try {
                    var originalFile = DriveApp.getFileById(match[1]);
                    targetFolder = originalFile.getParents().next();
                    // Verify if it is indeed inside "Financeiro" or acceptable root
                    // For now, trust the parent of the attached file is the correct project folder
                    break;
                } catch (e) {
                    console.warn("Could not retrieve parent folder for file: " + match[1]);
                }
            }
        }
    }

    // 2. Fallback: Create/Use Standard Structure if no original folder found
    if (!targetFolder) {
        var rootFolder = DriveApp.getFoldersByName("PPGPsi_Solicitacoes").hasNext() ? DriveApp.getFoldersByName("PPGPsi_Solicitacoes").next() : DriveApp.createFolder("PPGPsi_Solicitacoes");
