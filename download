function getUserData(authToken) {
  try {
    // 1. Try Token Auth (Priority for Subdomains/Failures)
    var email = "";
    if (authToken) {
        var tokenEmail = AuthService.validateToken(authToken);
        if (tokenEmail) {
            email = tokenEmail.trim().toLowerCase();
            Logger.log("getUserData - Autenticado via Token: " + email);
        }
    }
    
    // 2. Fallback to Session (Native Google Auth)
    if (!email) {
        var rawEmail = Session.getActiveUser().getEmail();
        email = (rawEmail || "").trim().toLowerCase();
        Logger.log("getUserData - Email Sessão: [" + rawEmail + "]");
    }
    
    if (!email) {
      Logger.log("getUserData - email vazio, retornando Externo");
      return {
        email: "desconhecido",
        roles: ["Externo"],
        nome: "Visitante",
        id: "Externo-anonimo"
      };
    }
    
    var users = getDataFromSheet("DB_Usuarios");
    // ROBUST SEARCH: Check trimmed and lowercased email
    var user = users.find(function(u) {
       var uEmail = String(u.Email || "").trim().toLowerCase();
       return uEmail === email && u.Status === 'Ativo';
    });
    
    // ... (rest of logic remains similar, copying robust logic)
    if (!user) {
      return {
        email: email,
        roles: ["Externo"],
        nome: "Visitante",
        id: "Externo-" + email
      };
    }

    var availableRoles = [];
    var roleRaw = user.Roles; 
    
    try {
        if (typeof roleRaw === 'string') {
            roleRaw = roleRaw.trim();
            if (roleRaw.startsWith("[") && roleRaw.endsWith("]")) {
                availableRoles = JSON.parse(roleRaw);
            } else if (roleRaw.includes(",")) {
                availableRoles = roleRaw.split(",").map(function(r){ return r.trim(); });
            } else {
                availableRoles = [roleRaw];
            }
        } else if (Array.isArray(roleRaw)) {
            availableRoles = roleRaw;
        }
    } catch (e) {
        availableRoles = [String(roleRaw)];
    }
    
    availableRoles = availableRoles.filter(function(r) { return r && r !== ""; });
    if (availableRoles.length === 0) availableRoles = ['Externo'];

    return {
      id: user.ID.toString(),
      email: user.Email,
      nome: user.Nome,
      roles: availableRoles,
      Telefone: user.Telefone || '',
      Celular: user.Celular || '',
      Endereco: user.Endereco || '',
      EmergenciaNome: user.EmergenciaNome || '',
      EmergenciaTel: user.EmergenciaTel || '',
      FotoUrl: user.FotoUrl || '',
      Data_Ingresso: user.Data_Ingresso || '',
      Creditos_Totais: user.Creditos_Totais || '',
      Data_Defesa: user.Data_Defesa || '',
      Data_Qualificacao: user.Data_Qualificacao || '',
      Data_Integralizacao: user.Data_Integralizacao || '',
      Nome_Orientador: user.Nome_Orientador || '',
      Email_Orientador: user.Email_Orientador || '',
      Nivel: user.Nivel || '',
      Creditos_Optativas: user.Creditos_Optativas || '',
      Creditos_Obrigatorias: user.Creditos_Obrigatorias || '',
      Data_Defesa_Realizada: user.Data_Defesa_Realizada || '',
      CPF: user.CPF || '',
      RG: user.RG || '',
      RG_Orgao: user.RG_Orgao || '',
      RG_Data_Emissao: user.RG_Data_Emissao || '',
      Data_Nascimento: user.Data_Nascimento || '',
      Sexo: user.Sexo || '',
      Raca: user.Raca || '',
      Logradouro: user.Logradouro || '',
      Numero: user.Numero || '',
      Complemento: user.Complemento || '',
      Bairro: user.Bairro || '',
      Cidade: user.Cidade || '',
      UF: user.UF || '',
      CEP: user.CEP || ''
    };
    
  } catch (err) {
    Logger.log("getUserData CATCH erro fatal: " + err.message);
    return {
      email: "erro",
      roles: ["Externo"],
      nome: "Erro: " + err.message,
      id: "error"
    };
  }
}

