/**
 * Shares a folder with a user without sending an email notification.
 * REQUIRES: "Drive API" service enabled in Apps Script.
 * Supports both v2 and v3.
 */
function shareFolderQuietly(folderId, email) {
    if (!email || email.indexOf('@') === -1) return "Email invalido";
    var log = "";
    try {
        var resource = {
            'role': 'reader',
            'type': 'user',
            'value': email,
            'emailAddress': email // Needed for Drive API v3
        };
        if (Drive.Permissions.insert) {
            Drive.Permissions.insert(resource, folderId, {
                'sendNotificationEmails': false
            });
            log = "OK (v2)";
        } else if (Drive.Permissions.create) {
             Drive.Permissions.create(resource, folderId, {
                'sendNotificationEmail': false
            });
            log = "OK (v3)";
        } else {
            log = "ERRO: Drive API nao detectado";
        }
    } catch (e) {
        log = "ERRO: " + e.message;
        console.error("shareFolderQuietly ERRO " + email + ": " + e.message);
    }
    return log;
}

