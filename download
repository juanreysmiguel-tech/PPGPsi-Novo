        if (String(data[i][0]) === user.id) {
            // Update columns (0-based indexes in sheet vs array)
            // Telefone: col 6 (index 5) -> sheet col 6
            // Celular: col 7 -> sheet 7
            // Endereco: col 8 -> sheet 8
            // EmergenciaNome: col 9 -> sheet 9
            // EmergenciaTel: col 10 -> sheet 10
            
            // Note: Sheet columns are 1-based. Array is 0-based.
            // ID is col 1 (idx 0).
            // Telefone is col 6 (idx 5)
            
            sheet.getRange(i+1, 6).setValue(contactData.Telefone || "");
            sheet.getRange(i+1, 7).setValue(contactData.Celular || "");
