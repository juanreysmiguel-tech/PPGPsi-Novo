function processAutoApprovals() { processDailyTriggers(); } // Legacy Trigger Support
function processDailyTriggers() {
  /**
   * Refined Logic for Status Updates
   * 1. Auto-Close Meetings: If Today > End_Period, Status -> 'Fechado'
   * 2. Advisor Silence: If Status 'Aguardando Orientador' AND Today > Prazo_Fechamento_Docentes,
   *    Auto-forward to 'Pendente' (Secretaria) with system note "Sem aceite Orientador".
   */
  
  var ss = getSpreadsheet();
  var today = new Date();
  today.setHours(0,0,0,0);
  
  var updates = false;
  
  // --- 1. MEETING MANAGEMENT ---
  var meetSheet = ss.getSheetByName("DB_Calendario_Reunioes");
  var meetData = meetSheet.getDataRange().getValues(); // Header row 0
  
  // Col indexes (0-based): 0=ID, 4=Data_Fim_Periodo, 5=Status, 6=Prazo_Fechamento
  var meetMap = {}; // ID -> {date, deadline}
  
  for (var i = 1; i < meetData.length; i++) {
     var mRow = meetData[i];
     
     // Store metadata for Request Check
     meetMap[String(mRow[0])] = {
         date: mRow[2] ? new Date(mRow[2]) : null,
         deadline: mRow[6] ? new Date(mRow[6]) : null
     };
     
     if (mRow[5] === 'Aberto') {
        var fimPeriodo = mRow[4] ? new Date(mRow[4]) : null;
        if (fimPeriodo && today > fimPeriodo) {
            meetSheet.getRange(i+1, 6).setValue("Fechado");
            updates = true;
        }
     }
  }
  
  // --- 2. REQUEST AUTO-FORWARD (Advisor Silence) ---
  var reqSheet = ss.getSheetByName("DB_Solicitacoes");
  var reqData = reqSheet.getDataRange().getValues();
  
  // Col indexes: 4=Detalhes, 5=Status, 6=Historico, 8=ID_Reuniao (Column 9 in sheet?)
  // Let's find index dynamically or assume fixed? 
         // Previous code map:
         // i=1 (row). 
         // But headers are in reqData[0] if needed.
         // Let's use dynamic headers.
  var headers = reqData[0];
  var colStatus = headers.indexOf("Status");
  var colHistory = headers.indexOf("Historico_Aprovacao");
  var colDetails = headers.indexOf("Detalhes");
  var colMeeting = headers.indexOf("ID_Reuniao"); // Assuming this exists or is in Detalhes
  
  for(var i=1; i<reqData.length; i++) {
     var row = reqData[i];
     var status = row[colStatus];
     
     if (status === 'Aguardando Orientador') {
        var details = {};
        try { details = JSON.parse(row[colDetails] || '{}'); } catch(e){}
        
        var meetingId = details.ID_Reuniao || (colMeeting > -1 ? row[colMeeting] : null);
        
        if (meetingId && meetMap[meetingId] && meetMap[meetingId].deadline) {
            var deadline = new Date(meetMap[meetingId].deadline);
            deadline.setHours(23,59,59,999);
            
            // If Today is AFTER Deadline
            if (today > deadline) {
               // Auto-forward
               reqSheet.getRange(i+1, colStatus + 1).setValue("Pendente"); // Move to Pending Secretariat
               
               // Add History
               var history = [];
               try { history = JSON.parse(row[colHistory] || '[]'); } catch(e){}
               history.push({
                 date: new Date().toISOString(),
                 action: "Aprovação Automática",
                 user: "Sistema",
                 justification: "Sem aceite Orientador no prazo. Encaminhado à Secretaria."
               });
               reqSheet.getRange(i+1, colHistory + 1).setValue(JSON.stringify(history));
               
               // Add System Note to Details
               details['Aviso_Sistema'] = "Sem aceite Orientador.";
               reqSheet.getRange(i+1, colDetails + 1).setValue(JSON.stringify(details));
               
               updates = true;
            }
        }
     }
  }
  
  if (updates) SpreadsheetApp.flush();
}

