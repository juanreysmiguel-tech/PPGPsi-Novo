   CG PARECER PROCESSING
   ========================================================================== */

/**
 * Process the complex CG Parecer with side-by-side review
 * Payload: { requestId, action, status, justification, approvedValue }
 */
function processCGParecer(payload) {
  try {
    var user = getUserData();
    // Security check: must be CG or Admin
    if (!user.roles.includes("CG") && !user.roles.includes("Conselho") && !user.roles.includes("Coordenação")) {
      throw new Error("Permissão negada: Apenas membros do CG podem emitir parecer.");
    }

    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Solicitacoes");
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    
    var rowIndex = -1;
    var requestRow = null;
    
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] == payload.requestId) {
        rowIndex = i;
        requestRow = data[i];
        break;
      }
    }
    
    if (rowIndex === -1) throw new Error("Solicitação não encontrada.");
    
    // Column Indices
    var cols = {};
    headers.forEach(function(h, idx) { cols[h] = idx; });
    
    // 1. Update Details
    var currentDetailsStr = requestRow[cols['Detalhes']];
    var details = {};
    try { details = JSON.parse(currentDetailsStr); } catch(e) {}
    var detailsChanged = false;

    // Handle Value Change
    if (payload.approvedValue) {
       var originalVal = details['Valor Solicitado (R$)'] || details['valor'];
       if (originalVal != payload.approvedValue) {
           details['Valor Solicitado (R$)'] = payload.approvedValue;
           details['valor'] = payload.approvedValue;
           details['_observacao_valor'] = "Valor alterado pelo CG de R$ " + originalVal + " para R$ " + payload.approvedValue;
           detailsChanged = true;
           Logger.log("processCGParecer: Valor atualizado para " + payload.approvedValue);
       }
    }

    // Handle CAPES Analysis (Parecer Técnico)
    if (payload.capesAnalysis) {
        details['Parecer_CG_Capes'] = payload.capesAnalysis;
        detailsChanged = true;
    }
    
