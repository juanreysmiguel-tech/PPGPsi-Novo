function archiveStudentRequests(studentEmail) {
   var me = getUserData();
   if (!me.roles.includes("Secretaria") && !me.roles.includes("Coordenação")) {
      return { success: false, error: "Permissão negada" };
   }
   
   if (!studentEmail) {
      return { success: false, error: "Email do aluno não fornecido." };
   }
   
   try {
     var ss = getSpreadsheet();
     
     // Get Student ID
     var userSheet = ss.getSheetByName("DB_Usuarios");
     var users = userSheet.getDataRange().getValues();
     var studentId = null;
     for (var i = 1; i < users.length; i++) {
        if (users[i][1] && String(users[i][1]).trim().toLowerCase() === String(studentEmail).trim().toLowerCase()) {
           studentId = users[i][0];
           break;
        }
     }
     
     if (!studentId) {
        return { success: false, error: "Aluno não encontrado no banco de dados com este email." };
     }
     
     var sheet = ss.getSheetByName("DB_Solicitacoes");
     var archiveSheet = ss.getSheetByName("DB_Solicitacoes_Arquivo");
     
     // Create Archive Sheet if it doesn't exist
     if (!archiveSheet) {
        archiveSheet = ss.insertSheet("DB_Solicitacoes_Arquivo");
        var headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues();
        archiveSheet.getRange(1, 1, 1, headers[0].length).setValues(headers);
        archiveSheet.getRange(1, 1, 1, headers[0].length).setFontWeight("bold");
        archiveSheet.setFrozenRows(1);
     }
     
     var data = sheet.getDataRange().getValues();
     if (data.length <= 1) return { success: true, count: 0 }; // Only headers
     
     var idUsuarioCol = data[0].indexOf("ID_Usuario");
     var statusCol = data[0].indexOf("Status");
     
     if (idUsuarioCol === -1 || statusCol === -1) {
       return { success: false, error: "Colunas ID_Usuario ou Status não encontradas em DB_Solicitacoes." };
     }
     
     var archiveCount = 0;
     var rowsToDelete = [];
     var rowsToAppend = [];
     
     // Loop backwards because we'll collect rows to delete from highest index to lowest
     for (var i = data.length - 1; i >= 1; i--) {
        var rowUserId = String(data[i][idUsuarioCol]).trim();
        var rowStatus = String(data[i][statusCol]).trim().toLowerCase();
        
        var isFinal = rowStatus.includes('concluíd') || 
                      rowStatus.includes('concluid') || 
                      rowStatus.includes('finalizad') || 
                      rowStatus.includes('indeferid') || 
                      rowStatus.includes('rejeitad') || 
                      rowStatus.includes('aceita') || 
                      rowStatus.includes('cancelad') ||
                      rowStatus.includes('não acatad');
        
        if (rowUserId === String(studentId).trim() && isFinal) {
           rowsToAppend.unshift(data[i]); // unshift to keep chronological order
           rowsToDelete.push(i + 1); // 1-based index
           archiveCount++;
        }
     }
     
     if (archiveCount > 0) {
        // Prepare rowsToAppend to ensure arrays are homogeneous and date objects are handled natively
        archiveSheet.getRange(archiveSheet.getLastRow() + 1, 1, rowsToAppend.length, rowsToAppend[0].length).setValues(rowsToAppend);
        
        // Delete rows from the active sheet (safely, since rowsToDelete is descending)
        rowsToDelete.forEach(function(rIndex) {
           sheet.deleteRow(rIndex);
        });
     }
     
     return { success: true, count: archiveCount };
   } catch(e) {
     return { success: false, error: e.message };
   }
}

function updateContactInfo(contactData) {
