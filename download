function checkTrancamentoContext(authToken) {
  try {
    var user = getUserData(authToken);
    var email = user.email;
    
    // 1. Calculate Current Semester
    var today = new Date();
    var year = today.getFullYear();
    var month = today.getMonth() + 1; // 1-12
    var semester = (month <= 6) ? "1º Semestre" : "2º Semestre";
    var currentPeriod = semester + " de " + year;
    
    // 2. Check Previous Requests
    // We need to check DB_Solicitacoes for this user and type "Trancamento"
    var hasPrevious = false;
    
    // Optimally, we should query DB_Solicitacoes. 
    // Since we don't have a direct "getByType" that is efficient for just boolean check,
    // we will fetch all requests (cached if possible by getDataFromSheet) and filter.
    // Ideally we should have a backend filter, but getDataFromSheet fetches all.
    
    var requests = getDataFromSheet("DB_Solicitacoes");
    
    // Filter for User + Type "Trancamento" + Status not Deleted/Rejected
    // Note: User ID is col 2 (index 2), Type is col 3 (index 3), Status is col 5 (index 5)
    // Actually getDataFromSheet returns objects now!
    
    var userRequests = requests.filter(function(r) {
       // Check ownership (Email in ID or ID match)
       // Our rows have "ID_Usuario" which might be "Externo-email" or UUID.
       // Easiest is to invoke getUserData behavior or just check rough match if we trust email.
       // Let's use the ID returned by getUserData for robust matching.
       
       var isOwner = (String(r.ID_Usuario) === String(user.id));
       var isTrancamento = (String(r.Tipo_Solicitacao).indexOf("Trancamento") !== -1);
       var isValidStatus = (r.Status !== "Excluído" && r.Status !== "Deletado" && r.Status !== "Indeferido" && r.Status !== "Rejeitado");
       
       return isOwner && isTrancamento && isValidStatus;
    });
    
    hasPrevious = (userRequests.length > 0);
    
    return {
       currentPeriod: currentPeriod,
       hasPrevious: hasPrevious,
       success: true
    };
    

  } catch (e) {
    Logger.log("Erro em checkTrancamentoContext: " + e.message);
    return {
       currentPeriod: "",
       hasPrevious: false,
       success: false,
       error: e.message
    };
  }
}

