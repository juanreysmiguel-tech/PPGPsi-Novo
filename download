             clean[key] = val;
          }
        }
        // Add implicit Name
        clean.Nome_Aluno = userMap[String(item.ID_Usuario)] || "Desconhecido / Externo";
        return clean;
      });
  } catch (e) {
    throw new Error("Erro ao buscar solicitações: " + e.message);
  }
