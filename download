  }
  var ss = SpreadsheetApp.create(DB_NAME);
  setupSheets(ss);
  return ss;
}

function setupDatabase() {
  getSpreadsheet(); // This triggers setupSheets if new
}

function setupSheets(ss) {
  var sheets = [
    { name: "DB_Usuarios", headers: ["ID", "Email", "Nome", "Roles", "Status", "Telefone", "Celular", "Endereco", "EmergenciaNome", "EmergenciaTel", "FotoUrl", "Data_Ingresso", "Creditos_Totais", "Data_Defesa", "Data_Qualificacao", "Data_Integralizacao", "Nome_Orientador", "Email_Orientador", "Nivel", "Creditos_Optativas", "Creditos_Obrigatorias", "Data_Defesa_Realizada", "CPF", "RG", "RG_Orgao", "RG_Data_Emissao", "Data_Nascimento", "Sexo", "Raca", "Logradouro", "Numero", "Complemento", "Bairro", "Cidade", "UF", "CEP", "Prazo_Acesso"] },
    { name: "DB_Solicitacoes", headers: ["ID", "Data_Criacao", "ID_Usuario", "Tipo_Solicitacao", "Detalhes", "Status", "Historico_Aprovacao", "Comentarios", "Nome_Orientador", "Email_Orientador", "ID_Parecerista_CG"] },
    { name: "DB_Eventos_Processos", headers: ["ID", "Tipo", "Titulo", "Data_Inicio", "Data_Fim", "Vagas", "Descricao", "Status"] },
    { name: "DB_Financeiro", headers: ["ID", "ID_Solicitacao", "Valor", "Rubrica", "Descricao", "Data_Autorizacao"] },
    { name: "DB_Calendario_Reunioes", headers: ["ID", "Nome", "Data_Reuniao", "Data_Inicio_Periodo", "Data_Fim_Periodo", "Status", "Prazo_Fechamento"] },
    { name: "DB_Notificacoes", headers: ["ID", "ID_Usuario", "Tipo", "Titulo", "Mensagem", "Data", "Lido", "ID_Solicitacao"] },
    { name: "DB_Ata", headers: ["ID", "ID_Reuniao", "ID_Solicitacao", "Observacao", "Data", "Usuario"] },
    { name: "DB_Mural", headers: ["ID", "ID_Usuario", "Nome_Usuario", "FotoUrl", "Conteudo", "Data_Publicacao"] }
  ];

  sheets.forEach(function(schema) {
    var sheet = ss.getSheetByName(schema.name);
    if (!sheet) {
      sheet = ss.insertSheet(schema.name);
      sheet.appendRow(schema.headers);
      
      // Default Admin User if creating users table
      if (schema.name === "DB_Usuarios") {
        var currentUser = Session.getActiveUser().getEmail();
        sheet.appendRow([Utilities.getUuid(), currentUser, "Admin Inicial", JSON.stringify(["Secretaria"]), "Ativo"]);
      }
    }
  });
  
  // delete default "Sheet1" if it exists
  var defaultSheet = ss.getSheetByName("Sheet1");
  if (defaultSheet) ss.deleteSheet(defaultSheet);
}

function getDataFromSheet(sheetName) {
  var ss = getSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);
  
  Logger.log("getDataFromSheet - Buscando: " + sheetName);
  
  // Self-Healing: If sheet missing, try running setup
  if (!sheet) {
      Logger.log("getDataFromSheet - Sheet não encontrada, tentando setup...");
      setupSheets(ss);
      sheet = ss.getSheetByName(sheetName);
  }
  
  if (!sheet) {
    Logger.log("getDataFromSheet - ERRO: Sheet ainda não encontrada após setup!");
    throw new Error("Tabela não encontrada: " + sheetName);
  }

  var data = sheet.getDataRange().getValues();
  Logger.log("getDataFromSheet - Total de linhas (incluindo header): " + data.length);
  
  if (data.length === 0) return [];
  
  var headers = data.shift().map(function(h) { return h.toString().trim(); }); // Trim headers
  Logger.log("getDataFromSheet - Headers: " + headers.join(", "));
  Logger.log("getDataFromSheet - Dados (excluindo header): " + data.length + " linhas");
  
  return data.map(function(row) {
    var obj = {};
    headers.forEach(function(header, i) {
      // Handle potential row length mismatch
      obj[header] = (row.length > i) ? row[i] : "";
    });
    return obj;
  });
}

