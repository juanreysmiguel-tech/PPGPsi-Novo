function applyRequestFolderPermissions(folder, user, advisorEmail) {
    var folderId = folder.getId();
    var actionLog = [];
    var groupCoord = getAllCoordinationEmails();
    var groupSec = getAllSecretariaEmails();
    var groupConselho = getAllConselhoEmails(); 
    var groupDocente = getAllDocenteEmails();

    var isDiscente = user.roles.some(function(r) { 
        var ru = r.toUpperCase();
        return ru.indexOf('DISCENTE') !== -1 || ru.indexOf('ALUNO') !== -1 || ru.indexOf('ESTUDANTE') !== -1 || ru.indexOf('SOLICITANTE') !== -1;
    });
    
    if (isDiscente) {
        var targetAdvisorEmail = advisorEmail;
        var lookupNote = "";
        if ((!targetAdvisorEmail || targetAdvisorEmail.indexOf('@') === -1) && user.Nome_Orientador) {
             try {
                var users = getDataFromSheet("DB_Usuarios");
                var advisor = users.find(function(u) {
                    return u.Nome && u.Nome.trim().toUpperCase() === user.Nome_Orientador.trim().toUpperCase();
                });
                if (advisor && advisor.Email) {
                    targetAdvisorEmail = advisor.Email;
                    lookupNote = "(Busca por nome: " + user.Nome_Orientador + ")";
                }
             } catch(e) {}
        }
        if (targetAdvisorEmail && targetAdvisorEmail.indexOf('@') !== -1) {
             var res = shareFolderQuietly(folderId, targetAdvisorEmail);
             actionLog.push("Orientador (" + targetAdvisorEmail + "): " + res + " " + lookupNote);
        } else {
             actionLog.push("Orientador: Nao encontrado/Sem email. " + lookupNote);
        }
    }
    
    var uniqueEmails = [];
    function addToUnique(list) {
        list.forEach(function(e) {
            if (e && uniqueEmails.indexOf(e) === -1) uniqueEmails.push(e);
        });
    }
    addToUnique(groupConselho);
    addToUnique(groupCoord);
    addToUnique(groupSec);
    addToUnique(groupDocente);
    
    uniqueEmails.forEach(function(email) {
        var res = shareFolderQuietly(folderId, email);
        if (res.indexOf("ERRO") !== -1) actionLog.push("Grupo (" + email + "): " + res);
    });
    
    if (actionLog.length === 0) actionLog.push("Grupos processados (" + uniqueEmails.length + " emails).");
    return actionLog.join("; ");
}

