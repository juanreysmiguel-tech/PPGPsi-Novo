var DriveService = {
    FOLDERS: {
        ROOT: "!Sistema de Gestão - PPGPsi/UFSCar",
        CPG: "Reunioes_CPG",
        FINANCEIRO: "Financeiro"
    },

    /**
     * Helper to get or create a folder within a parent
     */
    ensureFolder: function(parentFolder, name) {
        try {
            var folders = parentFolder.getFoldersByName(name);
            if (folders.hasNext()) {
                var f = folders.next();
                // console.log("DriveService: Pasta encontrada [" + name + "] ID: " + f.getId());
                return f;
            } else {
                console.log("DriveService: Criando nova pasta [" + name + "] em " + parentFolder.getName());
                return parentFolder.createFolder(name);
            }
        } catch(e) {
            console.error("DriveService: ERRO em ensureFolder (" + name + "): " + e.message);
            throw e;
        }
    },

    /**
     * Get or Create Root Folder
     */
    getRootFolder: function() {
        try {
            var roots = DriveApp.getFoldersByName(this.FOLDERS.ROOT);
            if (roots.hasNext()) {
                return roots.next();
            }
            console.log("DriveService: Criando Pasta Raiz [" + this.FOLDERS.ROOT + "]");
            return DriveApp.createFolder(this.FOLDERS.ROOT);
        } catch(e) {
            console.error("DriveService: ERRO CRITICO ao acessar Raiz: " + e.message);
            throw new Error("Não foi possível acessar a pasta raiz do Drive. Verifique permissões.");
        }
    },

    /**
     * CPG MEETING FOLDER
     * Structure: PPGPsi_Docs > Reunioes_CPG > [Date] - [Name]
     */
    getOrCreateMeetingFolder: function(meetingId, meetingName, meetingDate) {
        var root = this.getRootFolder();
        var cpgRoot = this.ensureFolder(root, this.FOLDERS.CPG);
        
        // Format Name: YYYY-MM-DD - MeetingName
        var dateStr = "";
        try {
            var d = new Date(meetingDate);
            if (!isNaN(d.getTime())) {
                dateStr = Utilities.formatDate(d, Session.getScriptTimeZone(), "yyyy-MM-dd");
            } else {
                dateStr = "Data_Indefinida";
            }
        } catch(e) { dateStr = "Erro_Data"; }

        var folderName = dateStr + " - " + meetingName.replace(/[/\\?%*:|"<>]/g, '-');
        
        // Search by name logic implies uniqueness. 
        // We could also store Folder ID in DB_Calendario to be precise, 
        // but name convention is sturdy enough for this refined scope.
        return this.ensureFolder(cpgRoot, folderName);
    },

    /**
     * ACADEMIC REQUEST FOLDER (Inside Meeting)
     * Structure: MeetingFolder > [Type] - [Student Name]
     */
    addFileToCPGRequest: function(meetingId, requestType, studentName, fileData, fileName, mimeType) {
        var ss = getSpreadsheet();
        var sheet = ss.getSheetByName("DB_Calendario_Reunioes");
        var data = sheet.getDataRange().getValues();
        
        var meetingRow = null;
        for (var i=1; i<data.length; i++) {
            if (String(data[i][0]) === String(meetingId)) { // ID Match
                meetingRow = data[i];
                break;
            }
        }

        var meetingFolder;
        if (meetingRow) {
            // Found specific meeting
            meetingFolder = this.getOrCreateMeetingFolder(meetingRow[0], meetingRow[1], meetingRow[2]);
        } else {
            // Valid Meeting not found/assigned yet -> Put in "Inbox_Pendentes"
            var root = this.getRootFolder();
            var cpgRoot = this.ensureFolder(root, this.FOLDERS.CPG);
            meetingFolder = this.ensureFolder(cpgRoot, "Inbox_Pendentes");
        }

        var reqFolderName = requestType + " - " + studentName.replace(/[/\\?%*:|"<>]/g, '-');
        var reqFolder = this.ensureFolder(meetingFolder, reqFolderName);
        
        var blob = Utilities.newBlob(Utilities.base64Decode(fileData), mimeType, fileName);
        var file = reqFolder.createFile(blob);
        file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
        
        // Share with Secretariat
        this.safeAddViewer(file, EMAIL_SECRETARIA);
        
        return file.getUrl();
    },

    /**
     * FINANCIAL REQUEST FOLDER
     * Structure: PPGPsi_Docs > Financeiro > [Type] - [Name] - [Value]
     */
    addFileToFinancialRequest: function(requestType, userName, value, requestDate, fileData, fileName, mimeType) {
        var root = this.getRootFolder();
        var finRoot = this.ensureFolder(root, this.FOLDERS.FINANCEIRO);

        var dateStr = "";
        try {
             var d = new Date(requestDate);
             dateStr = Utilities.formatDate(d, Session.getScriptTimeZone(), "dd-MM-yyyy");
        } catch(e) { dateStr = ""; }

        // Folder Name: PROAP - Joao Silva - R$ 500 - 12-05-2024
        var folderName = requestType + " - " + userName + " - " + value + " - " + dateStr;
        folderName = folderName.replace(/[/\\?%*:|"<>]/g, '-');

        var reqFolder = this.ensureFolder(finRoot, folderName);
        
        var blob = Utilities.newBlob(Utilities.base64Decode(fileData), mimeType, fileName);
        var file = reqFolder.createFile(blob);
        file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
        
        // Share with Secretariat and CG
        this.safeAddViewer(file, EMAIL_SECRETARIA);
        var cgEmails = getAllCGEmails();
        cgEmails.forEach(function(email) { DriveService.safeAddViewer(file, email); });

        return file.getUrl();
    },

    safeAddViewer: function(file, email) {
        try {
            if (email && email.includes('@')) file.addViewer(email);
        } catch (e) {
            console.log("DriveService: Erro ao compartilhar com " + email);
        }
    }
};

