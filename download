 */
function uploadUserPhoto(base64Data, fileName, mimeType) {
  try {
    var email = Session.getActiveUser().getEmail();
    
    // Create blob from base64
    var blob = Utilities.newBlob(Utilities.base64Decode(base64Data), mimeType, fileName);
    
    // Create or get "PPGPsi_Fotos" folder
    var folders = DriveApp.getFoldersByName("PPGPsi_Fotos");
    var folder;
    if (folders.hasNext()) {
      folder = folders.next();
    } else {
      folder = DriveApp.createFolder("PPGPsi_Fotos");
    }
    
    // Check for existing photo and delete
    var existingFiles = folder.getFilesByName(email.replace("@", "_at_") + "_photo");
    while (existingFiles.hasNext()) {
      existingFiles.next().setTrashed(true);
    }
    
    // Upload new photo
    var file = folder.createFile(blob).setName(email.replace("@", "_at_") + "_photo");
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    
    // Use thumbnail export format for proper embedding in img tags
    var photoUrl = "https://drive.google.com/thumbnail?id=" + file.getId() + "&sz=w300";
    
    // Update user record
    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Usuarios");
    var dataRange = sheet.getDataRange();
    var values = dataRange.getValues();
    var headers = values[0];
    
    var colFoto = headers.indexOf("FotoUrl");
    var colEmail = headers.indexOf("Email");
    
    for (var i = 1; i < values.length; i++) {
      if (values[i][colEmail] === email) {
        if (colFoto >= 0) sheet.getRange(i + 1, colFoto + 1).setValue(photoUrl);
        SpreadsheetApp.flush();
        return photoUrl;
      }
    }
    
    throw new Error("Usuário não encontrado");
  } catch (e) {
    throw new Error("Erro ao enviar foto: " + e.message);
  }
}

