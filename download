function sendToAgenda(requestId, meetingId) {
    var user = getUserData();
    if (!user.roles.includes("Secretaria") && !user.roles.includes("Coordenação")) {
        throw new Error("Acesso negado.");
    }
    
    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Solicitacoes");
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    
    // Map headers
    var map = {};
    headers.forEach(function(h, i) { map[h] = i; });
    
    // Find Request
    var rowIndex = -1;
    for(var i=1; i<data.length; i++) {
        if(String(data[i][0]) === String(requestId)) {
            rowIndex = i;
            break;
        }
    }
    
    if (rowIndex === -1) throw new Error("Solicitação não encontrada.");
    
    // Retrieve Request Data Object
    var row = data[rowIndex];
    var request = {};
    headers.forEach(function(h, i) { request[h] = row[i]; });
    
    // Update Status -> 'Em Pauta'
    if (map['Status'] > -1) sheet.getRange(rowIndex+1, map['Status'] + 1).setValue("Em Pauta");
    
    // Link Meeting
    if (meetingId && map['ID_Reuniao'] > -1) {
        sheet.getRange(rowIndex+1, map['ID_Reuniao'] + 1).setValue(meetingId);
        
        // --- FOLDER & PDF LOGIC FOR ALL REQUESTS ---
        try {
            // 1. Get Meeting Data & Folder
            var meeting = null;
            var meetings = getDataFromSheet("DB_Calendario_Reunioes");
            for(var m=0; m<meetings.length; m++) {
                if (String(meetings[m].ID) === String(meetingId)) {
                    meeting = meetings[m];
                    break;
                }
            }
            
            if (meeting) {
               var meetingFolder = getMeetingFolder(meeting);
               
               // 2. Get Request Folder
               var details = {};
               try { details = JSON.parse(request.Detalhes || '{}'); } catch(e){}
               
               var reqFolder = null;
               
               // Strategy A: ID (Works for most new requests)
               if (details.FolderId) {
                   try { reqFolder = DriveApp.getFolderById(details.FolderId); } catch(e) {}
               }
               
               // Strategy B: Fallback for Financial Requests if ID is missing
               var type = String(request.Tipo_Solicitacao || "");
               var isFinancial = (type.indexOf("Financeiro") !== -1 || type.indexOf("FIN_") !== -1 || type.indexOf("Auxílio") !== -1);

               if (!reqFolder && isFinancial) {
                   var financeiroRoot = getFolderByPath(["Financeiro"]);
                   
                   // Reconstruct Expected Name
                   var rType = (request.Tipo_Solicitacao || "Financeiro");
                   var rName = (request.Nome_Aluno || request.ID_Usuario || "Usuario");
                   
                   var valRaw = details['Valor Solicitado (R$)'] || details['valor'] || request.Valor_Solicitado || '0';
                   var rValStr = "R$ " + String(valRaw).replace('.', ',');
                   
                   // Date: Use stored Data_Criacao
                   var rDate = request.Data_Criacao ? new Date(request.Data_Criacao) : new Date();
                   var rDateStr = Utilities.formatDate(rDate, Session.getScriptTimeZone(), "yyyy-MM-dd");
                   
                   var expectedName = [ rType, rName, rValStr, rDateStr ].join(" - ");
                   
                   // Strict Search in Financeiro
                   var folders = financeiroRoot.getFoldersByName(expectedName);
                   if (folders.hasNext()) {
                       reqFolder = folders.next();
                   } 
               }
               
               // Action: Move to Meeting Folder
               if (reqFolder) {
                   // Determine if it's financial or academic to create/get subfolder
                   var subfolderName = isFinancial ? "Financeira" : "Acadêmica";
                   var targetSubfolder = null;
                   var existingSubfolders = meetingFolder.getFoldersByName(subfolderName);
                   if (existingSubfolders.hasNext()) {
                       targetSubfolder = existingSubfolders.next();
                   } else {
                       targetSubfolder = meetingFolder.createFolder(subfolderName);
                   }

                   // Add to new meeting subfolder
                   targetSubfolder.addFolder(reqFolder);

                   // Remove from OLD meeting folders or subfolders to prevent duplicates
                   // Note: Keep it in "Financeiro" if it's a financial request
                   var parents = reqFolder.getParents();
                   while (parents.hasNext()) {
                       var parentFolder = parents.next();
                       var parentId = parentFolder.getId();
                       var parentName = parentFolder.getName();

                       // Check if parent is the exact new target subfolder
                       if (parentId === targetSubfolder.getId()) {
                           continue;
                       }

                       // Check if parent is the Financeiro root
                       if (parentName === "Financeiro") {
                           continue;
                       }
                       
                       // For safety, only remove from folders that look like Meetings or "Sem Pauta Definida"
                       // Meetings usually follow a date format or just "Sem Pauta Definida"
                       // In this context, it's safe to assume any other parent in this tree is an old meeting
                       parentFolder.removeFolder(reqFolder);
                   }
               } else {
                   // Warning if folder missing? 
                   if (isFinancial) {
                       throw new Error("Pasta Financeira não encontrada (" + (expectedName || "ID ausente") + ").");
                   } else {
                       // Academic might legitimately not have a folder in older systems, but warn anyway
                       // throw new Error("Pasta do pedido não encontrada (ID ausente).");
                       console.log("Aviso: Pasta do pedido não encontrada (ID ausente).");
                   }
               }
               
               // 3. Generate PDF
               createRequestSummaryPDF(request, meetingFolder);
            }
        } catch(e) {
            // Throw error so Frontend catches it!
            throw new Error("Erro Pasta/PDF: " + e.message);
        }
    }
    
    // Add History
    var history = [];
    try { history = JSON.parse(request.Historico_Aprovacao || '[]'); } catch(e){}
    history.push({
        date: new Date().toISOString(),
        action: "Inserido em Pauta",
        user: user.email,
        justification: "Validado pela secretaria."
    });
    if (map['Historico_Aprovacao'] > -1) {
        sheet.getRange(rowIndex+1, map['Historico_Aprovacao'] + 1).setValue(JSON.stringify(history));
    }
    
    SpreadsheetApp.flush();
    return { success: true };
}

