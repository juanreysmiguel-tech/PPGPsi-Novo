/**
 * Process Secretaria action on a request (Aprovar/Editar/Reprovar)
 * @param {Object} actionData - Contains requestId, action, editedDetails, ataObservation, additionalInfo
 */
function processSecretariaAction(actionData) {
  try {
    var user = getUserData();
    if (!user.roles.includes("Secretaria") && !user.roles.includes("Coordenação")) {
      throw new Error("Acesso negado. Apenas Secretaria/Coordenação.");
    }
    
    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Solicitacoes");
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    
    // Find request row
    var rowIndex = -1;
    var request = null;
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] == actionData.requestId) {
        rowIndex = i;
        request = {};
        headers.forEach(function(h, idx) { request[h] = data[i][idx]; });
        break;
      }
    }
    
    if (rowIndex === -1) throw new Error("Solicitação não encontrada.");
    
    // Determine new status based on action
    var newStatus = "";
    var notificationType = "";
    var notificationTitle = "";
    
    switch (actionData.action) {
      case "Aprovar":
        newStatus = "Aprovado na CPG";
        notificationType = "aprovado";
        notificationTitle = "Solicitação Aprovada pela CPG";
        break;
      case "Editar":
        newStatus = "Aprovado com Ressalvas";
        notificationType = "aprovado_ressalvas";
        notificationTitle = "Solicitação Aprovada com Ressalvas pela CPG";
        break;
      case "Reprovar":
        newStatus = "Reprovado na CPG";
        notificationType = "reprovado";
        notificationTitle = "Solicitação Reprovada pela CPG";
        break;
      case "AprovarPrestacao":
        newStatus = "Aguardando Depósito";
        notificationType = "prestacao_aprovada";
        notificationTitle = "Prestação de Contas Aprovada (Aguardando Pagamento)";
        break;
      case "ReprovarPrestacao":
        newStatus = "Prestação de Contas Solicitada"; // Return to student for adjustment
        notificationType = "prestacao_rejeitada";
        notificationTitle = "Prestação de Contas Necessita Ajustes";
        break;
      default:
        throw new Error("Ação inválida: " + actionData.action);
    }
    // --- Date and Role Logic for CPG Actions ---
    var isCPGAction = ["Aprovar", "Editar", "Reprovar"].includes(actionData.action);
    if (isCPGAction) {
      var meetDetails = {};
      try { meetDetails = JSON.parse(request.Detalhes || '{}'); } catch(e) {}
      var meetingId = meetDetails.ID_Reuniao;
      
      if (meetingId) {
        var meetData = getDataFromSheet("DB_Calendario_Reunioes");
        var meeting = meetData.find(function(m) { return String(m.ID) === String(meetingId); });
        
        if (meeting && meeting.Data_Reuniao) {
          var todayDate = new Date();
          todayDate.setHours(0, 0, 0, 0);
          var meetDate = new Date(meeting.Data_Reuniao);
          meetDate.setHours(0, 0, 0, 0);
          
          if (todayDate < meetDate) {
            if (user.roles.includes("Coordenação")) {
              // Ad-referendum actions
              if (actionData.action === "Aprovar") {
                newStatus = "Aprovado ad referendum pela Coordenação";
              } else if (actionData.action === "Editar") {
                newStatus = "Aprovado ad referendum pela Coordenação (com ressalvas)";
              } else if (actionData.action === "Reprovar") {
                newStatus = "Reprovado pela Coordenação";
              }
            } else {
              throw new Error("Ações da CPG pela Secretaria só são permitidas a partir da data da reunião programada.");
            }
          }
        }
      }
    }
    
    // Update details if edited
    var details = {};
    try { details = JSON.parse(request.Detalhes || '{}'); } catch(e) {}
    
    if (actionData.editedDetails) {
      Object.assign(details, actionData.editedDetails);
    }
    
    // Add CPG observation if provided
    if (actionData.additionalInfo) {
      details.Info_CPG = actionData.additionalInfo;
    }
    
    // Update history
    var history = [];
    try { history = JSON.parse(request.Historico_Aprovacao || '[]'); } catch(e) {}
    
    history.push({
      date: new Date().toISOString(),
      action: newStatus,
      user: user.email,
      justification: actionData.justification || ""
    });
    
    // Column indices (0-based)
    var statusCol = headers.indexOf("Status");
    var historyCol = headers.indexOf("Historico_Aprovacao");
    var detailsCol = headers.indexOf("Detalhes");
    
    // Write updates
    sheet.getRange(rowIndex + 1, statusCol + 1).setValue(newStatus);
    sheet.getRange(rowIndex + 1, historyCol + 1).setValue(JSON.stringify(history));
    sheet.getRange(rowIndex + 1, detailsCol + 1).setValue(JSON.stringify(details));
    
    // Add to Ata if requested
    if (actionData.ataObservation) {
      addAtaObservation(details.ID_Reuniao, actionData.requestId, actionData.ataObservation, user.email);
    }
    
    // Send notifications to student
    var studentId = request.ID_Usuario;
    var notificationMsg = actionData.additionalInfo 
      ? notificationTitle + ": " + actionData.additionalInfo 
      : notificationTitle;
    
    sendNotification(studentId, notificationType, notificationTitle, notificationMsg, actionData.requestId);
    
    // TODO: Also notify advisor if we have that info
    // var advisorEmail = details.orientadorEmail;
    
    SpreadsheetApp.flush();
    return { success: true, newStatus: newStatus };
    
  } catch (e) {
    throw new Error("Erro ao processar ação: " + e.message);
  }
}

/**
 * Process CG (Conselho de Gestão) action for Financial Requests
 * Actions: Aprovar, Reprovar, Elucidação
 */
function submitCGAction(actionData) {
  try {
    // Use user from actionData (sent from frontend) as it has accurate roles
    var user = actionData.user;
    if (!user || !user.id) {
        // Fallback to session user if actionData.user is missing
        user = getUserData();
    }
    if (!user || !user.id) throw new Error("Usuário não identificado.");
    
    // Verify CG membership - use currentRole (the active selected role) as primary check
    var currentRole = actionData.currentRole || '';
    var roles = user.roles || [];
    var rolesStr = Array.isArray(roles) ? roles.join(',').toUpperCase() : String(roles).toUpperCase();
    
    // Check currentRole first, then fallback to roles array
    var isCG = currentRole.toUpperCase().includes('CONSELHO') || 
               currentRole.toUpperCase().includes('CG') ||
               currentRole.toUpperCase().includes('COORDENA') ||
               rolesStr.includes('CONSELHO') || rolesStr.includes('CG') || 
               rolesStr.includes('ADMIN') || rolesStr.includes('COORDENA');
    
    Logger.log("submitCGAction - currentRole: " + currentRole + ", roles: " + rolesStr + ", isCG: " + isCG);
    
    if (!isCG) {
        throw new Error("Acesso negado: Apenas membros do Conselho/CG podem emitir parecer. (Seu Perfil Atual: '" + currentRole + "', Seus Papéis: '" + rolesStr + "')");
    }
    
    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Solicitacoes");
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    
    // Find request
    var rowIndex = -1;
    var request = null;
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] == actionData.requestId) {
        rowIndex = i;
        request = {};
        headers.forEach(function(h, idx) { request[h] = data[i][idx]; });
        break;
      }
    }
    
    if (rowIndex === -1) throw new Error("Solicitação não encontrada.");
    
    // --- STATUS MAPPING ---
    var newStatus = "";
    var historyAction = "";
    
    // Using EXACT status strings from legacy system to ensure compatibility
    switch (actionData.action) {
      case "Aprovar":
        newStatus = 'Aprovado pela CG (Aguardando Trâmite da Secretaria)';
        historyAction = "Aprovado pelo Conselho de Gestão";
        notificationType = "aprovado_cg";
        notificationTitle = "Auxílio Financeiro Aprovado pelo CG";
        break;
      case "Reprovar":
        newStatus = 'Indeferido / Recusado';
        historyAction = "Indeferido pelo Conselho de Gestão";
        notificationType = "reprovado_cg";
        notificationTitle = "Auxílio Financeiro Rejeitado pelo CG";
        break;
      case "Elucidar":
      case "Info":
        newStatus = 'Aguardando Elucidação (Retornado para Ajustes)';
        historyAction = "Retornado para Elucidação (CG)";
        notificationType = "elucidacao";
        notificationTitle = "Solicitação de Esclarecimento - Auxílio Financeiro";
        break;
      case "Negar":
      case "recusar":
      case "Recusar":
        newStatus = 'Indeferido / Recusado';
        historyAction = "Indeferido pelo Conselho de Gestão";
        notificationType = "reprovado_cg";
        notificationTitle = "Auxílio Financeiro Rejeitado pelo CG";
        break;
      default:
        throw new Error("Ação inválida: " + actionData.action);
    }
    
    // --- DETAILS UPDATE (Justification, Value, CAPES) ---
    var detailsCol = headers.indexOf("Detalhes");
    var details = {};
    try { details = JSON.parse(request.Detalhes || '{}'); } catch(e) {}
    
    // 1. Save Justification
    if (actionData.justification) {
        details['Parecer_CG_Justificativa'] = actionData.justification;
    }
    
    // 2. Save CAPES Evaluation (if provided)
    if (actionData.cgCapesResponse && Object.keys(actionData.cgCapesResponse).length > 0) {
        details['Parecer_CG_CAPES'] = actionData.cgCapesResponse;
    }
    
    // 3. Handle Approved Value Change
    var approvedValue = actionData.approvedValue;
    if (approvedValue && actionData.action === 'Aprovar') {
        const currentVal = details['valor'] || details['Valor Solicitado (R$)'] || '';
        
        // If value changed
        if (String(currentVal) !== String(approvedValue)) {
             if (!details['Valor Original (R$)']) {
                 details['Valor Original (R$)'] = currentVal;
             }
             details['Valor Aprovado (R$)'] = approvedValue;
             details['valor'] = approvedValue; // Update main value for workflow
             // Note: We don't overwrite 'Valor Solicitado (R$)' to keep record of original request
        }
    }
    
    // --- HISTORY UPDATE ---
    var history = [];
    try { history = JSON.parse(request.Historico_Aprovacao || '[]'); } catch(e) {}
    
    history.push({
      date: new Date().toISOString(),
      action: historyAction, // Use readable action description
      user: user.Nome + " (" + currentRole + ")", 
      justification: actionData.justification || ""
    });
    
    // --- COMMIT UPDATES ---
    var statusCol = headers.indexOf("Status");
    var historyCol = headers.indexOf("Historico_Aprovacao");
    var pareceristaCol = headers.indexOf("ID_Parecerista_CG");
    
    // Update basic fields
    sheet.getRange(rowIndex + 1, statusCol + 1).setValue(newStatus);
    sheet.getRange(rowIndex + 1, historyCol + 1).setValue(JSON.stringify(history));
    sheet.getRange(rowIndex + 1, detailsCol + 1).setValue(JSON.stringify(details));
    
    // Update Parecerista (Current User)
    if (pareceristaCol > -1) {
        sheet.getRange(rowIndex + 1, pareceristaCol + 1).setValue(user.email);
    }
    
    // Send notification
    var studentId = request.ID_Usuario;
    var notificationMsg = actionData.justification 
      ? notificationTitle + ": " + actionData.justification 
      : notificationTitle;
    
    sendNotification(studentId, notificationType, notificationTitle, notificationMsg, actionData.requestId);
    
