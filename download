function generateDefesaPDF(payload, user) {
  var htmlTemplate =
    '<div style="font-family: Arial, sans-serif; padding: 40px; color: #333;">' +
      '<div style="text-align: center; margin-bottom: 30px;">' +
        '<h2 style="color: #004b85; margin-bottom: 5px;">Declaração de Agendamento de Defesa</h2>' +
        '<h4 style="margin-top: 0; color: #666;">Programa de Pós-Graduação em Psicologia (PPGPsi) - UFSCar</h4>' +
      '</div>' +
      '<p style="line-height: 1.6; font-size: 14pt; text-align: justify;">' +
      'Declaramos para os devidos fins que o/a discente <strong>' + user.nome + '</strong>, ' +
      'nível <strong>' + payload.nivel + '</strong>, registrou o agendamento de sua defesa com os seguintes dados:</p>' +
      '<div style="background-color: #f8f9fa; border-left: 4px solid #004b85; padding: 20px; margin: 30px 0;">' +
          '<table style="width: 100%; border-collapse: collapse; font-size: 13pt;">' +
            '<tr><td style="padding: 8px 0; width: 120px;"><strong>Título:</strong></td><td style="padding: 8px 0;">' + payload.titulo + '</td></tr>' +
            '<tr><td style="padding: 8px 0;"><strong>Data:</strong></td><td style="padding: 8px 0;">' + payload.data_defesa + '</td></tr>' +
            '<tr><td style="padding: 8px 0;"><strong>Horário:</strong></td><td style="padding: 8px 0;">' + payload.horario_defesa + '</td></tr>' +
            '<tr><td style="padding: 8px 0;"><strong>Local:</strong></td><td style="padding: 8px 0;">' + payload.local + '</td></tr>' +
          '</table>' +
      '</div>' +
      '<h3 style="color: #004b85; border-bottom: 1px solid #ccc; padding-bottom: 10px;">Artigos Validados no Qualis Capes:</h3><ul>';
      
  for(var i=0; i<payload.artigos.length; i++) {
     htmlTemplate += '<li style="margin-bottom: 10px; font-size: 12pt;"><strong>Ref APA:</strong> ' + payload.artigos[i].apa + '<br>' +
                     '<em>Base Qualis: ' + payload.artigos[i].estrato + ' (' + payload.artigos[i].periodicoEncontrado + ' / ISSN: ' + payload.artigos[i].issn + ')</em></li>';
  }      
  
  var dateNow = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd/MM/yyyy 'às' HH:mm");
  
  htmlTemplate += '</ul><br><br><br>' +
       '<p style="text-align: center; color: #888; border-top: 1px solid #eee; padding-top: 20px; font-size: 10pt;">' +
       'Documento gerado eletronicamente pelo Sistema de Gestão PPGPsi/UFSCar em ' + dateNow + '.</p></div>';

  var blob = Utilities.newBlob(htmlTemplate, MimeType.HTML).getAs(MimeType.PDF);
  blob.setName('Agendamento_Defesa_' + user.nome.replace(/[^a-zA-Z0-9]/g, '_') + '.pdf');
  
  var root = DriveService.getRootFolder();
  var defesasFolder = DriveService.ensureFolder(root, "Defesas_Agendadas");
  var file = defesasFolder.createFile(blob);
  
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  return file.getUrl();
}

function submitDefesa(payload, authToken) {
  try {
    var user = getUserData(authToken);
    if (!user || user.id.indexOf("error") !== -1 || user.id.indexOf("Externo") !== -1) {
        throw new Error("Usuário não autenticado ou inválido.");
    }

    var pdfUrl = generateDefesaPDF(payload, user);

    var detailsObj = {
      Nivel: payload.nivel,
      Titulo: payload.titulo,
      Artigos: payload.artigos,
      Data_Defesa: payload.data_defesa,
      Horario_Defesa: payload.horario_defesa,
      Local: payload.local,
      Declaracao_PDF: pdfUrl
    };

    var newHistoryItem = {
        data: new Date().toISOString(),
        usuario: user.nome,
        acao: "Agendamento de Defesa Concluído",
        justificativa: "Declaração gerada automaticamente e defesa registrada com sucesso no sistema."
    };

    var ss = getSpreadsheet();
    var sheet = ss.getSheetByName("DB_Solicitacoes");

    sheet.appendRow([
        Utilities.getUuid(),
        new Date().toISOString(),
        user.id,
        "Agendamento de Defesa",
        JSON.stringify(detailsObj),
        "Aguardando Secretaria", // Standard pending status for processing
        JSON.stringify([newHistoryItem]),
        "", // Comments
        user.Nome_Orientador || "",
        user.Email_Orientador || "",
        "" // CG Parecerista
    ]);

    return { success: true, pdfUrl: pdfUrl };
  } catch(e) {
    Logger.log("Erro em submitDefesa: " + e.message);
    return { success: false, error: e.message };
  }
}

function requestDefesaChange(reqId, reason, authToken) {
   try {
        var user = getUserData(authToken);
        if(!user || user.id.indexOf("error") !== -1 || user.id.indexOf("Externo") !== -1) {
            throw new Error("Acesso negado.");
        }
        
        var ss = getSpreadsheet();
        var sheet = ss.getSheetByName("DB_Solicitacoes");
        var data = sheet.getDataRange().getValues();
        
        var rowIndex = -1;
        var historyStr = "";
        for(var i=1; i<data.length; i++) {
           if(data[i][0] == reqId) { 
               rowIndex = i+1; 
               historyStr = data[i][6]; 
               break; 
           }
        }
        
        if(rowIndex == -1) throw new Error("Agendamento não encontrado.");
        
        var history = [];
        try{ history = JSON.parse(historyStr); }catch(e){}
        
        history.push({
             data: new Date().toISOString(),
             usuario: user.nome,
             acao: "Solicitação de Alteração de Defesa",
             justificativa: reason
        });
        
        sheet.getRange(rowIndex, 7).setValue(JSON.stringify(history));
        sheet.getRange(rowIndex, 6).setValue("Alteração Solicitada (Secretaria)");
        
        return {success: true};
   } catch(e) {
        return {success: false, error: e.message};
   }
}
