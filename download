             Data_Reuniao: (m.Data_Reuniao instanceof Date) ? m.Data_Reuniao.toISOString() : m.Data_Reuniao,
             Data_Inicio_Periodo: (m.Data_Inicio_Periodo instanceof Date) ? m.Data_Inicio_Periodo.toISOString() : m.Data_Inicio_Periodo,
             Data_Fim_Periodo: (m.Data_Fim_Periodo instanceof Date) ? m.Data_Fim_Periodo.toISOString() : m.Data_Fim_Periodo,
             Status: m.Status,
             Prazo_Fechamento: (m.Prazo_Fechamento instanceof Date) ? m.Prazo_Fechamento.toISOString() : m.Prazo_Fechamento
          };
      });
  } catch(e) {
      return [];
  }
