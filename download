        users.forEach(function(u) {
            if (!u.Email || u.Email.indexOf('@') === -1 || u.Status !== 'Ativo') return;
            var roles = [];
            try {
                 var roleRaw = u.Roles;
                 if (typeof roleRaw === 'string') {
                     roleRaw = roleRaw.trim();
                     if (roleRaw.charAt(0) === '[') roles = JSON.parse(roleRaw);
                     else roles = roleRaw.split(',').map(function(r) { return r.trim(); });
                 } else if (Array.isArray(roleRaw)) {
                     roles = roleRaw;
                 }
            } catch(e) { roles = []; }
            var matches = roles.some(function(r) { return String(r).toUpperCase().indexOf(keyword.toUpperCase()) !== -1; });
            if (matches) emails.push(u.Email);
        });
