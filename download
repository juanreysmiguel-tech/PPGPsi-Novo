/**
 * Returns aggregated data for Secretaria Dashboard
 */
function getSecretariaDashboardData() {
  try {
    var user = getUserData();
    if (!user.roles.includes("Secretaria") && !user.roles.includes("Coordenação")) {
      throw new Error("Acesso negado");
    }
    
    // Get all requests
    var requests = getDataFromSheet("DB_Solicitacoes");
    var meetings = getDataFromSheet("DB_Calendario_Reunioes");
    var users = getDataFromSheet("DB_Usuarios");
    
    // Build user map for names
    var userMap = {};
    users.forEach(u => userMap[String(u.ID)] = u.Nome);
    
    // Today and last 7 days
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    var sevenDaysAgo = new Date(today);
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
    
    // Statistics
    var stats = {
      aguardandoOrientador: 0,
      pautadosCPG: 0,
      aprovadosHoje: 0,
      reprovadosHoje: 0,
      totalPendentes: 0
    };
    
    // Pending actions for secretaria (requests waiting for their validation)
    var pendingActions = [];
    
    // Recent approvals
    var recentApprovals = [];
    
    requests.forEach(function(r) {
      var status = String(r.Status || '');
      
      // Count by status
      if (status === 'Aguardando Orientador') {
        stats.aguardandoOrientador++;
        stats.totalPendentes++;
      } else if (status.includes('Pautado') || status === 'Pendente' || status.includes('Aprovado pela CG') || status.includes('Aprovado CG') || status === 'approved_cg' || status.includes('Aprovado com Ressalvas') || status === 'Prestação de Contas em Análise') {
        stats.pautadosCPG++;
        stats.totalPendentes++;
        
        // Add to pending actions for secretaria
        pendingActions.push({
          id: r.ID,
          tipo: r.Tipo_Solicitacao,
          aluno: userMap[String(r.ID_Usuario)] || 'Desconhecido',
          data: r.Data_Criacao instanceof Date ? r.Data_Criacao.toISOString() : r.Data_Criacao,
          status: status
        });
      } else if (status.includes('Aprovado')) {
        // Check if approved today
        var dataCriacao = new Date(r.Data_Criacao);
        if (dataCriacao >= today) {
          stats.aprovadosHoje++;
        }
        // Recent approvals (last 7 days)
        if (dataCriacao >= sevenDaysAgo) {
          recentApprovals.push({
            id: r.ID,
            tipo: r.Tipo_Solicitacao,
            aluno: userMap[String(r.ID_Usuario)] || 'Desconhecido',
            data: r.Data_Criacao instanceof Date ? r.Data_Criacao.toISOString() : r.Data_Criacao,
            status: status
          });
        }
      } else if (status.includes('Reprovado') || status.includes('Rejeitado')) {
        var dataCriacao2 = new Date(r.Data_Criacao);
        if (dataCriacao2 >= today) {
          stats.reprovadosHoje++;
        }
      } else if (status.includes('Retornado')) {
        stats.totalPendentes++;
      }
    });
    
    // Sort pending by date (oldest first)
    pendingActions.sort(function(a, b) {
      return new Date(a.data) - new Date(b.data);
    });
    
    // Sort recent approvals (newest first)
    recentApprovals.sort(function(a, b) {
      return new Date(b.data) - new Date(a.data);
    });
    
    // Next meetings (open status)
    var upcomingMeetings = meetings
      .filter(function(m) { return m.Status === 'Aberto'; })
      .map(function(m) {
        return {
          id: m.ID,
          nome: m.Nome,
          data: m.Data_Reuniao instanceof Date ? m.Data_Reuniao.toISOString() : m.Data_Reuniao,
          prazo: m.Prazo_Fechamento instanceof Date ? m.Prazo_Fechamento.toISOString() : m.Prazo_Fechamento
        };
      })
      .sort(function(a, b) {
        return new Date(a.data) - new Date(b.data);
      });
    
    return {
      stats: stats,
      pendingActions: pendingActions.slice(0, 10), // Limit to 10
      recentApprovals: recentApprovals.slice(0, 5), // Limit to 5
      upcomingMeetings: upcomingMeetings.slice(0, 3) // Limit to 3
    };
    
  } catch (e) {
    throw new Error("Erro ao carregar dashboard: " + e.message);
  }
}

