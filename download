    try { details = JSON.parse(request.Detalhes || '{}'); } catch(e) {}

    var targetFolder = null;
    
    // 1. Try to find existing folder from file links
    var fileUrlRegex = /https:\/\/drive\.google\.com\/file\/d\/([a-zA-Z0-9_-]+)/;
    for (var key in details) {
        if (typeof details[key] === 'string' && details[key].indexOf("drive.google.com") !== -1) {
