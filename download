        // Note: Ideally 'action' should map to 'Status', but sometimes it's descriptive.
        // For most flows we use action == status.
        // If needed we can add logic here to normalize status.
    }

    // Update Sheet
    sheet.getRange(rowIndex + 1, colStatus + 1).setValue(newStatus);
    sheet.getRange(rowIndex + 1, colHistory + 1).setValue(JSON.stringify(history));

    return {
        success: true,
        message: "Ação desfeita: " + removedItem.action,
        newStatus: newStatus
    };

  } catch (e) {
    throw new Error("Erro ao desfazer ação: " + e.message);
  }
}

